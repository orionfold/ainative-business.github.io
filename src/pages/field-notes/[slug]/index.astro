---
import { getCollection, render } from 'astro:content';
import FieldNotesLayout from '../../../layouts/FieldNotesLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import BookmarkStar from '../../../components/field-notes/BookmarkStar.astro';
import TocDrawer from '../../../components/field-notes/TocDrawer.astro';
import ReaderSettings from '../../../components/field-notes/ReaderSettings.astro';
import TermsInThisPiece from '../../../components/field-notes/TermsInThisPiece.astro';
import ArticleArcNav from '../../../components/field-notes/ArticleArcNav.astro';
import { publishOrdinals } from '../../../lib/field-notes/article-order.mjs';
import { SERIES_SLUGS } from '../../../content.config.ts';
import { SITE } from '../../../data/seo';

export async function getStaticPaths() {
  const all = await getCollection('field-notes');
  const ordinalById = publishOrdinals(all, process.cwd());
  return all.map((article) => ({
    params: { slug: article.id },
    props: { article, ordinal: ordinalById.get(article.id)! },
  }));
}

const { article, ordinal } = Astro.props;
const { Content } = await render(article);
const { title, date, author, product, stage, difficulty, time_required, hardware, summary, status, series, tags } = article.data;

const isUpcoming = status === 'upcoming';
const ordinalLabel = isUpcoming ? 'Upcoming' : `№${String(ordinal).padStart(2, '0')}`;
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);
const seriesHref = series ? `/field-notes/series/${SERIES_SLUGS[series]}/` : null;

const dateIso = date.toISOString().slice(0, 10);
const articleUrl = `${SITE.url}/field-notes/${article.id}/`;
const ogImage = `/og/field-notes/${article.id}.png`;
const ogImageAlt = `${title} — AI Native Field Notes №${String(ordinal).padStart(2, '0')} by ${author}`;

// SEO contract: keep <title> ≤ 65 chars. Append the brand suffix only when
// it fits; otherwise fall back to the bare article title (which may still
// exceed 65 — those are inherent to the author's title style and live in
// source-of-record, not destination).
const SUFFIX = ' — AI Native Field Notes';
const pageTitle = (title.length + SUFFIX.length) <= 65 ? `${title}${SUFFIX}` : title;
const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
  { '@type': 'ListItem', position: 2, name: 'Field Notes', item: `${SITE.url}/field-notes/` },
  { '@type': 'ListItem', position: 3, name: stage, item: `${SITE.url}/field-notes/stages/${stage}/` },
  ...(series ? [{ '@type': 'ListItem', position: 4, name: series, item: `${SITE.url}/field-notes/series/${SERIES_SLUGS[series]}/` }] : []),
  { '@type': 'ListItem', position: series ? 5 : 4, name: title, item: articleUrl },
];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: title,
    description: summary,
    datePublished: dateIso,
    dateModified: dateIso,
    author: { '@type': 'Person', name: author, url: `${SITE.url}/about/` },
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    inLanguage: 'en',
    isAccessibleForFree: true,
    articleSection: stage,
    publisher: {
      '@type': 'Organization',
      name: 'ainative',
      url: SITE.url,
      logo: { '@type': 'ImageObject', url: SITE.logo },
    },
    keywords: (tags ?? []).join(', '),
    ...(series ? { isPartOf: { '@type': 'CreativeWorkSeries', name: series, url: `${SITE.url}/field-notes/series/${SERIES_SLUGS[series]}/` } } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems,
  },
];
---
<FieldNotesLayout
  title={pageTitle}
  description={summary}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  article={{ datePublished: dateIso, dateModified: dateIso, author, section: stage, tags }}
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <div class="fn-progress-bar" id="progress-bar"></div>

    <article class="article">
      <header class="article__header">
        <div class="article__header-row">
          <a class="article__breadcrumb" href="/field-notes/">← AI Native Field Notes</a>
          <div class="article__reader-controls">
            <BookmarkStar slug={article.id} />
            <TocDrawer />
            <ReaderSettings />
          </div>
        </div>
        {isUpcoming && (
          <p class="article__upcoming-banner">Upcoming — proposed abstract, not a published piece.</p>
        )}
        <h1 class="article__title">{title}</h1>
        <p class="article__summary">{summary}</p>
        {series && (
          <a class="article__series-badge" href={seriesHref!} data-series={SERIES_SLUGS[series]}>
            <span class="article__series-badge-label">Series</span>
            <span class="article__series-badge-name">{series}</span>
          </a>
        )}
        <div class="article__meta">
          <span>{ordinalLabel}</span>
          <a class="article__meta-link" href={`/field-notes/stages/${stage}/`}>{stage}</a>
          {product && <span>{product}</span>}
          <time datetime={dateIso}>{isUpcoming ? `planned · ${dateFmt}` : dateFmt}</time>
          {time_required && <span>{time_required}</span>}
          {difficulty && <span>{difficulty}</span>}
          {hardware && <span>{hardware}</span>}
          <span>{author}</span>
        </div>

        {(tags ?? []).length > 0 && (
          <ul class="article__tags" aria-label="Tags">
            {tags.map((tag) => (
              <li>
                <a class="article__tag" href={`/field-notes/tags/${tag}/`}>#{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </header>

      <div class="article__resume-banner" data-resume-slug={article.id} hidden>
        <span>Pick up where you left off?</span>
        <span class="article__resume-actions">
          <button type="button" class="js-resume" data-action="resume">Resume</button>
          <button type="button" class="js-dismiss is-dismiss" data-action="dismiss">Dismiss</button>
        </span>
      </div>

      <TermsInThisPiece body={article.body ?? ''} />

      <div class="fn-prose">
        <Content />
      </div>

      <ArticleArcNav slug={article.id} />
    </article>

    <script>
      const bar = document.getElementById('progress-bar');
      if (bar) {
        const update = () => {
          const doc = document.documentElement;
          const scrolled = window.scrollY;
          const total = doc.scrollHeight - window.innerHeight;
          const pct = total > 0 ? Math.min(1, scrolled / total) : 0;
          bar.style.transform = `scaleX(${pct})`;
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
      }
    </script>
  </main>
  <Footer />
</FieldNotesLayout>
