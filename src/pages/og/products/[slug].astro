---
import { getCollection } from 'astro:content';
import '@fontsource/geist-sans/700.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource-variable/geist-mono';

export async function getStaticPaths() {
  const all = await getCollection('products');
  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { product_name, tagline, series, status, build } = entry.data;
const badge = status === 'upcoming' ? 'Upcoming' : (series ?? 'Product');

const fmtCompact = (n: number): string => {
  if (n < 1000) return String(n);
  const s = (n / 1000).toFixed(1);
  return `${s.endsWith('.0') ? s.slice(0, -2) : s}k`;
};

const stats = [
  { value: `${build.wall_clock_hours}h`, label: 'to build' },
  { value: fmtCompact(build.lines_of_code), label: 'lines of code' },
  { value: String(build.test_cases), label: 'tests' },
  { value: String(build.feature_count), label: 'features' },
];
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex" />
  <title>OG · {product_name}</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 1200px;
      height: 630px;
      overflow: hidden;
      background: oklch(0.13 0.02 250);
      color: oklch(0.93 0.01 250);
      font-family: 'Geist Sans', system-ui, sans-serif;
    }

    .og {
      position: relative;
      width: 1200px;
      height: 630px;
      padding: 64px 72px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .og::before {
      content: '';
      position: absolute;
      top: -120px;
      right: -120px;
      width: 520px;
      height: 520px;
      border-radius: 50%;
      background: radial-gradient(circle,
        oklch(0.65 0.18 250 / 0.18) 0%,
        oklch(0.65 0.18 250 / 0.06) 40%,
        transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .top {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .brand img {
      width: 40px;
      height: 40px;
    }

    .brand-name {
      font-size: 24px;
      font-weight: 700;
      color: oklch(0.65 0.18 250);
      letter-spacing: -0.01em;
    }

    .badge {
      font-family: 'Geist Mono Variable', monospace;
      font-size: 18px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: oklch(0.65 0.18 250);
      padding: 8px 18px;
      border: 1px solid oklch(0.65 0.18 250 / 0.4);
      border-radius: 999px;
    }

    .body {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 24px;
      max-width: 1056px;
    }

    .eyebrow {
      font-family: 'Geist Mono Variable', monospace;
      font-size: 16px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: oklch(0.7 0.02 250);
    }

    h1 {
      font-size: 64px;
      font-weight: 700;
      line-height: 1.04;
      letter-spacing: -0.024em;
      color: oklch(0.96 0.005 250);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .tagline {
      font-size: 26px;
      font-weight: 500;
      line-height: 1.3;
      color: oklch(0.8 0.01 250);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .bottom {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding-top: 22px;
      border-top: 1px solid oklch(0.93 0.01 250 / 0.12);
    }

    .stats {
      display: flex;
      gap: 40px;
    }

    .stat-value {
      font-size: 30px;
      font-weight: 700;
      color: oklch(0.65 0.18 250);
      letter-spacing: -0.01em;
    }

    .stat-label {
      font-family: 'Geist Mono Variable', monospace;
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: oklch(0.62 0.02 250);
      margin-top: 4px;
    }

    .url {
      font-family: 'Geist Mono Variable', monospace;
      font-size: 14px;
      letter-spacing: 0.08em;
      color: oklch(0.55 0.02 250);
    }
  </style>
</head>
<body>
  <div class="og">
    <div class="top">
      <div class="brand">
        <img src="/ainative-s-128.png" alt="" />
        <div class="brand-name">ainative</div>
      </div>
      <div class="badge">{badge}</div>
    </div>

    <div class="body">
      <div class="eyebrow">Product Launch</div>
      <h1>{product_name}</h1>
      <div class="tagline">{tagline}</div>
    </div>

    <div class="bottom">
      <div class="stats">
        {stats.map((s) => (
          <div>
            <div class="stat-value">{s.value}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
      <div class="url">ainative.business</div>
    </div>
  </div>
</body>
</html>
