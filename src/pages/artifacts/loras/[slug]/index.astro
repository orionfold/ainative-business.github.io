---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import LoRASignature from '../../../../components/artifacts/LoRASignature.astro';
import LicenseChip from '../../../../components/artifacts/LicenseChip.astro';
import { SITE, PUBLISHER } from '../../../../data/seo';

export async function getStaticPaths() {
  const all = await getCollection('artifacts', ({ data }) => data.kind === 'lora');
  const fieldNotes = await getCollection('field-notes');
  const allArtifacts = await getCollection('artifacts');
  return all.map((artifact) => ({
    params: { slug: artifact.data.slug },
    props: { artifact, fieldNotes, allArtifacts },
  }));
}

interface PageProps {
  artifact: CollectionEntry<'artifacts'>;
  fieldNotes: CollectionEntry<'field-notes'>[];
  allArtifacts: CollectionEntry<'artifacts'>[];
}

const { artifact, fieldNotes, allArtifacts } = Astro.props as PageProps;
const {
  slug,
  class: artifactClass,
  base_model,
  hf_repo,
  vertical_eval,
  vertical_eval_name,
  lineage_run_id,
  license,
  article,
  published_at,
  positioning,
  stack_origin,
  lane_summary,
  known_drift,
  siblings,
} = artifact.data;

const hfUrl = hf_repo.includes('://') ? hf_repo : `https://huggingface.co/${hf_repo}`;
const baseModelHref =
  /^[^/\s]+\/[^/\s]+$/.test(base_model) ? `https://huggingface.co/${base_model}` : null;
const publishedDate = published_at
  ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(published_at))
  : null;

let linkedArticle: CollectionEntry<'field-notes'> | null = null;
if (article) {
  const articleSlug = article.replace(/^articles\//, '').replace(/\/$/, '');
  linkedArticle = fieldNotes.find((a) => a.id === articleSlug) ?? null;
}

// Find sibling artifacts sharing the same base_model (for lane block).
const sameBaseSiblings = allArtifacts.filter(
  (a) => a.data.slug !== slug && a.data.base_model === base_model,
);

// Resolve sibling cross-link entries to live artifact pages where possible.
type ResolvedSibling = { slug: string; hook: string; href: string | null; kind?: string; stack?: string };
const resolvedSiblings: ResolvedSibling[] = (siblings ?? []).map((s) => {
  const found = allArtifacts.find((a) => a.data.slug === s.slug);
  if (found) {
    const seg = found.data.kind === 'quant' ? 'quants'
      : found.data.kind === 'lora' ? 'loras'
      : found.data.kind === 'adapter' ? 'adapters'
      : found.data.kind === 'dataset' ? 'datasets'
      : 'benches';
    return { slug: s.slug, hook: s.hook, href: `/artifacts/${seg}/${s.slug}/`, kind: found.data.kind, stack: found.data.stack_origin };
  }
  // External sibling — link to HF if hf_repo supplied
  return { slug: s.slug, hook: s.hook, href: s.hf_repo ? (s.hf_repo.includes('://') ? s.hf_repo : `https://huggingface.co/${s.hf_repo}`) : null };
});

const pageTitle = `${slug} — LoRA fine-tune — ainative`;
const positioningHeadline = positioning?.headline ?? `LoRA fine-tune of ${base_model}`;
const pageDescription = positioning?.problem
  ? positioning.problem.replace(/\s+/g, ' ').slice(0, 280)
  : `LoRA fine-tune of ${base_model}. Spark-trained, bounded drift disclosed, wire-back to field notes.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: slug,
    description: pageDescription,
    url: `${SITE.url}/artifacts/loras/${slug}/`,
    publisher: PUBLISHER,
    license: license.tier === 'free' ? 'open' : license.tier,
    keywords: [stack_origin, 'lora', 'fine-tune', base_model].filter(Boolean),
    datePublished: published_at,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Artifacts', item: `${SITE.url}/artifacts/` },
      { '@type': 'ListItem', position: 3, name: 'LoRA fine-tunes', item: `${SITE.url}/artifacts/loras/` },
      { '@type': 'ListItem', position: 4, name: slug, item: `${SITE.url}/artifacts/loras/${slug}/` },
    ],
  },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="lora-detail">
    <header class="lora-detail__header">
      <a class="lora-detail__back" href="/artifacts/loras/">← LoRA fine-tunes</a>
      <div class="lora-detail__kicker">
        <span class="lora-detail__kicker-kind">LoRA fine-tune</span>
        <span>·</span>
        <span>{artifactClass.toUpperCase()}</span>
        {stack_origin && <><span>·</span><span class="lora-detail__kicker-stack">trained with {stack_origin}</span></>}
      </div>
      <h1 class="lora-detail__title">{slug}</h1>
      <p class="lora-detail__elevator">{positioningHeadline}</p>

      <div class="lora-detail__hero">
        <div class="lora-detail__hero-visual">
          <LoRASignature
            slug={slug}
            stack_origin={stack_origin}
            base_model={base_model}
            vertical_eval={vertical_eval}
            vertical_eval_name={vertical_eval_name}
            variant="hero"
          />
        </div>
        <div class="lora-detail__meta">
          <a class="lora-detail__meta-item" href={hfUrl} target="_blank" rel="noopener noreferrer">
            <span class="lora-detail__meta-label">HF</span>
            <span class="lora-detail__meta-value">{hf_repo}</span>
          </a>
          <div class="lora-detail__meta-item">
            <span class="lora-detail__meta-label">Base</span>
            {baseModelHref ? (
              <a href={baseModelHref} target="_blank" rel="noopener noreferrer" class="lora-detail__meta-value lora-detail__meta-value--link">{base_model}</a>
            ) : (
              <span class="lora-detail__meta-value">{base_model}</span>
            )}
          </div>
          <div class="lora-detail__meta-item">
            <span class="lora-detail__meta-label">License</span>
            <LicenseChip tier={license.tier} model={license.model} />
          </div>
          {publishedDate && (
            <div class="lora-detail__meta-item">
              <span class="lora-detail__meta-label">Published</span>
              <time class="lora-detail__meta-value" datetime={published_at}>{publishedDate}</time>
            </div>
          )}
        </div>
      </div>
    </header>

    {positioning?.problem && (
      <section class="lora-detail__section">
        <h2 class="lora-detail__h2">What this model does</h2>
        <p class="lora-detail__problem">{positioning.problem}</p>
        {positioning.use_cases && positioning.use_cases.length > 0 && (
          <>
            <h3 class="lora-detail__h3">Use cases</h3>
            <ul class="lora-detail__uses">
              {positioning.use_cases.map((uc) => <li>{uc}</li>)}
            </ul>
          </>
        )}
        {positioning.audience && (
          <p class="lora-detail__audience">
            <span class="lora-detail__audience-label">Audience —</span> {positioning.audience}
          </p>
        )}
      </section>
    )}

    {vertical_eval && Object.keys(vertical_eval).length >= 2 && (
      <section class="lora-detail__section">
        <h2 class="lora-detail__h2">Evaluated on Spark</h2>
        {vertical_eval_name && (
          <p class="lora-detail__h2-blurb">Vertical eval: <code>{vertical_eval_name}</code></p>
        )}
        <div class="lora-detail__eval-grid">
          {Object.entries(vertical_eval).map(([variant, score]) => (
            <div class="lora-detail__eval-cell">
              <span class="lora-detail__eval-variant">{variant}</span>
              <span class="lora-detail__eval-score">{score.toFixed(3)}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    {(stack_origin && (lane_summary || sameBaseSiblings.length > 0)) && (
      <section class="lora-detail__section">
        <h2 class="lora-detail__h2">Choosing this lane</h2>
        {lane_summary && <p class="lora-detail__lane">{lane_summary}</p>}
        {!lane_summary && sameBaseSiblings.length > 0 && (
          <p class="lora-detail__lane">
            This fine-tune is the <strong>{stack_origin}</strong> lane of {base_model.split('/').pop()}.
            {sameBaseSiblings.length === 1
              ? ` Compare to the ${sameBaseSiblings[0].data.stack_origin ?? 'sibling'} lane below.`
              : ` Compare to the ${sameBaseSiblings.length} sibling lanes below.`}
          </p>
        )}
      </section>
    )}

    <section class="lora-detail__section">
      <h2 class="lora-detail__h2">How to use</h2>
      <p class="lora-detail__h2-blurb">
        Load via Transformers + PEFT, or via the linked HF repo for inference snippets.
      </p>
      <pre class="lora-detail__code"><code>{`from transformers import AutoModelForCausalLM, AutoTokenizer
from peft import PeftModel

base = AutoModelForCausalLM.from_pretrained("${base_model}", torch_dtype="bfloat16", device_map="auto")
tok = AutoTokenizer.from_pretrained("${base_model}")
model = PeftModel.from_pretrained(base, "${hf_repo}")`}</code></pre>
      <p class="lora-detail__h2-after">
        Full inference walkthrough on <a class="lora-detail__inline-link" href={hfUrl} target="_blank" rel="noopener noreferrer">the HuggingFace model card</a>.
      </p>
    </section>

    {linkedArticle && (
      <section class="lora-detail__section">
        <h2 class="lora-detail__h2">Methods</h2>
        <a class="lora-detail__followup-card" href={`/field-notes/${linkedArticle.id}/`}>
          <span class="lora-detail__followup-kicker">Read the field note</span>
          <span class="lora-detail__followup-title">{linkedArticle.data.title}</span>
          {linkedArticle.data.summary && (
            <span class="lora-detail__followup-summary">{linkedArticle.data.summary}</span>
          )}
          <span class="lora-detail__followup-cta">Open article <span aria-hidden="true">→</span></span>
        </a>
      </section>
    )}

    {known_drift && known_drift.length > 0 && (
      <section class="lora-detail__section">
        <h2 class="lora-detail__h2">Known drift</h2>
        <p class="lora-detail__h2-blurb">
          Disclosed limitations from the v3 corpus. Each entry carries an explicit bound — the scope is named, not implied.
        </p>
        <dl class="lora-detail__drift">
          {known_drift.map((d) => (
            <div class="lora-detail__drift-row">
              <dt class="lora-detail__drift-item">{d.item}</dt>
              <dd class="lora-detail__drift-bound">{d.bound}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {resolvedSiblings.length > 0 && (
      <section class="lora-detail__section">
        <h2 class="lora-detail__h2">Other Orionfold variants</h2>
        <ul class="lora-detail__siblings" role="list">
          {resolvedSiblings.map((s) => (
            <li class="lora-detail__sibling">
              {s.href ? (
                <a class="lora-detail__sibling-link" href={s.href} {...(s.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                  <span class="lora-detail__sibling-slug">{s.slug}</span>
                  <span class="lora-detail__sibling-hook">{s.hook}</span>
                </a>
              ) : (
                <div class="lora-detail__sibling-static">
                  <span class="lora-detail__sibling-slug">{s.slug}</span>
                  <span class="lora-detail__sibling-hook">{s.hook}</span>
                </div>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    {lineage_run_id && (
      <section class="lora-detail__section">
        <div class="lora-detail__lineage">
          <span class="lora-detail__lineage-label">Lineage run</span>
          <code class="lora-detail__lineage-code">{lineage_run_id}</code>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .lora-detail {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem);
  }

  .lora-detail__back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }
  .lora-detail__back:hover { color: var(--color-primary); }

  .lora-detail__header { margin-bottom: clamp(3rem, 5vw, 4.5rem); }
  .lora-detail__kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .lora-detail__kicker-kind { color: var(--color-primary); }
  .lora-detail__kicker-stack { color: var(--color-accent); font-weight: 600; }

  .lora-detail__title {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 0.85rem;
    word-break: break-word;
  }
  .lora-detail__elevator {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.4;
    color: var(--color-text);
    margin: 0 0 2rem;
    max-width: 50ch;
  }

  .lora-detail__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(14rem, 22vw, 18rem);
    gap: 2.5rem;
    align-items: center;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .lora-detail__hero-visual {
    order: 2;
    justify-self: center;
    width: 100%;
    max-width: 18rem;
  }
  .lora-detail__meta {
    order: 1;
    display: grid;
    gap: 0.6rem 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
  }
  .lora-detail__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
    text-decoration: none;
  }
  a.lora-detail__meta-item { transition: color 0.2s; }
  a.lora-detail__meta-item:hover { color: var(--color-primary); }
  .lora-detail__meta-label {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-dim);
  }
  .lora-detail__meta-value { color: var(--color-text); word-break: break-word; }
  a.lora-detail__meta-value--link {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--color-primary) 50%, transparent);
  }
  a.lora-detail__meta-value--link:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }

  @media (max-width: 840px) {
    .lora-detail__hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .lora-detail__hero-visual { order: 1; max-width: 14rem; }
    .lora-detail__meta { order: 2; }
  }

  .lora-detail__section {
    margin: clamp(2.5rem, 4.5vw, 3.5rem) 0;
    max-width: 60rem;
  }

  .lora-detail__h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .lora-detail__h2-blurb {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
  }
  .lora-detail__h2-after {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    margin: 0.85rem 0 0;
  }
  .lora-detail__h3 {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin: 1.5rem 0 0.7rem;
  }
  .lora-detail__problem {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    max-width: 65ch;
  }
  .lora-detail__uses {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.7;
    color: var(--color-text);
    max-width: 65ch;
  }
  .lora-detail__uses li { margin-bottom: 0.35rem; }
  .lora-detail__audience {
    margin: 1.5rem 0 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    padding: 0.85rem 1rem;
    border-left: 2px solid color-mix(in oklch, var(--color-primary) 50%, transparent);
    background: color-mix(in oklch, var(--color-surface-raised) 35%, transparent);
    border-radius: 0 6px 6px 0;
    max-width: 65ch;
  }
  .lora-detail__audience-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    margin-right: 0.35rem;
  }

  .lora-detail__lane {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    max-width: 65ch;
  }
  .lora-detail__lane strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .lora-detail__eval-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 8rem), 1fr));
    gap: 0.75rem;
  }
  .lora-detail__eval-cell {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in oklch, var(--color-surface-raised) 40%, transparent);
  }
  .lora-detail__eval-variant {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }
  .lora-detail__eval-score {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .lora-detail__code {
    background: color-mix(in oklch, var(--color-surface-raised) 70%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text);
    margin: 0;
  }
  .lora-detail__code code {
    background: transparent;
    padding: 0;
    font: inherit;
    color: inherit;
  }
  .lora-detail__inline-link {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--color-primary) 50%, transparent);
  }
  .lora-detail__inline-link:hover { border-bottom-color: var(--color-primary); }

  .lora-detail__followup-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    max-width: 48rem;
  }
  .lora-detail__followup-card:hover {
    border-color: color-mix(in oklch, var(--color-primary) 50%, var(--color-border));
    background: color-mix(in oklch, var(--color-primary) 6%, var(--color-surface-raised));
    transform: translateY(-2px);
  }
  .lora-detail__followup-kicker {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-primary);
  }
  .lora-detail__followup-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.3;
    color: var(--color-text);
  }
  .lora-detail__followup-summary {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  .lora-detail__followup-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }

  .lora-detail__drift {
    display: grid;
    gap: 0.85rem;
    margin: 0;
  }
  .lora-detail__drift-row {
    display: grid;
    grid-template-columns: minmax(min(100%, 14rem), 1fr) 2fr;
    gap: 1rem;
    padding: 0.95rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in oklch, var(--color-surface-raised) 35%, transparent);
  }
  .lora-detail__drift-item {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--color-text);
    font-weight: 500;
    margin: 0;
  }
  .lora-detail__drift-bound {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
  }
  @media (max-width: 700px) {
    .lora-detail__drift-row { grid-template-columns: 1fr; gap: 0.45rem; }
  }

  .lora-detail__siblings {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .lora-detail__sibling-link, .lora-detail__sibling-static {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in oklch, var(--color-surface-raised) 35%, transparent);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, background 0.2s;
