---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import DatasetSignature from '../../../../components/artifacts/DatasetSignature.astro';
import LicenseChip from '../../../../components/artifacts/LicenseChip.astro';
import NotebookBadges from '../../../../components/artifacts/NotebookBadges.astro';
import { SITE, PUBLISHER } from '../../../../data/seo';

export async function getStaticPaths() {
  const all = await getCollection('artifacts', ({ data }) => data.kind === 'dataset');
  const fieldNotes = await getCollection('field-notes');
  return all.map((artifact) => ({
    params: { slug: artifact.data.slug },
    props: { artifact, fieldNotes },
  }));
}

interface PageProps {
  artifact: CollectionEntry<'artifacts'>;
  fieldNotes: CollectionEntry<'field-notes'>[];
}

const { artifact, fieldNotes } = Astro.props as PageProps;
const {
  slug, class: artifactClass, hf_repo, license, article, published_at,
  positioning, shapes, samples, how_to_load, citation, sources, notebooks,
} = artifact.data;

const hfUrl = hf_repo.includes('://') ? hf_repo : `https://huggingface.co/datasets/${hf_repo}`;
const publishedDate = published_at
  ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(published_at))
  : null;

let linkedArticle: CollectionEntry<'field-notes'> | null = null;
if (article) {
  const articleSlug = article.replace(/^articles\//, '').replace(/\/$/, '');
  linkedArticle = fieldNotes.find((a) => a.id === articleSlug) ?? null;
}

const totalRows = shapes?.reduce((s, x) => s + x.count, 0);
const pageTitle = `${slug} — Dataset — ainative`;
const pageDescription = positioning?.problem?.slice(0, 280) ?? `Dataset ${slug}.`;
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'Dataset', name: slug, description: pageDescription, url: `${SITE.url}/artifacts/datasets/${slug}/`, publisher: PUBLISHER, datePublished: published_at },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="ds-detail">
    <a class="ds-detail__back" href="/artifacts/datasets/">← Datasets</a>
    <div class="ds-detail__kicker"><span class="ds-detail__kicker-kind">Dataset</span><span>·</span><span>{artifactClass}</span>{totalRows && <><span>·</span><span>{totalRows.toLocaleString()} rows</span></>}</div>
    <h1 class="ds-detail__title">{slug}</h1>
    {positioning?.headline && <p class="ds-detail__elevator">{positioning.headline}</p>}

    <div class="ds-detail__hero">
      <div class="ds-detail__hero-visual">
        <DatasetSignature
          slug={slug}
          total_rows={totalRows}
          shapes={shapes?.map((s) => ({ code: s.code, count: s.count, label: s.label }))}
          license_tier={license.tier}
          variant="hero"
        />
      </div>
      <div class="ds-detail__meta">
        <a class="ds-detail__meta-item" href={hfUrl} target="_blank" rel="noopener noreferrer"><span class="ds-detail__meta-label">HF</span><span>{hf_repo}</span></a>
        <div class="ds-detail__meta-item"><span class="ds-detail__meta-label">License</span><LicenseChip tier={license.tier} model={license.model} /></div>
        {publishedDate && <div class="ds-detail__meta-item"><span class="ds-detail__meta-label">Published</span><time datetime={published_at}>{publishedDate}</time></div>}
      </div>
    </div>

    <NotebookBadges notebooks={notebooks} contextLabel={slug} />

    {positioning?.problem && (
      <section class="ds-detail__section">
        <h2 class="ds-detail__h2">What this dataset covers</h2>
        <p class="ds-detail__problem">{positioning.problem}</p>
      </section>
    )}

    {how_to_load && (
      <section class="ds-detail__section">
        <h2 class="ds-detail__h2">How to load</h2>
        <pre class="ds-detail__code"><code>{how_to_load}</code></pre>
      </section>
    )}

    {sources?.length > 0 && (
      <section class="ds-detail__section">
        <h2 class="ds-detail__h2">Sources</h2>
        <ul class="ds-detail__sources">
          {sources.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a> — {s.blurb}
            </li>
          ))}
        </ul>
      </section>
    )}

    {linkedArticle && (
      <section class="ds-detail__section">
        <h2 class="ds-detail__h2">Methods</h2>
        <a class="ds-detail__followup" href={`/field-notes/${linkedArticle.id}/`}>
          <span class="ds-detail__followup-kicker">Read the field note</span>
          <span class="ds-detail__followup-title">{linkedArticle.data.title}</span>
        </a>
      </section>
    )}

    {citation && (
      <section class="ds-detail__section">
        <h2 class="ds-detail__h2">Citation</h2>
        <pre class="ds-detail__code"><code>{citation}</code></pre>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .ds-detail { max-width: 72rem; margin: 0 auto; padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem); }
  .ds-detail__back { display: inline-block; font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-text-muted); text-decoration: none; margin-bottom: 2rem; }
  .ds-detail__kicker { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-text-muted); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.6rem; }
  .ds-detail__kicker-kind { color: var(--color-primary); }
  .ds-detail__title { font-family: var(--font-mono); font-weight: 500; font-size: clamp(1.6rem, 3.5vw, 2.5rem); margin: 0 0 0.85rem; color: var(--color-text); }
  .ds-detail__elevator { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.2rem, 2vw, 1.55rem); line-height: 1.4; color: var(--color-text); margin: 0 0 2rem; max-width: 50ch; }
  .ds-detail__hero { display: grid; grid-template-columns: minmax(0, 1fr) clamp(14rem, 22vw, 18rem); gap: 2.5rem; align-items: center; padding: 1.5rem 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .ds-detail__hero-visual { order: 2; justify-self: center; width: 100%; max-width: 18rem; }
  .ds-detail__meta { order: 1; display: grid; gap: 0.6rem 1.25rem; grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr)); }
  .ds-detail__meta-item { display: flex; flex-direction: column; gap: 0.25rem; font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-text); text-decoration: none; }
  .ds-detail__meta-label { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.16em; color: var(--color-text-dim); }
  @media (max-width: 840px) { .ds-detail__hero { grid-template-columns: 1fr; } .ds-detail__hero-visual { order: 1; max-width: 14rem; } .ds-detail__meta { order: 2; } }
  .ds-detail__section { margin: clamp(2.5rem, 4.5vw, 3.5rem) 0; max-width: 60rem; }
  .ds-detail__h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.4rem, 2.5vw, 1.8rem); margin: 0 0 0.85rem; color: var(--color-text); }
  .ds-detail__problem { font-size: 1.05rem; line-height: 1.7; color: var(--color-text); max-width: 65ch; }
  .ds-detail__code { background: color-mix(in oklch, var(--color-surface-raised) 70%, transparent); border: 1px solid var(--color-border); border-radius: 8px; padding: 1.1rem 1.25rem; overflow-x: auto; font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.55; color: var(--color-text); margin: 0; }
  .ds-detail__sources { line-height: 1.7; }
  .ds-detail__sources a { color: var(--color-primary); text-decoration: none; border-bottom: 1px solid color-mix(in oklch, var(--color-primary) 50%, transparent); }
  .ds-detail__followup { display: flex; flex-direction: column; gap: 0.55rem; padding: 1.5rem 1.75rem; border: 1px solid var(--color-border); border-radius: 12px; background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent); text-decoration: none; color: inherit; max-width: 48rem; }
  .ds-detail__followup-kicker { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-primary); }
  .ds-detail__followup-title { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: var(--color-text); }
</style>
