---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import {
  ARTIFACT_KINDS,
  kindToSegment,
  kindToPluralDisplayName,
  type ArtifactKind,
} from '../../lib/artifacts';
import LoRASignature from '../../components/artifacts/LoRASignature.astro';
import AdapterSignature from '../../components/artifacts/AdapterSignature.astro';
import DatasetSignature from '../../components/artifacts/DatasetSignature.astro';
import { SITE, PUBLISHER } from '../../data/seo';

const all = await getCollection('artifacts');

// Pick a featured artifact per kind for the tile preview signature.
// Sorted by recency so the freshest artifact represents the kind.
function pickFeatured(kind: ArtifactKind) {
  const sorted = all
    .filter((a) => a.data.kind === kind)
    .sort((a, b) => {
      const at = a.data.published_at ? Date.parse(a.data.published_at) : 0;
      const bt = b.data.published_at ? Date.parse(b.data.published_at) : 0;
      return bt - at;
    });
  return sorted[0] ?? null;
}

const featuredByKind: Record<ArtifactKind, ReturnType<typeof pickFeatured>> = Object.fromEntries(
  ARTIFACT_KINDS.map((k) => [k, pickFeatured(k)]),
) as Record<ArtifactKind, ReturnType<typeof pickFeatured>>;

const countsByKind: Record<ArtifactKind, number> = Object.fromEntries(
  ARTIFACT_KINDS.map((k) => [k, 0]),
) as Record<ArtifactKind, number>;
for (const a of all) {
  countsByKind[a.data.kind] = (countsByKind[a.data.kind] ?? 0) + 1;
}

const KIND_BLURBS: Record<ArtifactKind, string> = {
  quant: 'Quantized base models, Spark-measured across perplexity, throughput, vertical eval, and thermal envelope.',
  lora: 'LoRA fine-tunes with training receipts, evaluation deltas, and bounded drift disclosures.',
  adapter: 'Prefix, prompt, and IA³ adapters for specialized inference.',
  dataset: 'Curated and synthesized training/eval datasets.',
  bench: 'Open benchmarks and eval harnesses with publishable scores.',
};

const totalCount = all.length;
const activeKinds = ARTIFACT_KINDS.filter((k) => countsByKind[k] > 0);

const pageTitle = 'Artifacts catalog — ainative';
const pageDescription = `Open research artifacts from the AI Native Platform — ${totalCount} entries across ${activeKinds.length} kinds. Each one Spark-measured and four-axis carded.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Artifacts catalog',
    description: pageDescription,
    url: `${SITE.url}/artifacts/`,
    publisher: PUBLISHER,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Artifacts', item: `${SITE.url}/artifacts/` },
    ],
  },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="hub">
    <header class="hub__masthead">
      <div class="hub__strip" aria-hidden="true">
        <span>Catalog</span>
        <span class="hub__rule"></span>
        <span>{totalCount} published</span>
        <span class="hub__rule"></span>
        <span>{activeKinds.length} of {ARTIFACT_KINDS.length} kinds active</span>
      </div>
      <h1 class="hub__title">Open research artifacts, four-axis carded.</h1>
      <p class="hub__tagline">
        Every artifact here ships with the same disclosure shape — quality,
        throughput, vertical skill, thermal envelope — and was measured on a
        single DGX Spark. Browse by kind.
      </p>
    </header>

    <section class="hub__grid" data-animate-stagger>
      {ARTIFACT_KINDS.map((kind) => {
        const count = countsByKind[kind];
        const isActive = count > 0;
        const href = `/artifacts/${kindToSegment(kind)}/`;
        const TileTag = isActive ? 'a' : 'div';
        const featured = featuredByKind[kind];
        return (
          <TileTag
            class={`hub__tile ${isActive ? 'hub__tile--active' : 'hub__tile--inactive'}`}
            href={isActive ? href : undefined}
            data-animate
            aria-disabled={isActive ? undefined : 'true'}
          >
            <div class="hub__tile-visual" aria-hidden="true">
              {kind === 'lora' && featured && (
                <LoRASignature
                  slug={featured.data.slug}
                  stack_origin={featured.data.stack_origin}
                  base_model={featured.data.base_model}
                  vertical_eval={featured.data.vertical_eval}
                  vertical_eval_name={featured.data.vertical_eval_name}
                  variant="compact"
                />
              )}
              {kind === 'adapter' && (
                <AdapterSignature
                  slug={featured?.data.slug ?? `placeholder-${kind}`}
                  base_model={featured?.data.base_model}
                  variant="compact"
                />
              )}
              {kind === 'dataset' && (
                <DatasetSignature
                  slug={featured?.data.slug ?? `placeholder-${kind}`}
                  total_rows={featured?.data.shapes?.reduce((s, x) => s + x.count, 0)}
                  shapes={featured?.data.shapes?.map((s) => ({ code: s.code, count: s.count, label: s.label }))}
                  license_tier={featured?.data.license.tier}
                  variant="compact"
                />
              )}
              {kind === 'lora' && !featured && (
                <LoRASignature slug={`placeholder-${kind}`} variant="compact" />
              )}
              {(kind === 'quant' || kind === 'bench') && (
                <div class={`hub__tile-monogram hub__tile-monogram--${kind}`} aria-hidden="true">
                  {kind === 'quant' ? 'Q' : 'B'}
                </div>
              )}
            </div>
            <div class="hub__tile-head">
              <span class="hub__tile-kind">{kindToPluralDisplayName(kind)}</span>
              {isActive ? (
                <span class="hub__tile-count">{String(count).padStart(2, '0')}</span>
              ) : (
                <span class="hub__tile-soon">Coming soon</span>
              )}
            </div>
            <p class="hub__tile-blurb">{KIND_BLURBS[kind]}</p>
            {isActive && (
              <span class="hub__tile-cta">
                Browse {kindToPluralDisplayName(kind).toLowerCase()} <span aria-hidden="true">→</span>
              </span>
            )}
          </TileTag>
        );
      })}
    </section>

    <p class="hub__crosslink">
      Every artifact is published alongside a field note. Read the running log of
      releases at <a href="/field-notes/">/field-notes/</a>.
    </p>
  </main>
  <Footer />
</Layout>

<style>
  .hub {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem);
  }
  .hub__masthead {
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
    max-width: 60rem;
  }
  .hub__strip {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }
  .hub__rule {
    flex: 0 0 2.5rem;
    height: 1px;
    background: var(--color-border);
  }
  .hub__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.018em;
    color: var(--color-text);
    margin: 0 0 1.1rem;
    max-width: 22ch;
  }
  .hub__tagline {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }

  .hub__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .hub__tile {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem 1.5rem 1.6rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
  }
  .hub__tile--inactive {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .hub__tile--active:hover {
    border-color: color-mix(in oklch, var(--color-primary) 50%, var(--color-border));
    background: color-mix(in oklch, var(--color-primary) 6%, var(--color-surface-raised));
    transform: translateY(-2px);
  }
  .hub__tile--active:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .hub__tile-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 5.5rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid color-mix(in oklch, var(--color-border) 60%, transparent);
  }
  .hub__tile-monogram {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.05em;
    color: color-mix(in oklch, var(--color-primary) 75%, transparent);
  }
  .hub__tile-monogram--bench {
    color: color-mix(in oklch, var(--color-accent) 75%, transparent);
  }

  .hub__tile-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .hub__tile-kind {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-text);
    line-height: 1.2;
  }
  .hub__tile-count {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.95rem;
    color: var(--color-primary);
  }
  .hub__tile-soon {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-dim);
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    line-height: 1;
    white-space: nowrap;
  }
  .hub__tile-blurb {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
  .hub__tile-cta {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
  }
  .hub__tile--active:hover .hub__tile-cta {
    color: var(--color-text);
  }

  .hub__crosslink {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    text-align: center;
  }
  .hub__crosslink a {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--color-primary) 50%, transparent);
  }
  .hub__crosslink a:hover {
    border-bottom-color: var(--color-primary);
  }
</style>
