---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import QuantSpecTable from '../../../../components/artifacts/QuantSpecTable.astro';
import LicenseChip from '../../../../components/artifacts/LicenseChip.astro';
import { pickSweetSpot, type ArtifactDataShape } from '../../../../lib/artifacts';
import { SITE, PUBLISHER } from '../../../../data/seo';

export async function getStaticPaths() {
  const all = await getCollection('artifacts', ({ data }) => data.kind === 'quant');
  const fieldNotes = await getCollection('field-notes');
  return all.map((artifact) => ({
    params: { slug: artifact.data.slug },
    props: { artifact, fieldNotes },
  }));
}

interface PageProps {
  artifact: CollectionEntry<'artifacts'>;
  fieldNotes: CollectionEntry<'field-notes'>[];
}

const { artifact, fieldNotes } = Astro.props as PageProps;
const {
  slug,
  class: artifactClass,
  base_model,
  hf_repo,
  variants,
  recommended_variant,
  perplexity,
  spark_tokens_per_sec,
  sustained_load_minutes,
  vertical_eval,
  vertical_eval_name,
  lineage_run_id,
  license,
  article,
  published_at,
} = artifact.data;

const sweetSpot = pickSweetSpot({
  variants,
  recommended_variant,
  perplexity,
  spark_tokens_per_sec,
  vertical_eval,
} as ArtifactDataShape);

const hfUrl = hf_repo.includes('://')
  ? hf_repo
  : `https://huggingface.co/${hf_repo}`;

// base_model "vendor/model" → linked to HF.
const baseModelHref =
  /^[^/\s]+\/[^/\s]+$/.test(base_model)
    ? `https://huggingface.co/${base_model}`
    : null;

const publishedDate = published_at
  ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(
      new Date(published_at),
    )
  : null;

// Article wire-back: `article` is "articles/<slug>/" → match field-notes entry id.
let linkedArticle: CollectionEntry<'field-notes'> | null = null;
if (article) {
  const articleSlug = article.replace(/^articles\//, '').replace(/\/$/, '');
  linkedArticle = fieldNotes.find((a) => a.id === articleSlug) ?? null;
}

const pageTitle = `${slug} — Quantization — ainative`;
const pageDescription = `${variants.length}-variant ${artifactClass.toUpperCase()} quantization of ${base_model}. Spark-measured four-axis card across perplexity, throughput, ${vertical_eval_name ?? 'vertical eval'}, and sustained-load minutes.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: slug,
    description: pageDescription,
    url: `${SITE.url}/artifacts/quants/${slug}/`,
    publisher: PUBLISHER,
    license: license.tier === 'free' ? 'open' : license.tier,
    keywords: [artifactClass, 'gguf', 'quantization', base_model],
    datePublished: published_at,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Artifacts', item: `${SITE.url}/artifacts/` },
      { '@type': 'ListItem', position: 3, name: 'Quantizations', item: `${SITE.url}/artifacts/quants/` },
      { '@type': 'ListItem', position: 4, name: slug, item: `${SITE.url}/artifacts/quants/${slug}/` },
    ],
  },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="qa-detail">
    <header class="qa-detail__header">
      <a class="qa-detail__back" href="/artifacts/quants/">← Quantizations</a>
      <div class="qa-detail__kicker">
        <span class="qa-detail__kicker-kind">Quant</span>
        <span>·</span>
        <span>{artifactClass.toUpperCase()}</span>
        <span>·</span>
        <span>{variants.length} variants</span>
      </div>
      <h1 class="qa-detail__title">{slug}</h1>
      <p class="qa-detail__subtitle">
        Quantization of{' '}
        {baseModelHref ? (
          <a href={baseModelHref} target="_blank" rel="noopener noreferrer" class="qa-detail__base">
            {base_model}
          </a>
        ) : (
          <span class="qa-detail__base">{base_model}</span>
        )}.
      </p>
      <div class="qa-detail__meta">
        <a class="qa-detail__meta-item" href={hfUrl} target="_blank" rel="noopener noreferrer">
          <span class="qa-detail__meta-label">HF</span>
          <span class="qa-detail__meta-value">{hf_repo}</span>
        </a>
        <span class="qa-detail__meta-divider" aria-hidden="true"></span>
        <span class="qa-detail__meta-item">
          <span class="qa-detail__meta-label">License</span>
          <LicenseChip tier={license.tier} model={license.model} />
        </span>
        {publishedDate && (
          <>
            <span class="qa-detail__meta-divider" aria-hidden="true"></span>
            <span class="qa-detail__meta-item">
              <span class="qa-detail__meta-label">Published</span>
              <time class="qa-detail__meta-value" datetime={published_at}>{publishedDate}</time>
            </span>
          </>
        )}
      </div>
    </header>

    <section class="qa-detail__matrix">
      <div class="qa-detail__matrix-head">
        <h2 class="qa-detail__h2">Spec matrix</h2>
        <p class="qa-detail__h2-blurb">
          Ranks within each column drive the heatmap. Lower perplexity, higher
          throughput, higher vertical eval — the sweet-spot row balances all three.
        </p>
      </div>
      <div class="qa-detail__matrix-body">
        <div class="qa-detail__table">
          <QuantSpecTable
            variants={variants}
            perplexity={perplexity}
            spark_tokens_per_sec={spark_tokens_per_sec}
            vertical_eval={vertical_eval}
            vertical_eval_name={vertical_eval_name}
            sweetSpot={sweetSpot}
          />
        </div>
        {sustained_load_minutes !== undefined && (
          <aside class="qa-detail__envelope">
            <span class="qa-detail__envelope-kicker">Sustained load</span>
            <span class="qa-detail__envelope-value">{sustained_load_minutes.toFixed(1)}</span>
            <span class="qa-detail__envelope-unit">min</span>
            <span class="qa-detail__envelope-note">Single thermal envelope before throttle.</span>
          </aside>
        )}
      </div>
    </section>

    {(linkedArticle || lineage_run_id) && (
      <section class="qa-detail__followups">
        {linkedArticle && (
          <a class="qa-detail__followup-card" href={`/field-notes/${linkedArticle.id}/`}>
            <span class="qa-detail__followup-kicker">Read the field note</span>
            <span class="qa-detail__followup-title">{linkedArticle.data.title}</span>
            <span class="qa-detail__followup-cta">Open article <span aria-hidden="true">→</span></span>
          </a>
        )}
        {lineage_run_id && (
          <div class="qa-detail__lineage">
            <span class="qa-detail__lineage-label">Lineage</span>
            <code class="qa-detail__lineage-code">{lineage_run_id}</code>
          </div>
        )}
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .qa-detail {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem);
  }

  .qa-detail__back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }
  .qa-detail__back:hover {
    color: var(--color-primary);
  }

  .qa-detail__header {
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
    max-width: 60rem;
  }
  .qa-detail__kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .qa-detail__kicker-kind {
    color: var(--color-primary);
  }

  .qa-detail__title {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--color-text);
    margin: 0 0 1rem;
    word-break: break-word;
  }
  .qa-detail__subtitle {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 1.75rem;
  }
  .qa-detail__base {
    font-family: var(--font-mono);
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--color-primary) 50%, transparent);
    transition: color 0.2s, border-color 0.2s;
  }
  a.qa-detail__base:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .qa-detail__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .qa-detail__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
    text-decoration: none;
  }
  a.qa-detail__meta-item {
    transition: color 0.2s;
  }
  a.qa-detail__meta-item:hover {
    color: var(--color-primary);
  }
  .qa-detail__meta-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-dim);
  }
  .qa-detail__meta-value {
    color: var(--color-text);
  }
  .qa-detail__meta-divider {
    width: 1px;
    height: 1rem;
    background: var(--color-border);
  }

  .qa-detail__matrix {
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .qa-detail__matrix-head {
    margin-bottom: 1.5rem;
    max-width: 60ch;
  }
  .qa-detail__h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .qa-detail__h2-blurb {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .qa-detail__matrix-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(11rem, 18vw, 14rem);
    gap: 2rem;
    align-items: start;
  }
  .qa-detail__table {
    min-width: 0;
  }

  .qa-detail__envelope {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding: 1.5rem 1.5rem 1.6rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent);
  }
  .qa-detail__envelope-kicker {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
  }
  .qa-detail__envelope-value {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    line-height: 1;
    color: var(--color-primary);
    margin: 0.15rem 0 0;
  }
  .qa-detail__envelope-unit {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: -0.4rem;
  }
  .qa-detail__envelope-note {
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    max-width: 14rem;
  }

  @media (max-width: 840px) {
    .qa-detail__matrix-body {
      grid-template-columns: 1fr;
    }
    .qa-detail__envelope {
      flex-direction: row;
      align-items: baseline;
      gap: 0.75rem;
      flex-wrap: wrap;
      padding: 1.25rem 1.25rem 1.35rem;
    }
    .qa-detail__envelope-value {
      font-size: 2.4rem;
    }
    .qa-detail__envelope-unit {
      margin-top: 0;
    }
    .qa-detail__envelope-note {
      flex: 1 0 100%;
      margin-top: 0.5rem;
      max-width: none;
    }
  }

  .qa-detail__followups {
    display: grid;
    gap: 1rem;
    max-width: 48rem;
  }
  .qa-detail__followup-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .qa-detail__followup-card:hover {
    border-color: color-mix(in oklch, var(--color-primary) 50%, var(--color-border));
    background: color-mix(in oklch, var(--color-primary) 6%, var(--color-surface-raised));
    transform: translateY(-2px);
  }
  .qa-detail__followup-kicker {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-primary);
  }
  .qa-detail__followup-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--color-text);
  }
  .qa-detail__followup-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }

  .qa-detail__lineage {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent);
    align-self: flex-start;
  }
  .qa-detail__lineage-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-dim);
  }
  .qa-detail__lineage-code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
    background: transparent;
    padding: 0;
  }
</style>
