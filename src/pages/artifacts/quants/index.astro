---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import QuantCard from '../../../components/artifacts/QuantCard.astro';
import { SITE, PUBLISHER } from '../../../data/seo';

const all = await getCollection('artifacts', ({ data }) => data.kind === 'quant');
const sorted = [...all].sort((a, b) => {
  const at = a.data.published_at ? Date.parse(a.data.published_at) : 0;
  const bt = b.data.published_at ? Date.parse(b.data.published_at) : 0;
  return bt - at;
});

const countPadded = String(sorted.length).padStart(2, '0');
const volLabel = new Intl.DateTimeFormat('en-GB', { month: 'short', year: 'numeric' }).format(new Date());

const pageTitle = 'Quantizations — Artifacts — ainative';
const pageDescription = `${sorted.length} GGUF quantization artifacts measured on a DGX Spark. Each one carries perplexity, throughput, vertical eval, and sustained-load minutes across every variant.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Quantizations',
    description: pageDescription,
    url: `${SITE.url}/artifacts/quants/`,
    publisher: PUBLISHER,
    hasPart: sorted.map((a) => ({
      '@type': 'Dataset',
      name: a.data.slug,
      description: `${a.data.class.toUpperCase()} quantization of ${a.data.base_model}`,
      url: `${SITE.url}/artifacts/quants/${a.data.slug}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Artifacts', item: `${SITE.url}/artifacts/` },
      { '@type': 'ListItem', position: 3, name: 'Quantizations', item: `${SITE.url}/artifacts/quants/` },
    ],
  },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="qa-index">
    <header class="qa-index__masthead">
      <div class="qa-index__strip" aria-hidden="true">
        <a class="qa-index__back" href="/artifacts/">← Artifacts</a>
        <span class="qa-index__rule"></span>
        <span>/quants/</span>
        <span class="qa-index__rule"></span>
        <span>{volLabel}</span>
      </div>
      <h1 class="qa-index__title">Quantizations.</h1>
      <p class="qa-index__tagline">
        Open GGUF quants of vertical-finetuned base models — each shipped with a
        Spark-measured four-axis card so a downstream reader picks the right
        variant without re-running the eval. <span class="qa-index__count">{countPadded} published.</span>
      </p>
    </header>

    {sorted.length === 0 ? (
      <p class="qa-index__empty">No quantizations published yet.</p>
    ) : (
      <section class="qa-index__list">
        {sorted.map((artifact) => (
          <QuantCard artifact={artifact} />
        ))}
        <div class="qa-index__closer">
          <span class="qa-index__closer-glyph">※</span>
          <span>More artifacts in preparation</span>
          <span class="qa-index__closer-rule"></span>
          <span>End of {volLabel}</span>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .qa-index {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem);
  }
  .qa-index__masthead {
    margin-bottom: 2rem;
    max-width: 60rem;
  }
  .qa-index__strip {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }
  .qa-index__back {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .qa-index__back:hover {
    color: var(--color-primary);
  }
  .qa-index__rule {
    flex: 0 0 2rem;
    height: 1px;
    background: var(--color-border);
  }
  .qa-index__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 1rem;
  }
  .qa-index__tagline {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }
  .qa-index__count {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.95em;
    margin-left: 0.25rem;
  }

  .qa-index__list {
    margin-top: 1.5rem;
  }
  .qa-index__list > :global(.qa-card):first-of-type {
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }
  .qa-index__list > :global(.qa-card):last-of-type {
    border-bottom: none;
  }

  .qa-index__empty {
    margin-top: 3rem;
    padding: 3rem 2rem;
    border: 1px dashed var(--color-border);
    border-radius: 10px;
    text-align: center;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .qa-index__closer {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 3rem;
    padding: 2rem 0 0;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .qa-index__closer-glyph {
    color: var(--color-primary);
  }
  .qa-index__closer-rule {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }
</style>
