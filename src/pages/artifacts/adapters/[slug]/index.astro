---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import AdapterSignature from '../../../../components/artifacts/AdapterSignature.astro';
import LicenseChip from '../../../../components/artifacts/LicenseChip.astro';
import NotebookBadges from '../../../../components/artifacts/NotebookBadges.astro';
import { SITE, PUBLISHER } from '../../../../data/seo';

export async function getStaticPaths() {
  const all = await getCollection('artifacts', ({ data }) => data.kind === 'adapter');
  const fieldNotes = await getCollection('field-notes');
  return all.map((artifact) => ({
    params: { slug: artifact.data.slug },
    props: { artifact, fieldNotes },
  }));
}

interface PageProps {
  artifact: CollectionEntry<'artifacts'>;
  fieldNotes: CollectionEntry<'field-notes'>[];
}

const { artifact, fieldNotes } = Astro.props as PageProps;
const {
  slug, class: artifactClass, base_model, hf_repo, license, article, published_at,
  positioning, known_drift, notebooks,
} = artifact.data;

const hfUrl = hf_repo.includes('://') ? hf_repo : `https://huggingface.co/${hf_repo}`;
const publishedDate = published_at
  ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(published_at))
  : null;

let linkedArticle: CollectionEntry<'field-notes'> | null = null;
if (article) {
  const articleSlug = article.replace(/^articles\//, '').replace(/\/$/, '');
  linkedArticle = fieldNotes.find((a) => a.id === articleSlug) ?? null;
}

const pageTitle = `${slug} — Adapter — ainative`;
const truncateForMeta = (s: string, limit = 160): string => {
  if (s.length <= limit) return s;
  let cut = s.slice(0, limit - 1).trimEnd();
  const sp = cut.lastIndexOf(' ');
  if (sp > 0) cut = cut.slice(0, sp).replace(/[,;:\-—]+$/, '').trimEnd();
  return cut + '…';
};
const pageDescription = positioning?.problem
  ? truncateForMeta(positioning.problem.replace(/\s+/g, ' '))
  : `Adapter for ${base_model}.`;
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'Dataset', name: slug, description: pageDescription, url: `${SITE.url}/artifacts/adapters/${slug}/`, publisher: PUBLISHER, datePublished: published_at },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="adp-detail">
    <a class="adp-detail__back" href="/artifacts/adapters/">← Adapters</a>
    <div class="adp-detail__kicker"><span class="adp-detail__kicker-kind">Adapter</span><span>·</span><span>{artifactClass.toUpperCase()}</span></div>
    <h1 class="adp-detail__title">{slug}</h1>
    {positioning?.headline && <p class="adp-detail__elevator">{positioning.headline}</p>}

    <div class="adp-detail__hero">
      <div class="adp-detail__hero-visual">
        <AdapterSignature slug={slug} base_model={base_model} variant="hero" />
      </div>
      <div class="adp-detail__meta">
        <a class="adp-detail__meta-item" href={hfUrl} target="_blank" rel="noopener noreferrer"><span class="adp-detail__meta-label">HF</span><span>{hf_repo}</span></a>
        <div class="adp-detail__meta-item"><span class="adp-detail__meta-label">Base</span><span>{base_model}</span></div>
        <div class="adp-detail__meta-item"><span class="adp-detail__meta-label">License</span><LicenseChip tier={license.tier} model={license.model} /></div>
        {publishedDate && <div class="adp-detail__meta-item"><span class="adp-detail__meta-label">Published</span><time datetime={published_at}>{publishedDate}</time></div>}
      </div>
    </div>

    <NotebookBadges notebooks={notebooks} contextLabel={slug} />

    {positioning?.problem && (
      <section class="adp-detail__section">
        <h2 class="adp-detail__h2">What this adapter does</h2>
        <p class="adp-detail__problem">{positioning.problem}</p>
        {positioning.use_cases?.length > 0 && (
          <ul class="adp-detail__uses">{positioning.use_cases.map((uc) => <li>{uc}</li>)}</ul>
        )}
      </section>
    )}

    {linkedArticle && (
      <section class="adp-detail__section">
        <h2 class="adp-detail__h2">Methods</h2>
        <a class="adp-detail__followup" href={`/field-notes/${linkedArticle.id}/`}>
          <span class="adp-detail__followup-kicker">Read the field note</span>
          <span class="adp-detail__followup-title">{linkedArticle.data.title}</span>
        </a>
      </section>
    )}

    {known_drift?.length > 0 && (
      <section class="adp-detail__section">
        <h2 class="adp-detail__h2">Known drift</h2>
        <dl class="adp-detail__drift">
          {known_drift.map((d) => (
            <div class="adp-detail__drift-row">
              <dt>{d.item}</dt>
              <dd>{d.bound}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .adp-detail { max-width: 72rem; margin: 0 auto; padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem); }
  .adp-detail__back { display: inline-block; font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-text-muted); text-decoration: none; margin-bottom: 2rem; }
  .adp-detail__back:hover { color: var(--color-primary); }
  .adp-detail__kicker { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-text-muted); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.6rem; }
  .adp-detail__kicker-kind { color: var(--color-primary); }
  .adp-detail__title { font-family: var(--font-mono); font-weight: 500; font-size: clamp(1.6rem, 3.5vw, 2.5rem); margin: 0 0 0.85rem; color: var(--color-text); }
  .adp-detail__elevator { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.2rem, 2vw, 1.55rem); line-height: 1.4; color: var(--color-text); margin: 0 0 2rem; max-width: 50ch; }
  .adp-detail__hero { display: grid; grid-template-columns: minmax(0, 1fr) clamp(14rem, 22vw, 18rem); gap: 2.5rem; align-items: center; padding: 1.5rem 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .adp-detail__hero-visual { order: 2; justify-self: center; width: 100%; max-width: 18rem; }
  .adp-detail__meta { order: 1; display: grid; gap: 0.6rem 1.25rem; grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr)); }
  .adp-detail__meta-item { display: flex; flex-direction: column; gap: 0.25rem; font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-text); text-decoration: none; }
  .adp-detail__meta-label { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.16em; color: var(--color-text-dim); }
  @media (max-width: 840px) { .adp-detail__hero { grid-template-columns: 1fr; } .adp-detail__hero-visual { order: 1; max-width: 14rem; } .adp-detail__meta { order: 2; } }
  .adp-detail__section { margin: clamp(2.5rem, 4.5vw, 3.5rem) 0; max-width: 60rem; }
  .adp-detail__h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.4rem, 2.5vw, 1.8rem); margin: 0 0 0.85rem; color: var(--color-text); }
  .adp-detail__problem { font-size: 1.05rem; line-height: 1.7; color: var(--color-text); max-width: 65ch; }
  .adp-detail__uses { margin: 1rem 0 0; padding-left: 1.25rem; line-height: 1.7; color: var(--color-text); max-width: 65ch; }
  .adp-detail__followup { display: flex; flex-direction: column; gap: 0.55rem; padding: 1.5rem 1.75rem; border: 1px solid var(--color-border); border-radius: 12px; background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent); text-decoration: none; color: inherit; max-width: 48rem; }
  .adp-detail__followup:hover { border-color: color-mix(in oklch, var(--color-primary) 50%, var(--color-border)); }
  .adp-detail__followup-kicker { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-primary); }
  .adp-detail__followup-title { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: var(--color-text); }
  .adp-detail__drift { display: grid; gap: 0.85rem; margin: 0; }
  .adp-detail__drift-row { display: grid; grid-template-columns: minmax(min(100%, 14rem), 1fr) 2fr; gap: 1rem; padding: 0.95rem 1.1rem; border: 1px solid var(--color-border); border-radius: 8px; background: color-mix(in oklch, var(--color-surface-raised) 35%, transparent); }
  .adp-detail__drift-row dt { font-family: var(--font-mono); font-size: 0.88rem; color: var(--color-text); font-weight: 500; margin: 0; }
  .adp-detail__drift-row dd { font-size: 0.92rem; color: var(--color-text-muted); margin: 0; }
  @media (max-width: 700px) { .adp-detail__drift-row { grid-template-columns: 1fr; gap: 0.45rem; } }
</style>
