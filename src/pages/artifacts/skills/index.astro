---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import SkillSignature from '../../../components/artifacts/SkillSignature.astro';
import { SITE, PUBLISHER } from '../../../data/seo';

const all = await getCollection('artifacts', ({ data }) => data.kind === 'skill');
const sorted = [...all].sort((a, b) => {
  const at = a.data.published_at ? Date.parse(a.data.published_at) : 0;
  const bt = b.data.published_at ? Date.parse(b.data.published_at) : 0;
  return bt - at;
});

const countPadded = String(sorted.length).padStart(2, '0');
const volLabel = new Intl.DateTimeFormat('en-GB', { month: 'short', year: 'numeric' }).format(new Date());

const pageTitle = 'Skills — Artifacts — ainative';
const pageDescription = `${sorted.length} agentskills.io-format skill bundle${sorted.length === 1 ? '' : 's'} — portable across Claude Code, Hermes, and any agentskills.io-compatible runtime.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Skills',
    description: pageDescription,
    url: `${SITE.url}/artifacts/skills/`,
    publisher: PUBLISHER,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Artifacts', item: `${SITE.url}/artifacts/` },
      { '@type': 'ListItem', position: 3, name: 'Skills', item: `${SITE.url}/artifacts/skills/` },
    ],
  },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main class="si">
    <header class="si__masthead">
      <div class="si__strip" aria-hidden="true">
        <a class="si__back" href="/artifacts/">← Artifacts</a>
        <span class="si__rule"></span>
        <span>/skills/</span>
        <span class="si__rule"></span>
        <span>{volLabel}</span>
      </div>
      <h1 class="si__title">Skills.</h1>
      <p class="si__tagline">
        Agentskills.io-format skill bundles — the same <code>SKILL.md</code>
        Claude Code reads, packaged so any agentskills.io-compatible runtime
        (Hermes included) loads them unchanged.
        <span class="si__count">{countPadded} published.</span>
      </p>
    </header>

    {sorted.length === 0 ? (
      <p class="si__empty">No skills published yet.</p>
    ) : (
      <section class="si__list">
        {sorted.map((artifact) => {
          const a = artifact.data;
          return (
            <a class="si__row" href={`/artifacts/skills/${a.slug}/`}>
              <div class="si__row-visual" aria-hidden="true">
                <SkillSignature
                  slug={a.slug}
                  variants={a.variants}
                  recommended_variant={a.recommended_variant}
                  variant="compact"
                />
              </div>
              <div class="si__row-meta">
                <div class="si__row-head">
                  <h2 class="si__row-title">{a.slug}</h2>
                  <span class="si__row-class">{a.class}</span>
                </div>
                {a.positioning?.headline && <p class="si__row-blurb">{a.positioning.headline}</p>}
                <div class="si__row-chips">
                  {a.variants && a.variants.length > 0 && <span class="si__row-chip">{a.variants.length} variants</span>}
                  <span class="si__row-chip">{a.license.tier}</span>
                </div>
              </div>
              <span class="si__row-arrow" aria-hidden="true">→</span>
            </a>
          );
        })}
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .si { max-width: 72rem; margin: 0 auto; padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(4rem, 6vw, 6rem); }
  .si__masthead { margin-bottom: 2rem; max-width: 60rem; }
  .si__strip {
    display: flex; align-items: center; gap: 1rem;
    font-family: var(--font-mono); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--color-text-muted); margin-bottom: 1.25rem;
  }
  .si__back { color: var(--color-text-muted); text-decoration: none; transition: color 0.2s; }
  .si__back:hover { color: var(--color-primary); }
  .si__rule { flex: 0 0 2rem; height: 1px; background: var(--color-border); }
  .si__title { font-family: var(--font-display); font-weight: 700; font-size: clamp(2.2rem, 5vw, 3.8rem); line-height: 1.05; letter-spacing: -0.02em; color: var(--color-text); margin: 0 0 1rem; }
  .si__tagline { font-size: 1.05rem; line-height: 1.65; color: var(--color-text-muted); max-width: 56ch; margin: 0; }
  .si__tagline code { font-family: var(--font-mono); }
  .si__count { color: var(--color-primary); font-family: var(--font-mono); font-size: 0.95em; margin-left: 0.25rem; }

  .si__list { margin-top: 1.5rem; border-top: 1px solid var(--color-border); display: grid; gap: 0; }
  .si__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 1rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .si__row:hover { background: color-mix(in oklch, var(--color-primary) 4%, transparent); }
  .si__row-visual { display: flex; align-items: center; }
  .si__row-head { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.45rem; }
  .si__row-title { font-family: var(--font-display); font-size: 1.2rem; color: var(--color-text); margin: 0; line-height: 1.2; }
  .si__row-class { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-primary); }
  .si__row-blurb { margin: 0 0 0.65rem; color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.55; }
  .si__row-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .si__row-chip { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-text-muted); padding: 0.18rem 0.55rem; border: 1px solid var(--color-border); border-radius: 999px; }
  .si__row-arrow { font-family: var(--font-mono); color: var(--color-text-muted); font-size: 1.2rem; }
  .si__row:hover .si__row-arrow { color: var(--color-primary); }

  .si__empty {
    margin-top: 3rem; padding: 3rem 2rem;
    border: 1px dashed var(--color-border); border-radius: 10px;
    text-align: center; color: var(--color-text-muted); font-family: var(--font-mono);
  }

  @media (max-width: 36rem) {
    .si__row { grid-template-columns: 1fr; gap: 0.65rem; }
    .si__row-arrow { display: none; }
  }
</style>
