---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const status = Astro.url.searchParams.get('status') || 'success';
const error = Astro.url.searchParams.get('error');

const isError = status === 'error';
const isAlready = status === 'already';
---
<Layout title="Subscription Confirmed — ainative" noindex={true}>
  <Nav />
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="max-w-md text-center">
      {isError ? (
        <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center mx-auto mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </div>
      ) : (
        <div class="w-12 h-12 rounded-full bg-success/10 flex items-center justify-center mx-auto mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
      )}

      <h1 class="font-mono text-xl tracking-widest text-text uppercase mb-4">
        {isError ? 'Oops' : isAlready ? 'Already confirmed' : 'Thank you'}
      </h1>

      <p class="text-text-muted text-base leading-relaxed mb-8">
        {isError
          ? (error || 'Something went wrong. Please try again.')
          : isAlready
            ? "You're subscribed to AI Native research."
            : "You'll hear from us when new book chapters, research papers, or companion software releases ship."}
      </p>

      <div class="flex flex-col gap-3 items-center">
        <a href="/"
           class="inline-block font-mono text-xs tracking-[0.2em] uppercase bg-primary text-surface px-7 py-3 no-underline hover:brightness-110 transition-all rounded-md">
          Back to ainative
        </a>
        {!isError && (
          <a href="/docs/"
             class="inline-block font-mono text-xs tracking-[0.2em] uppercase text-primary border border-primary/40 px-7 py-3 no-underline hover:border-primary/70 transition-all rounded-md">
            View Documentation
          </a>
        )}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
