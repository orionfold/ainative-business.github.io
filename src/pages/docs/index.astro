---
import DocsLayout from '../../layouts/DocsLayout.astro';

const pages = [
  { href: '/docs/dashboard/', title: 'Home & Dashboard', description: 'Workspace briefing with micro-visualizations, execution lanes, and live operational signals.', screenshot: '/screenshots/home-list.png' },
  { href: '/docs/tasks/', title: 'Task Execution', description: 'Status-driven task flow, AI-assisted creation, bento detail view, and bulk operations.', screenshot: '/screenshots/dashboard-list.png' },
  { href: '/docs/projects/', title: 'Projects', description: 'Portfolio organization with working directories, completion donuts, and scoped execution.', screenshot: '/screenshots/projects-list.png' },
  { href: '/docs/workflows/', title: 'Workflows', description: 'Six execution patterns, blueprint catalog, step-level retry, and time-delay steps for drip sequences.', screenshot: '/screenshots/workflows-blueprints.png' },
  { href: '/docs/profiles/', title: 'Profiles', description: 'Technical and business-function profiles across 5 providers with auto-detect routing and supervised self-improvement.', screenshot: '/screenshots/profiles-list.png' },
  { href: '/docs/schedules/', title: 'Schedules', description: 'Clock-driven and heartbeat schedules with concurrency caps, per-schedule turn budgets, and natural language intervals.', screenshot: '/screenshots/schedules-list.png' },
  { href: '/docs/documents/', title: 'Documents', description: 'Drag-and-drop upload, automatic text extraction, filter namespace syntax, saved searches, and agent context injection.', screenshot: '/screenshots/documents-list.png' },
  { href: '/docs/inbox/', title: 'Human-in-the-Loop', description: 'Approval controls, ambient toasts, agent handoffs, budget alerts, and rich content rendering.', screenshot: '/screenshots/inbox-permissions.png' },
  { href: '/docs/monitoring/', title: 'Monitoring', description: 'Streaming logs with click-to-navigate, auto-pause on tab switch, and event filtering.', screenshot: '/screenshots/monitor-list.png' },
  { href: '/docs/costs/', title: 'Cost & Usage', description: 'Five-provider spend ledger with budget enforcement, project budgets, and Ollama at $0.', screenshot: '/screenshots/cost-codex-claude-code.png' },
  { href: '/docs/agents/', title: 'Agent Integration', description: 'Five provider runtimes with smart router, profile-backed policies, episodic memory, and async handoffs.', screenshot: '/screenshots/profiles-detail.png' },
  { href: '/docs/chat/', title: 'Chat', description: 'Tool Catalog with slash commands, skill composition, conversation templates, @ mentions, saved searches, and bidirectional channels.', screenshot: '/screenshots/chat-list.png' },
  { href: '/docs/environment/', title: 'Environment', description: 'Scan, audit, and manage Claude Code and Codex CLI environments with health scoring and artifact discovery.', screenshot: '/screenshots/environment-list.png' },
  { href: '/docs/tables/', title: 'Tables', description: 'Structured data tables with spreadsheet editing, charts, triggers, templates, and bulk row enrichment via agent loops.', screenshot: '/screenshots/tables-list.png' },
  { href: '/docs/settings/', title: 'Settings', description: 'Providers & Runtimes, delivery channels, permission presets, database snapshots, and instance upgrade flow.', screenshot: '/screenshots/settings-list.png' },
];
---
<DocsLayout title="Overview" description="Comprehensive documentation for ainative — your business, run by AI. Explore agent profiles, workflows, governance, cost controls, and more.">
  <h1>ainative Documentation</h1>
  <p>ainative is a local-first AI agent operations workspace. Explore the product surfaces below to see how home, execution, projects, workflows, profiles, schedules, documents, tables, chat, environment, monitoring, cost governance, and approvals fit together.</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 not-prose">
    {pages.map(({ href, title, description, screenshot }) => (
      <a href={href} class="group block border border-border rounded-lg overflow-hidden hover:border-primary/40 transition-colors">
        <div class="aspect-video overflow-hidden bg-surface-raised">
          <img
            src={screenshot}
            alt={title}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-sm text-text mb-1">{title}</h3>
          <p class="text-xs text-text-muted leading-relaxed">{description}</p>
        </div>
      </a>
    ))}
  </div>
</DocsLayout>
