---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/book.css';
import { PARTS, CHAPTERS, CHAPTER_SLUG_MAP } from '../../lib/book/content';
import { READING_PATHS } from '../../lib/book/reading-paths';
import { SITE, PUBLISHER } from '../../data/seo';
import BrowserFrame from '../../components/ui/BrowserFrame.astro';

const totalReadingTime = CHAPTERS.reduce((sum, ch) => sum + ch.readingTime, 0);
const totalWords = CHAPTERS.reduce((sum, ch) => sum + ch.wordCount, 0);
const totalPages = Math.ceil(totalWords / 250);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Book',
    name: 'AI Native Business: Building Autonomous Business Systems with AI Agents',
    author: {
      '@type': 'Person',
      name: 'Manav Sehgal',
    },
    description: 'A practical guide to building AI-native applications — 14 chapters across 4 parts, from organizational design to autonomous business systems built with AI agents.',
    publisher: PUBLISHER,
    url: `${SITE.url}/book/`,
    inLanguage: 'en',
    numberOfPages: totalPages,
    accessMode: 'textual',
    isAccessibleForFree: true,
    license: 'https://creativecommons.org/licenses/by-nc/4.0/',
  },
];
---
<Layout
  title="AI Native Business — The Book | Stagent"
  description="A practical guide to building AI-native applications. 14 chapters across 4 parts — from organizational design to autonomous business systems built with AI agents."
  ogImage="/book/og-image.png"
  jsonLd={jsonLd}
>
  <Nav />

  <main class="pt-28 pb-32">
    <!-- Hero -->
    <section class="relative px-6 overflow-x-clip pt-4 pb-8 mb-12">
      <!-- Atmospheric glow -->
      <div class="absolute inset-0 -z-10 flex items-center justify-center pointer-events-none">
        <div class="absolute w-[600px] h-[600px] rounded-full bg-primary/[0.08] blur-[150px]"></div>
      </div>

      <!-- Bottom gradient fade into parts grid -->
      <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>

      <!-- Two-column grid: content left, book cover right -->
      <div class="relative z-10 w-full max-w-5xl mx-auto grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-10 items-center">

        <!-- Left column: Content -->
        <div class="text-center lg:text-left" data-animate-stagger>

          <p data-animate class="font-mono text-[10px] tracking-[0.2em] uppercase text-success mb-4">
            Free Online Book
          </p>

          <h1 data-animate class="book-hero-gradient font-display text-[clamp(2.2rem,4.5vw,3.5rem)] font-bold leading-[1.1] mb-3">
            AI Native Business
          </h1>

          <p data-animate class="text-[clamp(1rem,2vw,1.25rem)] text-text-muted leading-relaxed mb-5 max-w-xl mx-auto lg:mx-0">
            Building Autonomous Business Systems with AI Agents
          </p>

          <p data-animate class="text-sm text-text-muted leading-relaxed max-w-md mx-auto lg:mx-0 mb-6">
            From two thousand years of organizational design to autonomous business
            systems. Every pattern demonstrated with working code from Stagent,
            a platform that built itself.
          </p>

          <!-- Value pills -->
          <div data-animate class="flex items-center justify-center lg:justify-start gap-1.5 flex-wrap mb-6 max-w-md mx-auto lg:mx-0">
            <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">{CHAPTERS.length} Chapters</span>
            <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">{PARTS.length} Parts</span>
            <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">~{totalReadingTime} Min Read</span>
            <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">{totalWords.toLocaleString()} Words</span>
            <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">~{totalPages} Pages</span>
          </div>

          <!-- CTA -->
          <div data-animate>
            <a
              href={`/book/${CHAPTER_SLUG_MAP['ch-1']}/`}
              class="inline-flex items-center gap-2 bg-primary text-white font-medium px-7 py-3.5 rounded-lg hover:opacity-90 transition-opacity no-underline primary-pulse"
            >
              Start Reading
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

        </div>

        <!-- Right column: Book cover -->
        <div data-animate class="book-cover-float flex items-center justify-center" style="transition-delay: 200ms">
          <img
            src="/book/images/ai-native-book-manav-sehgal.png"
            alt="AI Native Business book cover — Building Autonomous Business Systems with AI Agents"
            width="1024"
            height="1536"
            class="w-auto max-w-[720px] sm:max-w-[900px] lg:max-w-[1080px] max-h-[calc(100dvh-12rem)] h-auto"
            style="transform: perspective(800px) rotateY(-5deg) rotateX(2deg); filter: drop-shadow(-8px 12px 24px oklch(0.2 0.04 250 / 0.35)) drop-shadow(0 0 60px oklch(0.55 0.18 250 / 0.15));"
            loading="eager"
            decoding="async"
          />
        </div>

      </div>
    </section>

    <!-- Parts Grid -->
    <section class="max-w-5xl mx-auto px-6 mb-20" data-animate>
      <div class="grid md:grid-cols-2 gap-6">
        {PARTS.map((part) => {
          const partChapters = CHAPTERS.filter((ch) => ch.part.number === part.number);
          return (
            <div class="rounded-xl border border-border bg-surface-raised p-6 hover:border-primary/30 transition-colors">
              <div class="flex items-baseline gap-2 mb-3">
                <span class="font-mono text-xs tracking-wider text-primary">Part {part.number}</span>
              </div>
              <h2 class="text-xl font-bold mb-2">{part.title}</h2>
              <p class="text-sm text-text-muted mb-5">{part.description}</p>
              <div class="space-y-2">
                {partChapters.map((ch) => (
                  <a
                    href={`/book/${CHAPTER_SLUG_MAP[ch.id]}/`}
                    class="flex items-start gap-3 px-3 py-2 rounded-lg hover:bg-surface-overlay transition-colors group no-underline"
                  >
                    <span class="w-6 h-6 rounded-md bg-primary-dim text-primary text-xs font-semibold flex items-center justify-center shrink-0 mt-0.5">
                      {ch.number}
                    </span>
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium group-hover:text-primary transition-colors">
                        {ch.title}
                      </p>
                      <p class="text-xs text-text-muted leading-snug mt-0.5">{ch.subtitle}</p>
                      <p class="text-[11px] text-text-dim mt-1 font-mono">{ch.readingTime} min</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Reading Paths -->
    <section class="max-w-4xl mx-auto px-6 mb-20" data-animate>
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold mb-3">Choose Your Path</h2>
        <p class="text-text-muted">
          Four curated reading paths based on your role and experience level.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {READING_PATHS.map((rp) => (
          <a
            href={`/book/${CHAPTER_SLUG_MAP[rp.chapterIds[0]]}/`}
            class="rounded-xl border border-border bg-surface-raised p-5 hover:border-primary/30 transition-colors group no-underline"
          >
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold group-hover:text-primary transition-colors">
                {rp.name}
              </h3>
              <span class="font-mono text-xs text-text-muted">
                {rp.chapterIds.length} chapters
              </span>
            </div>
            <p class="text-sm text-text-muted mb-3">{rp.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {rp.chapterIds.map((chId) => {
                const ch = CHAPTERS.find((c) => c.id === chId);
                return ch ? (
                  <span class="text-xs px-2 py-0.5 rounded-md bg-surface-overlay text-text-muted">
                    Ch. {ch.number}
                  </span>
                ) : null;
              })}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Reading Experience Preview -->
    <section class="max-w-5xl mx-auto px-6 mb-20" data-animate>
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold mb-3">The Reading Experience</h2>
        <p class="text-text-muted">
          A distraction-free reader with customizable fonts, themes, reading progress, and chapter navigation.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <BrowserFrame src="/screenshots/book-list.png" alt="Book chapter list showing 14 chapters across 4 parts with reading progress" />
        <BrowserFrame src="/screenshots/book-reader.png" alt="Book reader with reading progress bar, customizable fonts, and chapter navigation" />
        <BrowserFrame src="/screenshots/book-toc.png" alt="Book table of contents sidebar with chapter list, reading paths, and completion checkmarks" />
        <BrowserFrame src="/screenshots/book-settings.png" alt="Book reading settings panel with font size, line height, font family, and theme selection" />
        <BrowserFrame src="/screenshots/book-chapter-nav.png" alt="Book chapter navigation with breadcrumb, reading time estimate, and section progress" />
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto px-6 text-center" data-animate>
      <div class="rounded-xl border border-border bg-surface-raised p-10">
        <h2 class="text-2xl font-bold mb-3">Ready to build AI-native?</h2>
        <p class="text-text-muted mb-6 max-w-lg mx-auto">
          Start with Chapter 1 and trace the journey from hierarchy to
          intelligence. Every pattern built with working code.
        </p>
        <a
          href={`/book/${CHAPTER_SLUG_MAP['ch-1']}/`}
          class="inline-flex items-center gap-2 bg-primary text-white font-medium px-6 py-3 rounded-lg hover:opacity-90 transition-opacity no-underline"
        >
          Begin Reading
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Book hero gradient text (matches Hero.astro pattern) ── */
  .book-hero-gradient {
    background: linear-gradient(135deg, oklch(0.78 0.12 230), var(--color-primary), oklch(0.58 0.18 280));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Book cover ambient float ── */
  .book-cover-float {
    animation: book-float 6s ease-in-out infinite;
  }
  @keyframes book-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .book-cover-float { animation: none; }
  }
</style>
