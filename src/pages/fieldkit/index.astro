---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';
import FieldNotesLayout from '../../layouts/FieldNotesLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { publishOrdinals } from '../../lib/field-notes/article-order.mjs';
import { SITE } from '../../data/seo';

// Read the fieldkit version from the small _version.py file mirrored from
// the source repo. The sync skill keeps this file in step with the upstream
// `fieldkit/src/fieldkit/_version.py`. Falls back to "unreleased" if missing.
let fieldkitVersion = 'unreleased';
try {
  const versionFile = resolve(process.cwd(), 'fieldkit/_version.py');
  const m = readFileSync(versionFile, 'utf8').match(/__version__\s*=\s*"([^"]+)"/);
  if (m) fieldkitVersion = m[1];
} catch {
  // File not present in this checkout — keep the fallback.
}

type FieldkitDoc = CollectionEntry<'fieldkit_docs'>;
type FieldNote = CollectionEntry<'field-notes'>;

const docs = (await getCollection('fieldkit_docs')).sort(
  (a: FieldkitDoc, b: FieldkitDoc) => a.data.order - b.data.order,
);

const articles: FieldNote[] = await getCollection('field-notes');
const ordinalById = publishOrdinals(articles, process.cwd());
const usingFieldkit = articles
  .filter((a: FieldNote) => (a.data.fieldkit_modules ?? []).length > 0)
  .sort((a: FieldNote, b: FieldNote) => ordinalById.get(b.id)! - ordinalById.get(a.id)!);

const moduleHref = (m: string) => `/fieldkit/api/${m}/`;
const articleHref = (slug: string) => `/field-notes/${slug}/`;

const capabilities = [
  { module: 'capabilities', tagline: 'KV-cache + weight memory arithmetic for any model size' },
  { module: 'nim',          tagline: 'OpenAI-compatible NIM client with retries + 8192-tok preflight' },
  { module: 'rag',          tagline: 'Ingest → retrieve → rerank → fuse pipeline on pgvector' },
  { module: 'eval',         tagline: 'Bench, Judge, refusal detector, and trajectory analyzer' },
  { module: 'cli',          tagline: 'Smoke checks + RAG benchmarks without writing Python' },
];

const pageTitle = 'Fieldkit — verified-on-Spark Python patterns — ainative';
const pageDescription =
  "Fieldkit is the open-source Python package the AI Native Field Notes are written against — KV-cache arithmetic, the NIM client with its 8192-token preflight, the strict-context RAG pipeline, and the eval harness. Every module is the tested distillate of the articles it appears under.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: 'fieldkit',
  description: pageDescription,
  programmingLanguage: 'Python',
  codeRepository: 'https://github.com/manavsehgal/ai-field-notes/tree/main/fieldkit',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  version: fieldkitVersion,
  url: `${SITE.url}/fieldkit/`,
};
---
<FieldNotesLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main>
    <header class="stage-header">
      <p class="stage-header__label">
        Package · <span class="fk-version">v{fieldkitVersion}</span>
      </p>
      <h1 class="stage-header__title">fieldkit</h1>
      <p class="stage-header__blurb">
        Verified-on-Spark patterns from AI Native Field Notes, lifted into one
        importable Python package. Every module is the tested distillate of the
        articles it appears under — KV-cache arithmetic, the NIM client with its
        8192-token preflight, the strict-context RAG pipeline from
        <em>naive-rag-on-spark</em>, and the eval harness behind the article
        evidence files.
      </p>
    </header>

    <section class="fk-section fk-glance" aria-labelledby="fk-glance-title">
      <h2 id="fk-glance-title" class="fk-section__title">At a glance</h2>

      <div class="fk-glance__kpis" role="list">
        <article class="fk-kpi" role="listitem">
          <div class="fk-kpi__value">{capabilities.length}</div>
          <div class="fk-kpi__label">Modules</div>
        </article>
        <article class="fk-kpi" role="listitem">
          <div class="fk-kpi__value">{usingFieldkit.length}</div>
          <div class="fk-kpi__label">Articles using fieldkit</div>
        </article>
        <article class="fk-kpi" role="listitem">
          <div class="fk-kpi__value">v{fieldkitVersion}</div>
          <div class="fk-kpi__label">Latest release</div>
        </article>
        <article class="fk-kpi" role="listitem">
          <div class="fk-kpi__value">Apache-2.0</div>
          <div class="fk-kpi__label">Python 3.11+</div>
        </article>
      </div>

      <div class="fk-glance__caps">
        <div class="fk-glance__caps-label">Capabilities</div>
        <div class="fk-glance__caps-grid">
          {capabilities.map((c) => (
            <a class="fk-cap" href={moduleHref(c.module)}>
              <span class="fk-cap__id">fieldkit.{c.module}</span>
              <span class="fk-cap__tag">{c.tagline}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="fk-section">
      <h2 class="fk-section__title">Install</h2>
      <div class="fk-code">
        <pre><code>pip install fieldkit</code></pre>
      </div>
      <p class="fk-section__note">
        Apache-2.0; Python 3.11+. The <code>fieldkit</code> CLI is on <code>$PATH</code> after install.
        For unreleased commits between tags, install from the git tag instead:
      </p>
      <div class="fk-code">
        <pre><code>{`pip install "git+https://github.com/manavsehgal/ai-field-notes.git@fieldkit/v${fieldkitVersion}#subdirectory=fieldkit"`}</code></pre>
      </div>
    </section>

    <section class="fk-section">
          <h2 class="fk-section__title">Quickstart</h2>
          <div class="fk-code">
            <pre><code>{`from fieldkit.capabilities import kv_cache_bytes, weight_bytes
      from fieldkit.nim import NIMClient
      from fieldkit.rag import Document, Pipeline
      from fieldkit.eval import Bench, Judge, is_refusal

      # 70B Llama 3.1 KV cache at 32-user × 16K ctx, FP16:
      kv_cache_bytes(hidden=8 * 128, n_layers=80, ctx=16384, batch=32, dtype="fp16")
      # → 171_798_691_840  (≈ 171.8 GB)

      # Naive RAG end-to-end:
      with NIMClient(base_url="http://localhost:8000/v1",
                     model="meta/llama-3.1-8b-instruct") as gen, \\
           Pipeline(embed_url="http://localhost:8001/v1",
                    pgvector_dsn="postgresql://spark:spark@localhost:5432/vectors",
                    generator=gen) as pipe:
          pipe.ensure_schema()
          pipe.ingest([Document(id=1, text="...", label="spark")])
          print(pipe.ask("How much memory does the Spark have?")["answer"])`}</code></pre>
          </div>
    </section>

    <section class="fk-section">
      <h2 class="fk-section__title">Modules</h2>
      <div class="fk-modules">
        {docs.map((doc: FieldkitDoc) => (
          <a class="fk-module" href={moduleHref(doc.data.module)}>
            <div class="fk-module__head">
              <span class="fk-module__id">fieldkit.{doc.data.module}</span>
              <span class="fk-module__arrow" aria-hidden="true">→</span>
            </div>
            <p class="fk-module__summary">{doc.data.summary}</p>
          </a>
        ))}
      </div>
    </section>

    {usingFieldkit.length > 0 && (
      <section class="fk-section">
        <h2 class="fk-section__title">Verified in</h2>
        <p class="fk-section__note">
          Articles that exercise one or more fieldkit modules end-to-end on the Spark.
        </p>
        <ul class="fk-articles">
          {usingFieldkit.map((article: FieldNote) => (
            <li class="fk-articles__row">
              <a class="fk-articles__title" href={articleHref(article.id)}>{article.data.title}</a>
              <span class="fk-articles__chips">
                {(article.data.fieldkit_modules ?? []).map((m) => (
                  <a class="fk-chip" href={moduleHref(m)}>fieldkit.{m}</a>
                ))}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="fk-section">
          <h2 class="fk-section__title">CLI</h2>
          <div class="fk-code">
            <pre><code>{`$ fieldkit version
      0.1.0.dev0

      $ fieldkit envelope "70B params fp8"
      ~70 GB weights; leaves ~50 GB for KV + activations + system; tight but possible

      $ fieldkit feasibility llama-3.1-70b --ctx 4096 --batch 32 --dtype fp8
      weights (fp8):       70.0 GB
      KV cache (fp8):      21.5 GB  (ctx=4096, batch=32)
      weights + KV:       91.5 GB

      $ fieldkit bench rag --table fieldkit_cli_bench_rag --out /tmp/bench.json`}</code></pre>
          </div>
          <p class="fk-section__note">
            See the <a href={moduleHref('cli')}>CLI reference</a> for all commands.
          </p>
    </section>
  </main>
  <Footer />
</FieldNotesLayout>

<style>
  .fk-version {
    font-family: var(--font-mono);
    color: var(--color-primary);
    letter-spacing: 0.04em;
  }
  .fk-section {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .fk-section__title {
    font-family: var(--font-display);
    font-size: var(--fn-size-4);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: var(--color-text);
  }
  .fk-section__note {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0.75rem 0 0;
  }
  .fk-section__note code {
    font-family: var(--font-mono);
    background: var(--color-surface-overlay);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.05em 0.4em;
    font-size: 0.85em;
  }
  .fk-code {
    background: var(--color-surface-overlay);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }
  .fk-code pre {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-text);
  }
  .fk-code code {
    font-family: inherit;
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .fk-modules {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1rem;
  }
  .fk-module {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem 1.25rem 1.4rem;
    background: var(--color-surface-overlay);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .fk-module:hover {
    border-color: color-mix(in oklch, var(--color-primary) 50%, transparent);
    transform: translateY(-1px);
  }
  .fk-module__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .fk-module__id {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }
  .fk-module__arrow {
    color: var(--color-text-dim);
    font-size: 1rem;
  }
  .fk-module__summary {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .fk-articles {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
  }
  .fk-articles__row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .fk-articles__title {
    font-family: var(--font-body);
    color: var(--color-text);
    text-decoration: none;
    font-size: 1.05rem;
    line-height: 1.3;
  }
  .fk-articles__title:hover {
    color: var(--color-primary);
  }
  .fk-articles__chips {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .fk-chip {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--color-primary);
    background: color-mix(in oklch, var(--color-primary) 16%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-primary) 40%, transparent);
    padding: 0.2em 0.55em;
    border-radius: 999px;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .fk-chip:hover {
    background: color-mix(in oklch, var(--color-primary) 30%, transparent);
  }

  .fk-glance__kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin: 0 0 2rem;
  }
  .fk-kpi {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.1rem;
    background: var(--color-surface-overlay);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .fk-kpi__value {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .fk-kpi__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
  }

  .fk-glance__caps {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  .fk-glance__caps-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    padding-top: 0.6rem;
  }
  .fk-glance__caps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0.6rem;
  }
  .fk-cap {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.9rem;
    background: color-mix(in oklch, var(--color-primary) 8%, var(--color-surface-overlay));
    border: 1px solid color-mix(in oklch, var(--color-primary) 30%, transparent);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, background 120ms ease, transform 120ms ease;
  }
  .fk-cap:hover {
    border-color: var(--color-primary);
    background: color-mix(in oklch, var(--color-primary) 16%, var(--color-surface-overlay));
    transform: translateY(-1px);
  }
  .fk-cap__id {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }
  .fk-cap__tag {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  @media (max-width: 48rem) {
    .fk-glance__kpis {
      grid-template-columns: repeat(2, 1fr);
    }
    .fk-glance__caps {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    .fk-glance__caps-label {
      padding-top: 0;
    }
  }
</style>
