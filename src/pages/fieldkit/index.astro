---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FieldkitHero from '../../components/sections/fieldkit/FieldkitHero.astro';
import FieldkitProblem from '../../components/sections/fieldkit/FieldkitProblem.astro';
import FieldkitModules from '../../components/sections/fieldkit/FieldkitModules.astro';
import FieldkitQuickstart from '../../components/sections/fieldkit/FieldkitQuickstart.astro';
import FieldkitVerified from '../../components/sections/fieldkit/FieldkitVerified.astro';
import FieldkitCli from '../../components/sections/fieldkit/FieldkitCli.astro';
import FieldkitCTAFooter from '../../components/sections/fieldkit/FieldkitCTAFooter.astro';
import ProofBridge from '../../components/proof/ProofBridge.astro';
import { publishOrdinals } from '../../lib/field-notes/article-order.mjs';
import { SITE } from '../../data/seo';

// Read the fieldkit version straight from the package's single source of
// truth (`pyproject.toml`'s hatch version reads the same file). The old
// `fieldkit/_version.py` mirror from the two-repo sync era is gone — it
// froze at v0.13.0 after the 2026-05-29 monorepo cutover.
// Falls back to "unreleased" if missing.
let fieldkitVersion = 'unreleased';
try {
  const versionFile = resolve(process.cwd(), 'fieldkit/src/fieldkit/_version.py');
  const m = readFileSync(versionFile, 'utf8').match(/__version__\s*=\s*"([^"]+)"/);
  if (m) fieldkitVersion = m[1];
} catch {
  // File not present in this checkout — keep the fallback.
}

type FieldkitDoc = CollectionEntry<'fieldkit_docs'>;
type FieldNote = CollectionEntry<'field-notes'>;

const docs = (await getCollection('fieldkit_docs')).sort(
  (a: FieldkitDoc, b: FieldkitDoc) => a.data.order - b.data.order,
);

const articles: FieldNote[] = await getCollection('field-notes');
const ordinalById = publishOrdinals(articles, process.cwd());
const usingFieldkit = articles
  .filter((a: FieldNote) => (a.data.fieldkit_modules ?? []).length > 0)
  .sort((a: FieldNote, b: FieldNote) => ordinalById.get(b.id)! - ordinalById.get(a.id)!);

const pageTitle = 'Fieldkit — verified-on-Spark Python patterns — ainative';
const pageDescription =
  "Open-source Python package the AI Native Field Notes are written against — KV-cache, NIM, RAG, eval, quant, and HF publish modules verified on a single Spark.";

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareSourceCode',
    name: 'fieldkit',
    description: pageDescription,
    programmingLanguage: 'Python',
    codeRepository: 'https://github.com/manavsehgal/ai-field-notes/tree/main/fieldkit',
    license: 'https://www.apache.org/licenses/LICENSE-2.0',
    version: fieldkitVersion,
    url: `${SITE.url}/fieldkit/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Fieldkit', item: `${SITE.url}/fieldkit/` },
    ],
  },
];
---
<Layout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <Nav />
  <main>
    <FieldkitHero version={fieldkitVersion} />
    <FieldkitProblem articleCount={usingFieldkit.length} />
    <FieldkitModules docs={docs} />
    <FieldkitQuickstart />
    <FieldkitVerified articles={usingFieldkit} />
    <FieldkitCli version={fieldkitVersion} />
    <section class="px-6"><ProofBridge variant="builder" surface="fieldkit-docs" /></section>
    <FieldkitCTAFooter version={fieldkitVersion} />
  </main>
  <Footer />
</Layout>
