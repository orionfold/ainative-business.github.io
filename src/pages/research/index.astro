---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MarketGrowth from '../../components/svg/MarketGrowth.astro';
import BuildCascade from '../../components/svg/BuildCascade.astro';
import { SITE, PUBLISHER } from '../../data/seo';
import '../../styles/prose.css';

const papers = [
  {
    number: '01',
    slug: 'ai-transformation',
    category: 'Market Analysis',
    title: 'AI Transformation Research',
    subtitle: 'Building and Governing AI-Native Businesses',
    dateline: 'Manav Sehgal · March 2026 · 22 min read',
    datePublished: '2026-03-01',
    abstract:
      'How solo founders, agencies, and PE firms build AI-native businesses with governed agent orchestration. A market-sizing, governance, and competitive-landscape analysis of the $7.63B→$52.62B agent economy, the 80–90% production failure rate, and the structural gap no platform currently fills.',
    metrics: [
      { value: '$52.62B', label: 'market by 2030' },
      { value: '46.3%',   label: 'CAGR 2025–30' },
      { value: '80–90%',  label: 'agent project failures' },
    ],
  },
  {
    number: '02',
    slug: 'solo-builder-case-study',
    category: 'Applied Research',
    title: 'Case Study: One Day, One Builder',
    subtitle: 'A Wealth Manager Built on ainative in 11 Commits',
    dateline: 'Manav Sehgal · April 2026 · 22 min read',
    datePublished: '2026-04-07',
    abstract:
      'A single-day, verifiable build of a full wealth-management application — prediction-market integration, divergence detection, scenario modeling, and conviction synthesis — entirely on ainative primitives. 7,435 lines of domain code built on 31k–57k lines of inherited platform. Every metric traceable to a specific git commit.',
    metrics: [
      { value: '11',       label: 'commits in a day' },
      { value: '7,435',    label: 'lines of code' },
      { value: '25–40×',   label: 'time compression' },
    ],
  },
];

const pageTitle = 'Research — ainative';
const pageDescription =
  'ainative Research is a small, growing library of papers on the agentic economy, governed AI-native businesses, and the solo-builder pattern. Two papers published.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'ainative Research',
    description: pageDescription,
    url: `${SITE.url}/research/`,
    publisher: PUBLISHER,
    hasPart: papers.map((p) => ({
      '@type': 'TechArticle',
      headline: `${p.title}: ${p.subtitle}`,
      datePublished: p.datePublished,
      author: { '@type': 'Person', name: 'Manav Sehgal' },
      url: `${SITE.url}/research/${p.slug}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home',     item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Research', item: `${SITE.url}/research/` },
    ],
  },
];
---
<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="website"
  jsonLd={jsonLd}
>
  <Nav />

  <main class="relative">
    <!-- =============================================================
         MASTHEAD (above fold — no data-animate per pagespeed rules)
    ============================================================== -->
    <header class="max-w-6xl mx-auto px-6 pt-28 pb-10">
      <div class="flex items-baseline gap-4 font-mono text-[10px] tracking-[0.28em] uppercase text-text-muted">
        <span>Vol. 01</span>
        <span class="h-px flex-1 bg-border"></span>
        <span>ainative Research</span>
        <span class="h-px flex-1 bg-border"></span>
        <span>Apr 2026</span>
      </div>

      <h1 class="mt-10 font-display font-bold leading-[0.95] tracking-tight text-text"
          style="font-size: clamp(2.5rem, 7vw, 6rem);">
        Papers on the<br/>
        <span class="text-amber italic">agentic</span> economy.
      </h1>

      <p class="mt-8 font-body text-text-muted leading-relaxed max-w-[58ch]"
         style="font-size: clamp(1rem, 1.4vw, 1.15rem);">
        A small, growing library. Each paper is written with the same platform
        it describes, and every metric is traceable to source — either public
        market data or git version control. No projections without provenance.
      </p>

      <div class="mt-10 flex items-center gap-6 font-mono text-[11px] tracking-[0.15em] uppercase text-text-muted">
        <span><span class="text-text">02</span> papers published</span>
        <span class="h-px flex-1 bg-border"></span>
        <span>Apache 2.0</span>
      </div>
    </header>

    <!-- =============================================================
         PAPER ENTRIES
    ============================================================== -->
    <div class="max-w-6xl mx-auto px-6 pb-32">
      {papers.map((paper, i) => (
        <article
          class:list={[
            'relative grid md:grid-cols-[1fr_auto] gap-10 md:gap-16 items-start',
            'border-t border-border pt-16 md:pt-20',
            i === 0 ? 'mt-8' : 'mt-24',
          ]}
        >
          <!-- Oversized paper number, bleeds into left margin on desktop -->
          <div
            aria-hidden="true"
            class="absolute -top-2 md:-top-4 left-0 font-display font-bold leading-none text-text/5 select-none pointer-events-none"
            style="font-size: clamp(7rem, 18vw, 14rem); letter-spacing: -0.05em;"
          >
            {paper.number}
          </div>

          <!-- LEFT column: metadata + title + abstract + metrics + CTA -->
          <div class="relative">
            <div class="flex items-center gap-3 font-mono text-[10px] tracking-[0.22em] uppercase text-amber">
              <span>Paper №{paper.number}</span>
              <span class="h-px w-8 bg-amber/60"></span>
              <span class="text-text-muted">{paper.category}</span>
            </div>

            <h2
              class="mt-6 font-display font-bold leading-[1.05] tracking-tight text-text"
              style="font-size: clamp(1.85rem, 4.2vw, 3.25rem);"
            >
              {paper.title}
            </h2>
            <p class="mt-3 font-display italic text-text-muted leading-snug"
               style="font-size: clamp(1.15rem, 1.9vw, 1.5rem);">
              {paper.subtitle}
            </p>

            <p class="mt-6 font-mono text-[11px] tracking-[0.15em] uppercase text-text-muted">
              {paper.dateline}
            </p>

            <!-- Abstract with editorial ornament -->
            <div class="mt-8 relative pl-6 border-l border-amber/40 max-w-[60ch]">
              <span aria-hidden="true"
                    class="absolute -left-[0.6rem] top-0 font-display text-amber"
                    style="font-size: 1.5rem; line-height: 1;">§</span>
              <p class="font-body text-text leading-[1.75]"
                 style="font-size: 1.0625rem;">
                {paper.abstract}
              </p>
            </div>

            <!-- Key findings strip -->
            <dl class="mt-10 grid grid-cols-3 gap-6 max-w-[60ch]">
              {paper.metrics.map((m) => (
                <div class="border-t border-border pt-3">
                  <dt class="font-mono text-[9px] tracking-[0.18em] uppercase text-text-muted">
                    {m.label}
                  </dt>
                  <dd class="mt-1 font-mono font-bold text-text"
                      style="font-size: clamp(1.1rem, 1.8vw, 1.5rem);">
                    {m.value}
                  </dd>
                </div>
              ))}
            </dl>

            <!-- CTA -->
            <a
              href={`/research/${paper.slug}/`}
              class="group mt-10 inline-flex items-center gap-3 font-mono text-sm tracking-wide text-primary hover:text-primary transition-colors"
            >
              <span class="border-b border-primary/40 group-hover:border-primary pb-0.5">
                Read full paper
              </span>
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>

          <!-- RIGHT column: thumbnail signature figure -->
          <aside class="md:w-[300px] md:mt-6 md:sticky md:top-28">
            <div class="rounded-lg border border-border bg-surface-raised/50 p-5">
              {paper.number === '01' && <MarketGrowth />}
              {paper.number === '02' && <BuildCascade />}
              <p class="mt-4 font-mono text-[9px] tracking-[0.15em] uppercase text-text-muted text-center">
                Signature figure
              </p>
            </div>
          </aside>
        </article>
      ))}

      <!-- Footer note -->
      <div class="mt-24 pt-10 border-t border-border">
        <div class="flex items-center gap-4 font-mono text-[10px] tracking-[0.22em] uppercase text-text-muted">
          <span class="text-amber">※</span>
          <span>More papers in preparation</span>
          <span class="h-px flex-1 bg-border"></span>
          <span>End of Vol. 01</span>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
