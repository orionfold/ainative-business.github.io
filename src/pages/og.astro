---
/**
 * OG Image page — rendered at 1200×630 then screenshotted to public/og-image.png
 * Standalone page with no layout wrapper, fixed dimensions, no overflow.
 *
 * Design: Centered logo + wordmark + title on dark background
 */
import "@fontsource/geist-sans/700.css";
import "@fontsource-variable/geist-mono";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex" />
  <title>OG Image — ainative</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 1200px;
      height: 630px;
      overflow: hidden;
      background: oklch(0.13 0.02 250);
      color: oklch(0.93 0.01 250);
    }

    .og {
      position: relative;
      width: 1200px;
      height: 630px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
    }

    /* Ambient glow behind logo */
    .og::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -55%);
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        oklch(0.65 0.18 250 / 0.12) 0%,
        oklch(0.65 0.18 250 / 0.04) 40%,
        transparent 70%
      );
      pointer-events: none;
    }

    .logo {
      width: 72px;
      height: 72px;
      margin-bottom: 20px;
      position: relative;
      z-index: 1;
    }

    .wordmark {
      font-family: "Geist Sans", system-ui, sans-serif;
      font-size: 72px;
      font-weight: 700;
      color: oklch(0.65 0.18 250);
      letter-spacing: -0.01em;
      line-height: 1;
      margin-bottom: 24px;
      position: relative;
      z-index: 1;
    }

    .title {
      font-family: "Geist Sans", system-ui, sans-serif;
      font-size: 36px;
      font-weight: 700;
      color: oklch(0.93 0.01 250);
      line-height: 1.3;
      text-align: center;
      max-width: 720px;
      position: relative;
      z-index: 1;
    }

    .url {
      position: absolute;
      bottom: 28px;
      right: 40px;
      font-family: "Geist Mono Variable", monospace;
      font-size: 15px;
      letter-spacing: 0.06em;
      color: oklch(0.5 0.02 250);
      z-index: 1;
    }

    /* Accent line — above URL */
    .accent-line {
      position: absolute;
      bottom: 54px;
      left: 0;
      width: 100%;
      height: 1px;
      background: linear-gradient(
        90deg,
        oklch(0.65 0.18 250 / 0.05),
        oklch(0.65 0.18 250 / 0.35) 50%,
        oklch(0.65 0.18 250 / 0.05)
      );
      z-index: 3;
    }
  </style>
</head>
<body>
  <div class="og">
    <img src="/ainative-s-128.png" alt="" class="logo" />
    <div class="wordmark">ainative</div>
    <div class="title">AI Native Business</div>
    <span class="url">ainative.business</span>
    <div class="accent-line"></div>
  </div>
</body>
</html>
