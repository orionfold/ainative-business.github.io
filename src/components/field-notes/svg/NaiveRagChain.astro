---
// Signature figure for "naive-rag-on-spark".
// Five-stage naive-RAG chain: question → embed NIM → pgvector store →
// Llama 3.1 NIM (accent, the generator) → streamed answer. A dashed
// divider splits the retrieve half (teal, left) from the generate half
// (blue, right) — the thesis in one glance: two retrieval endpoints +
// one store feeding one generator, all on one box.
const stages = [
  { x: 38,  label: 'Q',        sub: 'question', theme: 'teal' as const, kind: 'text' as const },
  { x: 100, label: 'embed',    sub: ':8001',    theme: 'teal' as const, kind: 'node' as const },
  { x: 160, label: 'pgvector', sub: 'top-K',    theme: 'teal' as const, kind: 'store' as const },
  { x: 226, label: 'llama 8b', sub: ':8000',    theme: 'blue' as const, kind: 'accent' as const },
  { x: 284, label: 'A',        sub: 'answer',   theme: 'blue' as const, kind: 'stream' as const },
];
const cy = 100;
---
<svg viewBox="0 0 300 200" role="img" aria-label="Naive RAG chain — question embeds into pgvector for top-K retrieval, chunks feed into a local Llama 3.1 NIM, and the grounded answer streams back" data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="rag-band-teal" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-teal)" stop-opacity="0.02"/>
      <stop offset="50%"  stop-color="var(--svg-accent-teal)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--svg-accent-teal)" stop-opacity="0.02"/>
    </linearGradient>
    <linearGradient id="rag-band-blue" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-blue)" stop-opacity="0.02"/>
      <stop offset="50%"  stop-color="var(--svg-accent-blue)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.02"/>
    </linearGradient>
    <linearGradient id="rag-gen-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"  stop-color="var(--svg-accent-blue)" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.15"/>
    </linearGradient>
    <radialGradient id="rag-gen-halo" cx="0.5" cy="0.5" r="0.6">
      <stop offset="0%"   stop-color="var(--svg-accent-blue)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <!-- atmospheric bands: teal retrieve half, blue generate half -->
  <rect x="10"  y={cy - 18} width="178" height="36" rx="3"
        fill="url(#rag-band-teal)" stroke="none"/>
  <rect x="192" y={cy - 18} width="98"  height="36" rx="3"
        fill="url(#rag-band-blue)" stroke="none"/>
  <rect x="200" y={cy - 36} width="72" height="72"
        fill="url(#rag-gen-halo)" stroke="none"/>
  <!-- flow line, teal left-half then blue right-half, with draw animation -->
  <g class="svg-reveal svg-reveal-d1">
    <line x1={stages[0].x + 10} y1={cy} x2={stages[4].x - 10} y2={cy}
          stroke="var(--svg-connector)" stroke-width="1" stroke-linecap="round"/>
    <path class="line-draw svg-reveal-d2"
          d={`M ${stages[0].x + 10} ${cy} L ${stages[2].x + 18} ${cy}`}
          fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.5"/>
    <path class="line-draw svg-reveal-d3"
          d={`M ${stages[2].x + 18} ${cy} L ${stages[4].x - 10} ${cy}`}
          fill="none" stroke="var(--svg-accent-blue)" stroke-width="1.5"/>
  </g>
  <!-- retrieve / generate divider -->
  <g class="svg-reveal svg-reveal-d4">
    <line x1="190" y1={cy - 44} x2="190" y2={cy + 44}
          stroke="var(--svg-stroke)" stroke-width="0.5" stroke-dasharray="2 3"/>
    <text x="186" y={cy + 58} text-anchor="end"
          fill="var(--svg-accent-teal)" font-family="var(--font-mono)"
          font-size="8" letter-spacing="0.2em" font-weight="600">RETRIEVE</text>
    <text x="194" y={cy + 58} text-anchor="start"
          fill="var(--svg-accent-blue)" font-family="var(--font-mono)"
          font-size="8" letter-spacing="0.2em" font-weight="600">GENERATE</text>
  </g>
  <!-- stage 0: question chunk (shimmer lines like EmbeddingPipeline) -->
  <g class="svg-reveal svg-reveal-d2">
    <rect x="14" y={cy - 12} width="32" height="24" rx="4"
          fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)"/>
    <line x1="20" y1={cy - 4} x2="40" y2={cy - 4}
          stroke="var(--svg-text-faint)" stroke-width="1"/>
    <line x1="20" y1={cy + 2} x2="36" y2={cy + 2}
          stroke="var(--svg-text-faint)" stroke-width="1"/>
    <text x="30" y={cy - 22} text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="8">question</text>
  </g>
  <!-- stage 1: embed NIM (teal, solid-chrome) -->
  <g class="svg-reveal svg-reveal-d3">
    <rect x={stages[1].x - 22} y={cy - 18} width="44" height="36" rx="6"
          fill="var(--svg-bg-inner)" stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <text x={stages[1].x} y={cy - 2} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">embed</text>
    <text x={stages[1].x} y={cy + 10} text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="8">:8001</text>
  </g>
  <!-- stage 2: pgvector store — cylinder silhouette (teal) -->
  <g class="svg-reveal svg-reveal-d4">
    <ellipse cx={stages[2].x} cy={cy - 16} rx="20" ry="4"
             fill="var(--svg-bg-inner)" stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <line x1={stages[2].x - 20} y1={cy - 16} x2={stages[2].x - 20} y2={cy + 16}
          stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <line x1={stages[2].x + 20} y1={cy - 16} x2={stages[2].x + 20} y2={cy + 16}
          stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <path d={`M ${stages[2].x - 20} ${cy + 16} A 20 4 0 0 0 ${stages[2].x + 20} ${cy + 16}`}
          fill="var(--svg-bg-inner)" stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <text x={stages[2].x} y={cy + 1} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">pgvector</text>
    <text x={stages[2].x} y={cy + 12} text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="8">top-K</text>
  </g>
  <!-- top-K marker dots trailing out of pgvector toward the LLM (teal → blue gradient feel) -->
  <g class="svg-reveal svg-reveal-d5" fill="var(--svg-accent-teal)">
    <circle cx="184" cy={cy - 4} r="1.8" opacity="0.85"/>
    <circle cx="184" cy={cy + 4} r="1.8" opacity="0.85"/>
    <circle cx="180" cy={cy}     r="1.8" opacity="0.85"/>
  </g>
  <!-- stage 3: Llama NIM (accent — the generator, halo'd) -->
  <g class="svg-reveal svg-reveal-d6">
    <rect x={stages[3].x - 24} y={cy - 22} width="48" height="44" rx="7"
          fill="url(#rag-gen-grad)"
          stroke="var(--svg-accent-blue)" stroke-width="1.5"/>
    <text x={stages[3].x} y={cy - 3} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="10" font-weight="600">llama</text>
    <text x={stages[3].x} y={cy + 10} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="8">:8000</text>
  </g>
  <!-- "GROUNDED" callout over generator -->
  <g class="svg-reveal svg-reveal-d7">
    <text x={stages[3].x} y={cy - 35} text-anchor="middle"
          fill="var(--svg-accent-blue)" font-family="var(--font-mono)"
          font-size="8" letter-spacing="0.2em" font-weight="600">GROUNDED</text>
  </g>
  <!-- stage 4: streamed answer (token ticks) -->
  <g class="svg-reveal svg-reveal-d7">
    <rect x="266" y={cy - 12} width="24" height="24" rx="4"
          fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)"/>
    <line x1="270" y1={cy - 4} x2="286" y2={cy - 4}
          stroke="var(--svg-accent-blue)" stroke-width="1"/>
    <line x1="270" y1={cy + 2} x2="282" y2={cy + 2}
          stroke="var(--svg-accent-blue)" stroke-width="1"/>
    <text x="278" y={cy - 22} text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="8">answer</text>
  </g>
</svg>
