---
// Signature figure for "kv-cache-arithmetic-at-inference".
// KV-cache memory for Llama 3.1 70B (FP16) across four concurrency / context
// tiers. Bars drawn to scale by KV bytes (1.3 GB → 1,300 GB), so the
// reader can see at thumbnail size that KV is the dominant serving bill,
// and that concurrency × context — not parameters — is what climbs the
// hardware tier ladder. The 32-user × 16k accent row carries the indigo
// primary because that's the single most representative "real serve"
// configuration the article argues you should size to.
//
// The Spark anchor at the bottom is the article's hook: 8B at FP8,
// single-user — KV is a rounding error. Same equation, different
// coefficients.

// Bar widths — 180 px plot area, scaled against 1,400 GB max.
const plotX0 = 64;
const plotW = 180;
const scale = (gb: number) => (gb / 1400) * plotW;

const wInteractive = Math.max(scale(1.3), 4);
const wH100 = scale(42);
const wH200 = scale(168);
const wMulti = scale(336);
---

<svg viewBox="0 0 300 200" role="img"
     aria-label="KV cache memory for Llama 3.1 70B at FP16 across four concurrency-by-context tiers. One user at 4k context: 1.3 gigabytes, trivial. 32 users at 4k context: 42 gigabytes, fits one H100. 32 users at 16k context: 168 gigabytes, needs one H200 or two H100s. 128 users at 8k context: 336 gigabytes, needs four H100s. Spark anchor: 8 billion FP8 single-user — KV is a rounding error inside 2.5 gigabytes resident."
     data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="kvc-trivial-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-green)" stop-opacity="0.42"/>
      <stop offset="100%" stop-color="var(--svg-accent-green)" stop-opacity="0.14"/>
    </linearGradient>
    <linearGradient id="kvc-h100-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-cyan)" stop-opacity="0.42"/>
      <stop offset="100%" stop-color="var(--svg-accent-cyan)" stop-opacity="0.14"/>
    </linearGradient>
    <linearGradient id="kvc-h200-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.18"/>
    </linearGradient>
    <linearGradient id="kvc-multi-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-orange)" stop-opacity="0.42"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.14"/>
    </linearGradient>
    <linearGradient id="kvc-h200-lane" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.02"/>
      <stop offset="50%"  stop-color="var(--color-primary)" stop-opacity="0.14"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.02"/>
    </linearGradient>
  </defs>

  <!-- Atmospheric lane wash behind the H200 row — the row the article
       argues is the most representative real serve. Linear gradient =
       semantic backdrop, exempt from the bounded-halo rule. -->
  <rect x="4" y="92" width="292" height="30" fill="url(#kvc-h200-lane)" stroke="none"/>

  <!-- Title -->
  <g class="svg-reveal svg-reveal-d1">
    <text x="150" y="18" text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="8" letter-spacing="0.18em">70B SERVE · KV BUDGET (FP16)</text>
  </g>

  <!-- 1 user × 4k row — 1.3 GB, near-zero -->
  <g class="svg-reveal svg-reveal-d2">
    <text x="58" y="46" text-anchor="end"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">1 × 4k</text>
    <text x="58" y="56" text-anchor="end"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5">1.3 GB</text>
    <rect class="bar-grow-x" x={plotX0} y="36" width={wInteractive} height="18" rx="3"
          fill="url(#kvc-trivial-grad)"
          stroke="var(--svg-accent-green)" stroke-width="0.5"/>
    <rect x="248" y="36" width="48" height="18" rx="3"
          fill="var(--svg-bg-inner)"
          stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5"/>
    <text x="272" y="48" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="7" font-weight="600">trivial</text>
  </g>

  <!-- 32 × 4k row — 42 GB -->
  <g class="svg-reveal svg-reveal-d3">
    <text x="58" y="76" text-anchor="end"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">32 × 4k</text>
    <text x="58" y="86" text-anchor="end"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5">42 GB</text>
    <rect class="bar-grow-x" x={plotX0} y="66" width={wH100} height="18" rx="3"
          fill="url(#kvc-h100-grad)"
          stroke="var(--svg-accent-cyan)" stroke-width="0.5"/>
    <rect x="248" y="66" width="48" height="18" rx="3"
          fill="var(--svg-bg-inner)"
          stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5"/>
    <text x="272" y="78" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="7" font-weight="600">1× H100</text>
  </g>

  <!-- 32 × 16k row — 168 GB · the accent thesis row -->
  <g class="svg-reveal svg-reveal-d4">
    <text x="58" y="106" text-anchor="end"
          fill="var(--color-primary)" font-family="var(--font-mono)"
          font-size="9" font-weight="700">32 × 16k</text>
    <text x="58" y="116" text-anchor="end"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5">168 GB</text>
    <rect class="bar-grow-x" x={plotX0} y="96" width={wH200} height="18" rx="3"
          fill="url(#kvc-h200-grad)"
          stroke="var(--color-primary)" stroke-width="1"/>
    <rect x="248" y="96" width="48" height="18" rx="3"
          fill="var(--svg-bg-inner)"
          stroke="var(--color-primary)" stroke-width="1"/>
    <text x="272" y="108" text-anchor="middle"
          fill="var(--color-primary)" font-family="var(--font-mono)"
          font-size="7" font-weight="700">1× H200</text>
  </g>

  <!-- 128 × 8k row — 336 GB -->
  <g class="svg-reveal svg-reveal-d5">
    <text x="58" y="136" text-anchor="end"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">128 × 8k</text>
    <text x="58" y="146" text-anchor="end"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5">336 GB</text>
    <rect class="bar-grow-x" x={plotX0} y="126" width={wMulti} height="18" rx="3"
          fill="url(#kvc-multi-grad)"
          stroke="var(--svg-accent-orange)" stroke-width="0.5"/>
    <rect x="248" y="126" width="48" height="18" rx="3"
          fill="var(--svg-bg-inner)"
          stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5"/>
    <text x="272" y="138" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="7" font-weight="600">4× H100</text>
  </g>

  <!-- Divider + Spark anchor line -->
  <g class="svg-reveal svg-reveal-d6">
    <line x1="10" y1="160" x2="290" y2="160"
          stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5"
          stroke-dasharray="2 3"/>
    <text x="150" y="174" text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="7.5" letter-spacing="0.14em">SPARK ANCHOR</text>
    <text x="150" y="188" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="7">8B FP8 · 1 user · KV ≈ rounding error</text>
  </g>
</svg>
