---
// Signature figure for "a2tgpo-turn-clipping-on-spark".
// One trajectory across 6 agentic turns. A horizontal axis runs left-to-right;
// the y-coordinate at 100 is the PPO ratio centre (1.0). The PPO/GRPO baseline
// clip range [0.8, 1.2] is drawn as a flat dashed band — every turn gets the
// same update bandwidth regardless of how much that turn moved the agent
// toward the answer. The A²TGPO adaptive-clip band overlays it, expanding
// where σ(normed_IG) > 0.5 (informative turns deserve wider updates) and
// contracting where σ(normed_IG) < 0.5 (uninformative turns get narrower
// updates), bounded in (0.7, 1.3) by construction. The headline +1.75 EM
// number sits to the right — the paper's reported multi-hop QA lift over
// the strong RL baseline on Qwen3-4B (arXiv 2605.06200, Table 1).
---

<svg viewBox="0 0 300 200" role="img"
     aria-label="A²TGPO adaptive clip band over 6 agentic turns: PPO/GRPO baseline maintains a flat dashed clip range [0.8, 1.2] regardless of turn informativeness, while A²TGPO modulates per turn via c = 1 + 0.3 * (2*sigmoid(normed_IG) - 1), bounded (0.7, 1.3). Informative turns widen the update region; uninformative ones narrow it. Paper reports +1.75 EM on multi-hop QA over the RL baseline."
     data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="acb-band-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-green)" stop-opacity="0.42"/>
      <stop offset="100%" stop-color="var(--svg-accent-green)" stop-opacity="0.10"/>
    </linearGradient>
    <radialGradient id="acb-halo" cx="0.5" cy="0.5" r="0.7">
      <stop offset="0%"   stop-color="var(--svg-accent-green)" stop-opacity="0.16"/>
      <stop offset="100%" stop-color="var(--svg-accent-green)" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <g class="svg-reveal svg-reveal-d1">
    <text x="150" y="14" text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="7.5" letter-spacing="0.18em">A²TGPO · ADAPTIVE TURN CLIP</text>
    <text x="150" y="24" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6" letter-spacing="0.14em">c = 1 + 0.3 · (2·σ(IG) − 1)</text>
  </g>
  <g class="svg-reveal svg-reveal-d2">
    <rect x="22" y="56" width="186" height="80"
          fill="url(#acb-halo)" stroke="none"/>
    <rect x="22" y="56" width="186" height="80" rx="4"
          fill="none" stroke="var(--svg-bg-inner-stroke)"
          stroke-width="1" stroke-dasharray="3 3"/>
    <line x1="22" y1="96" x2="208" y2="96"
          stroke="var(--svg-text-faint)" stroke-width="0.5"/>
    <text x="14" y="99" text-anchor="end"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5">1.0</text>
    <line x1="22" y1="80" x2="208" y2="80"
          stroke="var(--svg-text-muted)" stroke-width="1"
          stroke-dasharray="4 3" opacity="0.55"/>
    <line x1="22" y1="112" x2="208" y2="112"
          stroke="var(--svg-text-muted)" stroke-width="1"
          stroke-dasharray="4 3" opacity="0.55"/>
    <text x="212" y="83"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6">1.2</text>
    <text x="212" y="115"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6">0.8</text>
  </g>
  <g class="svg-reveal svg-reveal-d3">
    <path class="line-draw" d="M 28 76 L 56 76 L 56 80 L 84 80 L 84 70 L 112 70 L 112 82 L 140 82 L 140 72 L 168 72 L 168 78 L 196 78 L 196 84 L 204 84"
          fill="none" stroke="var(--svg-accent-green)" stroke-width="1.5"/>
    <path class="line-draw" d="M 28 116 L 56 116 L 56 112 L 84 112 L 84 122 L 112 122 L 112 110 L 140 110 L 140 120 L 168 120 L 168 114 L 196 114 L 196 108 L 204 108"
          fill="none" stroke="var(--svg-accent-green)" stroke-width="1.5"/>
    <path class="bar-grow" d="M 28 76 L 56 76 L 56 116 L 28 116 Z"
          fill="url(#acb-band-grad)" stroke="none" opacity="0.55"/>
    <path class="bar-grow" d="M 56 80 L 84 80 L 84 112 L 56 112 Z"
          fill="url(#acb-band-grad)" stroke="none" opacity="0.40"/>
    <path class="bar-grow" d="M 84 70 L 112 70 L 112 122 L 84 122 Z"
          fill="url(#acb-band-grad)" stroke="none" opacity="0.65"/>
    <path class="bar-grow" d="M 112 82 L 140 82 L 140 110 L 112 110 Z"
          fill="url(#acb-band-grad)" stroke="none" opacity="0.35"/>
    <path class="bar-grow" d="M 140 72 L 168 72 L 168 120 L 140 120 Z"
          fill="url(#acb-band-grad)" stroke="none" opacity="0.62"/>
    <path class="bar-grow" d="M 168 78 L 196 78 L 196 114 L 168 114 Z"
          fill="url(#acb-band-grad)" stroke="none" opacity="0.42"/>
  </g>
  <g class="svg-reveal svg-reveal-d4">
    <text x="42" y="148" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6">t1</text>
    <text x="70" y="148" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6">t2</text>
    <text x="98" y="148" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6">t3</text>
    <text x="126" y="148" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6">t4</text>
    <text x="154" y="148" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6">t5</text>
    <text x="182" y="148" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6">t6</text>
    <text x="115" y="162" text-anchor="middle" fill="var(--svg-text-faint)" font-family="var(--font-mono)" font-size="6" letter-spacing="0.10em">AGENTIC TURNS · MULTI-HOP QA</text>
  </g>
  <g class="svg-reveal svg-reveal-d5">
    <text x="150" y="178" text-anchor="middle"
          fill="var(--svg-accent-green)" font-family="var(--font-sans)"
          font-size="14" font-weight="600">+1.75 EM</text>
    <text x="150" y="192" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5" letter-spacing="0.10em">vs RL baseline · HotpotQA dev · Qwen3-4B</text>
  </g>
</svg>
