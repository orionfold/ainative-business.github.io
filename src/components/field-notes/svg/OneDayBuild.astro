---
// Signature figure for "solo-builder-case-study".
// One day, 11 commits: 7,435 lines of domain code built on 31–57k lines of
// inherited platform — infrastructure leverage. A small accent DOMAIN cap
// rides a wide faint PLATFORM foundation; 11 commit ticks mark the day. Owns
// the leverage thesis of the one-day wealth-manager build.
---
<svg viewBox="0 0 300 200" role="img"
     aria-label="One day, 11 commits: 7,435 lines of domain code ride on 31 to 57 thousand lines of inherited platform. A small accent domain block sits atop a wide foundation — infrastructure leverage."
     data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="odb-accent" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.15"/>
    </linearGradient>
    <radialGradient id="odb-halo" cx="0.5" cy="0.5" r="0.7">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.14"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- kicker -->
  <g class="svg-reveal svg-reveal-d1">
    <text x="150" y="20" text-anchor="middle" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="7.5" letter-spacing="0.2em">ONE-DAY BUILD</text>
  </g>

  <!-- 11 commit ticks across the day -->
  <g class="svg-reveal svg-reveal-d3" stroke="var(--color-primary)" stroke-width="2">
    <line x1="64"  y1="34" x2="64"  y2="46"/>
    <line x1="81"  y1="34" x2="81"  y2="46"/>
    <line x1="98"  y1="34" x2="98"  y2="46"/>
    <line x1="115" y1="34" x2="115" y2="46"/>
    <line x1="132" y1="34" x2="132" y2="46"/>
    <line x1="149" y1="34" x2="149" y2="46"/>
    <line x1="166" y1="34" x2="166" y2="46"/>
    <line x1="183" y1="34" x2="183" y2="46"/>
    <line x1="200" y1="34" x2="200" y2="46"/>
    <line x1="217" y1="34" x2="217" y2="46"/>
    <line x1="234" y1="34" x2="234" y2="46"/>
  </g>
  <g class="svg-reveal svg-reveal-d3">
    <text x="150" y="58" text-anchor="middle" fill="var(--svg-text-faint)"
          font-family="var(--font-mono)" font-size="6" letter-spacing="0.12em">11 COMMITS · 1 DAY</text>
  </g>

  <!-- domain cap (accent, small) -->
  <g class="svg-reveal svg-reveal-d5">
    <rect x="104" y="72" width="92" height="34" fill="url(#odb-halo)" stroke="none"/>
    <rect x="108" y="76" width="84" height="30" rx="4"
          fill="url(#odb-accent)" stroke="var(--color-primary)" stroke-width="1.5"/>
    <text x="150" y="91" text-anchor="middle" fill="var(--svg-text-bright)"
          font-family="var(--font-mono)" font-size="7" font-weight="600">DOMAIN</text>
    <text x="150" y="101" text-anchor="middle" fill="var(--svg-text-bright)"
          font-family="var(--font-mono)" font-size="6">7,435 LOC</text>
  </g>

  <!-- it rests on the platform (leverage supports) -->
  <g class="svg-reveal svg-reveal-d6" stroke="var(--svg-connector)" stroke-width="1" stroke-dasharray="2 2">
    <line x1="124" y1="106" x2="124" y2="120"/>
    <line x1="176" y1="106" x2="176" y2="120"/>
  </g>

  <!-- inherited platform foundation (wide, faint) -->
  <g class="svg-reveal svg-reveal-d4">
    <rect x="44" y="120" width="212" height="36" rx="4"
          fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="1"/>
    <text x="150" y="135" text-anchor="middle" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="7" font-weight="600">INHERITED PLATFORM</text>
    <text x="150" y="147" text-anchor="middle" fill="var(--svg-text-faint)"
          font-family="var(--font-mono)" font-size="6">31–57k LOC</text>
  </g>

  <!-- bottom label -->
  <g class="svg-reveal svg-reveal-d7">
    <text x="150" y="180" text-anchor="middle" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="7" letter-spacing="0.12em">LEVERAGE · SMALL CODE ON BIG PLATFORM</text>
  </g>
</svg>
