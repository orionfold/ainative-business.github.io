---
// Signature figure for "t2po-uncertainty-guided-rl-on-spark".
// Two paired bars: task_pass at the run's strongest training-side step (45).
// Pool task_pass = 28/32 = 87.5%; held-out task_pass = 9/158 = 5.7%.
// The −81.8 pp callout is the load-bearing claim — training-side pool
// saturation does not predict held-out generalization on a single-Spark
// RL run with K=4 and 8 tasks per step. Mono captions under each bar
// carry the raw counts (28/32 vs 9/158) so a reader stopped at the card
// sees both the percentage and the population disparity that produced it.
---

<svg viewBox="0 0 300 200" role="img"
     aria-label="task_pass at T²PO step 45: training pool 28/32 = 87.5%, held-out 158-task eval 9/158 = 5.7%. The strongest training-side checkpoint is the worst held-out checkpoint; the pool-vs-held-out gap is 81.8 percentage points."
     data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="t2po-pool-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-blue)" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.18"/>
    </linearGradient>
    <linearGradient id="t2po-heldout-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.15"/>
    </linearGradient>
    <radialGradient id="t2po-heldout-halo" cx="0.5" cy="0.5" r="0.7">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <g class="svg-reveal svg-reveal-d1">
    <text x="150" y="14" text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="7.5" letter-spacing="0.18em">T²PO STEP 45 · TASK_PASS</text>
    <text x="150" y="24" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6" letter-spacing="0.14em">pool sample vs 158-task held-out</text>
  </g>
  <g class="svg-reveal svg-reveal-d2">
    <text x="78" y="48" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5" letter-spacing="0.12em">TRAINING POOL</text>
    <rect x="58" y="60" width="40" height="92" rx="4"
          fill="none" stroke="var(--svg-bg-inner-stroke)"
          stroke-width="1" stroke-dasharray="3 3"/>
    <rect class="bar-grow" x="58" y={60 + (92 - 80.5)} width="40" height="80.5" rx="4"
          fill="url(#t2po-pool-grad)"
          stroke="var(--svg-accent-blue)" stroke-width="1"
          style="transform-origin: 78px 152px;"/>
    <text x="78" y="170" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-sans)"
          font-size="14" font-weight="600">87.5%</text>
    <text x="78" y="184" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5" letter-spacing="0.10em">28/32 pool</text>
  </g>
  <g class="svg-reveal svg-reveal-d3">
    <rect x="178" y="60" width="40" height="92"
          fill="url(#t2po-heldout-halo)" stroke="none"/>
    <text x="198" y="48" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5" letter-spacing="0.12em">HELD-OUT 158</text>
    <rect x="178" y="60" width="40" height="92" rx="4"
          fill="none" stroke="var(--svg-bg-inner-stroke)"
          stroke-width="1" stroke-dasharray="3 3"/>
    <rect class="bar-grow" x="178" y={60 + (92 - 5.2)} width="40" height="5.2" rx="2"
          fill="url(#t2po-heldout-grad)"
          stroke="var(--color-primary)" stroke-width="1"
          style="transform-origin: 198px 152px;"/>
    <text x="198" y="170" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-sans)"
          font-size="14" font-weight="600">5.7%</text>
    <text x="198" y="184" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5" letter-spacing="0.10em">9/158 held-out</text>
  </g>
  <g class="svg-reveal svg-reveal-d4">
    <line x1="225" y1="108" x2="252" y2="108"
          class="line-draw"
          stroke="var(--color-primary)" stroke-width="1.5"/>
    <text x="270" y="103" text-anchor="middle"
          fill="var(--color-primary)" font-family="var(--font-sans)"
          font-size="13" font-weight="600">−81.8</text>
    <text x="270" y="116" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="6.5" letter-spacing="0.14em">PP</text>
  </g>
</svg>
