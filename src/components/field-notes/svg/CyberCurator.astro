---
// Signature figure for "becoming-a-cyber-curator-on-spark".
// Five GGUF variants of SecurityLLM on CyberMetric MCQ — accuracy holds and
// even rises as the quant shrinks: F16 34% up to Q4_K_M 40% at 4.1 GB and
// 47.7 tok/s (the accent pick). A shield marks the cyber vertical. Sibling to
// LegalCurator (scales); owns the "smaller variants matched or beat F16"
// inversion for the cyber card.
---
<svg viewBox="0 0 300 200" role="img"
     aria-label="Five GGUF variants of SecurityLLM scored on CyberMetric MCQ — F16 34 percent rising to Q4_K_M 40 percent at 4.1 gigabytes, the accent pick. Smaller variants matched or beat full-precision F16, well above the 25 percent MCQ chance line."
     data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="cyc-accent" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.15"/>
    </linearGradient>
    <radialGradient id="cyc-halo" cx="0.5" cy="0.5" r="0.7">
      <stop offset="0%"   stop-color="var(--color-primary)" stop-opacity="0.14"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- kicker + shield glyph -->
  <g class="svg-reveal svg-reveal-d1">
    <path d="M44 12 L54 15 L54 23 Q54 30 44 33 Q34 30 34 23 L34 15 Z"
          fill="none" stroke="var(--svg-text-muted)" stroke-width="1.2"/>
    <path d="M44 19 l-3 4 4 3" fill="none" stroke="var(--color-primary)" stroke-width="1.2"/>
    <text x="160" y="22" text-anchor="middle" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="7.5" letter-spacing="0.2em">CYBER CURATOR</text>
  </g>

  <!-- baseline + 25% chance line -->
  <line class="line-draw svg-reveal-d2" x1="36" y1="150" x2="264" y2="150"
        stroke="var(--svg-connector)" stroke-width="1"/>
  <g class="svg-reveal svg-reveal-d2">
    <line x1="40" y1="132" x2="252" y2="132"
          stroke="var(--svg-text-faint)" stroke-width="1" stroke-dasharray="3 3"/>
    <text x="264" y="130" text-anchor="end" fill="var(--svg-text-faint)"
          font-family="var(--font-mono)" font-size="5.5">25% chance</text>
  </g>

  <!-- 5 accuracy bars: F16 34 / Q8 36 / Q6 36 / Q5 38 / Q4 40 (rising as quant shrinks) -->
  <g class="svg-reveal svg-reveal-d3">
    <rect x="46"  y="78" width="28" height="72" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="1"/>
    <rect x="90"  y="66" width="28" height="84" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="1"/>
    <rect x="134" y="66" width="28" height="84" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="1"/>
    <rect x="178" y="54" width="28" height="96" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="1"/>
  </g>
  <!-- Q4_K_M accent (the pick) -->
  <g class="svg-reveal svg-reveal-d5">
    <rect x="218" y="36" width="36" height="114" fill="url(#cyc-halo)" stroke="none"/>
    <rect x="222" y="42" width="28" height="108" rx="2"
          fill="url(#cyc-accent)" stroke="var(--color-primary)" stroke-width="1.5"/>
  </g>

  <!-- % above bars + variant labels below -->
  <g class="svg-reveal svg-reveal-d6" font-family="var(--font-mono)" font-size="6.5" text-anchor="middle">
    <text x="60"  y="73" fill="var(--svg-text-faint)">34</text>
    <text x="104" y="61" fill="var(--svg-text-faint)">36</text>
    <text x="148" y="61" fill="var(--svg-text-faint)">36</text>
    <text x="192" y="49" fill="var(--svg-text-muted)">38</text>
    <text x="236" y="37" fill="var(--svg-text-bright)" font-weight="600">40%</text>
  </g>
  <g class="svg-reveal svg-reveal-d6" font-family="var(--font-mono)" font-size="6" text-anchor="middle" fill="var(--svg-text-faint)">
    <text x="60"  y="162">F16</text>
    <text x="104" y="162">Q8</text>
    <text x="148" y="162">Q6</text>
    <text x="192" y="162">Q5</text>
    <text x="236" y="162" fill="var(--color-primary)" font-weight="600">Q4_K_M</text>
  </g>

  <!-- caption -->
  <g class="svg-reveal svg-reveal-d7">
    <text x="150" y="184" text-anchor="middle" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="6.5" letter-spacing="0.08em">CyberMetric MCQ · n=50 · 4.1 GB · 47.7 tok/s</text>
  </g>
</svg>
