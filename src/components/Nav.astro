---
---
<div id="nav-wrapper" class="fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter] duration-300">
  <nav id="main-nav" aria-label="Main navigation" class="border-b border-transparent transition-[border-color] duration-300">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <div class="flex flex-col gap-1 -ml-6">
      <a
        href="/"
        class="group inline-flex items-center gap-2.5 text-text transition-colors hover:text-primary"
        aria-label="ainative.business home"
      >
        <img
          src="/orionfold-mark.svg"
          alt=""
          width="34"
          height="34"
          class="h-[34px] w-[34px] shrink-0 transition-transform duration-300 group-hover:scale-[1.03]"
        />
        <span class="text-2xl font-semibold tracking-tight leading-none">
          <span class="text-primary">ai</span><span class="text-text">native</span><span class="text-text-muted">.business</span>
        </span>
      </a>
      <a
        href="https://orionfold.com"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-[44px] font-mono text-[0.62rem] tracking-wider text-text-dim hover:text-primary transition-colors"
      >
        Made by Orionfold&nbsp;↗
      </a>
    </div>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="/arena/"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Arena
      </a>
      <a
        href="/fieldkit/"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Fieldkit
      </a>
      <span class="h-4 w-px bg-border" aria-hidden="true"></span>
      <a
        href="/book/"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Book
      </a>
      <a
        href="/field-notes/"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Field Notes
      </a>
      <button
        id="theme-toggle"
        type="button"
        class="text-text-muted hover:text-primary transition-colors inline-flex items-center"
        aria-label="Toggle dark mode"
      >
        <svg class="theme-icon-light h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="theme-icon-dark h-[18px] w-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text-muted hover:text-primary transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="hidden">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-3">
      <a href="/arena/" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Arena</a>
      <a href="/fieldkit/" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Fieldkit</a>
      <hr class="border-border" />
      <a href="/book/" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Book</a>
      <a href="/field-notes/" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Field Notes</a>
      <hr class="border-border" />
      <a href="https://github.com/orionfold/ainative" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">GitHub</a>
      <button id="theme-toggle-mobile" type="button" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2 inline-flex items-center gap-2 text-left" aria-label="Toggle dark mode">
        <span class="theme-label-light">Switch to dark</span>
        <span class="theme-label-dark hidden">Switch to light</span>
      </button>
    </div>
  </div>
</nav>
</div>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    const navWrapper = document.getElementById('nav-wrapper');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    if (!nav || !navWrapper || !menuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;

    // Scroll-triggered blur
    let scrolled = false;
    function onScroll() {
      const isScrolled = window.scrollY > 40;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        if (scrolled) {
          navWrapper.classList.add('bg-surface/80', 'backdrop-blur-md');
          nav.classList.add('border-border');
          nav.classList.remove('border-transparent');
        } else {
          navWrapper.classList.remove('bg-surface/80', 'backdrop-blur-md');
          nav.classList.remove('border-border');
          nav.classList.add('border-transparent');
        }
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu toggle
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close mobile menu on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // ── Theme toggle (DS v6.2 light + dark) ──
  function syncThemeIcons() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.querySelectorAll('.theme-icon-light, .theme-label-light').forEach(el => el.classList.toggle('hidden', isDark));
    document.querySelectorAll('.theme-icon-dark, .theme-label-dark').forEach(el => el.classList.toggle('hidden', !isDark));
  }
  function toggleTheme() {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('of-theme', next); } catch (e) { /* no-op */ }
    syncThemeIcons();
  }
  function initThemeToggle() {
    syncThemeIcons();
    const btn = document.getElementById('theme-toggle');
    const btnM = document.getElementById('theme-toggle-mobile');
    if (btn) btn.addEventListener('click', toggleTheme);
    if (btnM) btnM.addEventListener('click', toggleTheme);
  }

  initNav();
  initThemeToggle();
  document.addEventListener('astro:after-swap', () => { initNav(); initThemeToggle(); });
</script>
