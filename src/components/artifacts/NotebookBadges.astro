---
interface NotebookEntry {
  label?: string;
  colab?: string;
  kaggle?: string;
}

interface Props {
  notebooks?: NotebookEntry[];
  contextLabel?: string;
  layout?: 'inline' | 'block';
}

const { notebooks, contextLabel, layout = 'block' } = Astro.props;

const entries = (notebooks ?? []).filter((n) => n && (n.colab || n.kaggle));
const showLabels = entries.some((n) => !!n.label) && entries.length > 1;

const linkLabel = (entry: NotebookEntry, host: 'Google Colab' | 'Kaggle'): string => {
  const ctx = entry.label
    ? (contextLabel ? `${contextLabel} — ${entry.label}` : entry.label)
    : contextLabel;
  return ctx ? `Open ${ctx} in ${host}` : `Open this notebook in ${host}`;
};
---
{entries.length > 0 && (
  <div class={`notebook-badges-group notebook-badges-group--${layout}`} data-component="notebook-badges">
    {entries.map((entry) => (
      <div class="notebook-badges-row">
        {showLabels && entry.label && (
          <span class="notebook-badges-row__label">{entry.label}</span>
        )}
        <div class="notebook-badges">
          {entry.colab && (
            <a
              class="notebook-badges__link"
              href={entry.colab}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={linkLabel(entry, 'Google Colab')}
            >
              <img
                src="/badges/colab-badge.svg"
                alt=""
                width="148"
                height="28"
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
          {entry.kaggle && (
            <a
              class="notebook-badges__link"
              href={entry.kaggle}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={linkLabel(entry, 'Kaggle')}
            >
              <img
                src="/badges/open-in-kaggle.svg"
                alt=""
                width="148"
                height="28"
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
)}

<style>
  .notebook-badges-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .notebook-badges-group--block {
    margin: 1.5rem 0 2rem;
    padding: 0.9rem 1.05rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in oklch, var(--color-surface-raised) 40%, transparent);
  }
  .notebook-badges-group--inline {
    margin: 0.6rem 0 0;
    gap: 0.4rem;
  }
  .notebook-badges-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
  }
  .notebook-badges-row__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    min-width: 4.5rem;
  }
  .notebook-badges {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .notebook-badges__link {
    display: inline-flex;
    align-items: center;
    transition: transform 0.15s ease-out, filter 0.15s ease-out;
    line-height: 0;
    border-radius: 6px;
  }
  .notebook-badges__link:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
  .notebook-badges__link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }
  .notebook-badges__link img {
    height: 28px;
    width: auto;
    display: block;
  }
  .notebook-badges-group--inline .notebook-badges__link img {
    height: 22px;
  }

  @media (prefers-reduced-motion: reduce) {
    .notebook-badges__link {
      transition: none;
    }
    .notebook-badges__link:hover {
      transform: none;
    }
  }
</style>
