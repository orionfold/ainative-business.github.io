---
import type { CollectionEntry } from 'astro:content';
import AppSignature from './AppSignature.astro';
import LicenseChip from './LicenseChip.astro';

// AppCard — the /artifacts/apps/ list tile for `arena_run` artifacts. Leads
// with positioning (headline + problem), not quant economics — an app is an
// application, not a measured model. Mirrors QuantCard's layout/classes.

interface Props {
  artifact: CollectionEntry<'artifacts'>;
}

const { artifact } = Astro.props;
const { slug, class: artifactClass, base_model, license, published_at, positioning } = artifact.data;

const href = `/artifacts/apps/${slug}/`;
const publishedDate = published_at
  ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(published_at))
  : null;
---
<a class="qa-card" href={href} aria-label={`App: ${slug}`}>
  <span class="qa-card__watermark" aria-hidden="true">A</span>
  <div class="qa-card__body">
    <div class="qa-card__meta">
      <span class="qa-card__kind">App</span>
      <span>{artifactClass.toUpperCase()}</span>
      {publishedDate && <time datetime={published_at}>{publishedDate}</time>}
    </div>
    <h2 class="qa-card__title">{slug}</h2>
    {positioning?.headline && (
      <p class="qa-card__headline">{positioning.headline}</p>
    )}
    {positioning?.problem && (
      <p class="qa-card__summary">{positioning.problem}</p>
    )}
    <div class="qa-card__chips">
      <LicenseChip tier={license.tier} model={license.model} />
    </div>
  </div>
  <aside class="qa-card__signature" aria-hidden="true">
    <div class="qa-card__signature-frame">
      <AppSignature slug={slug} />
    </div>
  </aside>
</a>

<style>
  .qa-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(14rem, 22vw, 19rem);
    align-items: center;
    gap: clamp(2rem, 4vw, 4rem);
    padding: 3.75rem 0 3.5rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    isolation: isolate;
    transition: background 0.2s;
  }
  .qa-card + .qa-card { padding-top: 4.5rem; }
  .qa-card:hover { background: color-mix(in oklch, var(--color-primary) 4%, transparent); }
  .qa-card:hover .qa-card__title { color: var(--color-primary); }
  .qa-card:hover .qa-card__signature-frame {
    border-color: color-mix(in oklch, var(--color-primary) 35%, var(--color-border));
    box-shadow: 0 8px 24px -16px color-mix(in oklch, var(--color-primary) 30%, transparent);
  }
  .qa-card:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 4px; }

  .qa-card__watermark {
    position: absolute;
    top: -0.15em;
    left: -0.05em;
    z-index: -1;
    pointer-events: none;
    user-select: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(7rem, 16vw, 12rem);
    line-height: 1;
    letter-spacing: -0.05em;
    color: color-mix(in oklch, var(--color-text) 5%, transparent);
  }

  .qa-card__body { min-width: 0; position: relative; z-index: 1; }

  .qa-card__meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.1rem;
  }
  .qa-card__meta > *:not(:last-child)::after {
    content: "·";
    margin-left: 1.1rem;
    color: var(--color-text-dim);
  }
  .qa-card__kind { color: var(--color-primary); }

  .qa-card__headline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.35;
    color: var(--color-text);
    margin: 0 0 0.7rem;
    max-width: 50ch;
  }
  .qa-card__title {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    line-height: 1.2;
    color: var(--color-text);
    margin: 0 0 0.85rem;
    transition: color 0.15s;
    word-break: break-word;
  }
  .qa-card__summary {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0;
  }
  .qa-card__chips { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .qa-card__signature {
    width: 100%;
    max-width: 16rem;
    justify-self: center;
    align-self: center;
    position: relative;
    z-index: 1;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .qa-card:hover .qa-card__signature { transform: translateY(-2px); }
  .qa-card__signature-frame {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in oklch, var(--color-surface-raised) 60%, transparent);
    padding: 1.1rem 1rem 0.9rem;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  @media (max-width: 900px) {
    .qa-card { grid-template-columns: 1fr; padding: 3rem 0 2.5rem; }
    .qa-card + .qa-card { padding-top: 3.5rem; }
    .qa-card__signature { max-width: 18rem; justify-self: start; }
    .qa-card__watermark { font-size: clamp(5rem, 18vw, 8rem); }
  }
</style>
