---
interface Props {
  slug: string;
  variants?: string[];
  spark_tokens_per_sec?: Record<string, number>;
  recommended_variant?: string;
  variant?: 'compact' | 'hero';
}

const { slug, variants = [], spark_tokens_per_sec, recommended_variant, variant = 'compact' } = Astro.props;

const haveRates = !!spark_tokens_per_sec && Object.keys(spark_tokens_per_sec).length > 0;
const maxRate = haveRates ? Math.max(...Object.values(spark_tokens_per_sec)) : 0;

const bars = variants.map((v) => {
  const rate = haveRates ? spark_tokens_per_sec[v] ?? 0 : 0;
  const heightPct = maxRate > 0 ? Math.max(8, (rate / maxRate) * 100) : 30;
  const isRecommended = recommended_variant === v;
  const shortLabel = v.split(/[·\s]/).slice(-1)[0]?.slice(0, 6) ?? '';
  return { label: v, shortLabel, rate, heightPct, isRecommended };
});

const ariaLabel = haveRates
  ? `Spark serving lanes: ${variants.length} variants, peak ${Math.round(maxRate)} tok/s`
  : `Spark agent harness ${slug}: ${variants.length} lanes`;
---

{variant === 'compact' && (
  <svg
    class="harness-sig harness-sig--compact"
    viewBox="0 0 100 32"
    preserveAspectRatio="none"
    role="img"
    aria-label={ariaLabel}
  >
    {bars.map((b, i) => {
      const segWidth = 100 / Math.max(bars.length, 1);
      const x = i * segWidth;
      const h = (b.heightPct / 100) * 26;
      const y = 32 - h - 3;
      return (
        <g>
          <rect
            x={x + 1}
            y={y}
            width={segWidth - 2}
            height={h}
            fill={b.isRecommended ? 'var(--color-primary)' : 'var(--color-text-muted)'}
            opacity={b.isRecommended ? '0.95' : '0.45'}
            rx="1"
          />
          <rect x={x + 1} y="29" width={segWidth - 2} height="2" fill="var(--color-border)" />
        </g>
      );
    })}
  </svg>
)}

{variant === 'hero' && (
  <figure class="harness-sig harness-sig--hero" aria-label={ariaLabel}>
    <ul class="harness-sig__lanes" role="list">
      {bars.map((b) => (
        <li class={`harness-sig__lane ${b.isRecommended ? 'harness-sig__lane--rec' : ''}`}>
          <div class="harness-sig__bar-wrap" aria-hidden="true">
            <div class="harness-sig__bar" style={`height: ${b.heightPct}%`}></div>
          </div>
          <div class="harness-sig__lane-meta">
            <span class="harness-sig__lane-name">{b.label}</span>
            {haveRates && b.rate > 0 && (
              <span class="harness-sig__lane-rate">{b.rate.toFixed(1)} tok/s</span>
            )}
            {b.isRecommended && <span class="harness-sig__lane-pin">recommended</span>}
          </div>
        </li>
      ))}
    </ul>
    <figcaption class="harness-sig__caption">
      {haveRates
        ? `${bars.length} lanes · peak ${Math.round(maxRate)} tok/s`
        : `${bars.length} lanes`}
    </figcaption>
  </figure>
)}

<style>
  .harness-sig--compact {
    width: 80px;
    height: 32px;
    display: inline-block;
    vertical-align: middle;
  }

  .harness-sig--hero {
    margin: 0;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in oklch, var(--color-surface-raised) 50%, transparent);
  }
  .harness-sig__lanes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  .harness-sig__lane {
    display: grid;
    grid-template-columns: 4rem 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.45rem 0.6rem;
    border-radius: 6px;
    background: color-mix(in oklch, var(--color-border) 20%, transparent);
  }
  .harness-sig__lane--rec {
    background: color-mix(in oklch, var(--color-primary) 10%, transparent);
    box-shadow: inset 2px 0 0 var(--color-primary);
  }
  .harness-sig__bar-wrap {
    height: 1.5rem;
    display: flex;
    align-items: flex-end;
    background: color-mix(in oklch, var(--color-border) 40%, transparent);
    border-radius: 3px;
    overflow: hidden;
  }
  .harness-sig__bar {
    width: 100%;
    background: var(--color-text-muted);
    transition: height 0.3s;
  }
  .harness-sig__lane--rec .harness-sig__bar {
    background: var(--color-primary);
  }
  .harness-sig__lane-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.55rem;
    font-size: 0.85rem;
  }
  .harness-sig__lane-name {
    font-family: var(--font-mono);
    color: var(--color-text);
    line-height: 1.3;
  }
  .harness-sig__lane-rate {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }
  .harness-sig__lane-pin {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    padding: 0.1rem 0.4rem;
    border: 1px solid color-mix(in oklch, var(--color-primary) 35%, transparent);
    border-radius: 999px;
  }
  .harness-sig__caption {
    margin-top: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    text-align: right;
  }
</style>
