---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navGroups = [
  {
    group: 'Overview',
    items: [
      { href: '/docs/api/', label: 'API Reference' },
    ],
  },
  {
    group: 'Core',
    items: [
      { href: '/docs/api/tasks/', label: 'Tasks' },
      { href: '/docs/api/projects/', label: 'Projects' },
      { href: '/docs/api/workflows/', label: 'Workflows' },
      { href: '/docs/api/blueprints/', label: 'Blueprints' },
      { href: '/docs/api/schedules/', label: 'Schedules' },
      { href: '/docs/api/apps/', label: 'Apps' },
    ],
  },
  {
    group: 'Intelligence',
    items: [
      { href: '/docs/api/chat/', label: 'Chat' },
      { href: '/docs/api/profiles/', label: 'Profiles' },
      { href: '/docs/api/runtimes/', label: 'Runtimes' },
      { href: '/docs/api/memory/', label: 'Memory' },
    ],
  },
  {
    group: 'Content',
    items: [
      { href: '/docs/api/documents/', label: 'Documents' },
      { href: '/docs/api/tables/', label: 'Tables' },
      { href: '/docs/api/uploads/', label: 'Uploads' },
      { href: '/docs/api/views/', label: 'Views' },
    ],
  },
  {
    group: 'Platform',
    items: [
      { href: '/docs/api/settings/', label: 'Settings' },
      { href: '/docs/api/permissions/', label: 'Permissions' },
      { href: '/docs/api/notifications/', label: 'Notifications' },
      { href: '/docs/api/channels/', label: 'Channels' },
      { href: '/docs/api/environment/', label: 'Environment' },
      { href: '/docs/api/snapshots/', label: 'Snapshots' },
      { href: '/docs/api/workspace/', label: 'Workspace' },
      { href: '/docs/api/instance/', label: 'Instance' },
    ],
  },
  {
    group: 'Operations',
    items: [
      { href: '/docs/api/logs/', label: 'Logs' },
      { href: '/docs/api/handoffs/', label: 'Handoffs' },
      { href: '/docs/api/data/', label: 'Data' },
      { href: '/docs/api/context/', label: 'Context' },
    ],
  },
];

function isActive(href: string): boolean {
  const normalized = currentPath.replace(/\/$/, '');
  const normalizedHref = href.replace(/\/$/, '');
  return normalized === normalizedHref;
}

const allItems = navGroups.flatMap(g => g.items);
---

<!-- Mobile dropdown -->
<div class="lg:hidden mb-8 w-full">
  <select
    id="api-docs-mobile-nav"
    class="w-full bg-surface-raised border border-border rounded-md px-4 py-3 text-sm text-text font-mono"
  >
    {navGroups.map(({ group, items }) => (
      <optgroup label={group}>
        {items.map(({ href, label }) => (
          <option value={href} selected={isActive(href)}>{label}</option>
        ))}
      </optgroup>
    ))}
  </select>
</div>

<!-- Desktop sidebar -->
<aside class="hidden lg:block w-[260px] shrink-0 sticky top-20 self-start max-h-[calc(100vh-6rem)] overflow-y-auto">
  <nav aria-label="API documentation pages" class="flex flex-col gap-0.5">
    {navGroups.map(({ group, items }, gi) => (
      <div class:list={["mb-3", gi > 0 && "mt-1"]}>
        {group !== 'Overview' && (
          <span class="block font-mono text-[0.65rem] uppercase tracking-[0.12em] text-text-dim px-3 py-1.5 select-none">
            {group}
          </span>
        )}
        {items.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "block px-3 py-1.5 rounded-md text-sm transition-colors",
              isActive(href)
                ? "bg-primary/10 text-primary font-medium"
                : "text-text-muted hover:text-text hover:bg-surface-raised"
            ]}
          >
            {label}
          </a>
        ))}
      </div>
    ))}

    <!-- Bridge to product docs -->
    <div class="mt-4 pt-4 border-t border-border">
      <a
        href="/docs/"
        class="block px-3 py-1.5 rounded-md text-sm text-text-dim hover:text-text-muted hover:bg-surface-raised transition-colors"
      >
        &larr; Product Docs
      </a>
    </div>
  </nav>
</aside>

<script>
  function initApiDocsNav() {
    const select = document.getElementById('api-docs-mobile-nav') as HTMLSelectElement;
    if (!select) return;
    select.addEventListener('change', () => {
      window.location.href = select.value;
    });
  }
  initApiDocsNav();
  document.addEventListener('astro:after-swap', initApiDocsNav);
</script>
