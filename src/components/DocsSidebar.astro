---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navGroups = [
  {
    group: 'Overview',
    items: [
      { href: '/docs/', label: 'Overview' },
    ],
  },
  {
    group: 'Work',
    items: [
      { href: '/docs/dashboard/', label: 'Dashboard' },
      { href: '/docs/tasks/', label: 'Task Execution' },
      { href: '/docs/projects/', label: 'Projects' },
      { href: '/docs/workflows/', label: 'Workflows' },
      { href: '/docs/documents/', label: 'Documents' },
      { href: '/docs/tables/', label: 'Tables' },
      { href: '/docs/chat/', label: 'Chat' },
      { href: '/docs/apps/', label: 'Apps' },
      { href: '/docs/inbox/', label: 'Human-in-the-Loop' },
    ],
  },
  {
    group: 'Manage',
    items: [
      { href: '/docs/monitoring/', label: 'Monitoring' },
      { href: '/docs/profiles/', label: 'Profiles' },
      { href: '/docs/schedules/', label: 'Schedules' },
      { href: '/docs/costs/', label: 'Cost & Usage' },
      { href: '/docs/agents/', label: 'Agent Integration' },
    ],
  },
  {
    group: 'Configure',
    items: [
      { href: '/docs/environment/', label: 'Environment' },
      { href: '/docs/settings/', label: 'Settings' },
    ],
  },
];

function isActive(href: string): boolean {
  const normalized = currentPath.replace(/\/$/, '');
  const normalizedHref = href.replace(/\/$/, '');
  return normalized === normalizedHref;
}
---

<!-- Mobile dropdown -->
<div class="md:hidden mb-8 w-full">
  <select
    id="docs-mobile-nav"
    class="w-full bg-surface-raised border border-border rounded-md px-4 py-3 text-sm text-text font-mono"
  >
    <optgroup label="Reference">
      <option value="/docs/api/" selected={isActive('/docs/api/')}>API Reference</option>
    </optgroup>
    {navGroups.map(({ group, items }) => (
      <optgroup label={group}>
        {items.map(({ href, label }) => (
          <option value={href} selected={isActive(href)}>{label}</option>
        ))}
      </optgroup>
    ))}
  </select>
</div>

<!-- Desktop sidebar -->
<aside class="hidden md:block md:w-[220px] lg:w-[260px] shrink-0 sticky top-20 self-start max-h-[calc(100vh-6rem)] overflow-y-auto">
  <nav aria-label="Documentation pages" class="flex flex-col gap-0.5">
    <div class="mb-3 pb-3 border-b border-border">
      <a
        href="/docs/api/"
        class:list={[
          "block px-3 py-1.5 rounded-md text-sm transition-colors",
          isActive('/docs/api/')
            ? "bg-primary/10 text-primary font-medium"
            : "text-text-muted hover:text-text hover:bg-surface-raised"
        ]}
      >
        API Reference
      </a>
    </div>
    {navGroups.map(({ group, items }, gi) => (
      <div class:list={["mb-3", gi > 0 && "mt-1"]}>
        {group !== 'Overview' && (
          <span class="block font-mono text-[0.65rem] uppercase tracking-[0.12em] text-text-dim px-3 py-1.5 select-none">
            {group}
          </span>
        )}
        {items.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "block px-3 py-1.5 rounded-md text-sm transition-colors",
              isActive(href)
                ? "bg-primary/10 text-primary font-medium"
                : "text-text-muted hover:text-text hover:bg-surface-raised"
            ]}
          >
            {label}
          </a>
        ))}
      </div>
    ))}
  </nav>
</aside>

<script>
  function initDocsNav() {
    const select = document.getElementById('docs-mobile-nav') as HTMLSelectElement;
    if (!select) return;
    select.addEventListener('change', () => {
      window.location.href = select.value;
    });
  }
  initDocsNav();
  document.addEventListener('astro:after-swap', initDocsNav);
</script>
