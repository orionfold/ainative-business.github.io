---
// Permanent notification bar for book release announcement
// Gradient tint + pill badge style, designed for light-first with dark mode support
---
<div class="notification-bar border-b border-border/50 py-2">
  <a href="/book/" class="max-w-7xl mx-auto px-6 flex items-center justify-center gap-3 text-sm hover:opacity-80 transition-opacity">
    <span class="inline-flex items-center gap-1.5 bg-success-dim px-2.5 py-0.5 rounded-full">
      <span class="h-1.5 w-1.5 rounded-full bg-success animate-pulse" aria-hidden="true"></span>
      <span class="font-mono text-[10px] tracking-wider font-semibold text-success uppercase">
        New Release
      </span>
    </span>
    <span class="text-text">
      Read <strong class="font-semibold">AI Native Business</strong> — free online book
    </span>
    <span class="text-primary font-medium">→</span>
  </a>
</div>

<style>
  .notification-bar {
    background: linear-gradient(
      90deg,
      rgba(247, 101, 59, 0.06),  /* spark accent-soft tint */
      rgba(17, 175, 34, 0.05)    /* green-soft tint */
    );
  }
</style>
