---
/**
 * GateReadings — signature figure for "The Gate Before the GPU".
 * The four gate measurements that decided method selection for the Kepler
 * astrodynamics model: base preflight (12.5% reward), the SFT gate (86%),
 * C6 generalization (86%), and the error-mined RL-headroom transfer set (21%).
 * The verdict the bars carry: SFT cleared; RL had no productive headroom → ship SFT.
 *
 * Data source: evidence/astrodynamics/{av10-preflight,av10-preflight-sft,
 * c6-sft-heldout,av12-headroom-transfer}.json
 */

type Bar = { key: string; label: string; value: number; accent: boolean };

const bars: Bar[] = [
  { key: 'base', label: 'BASE FP',  value: 12.5,  accent: false },
  { key: 'sft',  label: 'SFT GATE', value: 86.36, accent: true },
  { key: 'gen',  label: 'C6 GEN',   value: 86.36, accent: false },
  { key: 'xfer', label: 'HEADROOM', value: 20.83, accent: false },
];

// Plot geometry (300×200 signature canvas).
const plotY0 = 36;   // top of 100% plot region
const plotY1 = 168;  // baseline (0%)
const plotH = plotY1 - plotY0;
const barW = 44;
const xAt = (i: number) => 56 + i * 64;
const hAt = (v: number) => (v / 100) * plotH;

const yTicks = [0, 50, 100];
---
<svg
  viewBox="0 0 320 210"
  xmlns="http://www.w3.org/2000/svg"
  class="w-full max-w-md mx-auto"
  data-svg-animate
  role="img"
  aria-label="Four gate readings: base FP reward 12.5 percent, SFT gate 86 percent, C6 generalization 86 percent, error-mined RL-headroom transfer 21 percent — SFT cleared, RL had no productive headroom"
>
  <defs>
    <linearGradient id="gr-band" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.01"/>
    </linearGradient>
  </defs>

  <!-- Panel -->
  <rect x="8" y="10" width="304" height="192" rx="10"
    fill="var(--svg-bg)" stroke="var(--svg-stroke)" stroke-width="1" />
  <!-- Atmospheric wash over the plot region -->
  <rect x="44" y="36" width="252" height="132" rx="4" fill="url(#gr-band)" stroke="none" />

  <!-- Gridlines + y labels -->
  <g class="svg-reveal">
    {yTicks.map((tick) => {
      const y = plotY1 - hAt(tick);
      return (
        <g>
          <line x1="44" y1={y} x2="296" y2={y}
            stroke="var(--svg-stroke)" stroke-width="0.5" stroke-dasharray="2 4" />
          <text x="38" y={y + 4} fill="var(--svg-text-muted)"
            font-family="var(--font-mono)" font-size="9" text-anchor="end">{`${tick}`}</text>
        </g>
      );
    })}
  </g>

  <!-- Bars -->
  {bars.map((b, i) => {
    const x = xAt(i);
    const h = hAt(b.value);
    const y = plotY1 - h;
    const stroke = b.accent ? 'var(--svg-accent-blue)' : 'var(--svg-text-faint)';
    const fillOpacity = b.accent ? 0.42 : 0.16;
    return (
      <g class={`bar-grow svg-reveal-d${i + 1}`} style={`transform-origin: ${x + barW / 2}px ${plotY1}px`}>
        <rect x={x} y={y} width={barW} height={h} rx="3"
          fill="var(--svg-accent-blue)" fill-opacity={fillOpacity}
          stroke={stroke} stroke-width={b.accent ? 2 : 1} />
        <text x={x + barW / 2} y={y - 5} fill={b.accent ? 'var(--svg-accent-blue)' : 'var(--svg-text-muted)'}
          font-family="var(--font-mono)" font-size="11" font-weight={b.accent ? 700 : 400}
          text-anchor="middle">{`${Math.round(b.value)}%`}</text>
        <text x={x + barW / 2} y={plotY1 + 14} fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="8" text-anchor="middle">{b.label}</text>
      </g>
    );
  })}

  <!-- Verdict callout -->
  <g class="svg-reveal svg-reveal-d6">
    <text x="160" y="198" fill="var(--svg-text-muted)"
      font-family="var(--font-mono)" font-size="9" text-anchor="middle">SFT CLEARED · NO RL HEADROOM · SHIP SFT</text>
  </g>
</svg>
