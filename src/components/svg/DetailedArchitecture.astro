---
/**
 * 3-layer detailed architecture: Browser → Next.js Server → External Services
 * OKLCH palette with scroll-reveal animations, inline SVG icons, animated connectors
 */
---
<svg viewBox="0 0 960 680" xmlns="http://www.w3.org/2000/svg" class="w-full mx-auto" data-svg-animate>
  <defs>
    <linearGradient id="da-browser-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="var(--svg-accent-teal)" stop-opacity="0.2" />
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.08" />
    </linearGradient>
    <linearGradient id="da-server-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.15" />
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.05" />
    </linearGradient>
    <linearGradient id="da-external-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="var(--svg-accent-purple)" stop-opacity="0.15" />
      <stop offset="100%" stop-color="var(--svg-accent-purple)" stop-opacity="0.05" />
    </linearGradient>
  </defs>
  <style>
    @keyframes dash-flow {
      to { stroke-dashoffset: -14; }
    }
    .connector-flow {
      stroke-dasharray: 4 3;
      animation: dash-flow 0.8s linear infinite;
    }
    @media (prefers-reduced-motion: reduce) {
      .connector-flow { animation: none; }
    }
  </style>

  <!-- ═══════════════════════════════════════════ -->
  <!-- BROWSER LAYER                               -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal">
    <rect x="20" y="16" width="920" height="160" rx="8" fill="var(--svg-bg)" stroke="var(--svg-stroke)" stroke-width="1" />
    <rect x="20" y="16" width="4" height="160" rx="2" fill="var(--svg-accent-teal)" />
    <!-- Globe icon — centered with label -->
    <g transform="translate(44, 28) scale(0.75)" fill="none" stroke="var(--svg-accent-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <line x1="2" y1="12" x2="22" y2="12" />
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
    </g>
    <text x="70" y="42" fill="var(--svg-accent-teal)" font-family="var(--font-mono)" font-size="13" font-weight="700" letter-spacing="1.5">BROWSER</text>
    <text x="168" y="42" fill="var(--svg-text-muted)" font-family="var(--font-body)" font-size="11">React 19</text>
  </g>

  <!-- Standalone pills: Home + ⌘K -->
  <g class="svg-reveal svg-reveal-d1" font-family="var(--font-mono)" font-size="10.5">
    <rect x="770" y="28" width="62" height="22" rx="4" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.75" />
    <text x="801" y="43" fill="var(--svg-accent-teal)" text-anchor="middle">Home</text>
    <rect x="840" y="28" width="46" height="22" rx="4" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.75" />
    <text x="863" y="43" fill="var(--svg-accent-teal)" text-anchor="middle">⌘K</text>
  </g>

  <!-- ── WORK card (6 surfaces) ── -->
  <g class="svg-reveal svg-reveal-d1">
    <rect x="42" y="56" width="410" height="80" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="42" y="56" width="3" height="80" rx="1.5" fill="var(--svg-accent-blue)" />
    <text x="62" y="72" fill="var(--svg-accent-blue)" font-family="var(--font-mono)" font-size="9" font-weight="600" letter-spacing="1.2">WORK</text>
  </g>
  <g class="svg-reveal svg-reveal-d1" font-family="var(--font-mono)" font-size="10">
    <!-- Row 1: evenly spaced across 380px (x=62 to x=442) -->
    <rect x="62" y="80" width="96" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="110" y="95" fill="var(--svg-accent-blue)" text-anchor="middle">Dashboard</text>
    <rect x="170" y="80" width="66" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="203" y="95" fill="var(--svg-accent-blue)" text-anchor="middle">Inbox</text>
    <rect x="248" y="80" width="60" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="278" y="95" fill="var(--svg-accent-blue)" text-anchor="middle">Chat</text>
    <!-- Row 2 -->
    <rect x="62" y="108" width="82" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="103" y="123" fill="var(--svg-accent-blue)" text-anchor="middle">Projects</text>
    <rect x="156" y="108" width="92" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="202" y="123" fill="var(--svg-accent-blue)" text-anchor="middle">Workflows</text>
    <rect x="260" y="108" width="60" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="290" y="123" fill="var(--svg-accent-blue)" text-anchor="middle">Docs</text>
  </g>

  <!-- ── MANAGE card (4 surfaces) ── -->
  <g class="svg-reveal svg-reveal-d2">
    <rect x="464" y="56" width="248" height="80" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="464" y="56" width="3" height="80" rx="1.5" fill="var(--svg-accent-green-alt)" />
    <text x="484" y="72" fill="var(--svg-accent-green-alt)" font-family="var(--font-mono)" font-size="9" font-weight="600" letter-spacing="1.2">MANAGE</text>
  </g>
  <g class="svg-reveal svg-reveal-d2" font-family="var(--font-mono)" font-size="10">
    <!-- Row 1: evenly spaced across 220px (x=484 to x=700) -->
    <rect x="484" y="80" width="78" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="523" y="95" fill="var(--svg-accent-green-alt)" text-anchor="middle">Monitor</text>
    <rect x="576" y="80" width="76" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="614" y="95" fill="var(--svg-accent-green-alt)" text-anchor="middle">Profiles</text>
    <!-- Row 2 -->
    <rect x="484" y="108" width="88" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="528" y="123" fill="var(--svg-accent-green-alt)" text-anchor="middle">Schedules</text>
    <rect x="586" y="108" width="64" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="618" y="123" fill="var(--svg-accent-green-alt)" text-anchor="middle">Costs</text>
  </g>

  <!-- ── CONFIGURE card (3 surfaces) ── -->
  <g class="svg-reveal svg-reveal-d2">
    <rect x="724" y="56" width="204" height="80" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="724" y="56" width="3" height="80" rx="1.5" fill="var(--svg-accent-orange)" />
    <text x="744" y="72" fill="var(--svg-accent-orange)" font-family="var(--font-mono)" font-size="9" font-weight="600" letter-spacing="1.2">CONFIGURE</text>
  </g>
  <g class="svg-reveal svg-reveal-d2" font-family="var(--font-mono)" font-size="10">
    <!-- Row 1: evenly spaced across 176px (x=744 to x=914) -->
    <rect x="744" y="80" width="80" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="784" y="95" fill="var(--svg-accent-orange)" text-anchor="middle">Playbook</text>
    <rect x="838" y="80" width="52" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="864" y="95" fill="var(--svg-accent-orange)" text-anchor="middle">Env</text>
    <!-- Row 2 -->
    <rect x="744" y="108" width="76" height="22" rx="3" fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)" stroke-width="0.5" />
    <text x="782" y="123" fill="var(--svg-accent-orange)" text-anchor="middle">Settings</text>
  </g>

  <!-- Browser subtitle -->
  <g class="svg-reveal svg-reveal-d2">
    <text x="42" y="156" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="10">38 operator-facing surfaces across 3 workspace categories</text>
  </g>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CONNECTION: Browser → Server                -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal svg-reveal-d3">
    <!-- Animated flowing dashes -->
    <line x1="240" y1="176" x2="240" y2="210" stroke="var(--svg-connector)" stroke-width="1.2" class="connector-flow" />
    <line x1="700" y1="176" x2="700" y2="210" stroke="var(--svg-connector)" stroke-width="1.2" class="connector-flow" />
    <!-- Labels with padding from lines -->
    <text x="250" y="198" fill="var(--svg-connector-label)" font-family="var(--font-mono)" font-size="9">Server Components (direct DB queries)</text>
    <text x="710" y="198" fill="var(--svg-connector-label)" font-family="var(--font-mono)" font-size="9">API Routes</text>
  </g>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SERVER LAYER                                -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal svg-reveal-d3">
    <rect x="20" y="210" width="920" height="272" rx="8" fill="var(--svg-bg)" stroke="var(--svg-stroke)" stroke-width="1" />
    <rect x="20" y="210" width="4" height="272" rx="2" fill="var(--svg-accent-blue)" />
    <!-- Server/stack icon — centered with label -->
    <g transform="translate(44, 222) scale(0.75)" fill="none" stroke="var(--svg-accent-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="8" rx="2" />
      <rect x="2" y="14" width="20" height="8" rx="2" />
      <circle cx="6" cy="6" r="1" fill="var(--svg-accent-blue)" />
      <circle cx="6" cy="18" r="1" fill="var(--svg-accent-blue)" />
    </g>
    <text x="70" y="236" fill="var(--svg-accent-blue)" font-family="var(--font-mono)" font-size="13" font-weight="700" letter-spacing="1.5">NEXT.JS 16 SERVER</text>
  </g>

  <!-- Service grid — Row 1 -->
  <!-- Drizzle ORM -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="42" y="250" width="208" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="42" y="250" width="3" height="60" rx="1.5" fill="var(--svg-accent-teal)" />
    <g transform="translate(54, 266) scale(1.2)" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <ellipse cx="12" cy="5" rx="9" ry="3" />
      <path d="M21 5v14a9 3 0 0 1-18 0V5" />
    </g>
    <text x="92" y="276" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Drizzle ORM</text>
    <text x="92" y="292" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">SQLite · WAL mode</text>
  </g>

  <!-- Runtime Registry -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="262" y="250" width="208" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="262" y="250" width="3" height="60" rx="1.5" fill="var(--svg-accent-blue)" />
    <g transform="translate(274, 266) scale(1.2)" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" />
      <line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" />
      <line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="15" x2="4" y2="15" />
      <line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="15" x2="23" y2="15" />
    </g>
    <text x="312" y="276" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Runtime Registry</text>
    <text x="312" y="292" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Claude + OpenAI adapters</text>
  </g>

  <!-- SSE Stream -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="482" y="250" width="208" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="482" y="250" width="3" height="60" rx="1.5" fill="var(--svg-accent-purple)" />
    <g transform="translate(494, 266) scale(1.2)" fill="none" stroke="var(--svg-accent-purple)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 20h.01" />
      <path d="M8.5 16.5a5 5 0 0 1 7 0" />
      <path d="M5 13a10 10 0 0 1 14 0" />
      <path d="M1.5 9.5a15 15 0 0 1 21 0" />
    </g>
    <text x="532" y="276" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">SSE Stream</text>
    <text x="532" y="292" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Real-time event push</text>
  </g>

  <!-- Profile Engine -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="702" y="250" width="220" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="702" y="250" width="3" height="60" rx="1.5" fill="var(--svg-accent-orange)" />
    <g transform="translate(714, 266) scale(1.2)" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="8" r="5" />
      <path d="M20 21a8 8 0 0 0-16 0" />
    </g>
    <text x="752" y="276" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Profile Engine</text>
    <text x="752" y="292" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Instructions · tool policy</text>
  </g>

  <!-- Service grid — Row 2 -->
  <!-- Scheduler Engine -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="42" y="322" width="208" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="42" y="322" width="3" height="60" rx="1.5" fill="var(--svg-accent-green-alt)" />
    <g transform="translate(54, 338) scale(1.2)" fill="none" stroke="var(--svg-accent-green-alt)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </g>
    <text x="92" y="348" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Scheduler Engine</text>
    <text x="92" y="364" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Cron · one-shot triggers</text>
  </g>

  <!-- Workflow Engine -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="262" y="322" width="208" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="262" y="322" width="3" height="60" rx="1.5" fill="var(--svg-accent-pink)" />
    <g transform="translate(274, 338) scale(1.2)" fill="none" stroke="var(--svg-accent-pink)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="6" y1="3" x2="6" y2="15" />
      <circle cx="18" cy="6" r="3" />
      <circle cx="6" cy="18" r="3" />
      <path d="M18 9a9 9 0 0 1-9 9" />
    </g>
    <text x="312" y="348" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Workflow Engine</text>
    <text x="312" y="364" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">37 orchestration patterns</text>
  </g>

  <!-- Permission Gate -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="482" y="322" width="208" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="482" y="322" width="3" height="60" rx="1.5" fill="var(--svg-accent-red)" />
    <g transform="translate(494, 338) scale(1.2)" fill="none" stroke="var(--svg-accent-red)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    </g>
    <text x="532" y="348" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Permission Gate</text>
    <text x="532" y="364" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">canUseTool enforcement</text>
  </g>

  <!-- Doc Processor -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="702" y="322" width="220" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="702" y="322" width="3" height="60" rx="1.5" fill="var(--svg-accent-cyan)" />
    <g transform="translate(714, 338) scale(1.2)" fill="none" stroke="var(--svg-accent-cyan)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
      <polyline points="14 2 14 8 20 8" />
      <line x1="8" y1="13" x2="16" y2="13" />
      <line x1="8" y1="17" x2="16" y2="17" />
    </g>
    <text x="752" y="348" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Doc Processor</text>
    <text x="752" y="364" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Upload · extraction · context</text>
  </g>

  <!-- Service grid — Row 3 (NEW — centered 3 cards) -->
  <!-- Chat Engine -->
  <g class="ring-expand svg-reveal-d6">
    <rect x="112" y="394" width="228" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="112" y="394" width="3" height="60" rx="1.5" fill="var(--svg-accent-purple)" />
    <!-- MessageCircle icon -->
    <g transform="translate(124, 410) scale(1.2)" fill="none" stroke="var(--svg-accent-purple)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </g>
    <text x="162" y="420" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Chat Engine</text>
    <text x="162" y="436" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Context-aware workspace AI</text>
  </g>

  <!-- Environment Scanner -->
  <g class="ring-expand svg-reveal-d6">
    <rect x="356" y="394" width="248" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="356" y="394" width="3" height="60" rx="1.5" fill="var(--svg-accent-green-alt)" />
    <!-- Search/scan icon -->
    <g transform="translate(368, 410) scale(1.2)" fill="none" stroke="var(--svg-accent-green-alt)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8" />
      <line x1="21" y1="21" x2="16.65" y2="16.65" />
    </g>
    <text x="406" y="420" fill="var(--svg-text-bright)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Env Scanner</text>
    <text x="406" y="436" fill="var(--svg-text-dim)" font-family="var(--font-body)" font-size="9.5">Health scoring · skill portfolio</text>
  </g>

  <!-- Cost Engine -->
  <g class="ring-expand svg-reveal-d6">
    <rect x="620" y="394" width="228" height="60" rx="6" fill="var(--svg-card-fill)" stroke="var(--svg-card-stroke)" stroke-width="0.75" />
    <rect x="620" y="394" width="3" height="60" rx="1.5" fill="var(--svg-accent-orange)" />
