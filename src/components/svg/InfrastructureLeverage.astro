---
/**
 * InfrastructureLeverage — case-study Figure 4.
 * Contrasts 7,435 lines of domain code against 31,000–57,000 lines of
 * inherited platform infrastructure. Top: two summary bars. Below: a
 * breakdown of the platform components the builder did not have to write.
 *
 * Source: src/pages/research/solo-builder-case-study.mdx §6.
 */

type Row = { label: string; min: number; max: number };

const breakdown: Row[] = [
  { label: 'Agent runtime',     min: 8000,  max: 15000 },
  { label: 'Workflow engine',   min: 5000,  max: 8000  },
  { label: 'UI framework',      min: 5000,  max: 10000 },
  { label: 'Schema + migration',min: 3000,  max: 5000  },
  { label: 'Governance layer',  min: 3000,  max: 5000  },
  { label: 'Scheduler (cron)',  min: 2000,  max: 4000  },
  { label: 'SQLite + WAL',      min: 2000,  max: 5000  },
  { label: 'Auth + settings',   min: 2000,  max: 3000  },
  { label: 'Cost metering',     min: 1000,  max: 2000  },
];

const scaleMax = 60000;
const trackX0 = 220;
const trackX1 = 680;
const trackW = trackX1 - trackX0;
const xFor = (v: number) => trackX0 + (v / scaleMax) * trackW;
---
<svg
  viewBox="0 0 720 520"
  xmlns="http://www.w3.org/2000/svg"
  class="w-full max-w-2xl mx-auto"
  data-svg-animate
  role="img"
  aria-label="Infrastructure leverage: 7,435 lines of domain code built on 31,000–57,000 lines of inherited platform"
>
  <defs>
    <linearGradient id="il-domain-bar" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.95" />
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.55" />
    </linearGradient>
  </defs>

  <!-- Panel background -->
  <rect x="20" y="20" width="680" height="480" rx="10"
        fill="var(--svg-bg)" stroke="var(--svg-stroke)" stroke-width="1" />

  <!-- Title -->
  <text x="40" y="52" fill="var(--svg-text-bright)"
        font-family="var(--font-mono)" font-size="12"
        letter-spacing="1.5">INFRASTRUCTURE LEVERAGE</text>

  <!-- Scale markers -->
  <g class="svg-reveal">
    {[0, 15000, 30000, 45000, 60000].map((tick) => {
      const x = xFor(tick);
      return (
        <g>
          <line x1={x} y1="76" x2={x} y2="470"
                stroke="var(--svg-stroke)" stroke-width="0.5"
                stroke-dasharray="2 4" />
          <text x={x} y="72" fill="var(--svg-text-muted)"
                font-family="var(--font-mono)" font-size="9"
                text-anchor="middle">{(tick / 1000).toFixed(0)}k</text>
        </g>
      );
    })}
  </g>

  <!-- ========== SUMMARY BARS ========== -->

  <!-- Domain bar -->
  <g class="svg-reveal svg-reveal-d1">
    <text x="40" y="108" fill="var(--svg-text-bright)"
          font-family="var(--font-mono)" font-size="11"
          font-weight="600">DOMAIN CODE</text>
    <text x="40" y="122" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="9">
      what the builder wrote
    </text>
  </g>
  <g class="bar-grow-x svg-reveal-d1" style={`transform-origin: ${trackX0}px 108px`}>
    <rect
      x={trackX0} y="92"
      width={xFor(7435) - trackX0} height="28" rx="2"
      fill="url(#il-domain-bar)"
    />
    <text
      x={xFor(7435) + 8} y="111"
      fill="var(--svg-accent-blue)"
      font-family="var(--font-mono)" font-size="13"
      font-weight="700"
    >7,435</text>
  </g>

  <!-- Platform bar (range: min to max) -->
  <g class="svg-reveal svg-reveal-d2">
    <text x="40" y="172" fill="var(--svg-text-bright)"
          font-family="var(--font-mono)" font-size="11"
          font-weight="600">PLATFORM INFRASTRUCTURE</text>
    <text x="40" y="186" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="9">
      what the builder inherited
    </text>
  </g>
  <g class="bar-grow-x svg-reveal-d2" style={`transform-origin: ${trackX0}px 172px`}>
    {/* min span solid-ish */}
    <rect
      x={trackX0} y="156"
      width={xFor(31000) - trackX0} height="28" rx="2"
      fill="var(--svg-accent-blue)"
      fill-opacity="0.30"
    />
    {/* range span lighter */}
    <rect
      x={xFor(31000)} y="156"
      width={xFor(57000) - xFor(31000)} height="28" rx="2"
      fill="var(--svg-accent-blue)"
      fill-opacity="0.15"
      stroke="var(--svg-accent-blue)"
      stroke-width="1"
      stroke-dasharray="3 3"
      stroke-opacity="0.5"
    />
    <text
      x={xFor(57000) + 8} y="175"
      fill="var(--svg-accent-blue)"
      font-family="var(--font-mono)" font-size="13"
      font-weight="700"
    >31k–57k</text>
  </g>

  <!-- Leverage ratio callout -->
  <g class="svg-reveal svg-reveal-d3">
    <line x1="40" y1="212" x2="680" y2="212"
          stroke="var(--svg-stroke)" stroke-width="0.5" />
    <text x="40" y="236" fill="var(--svg-text-bright)"
          font-family="var(--font-mono)" font-size="11"
          font-weight="600">LEVERAGE RATIO</text>
    <text x="680" y="236" fill="var(--svg-accent-green)"
          font-family="var(--font-mono)" font-size="13"
          font-weight="700" text-anchor="end">4.2× – 7.7×</text>
  </g>

  <!-- ========== BREAKDOWN ========== -->
  <g class="svg-reveal svg-reveal-d4">
    <text x="40" y="272" fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="10"
          letter-spacing="1">PLATFORM BREAKDOWN</text>
  </g>

  {breakdown.map((row, i) => {
    const y = 290 + i * 22;
    const barY = y - 7;
    const delay = Math.min(i + 4, 8);
    return (
      <g class={`svg-reveal svg-reveal-d${delay}`}>
        {/* Label */}
        <text x="40" y={y} fill="var(--svg-text-muted)"
              font-family="var(--font-mono)" font-size="10">
          {row.label}
        </text>
        {/* Min bar (solid-ish) */}
        <rect
          x={trackX0} y={barY}
          width={xFor(row.min) - trackX0} height="10" rx="1"
          fill="var(--svg-accent-blue)"
          fill-opacity="0.35"
        />
        {/* Range extension (lighter) */}
        <rect
          x={xFor(row.min)} y={barY}
          width={xFor(row.max) - xFor(row.min)} height="10" rx="1"
          fill="var(--svg-accent-blue)"
          fill-opacity="0.15"
        />
        {/* Range text */}
        <text
          x={xFor(row.max) + 6} y={y - 1}
          fill="var(--svg-text-muted)"
          font-family="var(--font-mono)" font-size="9"
        >
          {`${(row.min / 1000).toFixed(0)}–${(row.max / 1000).toFixed(0)}k`}
        </text>
      </g>
    );
  })}
</svg>
