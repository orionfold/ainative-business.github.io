---
/**
 * FieldkitConstellation — Hero visualization for /fieldkit/
 * Central "fieldkit" core pill with five satellite module nodes
 * (capabilities, nim, eval, rag, cli). Mirrors BusinessConstellation's
 * visual language (3D sphere gradients, edge-terminated bezier curves,
 * flowing particles, .svg-reveal stagger) at a calmer scale — no spring
 * drift, just static positions that feel composed.
 */
---
<svg viewBox="0 0 560 400" xmlns="http://www.w3.org/2000/svg" class="fkc w-full mx-auto" data-svg-animate>
  <defs>
    <!-- Soft glow for the core node -->
    <filter id="fkc-glow">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="fkc-glow-soft">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- 3D sphere gradients per module accent -->
    <radialGradient id="fkc-sphere-blue" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-blue)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="fkc-sphere-teal" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-teal)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-teal)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-teal)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="fkc-sphere-purple" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-purple)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-purple)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-purple)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="fkc-sphere-orange" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-orange)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-orange)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="fkc-sphere-green" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-green)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-green)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-green)" stop-opacity="0.03"/>
    </radialGradient>

    <!-- Core pill: 135° gradient matching the hero gradient title -->
    <linearGradient id="fkc-core-stroke" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="oklch(0.78 0.12 230)"/>
      <stop offset="50%" stop-color="var(--color-primary)"/>
      <stop offset="100%" stop-color="oklch(0.58 0.18 280)"/>
    </linearGradient>
    <linearGradient id="fkc-core-fill" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="oklch(0.78 0.12 230)" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="oklch(0.58 0.18 280)" stop-opacity="0.10"/>
    </linearGradient>

    <!-- Atmospheric glow behind everything -->
    <radialGradient id="fkc-atmo" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.10"/>
      <stop offset="40%" stop-color="var(--svg-accent-blue)" stop-opacity="0.04"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <style>
    @keyframes fkc-dash { to { stroke-dashoffset: -14; } }
    .fkc-conn-dashed { stroke-dasharray: 3 4; animation: fkc-dash 3s linear infinite; }

    :global(html[data-theme="light"]) .fkc .fkc-atmo-circle { opacity: 0.5; }
    :global(html[data-theme="light"]) .fkc .fkc-particle { opacity: 0.45; }

    @media (prefers-reduced-motion: reduce) {
      .fkc-conn-dashed { animation: none; }
      .fkc .fkc-particle { display: none; }
      .fkc .fkc-halo { animation: none !important; }
    }
  </style>

  <!-- ═══ ATMOSPHERE ═══ -->
  <g class="svg-reveal">
    <circle class="fkc-atmo-circle" cx="280" cy="200" r="180" fill="url(#fkc-atmo)"/>
  </g>

  <!-- ═══ CONNECTIONS: Core ↔ Modules (edge-terminated bezier curves) ═══ -->
  <g class="svg-reveal svg-reveal-d6">
    <!-- core → capabilities (top) -->
    <path id="fkc-p-cap" d="M280,179 Q280,140 280,100" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.18" stroke-width="1"/>
    <!-- core → nim (left) -->
    <path id="fkc-p-nim" d="M218,200 Q170,200 150,190" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.18" stroke-width="1"/>
    <!-- core → eval (right) -->
    <path id="fkc-p-eval" d="M342,200 Q390,200 410,190" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.18" stroke-width="1"/>
    <!-- core → rag (bottom) -->
    <path id="fkc-p-rag" d="M280,221 Q280,260 280,300" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.18" stroke-width="1"/>
    <!-- rag → cli (bottom-right satellite of rag) -->
    <path id="fkc-p-cli" d="M309,318 Q360,330 408,338" fill="none" stroke="var(--svg-accent-green)" stroke-opacity="0.16" stroke-width="0.9"/>
  </g>

  <!-- ═══ CONNECTIONS: Inter-module hints (dashed) ═══ -->
  <g class="svg-reveal svg-reveal-d4">
    <line x1="139" y1="172" x2="265" y2="115" class="fkc-conn-dashed" stroke="var(--svg-accent-teal)" stroke-opacity="0.10" stroke-width="0.7"/>
    <line x1="421" y1="172" x2="295" y2="115" class="fkc-conn-dashed" stroke="var(--svg-accent-purple)" stroke-opacity="0.10" stroke-width="0.7"/>
    <line x1="155" y1="208" x2="262" y2="305" class="fkc-conn-dashed" stroke="var(--svg-accent-orange)" stroke-opacity="0.08" stroke-width="0.7"/>
    <line x1="405" y1="208" x2="298" y2="305" class="fkc-conn-dashed" stroke="var(--svg-accent-orange)" stroke-opacity="0.08" stroke-width="0.7"/>
  </g>

  <!-- ═══ PARTICLES (data flowing into fieldkit core) ═══ -->
  <g class="svg-reveal svg-reveal-d8">
    <circle class="fkc-particle" r="2.2" fill="var(--svg-accent-blue)" opacity="0.7">
      <animateMotion dur="3.6s" repeatCount="indefinite"><mpath href="#fkc-p-cap"/></animateMotion>
    </circle>
    <circle class="fkc-particle" r="2" fill="var(--svg-accent-teal)" opacity="0.6">
      <animateMotion dur="4.2s" repeatCount="indefinite"><mpath href="#fkc-p-nim"/></animateMotion>
    </circle>
    <circle class="fkc-particle" r="2" fill="var(--svg-accent-purple)" opacity="0.6">
      <animateMotion dur="3.9s" repeatCount="indefinite"><mpath href="#fkc-p-eval"/></animateMotion>
    </circle>
    <circle class="fkc-particle" r="2.2" fill="var(--svg-accent-orange)" opacity="0.7">
      <animateMotion dur="4.5s" repeatCount="indefinite"><mpath href="#fkc-p-rag"/></animateMotion>
    </circle>
    <circle class="fkc-particle" r="1.8" fill="var(--svg-accent-green)" opacity="0.55">
      <animateMotion dur="4.8s" repeatCount="indefinite"><mpath href="#fkc-p-cli"/></animateMotion>
    </circle>
  </g>

  <!-- ═══ CORE: fieldkit pill (center) ═══ -->
  <g class="svg-reveal svg-reveal-d3">
    <!-- Pulsing halo -->
    <rect class="fkc-halo" x="218" y="179" width="124" height="42" rx="21"
          fill="none" stroke="url(#fkc-core-stroke)" stroke-opacity="0.20" stroke-width="0.6">
      <animate attributeName="stroke-opacity" values="0.20;0.08;0.20" dur="4.5s" repeatCount="indefinite"/>
    </rect>
    <!-- Pill body -->
    <rect x="218" y="179" width="124" height="42" rx="21"
          fill="url(#fkc-core-fill)" stroke="url(#fkc-core-stroke)" stroke-width="1.4"
          filter="url(#fkc-glow)"/>
    <!-- Label -->
    <text x="280" y="206" text-anchor="middle"
          font-family="var(--font-display)" font-size="16" font-weight="700"
          fill="var(--color-primary)" letter-spacing="0.5">fieldkit</text>
  </g>

  <!-- ═══ MODULES (satellites) ═══ -->

  <!-- capabilities (top, blue) -->
  <g class="svg-reveal svg-reveal-d1">
    <circle class="fkc-halo" cx="280" cy="78" r="26" fill="none"
            stroke="var(--svg-accent-blue)" stroke-opacity="0.15" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.15;0.06;0.15" dur="5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="280" cy="78" r="26" fill="url(#fkc-sphere-blue)"
            stroke="var(--svg-accent-blue)" stroke-opacity="0.45" stroke-width="1"
            filter="url(#fkc-glow-soft)"/>
    <!-- σ icon: simple bracketed equation glyph -->
    <g transform="translate(280,78)">
      <path d="M-7,-7 L7,-7 L1,0 L7,7 L-7,7" fill="none"
            stroke="var(--svg-accent-blue)" stroke-width="1.4"
            stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
    </g>
    <text x="280" y="121" text-anchor="middle"
          font-family="var(--font-mono)" font-size="9" font-weight="500"
          letter-spacing="0.05em" fill="var(--svg-accent-blue)">capabilities</text>
  </g>

  <!-- nim (left, teal) -->
  <g class="svg-reveal svg-reveal-d2">
    <circle class="fkc-halo" cx="110" cy="190" r="24" fill="none"
            stroke="var(--svg-accent-teal)" stroke-opacity="0.13" stroke-width="0.5">
      <animate attributeName="r" values="24;27;24" dur="5.4s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.13;0.05;0.13" dur="5.4s" repeatCount="indefinite"/>
    </circle>
    <circle cx="110" cy="190" r="24" fill="url(#fkc-sphere-teal)"
            stroke="var(--svg-accent-teal)" stroke-opacity="0.45" stroke-width="0.9"/>
    <!-- Plug icon: NIM as inference plug -->
    <g transform="translate(110,190)">
      <rect x="-7" y="-5" width="14" height="10" rx="1.5" fill="none"
            stroke="var(--svg-accent-teal)" stroke-width="1.1" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="-9" x2="-3" y2="-5" stroke="var(--svg-accent-teal)" stroke-width="1.1" stroke-linecap="round"/>
      <line x1="3" y1="-9" x2="3" y2="-5" stroke="var(--svg-accent-teal)" stroke-width="1.1" stroke-linecap="round"/>
      <line x1="0" y1="5" x2="0" y2="9" stroke="var(--svg-accent-teal)" stroke-width="1.1" stroke-linecap="round"/>
    </g>
    <text x="110" y="231" text-anchor="middle"
          font-family="var(--font-mono)" font-size="9" font-weight="500"
          letter-spacing="0.05em" fill="var(--svg-accent-teal)">nim</text>
  </g>

  <!-- eval (right, purple) -->
  <g class="svg-reveal svg-reveal-d2">
    <circle class="fkc-halo" cx="450" cy="190" r="24" fill="none"
            stroke="var(--svg-accent-purple)" stroke-opacity="0.13" stroke-width="0.5">
      <animate attributeName="r" values="24;27;24" dur="5.6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.13;0.05;0.13" dur="5.6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="450" cy="190" r="24" fill="url(#fkc-sphere-purple)"
            stroke="var(--svg-accent-purple)" stroke-opacity="0.45" stroke-width="0.9"/>
    <!-- Gauge icon: judge / scoring -->
    <g transform="translate(450,190)">
      <path d="M-8,3 A8,8 0 0,1 8,3" fill="none"
            stroke="var(--svg-accent-purple)" stroke-width="1.1"
            stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <line x1="0" y1="3" x2="5" y2="-4"
            stroke="var(--svg-accent-purple)" stroke-width="1.3" stroke-linecap="round"/>
      <circle cx="0" cy="3" r="1.4" fill="var(--svg-accent-purple)"/>
    </g>
    <text x="450" y="231" text-anchor="middle"
          font-family="var(--font-mono)" font-size="9" font-weight="500"
          letter-spacing="0.05em" fill="var(--svg-accent-purple)">eval</text>
  </g>

  <!-- rag (bottom, orange) -->
  <g class="svg-reveal svg-reveal-d3">
    <circle class="fkc-halo" cx="280" cy="318" r="26" fill="none"
            stroke="var(--svg-accent-orange)" stroke-opacity="0.15" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="5.2s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.15;0.06;0.15" dur="5.2s" repeatCount="indefinite"/>
    </circle>
    <circle cx="280" cy="318" r="26" fill="url(#fkc-sphere-orange)"
            stroke="var(--svg-accent-orange)" stroke-opacity="0.45" stroke-width="1"
            filter="url(#fkc-glow-soft)"/>
    <!-- Stack/database icon: vector store -->
    <g transform="translate(280,318)">
      <ellipse cx="0" cy="-5" rx="7" ry="2.2" fill="none"
               stroke="var(--svg-accent-orange)" stroke-width="1.1" vector-effect="non-scaling-stroke"/>
      <path d="M-7,-5 L-7,5 A7,2.2 0 0,0 7,5 L7,-5"
            fill="none" stroke="var(--svg-accent-orange)" stroke-width="1.1" vector-effect="non-scaling-stroke"/>
      <path d="M-7,0 A7,2.2 0 0,0 7,0"
            fill="none" stroke="var(--svg-accent-orange)" stroke-width="0.9" stroke-opacity="0.7" vector-effect="non-scaling-stroke"/>
    </g>
    <text x="280" y="361" text-anchor="middle"
          font-family="var(--font-mono)" font-size="9" font-weight="500"
          letter-spacing="0.05em" fill="var(--svg-accent-orange)">rag</text>
  </g>

  <!-- cli (bottom-right, green; satellite of rag) -->
  <g class="svg-reveal svg-reveal-d5">
    <circle class="fkc-halo" cx="430" cy="338" r="20" fill="none"
            stroke="var(--svg-accent-green)" stroke-opacity="0.13" stroke-width="0.5">
      <animate attributeName="r" values="20;23;20" dur="5.8s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.13;0.05;0.13" dur="5.8s" repeatCount="indefinite"/>
    </circle>
    <circle cx="430" cy="338" r="20" fill="url(#fkc-sphere-green)"
            stroke="var(--svg-accent-green)" stroke-opacity="0.45" stroke-width="0.9"/>
    <!-- Caret prompt icon -->
    <g transform="translate(430,338)">
      <path d="M-5,-4 L-1,0 L-5,4" fill="none"
            stroke="var(--svg-accent-green)" stroke-width="1.4"
            stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
      <line x1="2" y1="4" x2="6" y2="4"
            stroke="var(--svg-accent-green)" stroke-width="1.3" stroke-linecap="round"/>
    </g>
    <text x="430" y="372" text-anchor="middle"
          font-family="var(--font-mono)" font-size="9" font-weight="500"
          letter-spacing="0.05em" fill="var(--svg-accent-green)">cli</text>
  </g>
</svg>
