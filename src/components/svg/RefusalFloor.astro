---
/**
 * RefusalFloor — signature figure for "The Refusal Floor Is Trainable".
 * The frozen curveball-v0.2 verdict that promoted the trained 4B over the
 * prompt-engineered 30B: refusals under novel adversarial pretexts (3/9 vs
 * 9/9) and overall scored==strict (8/21 vs 18/21). Same bench, same packets,
 * frozen before training — the only mover between the pairs is the weights.
 *
 * Data source: evidence/orionfold-advisor/advisor-curveball2-compare-v0.1.json
 */

type Bar = { key: string; label: string; sub: string; value: number; accent: boolean };

// Percent of rows passed on frozen curveball-v0.2 (sha 4b6cac85e41f).
const bars: Bar[] = [
  { key: 'p-ref', label: 'REFUSALS', sub: '30B PROMPT', value: 33.3, accent: false }, // 3/9
  { key: 't-ref', label: 'REFUSALS', sub: '4B TRAINED', value: 100, accent: true },   // 9/9
  { key: 'p-all', label: 'ALL ROWS', sub: '30B PROMPT', value: 38.1, accent: false }, // 8/21
  { key: 't-all', label: 'ALL ROWS', sub: '4B TRAINED', value: 85.7, accent: true },  // 18/21
];

// Plot geometry (320×210 signature canvas).
const plotY0 = 36;   // top of 100% plot region
const plotY1 = 160;  // baseline (0%)
const plotH = plotY1 - plotY0;
const barW = 40;
const xAt = (i: number) => 48 + i * 62 + (i > 1 ? 14 : 0); // gap between pairs
const hAt = (v: number) => (v / 100) * plotH;

const yTicks = [0, 50, 100];
---
<svg
  viewBox="0 0 320 210"
  xmlns="http://www.w3.org/2000/svg"
  class="w-full max-w-md mx-auto"
  data-svg-animate
  role="img"
  aria-label="Frozen curveball verdict: the prompt-engineered 30B refused 3 of 9 novel pretexts and passed 8 of 21 rows; the trained 4B refused 9 of 9 and passed 18 of 21 — the refusal floor moved with the weights, not the prompt"
>
  <defs>
    <linearGradient id="rf-band" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.01"/>
    </linearGradient>
    <linearGradient id="rf-accent" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.15"/>
    </linearGradient>
  </defs>

  <rect x="16" y={plotY0 - 8} width="288" height={plotH + 8} rx="6" fill="url(#rf-band)" stroke="none"/>

  {yTicks.map((t) => (
    <g>
      <line
        x1="34" x2="300"
        y1={plotY1 - hAt(t)} y2={plotY1 - hAt(t)}
        stroke="var(--svg-grid)" stroke-width="0.5"
        stroke-dasharray={t === 0 ? 'none' : '3 3'}
      />
      <text x="28" y={plotY1 - hAt(t) + 3} text-anchor="end" font-size="8" fill="var(--svg-text-muted)" font-family="var(--font-mono)">{t}</text>
    </g>
  ))}

  {bars.map((b, i) => (
    <g>
      <rect
        x={xAt(i)} y={plotY1 - hAt(b.value)}
        width={barW} height={hAt(b.value)}
        rx="3"
        fill={b.accent ? 'url(#rf-accent)' : 'var(--svg-node-fill)'}
        stroke={b.accent ? 'var(--color-primary)' : 'var(--svg-node-stroke)'}
        stroke-width={b.accent ? '1.5' : '1'}
      />
      <text x={xAt(i) + barW / 2} y={plotY1 - hAt(b.value) - 5} text-anchor="middle" font-size="9" font-weight="600" fill={b.accent ? 'var(--color-primary)' : 'var(--svg-text)'} font-family="var(--font-mono)">{b.value.toFixed(0)}%</text>
      <text x={xAt(i) + barW / 2} y={plotY1 + 13} text-anchor="middle" font-size="7" fill="var(--svg-text-muted)" font-family="var(--font-mono)">{b.sub}</text>
    </g>
  ))}

  <text x="79" y={plotY1 + 26} text-anchor="middle" font-size="8" fill="var(--svg-text)" font-family="var(--font-mono)">REFUSALS 9</text>
  <text x="217" y={plotY1 + 26} text-anchor="middle" font-size="8" fill="var(--svg-text)" font-family="var(--font-mono)">ALL ROWS 21</text>

  <text x="160" y="20" text-anchor="middle" font-size="9" fill="var(--svg-text-muted)" font-family="var(--font-mono)">FROZEN CURVEBALL v0.2 · PRE-REGISTERED</text>
  <text x="160" y={plotY1 + 42} text-anchor="middle" font-size="8" fill="var(--svg-text-muted)" font-family="var(--font-mono)">prompt contract vs trained weights · same packets</text>
</svg>
