---
/**
 * BusinessConstellation — Hero visualization
 * Network constellation: 4 inner ainative product nodes → 6 outer business outcome nodes
 * 3D sphere gradients, galaxy drift, edge-terminated bezier curves, external labels
 */
---
<svg viewBox="0 0 560 400" xmlns="http://www.w3.org/2000/svg" class="bc w-full mx-auto" data-svg-animate>
  <defs>
    <!-- Soft glow filter for Agents hero node -->
    <filter id="bc-glow">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <!-- Lighter glow for prominent outer nodes -->
    <filter id="bc-glow-soft">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- 3D sphere gradients with offset highlight -->
    <radialGradient id="bc-sphere-blue" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-blue)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="bc-sphere-teal" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-teal)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-teal)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-teal)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="bc-sphere-purple" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-purple)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-purple)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-purple)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="bc-sphere-orange" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-orange)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-orange)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.03"/>
    </radialGradient>

    <!-- Central atmospheric glow -->
    <radialGradient id="bc-atmo" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.12"/>
      <stop offset="40%" stop-color="var(--svg-accent-blue)" stop-opacity="0.04"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <style>
    /* Ambient animations */
    @keyframes bc-dash { to { stroke-dashoffset: -14; } }
    .bc-inner-conn { stroke-dasharray: 3 4; animation: bc-dash 3s linear infinite; }

    /* Light mode overrides */
    :global(html[data-theme="light"]) .bc .bc-atmo-circle { opacity: 0.5; }
    :global(html[data-theme="light"]) .bc .bc-particle { opacity: 0.4; }
    :global(html[data-theme="light"]) .bc .bc-watermark { opacity: 0.2; }
    :global(html[data-theme="light"]) .bc .bc-outer-halo { opacity: 0.5; }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .bc-inner-conn { animation: none; }
      .bc .bc-particle { display: none; }
      .bc .bc-halo { animation: none !important; }
    }
  </style>

  <!-- ═══ ATMOSPHERE ═══ -->
  <g class="svg-reveal">
    <circle class="bc-atmo-circle" cx="280" cy="200" r="190" fill="url(#bc-atmo)"/>
  </g>

  <!-- ═══ CONNECTIONS: Inner ↔ Outer (edge-terminated bezier curves) ═══ -->
  <g class="svg-reveal svg-reveal-d7">
    <!-- Primary connections (10% opacity, 1px) -->
    <!-- Agents → Revenue Growth -->
    <path id="bc-p-ag-rev" data-bc-conn="ag-rev" d="M253.5,131.1 Q200,95 138.6,73.3" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Agents → Customer Success -->
    <path id="bc-p-ag-cus" data-bc-conn="ag-cus" d="M306.5,131.1 Q360,95 424.9,75.9" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Workflows → Operations Excellence -->
    <path id="bc-p-wf-ops" data-bc-conn="wf-ops" d="M177.1,212.9 Q140,210 88.3,195.2" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Workflows → Cost Efficiency -->
    <path id="bc-p-wf-cost" data-bc-conn="wf-cost" d="M189.4,237.1 Q160,285 119.9,308.4" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Documents → Business Intelligence -->
    <path id="bc-p-doc-bi" data-bc-conn="doc-bi" d="M372.4,235.9 Q405,280 443.7,311.7" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Knowledge → Compliance & Governance -->
    <path id="bc-p-kb-comp" data-bc-conn="kb-comp" d="M305.9,278.5 Q395,270 470.4,210.5" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Knowledge → Cost Efficiency -->
    <path id="bc-p-kb-cost" data-bc-conn="kb-cost" d="M255.1,288.6 Q185,310 122.8,317.3" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.1" stroke-width="1"/>

    <!-- Cross connections (6% opacity, 0.7px) -->
    <!-- Agents → Compliance -->
    <path data-bc-conn="ag-comp" d="M311.7,153.2 Q400,165 466.3,187.1" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.06" stroke-width="0.7"/>
    <!-- Workflows → Revenue -->
    <path data-bc-conn="wf-rev" d="M189.6,192.7 Q155,135 127.4,86.7" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.06" stroke-width="0.7"/>
    <!-- Documents → Customer Success -->
    <path data-bc-conn="doc-cus" d="M373.4,194.9 Q410,150 436.6,89.2" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.06" stroke-width="0.7"/>
    <!-- Knowledge → Business Intelligence -->
    <path data-bc-conn="kb-bi" d="M304.7,289.0 Q370,310 439.3,321.5" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.06" stroke-width="0.7"/>
  </g>

  <!-- ═══ CONNECTIONS: Inner ↔ Inner (dashed diamond, edge-terminated) ═══ -->
  <g class="svg-reveal svg-reveal-d4">
    <line data-bc-line="ag-wf" x1="255.7" y1="169.8" x2="222.7" y2="198.1" class="bc-inner-conn" stroke="var(--svg-accent-blue)" stroke-opacity="0.08" stroke-width="0.8"/>
    <line data-bc-line="ag-doc" x1="304.3" y1="169.8" x2="337.3" y2="198.1" class="bc-inner-conn" stroke="var(--svg-accent-blue)" stroke-opacity="0.08" stroke-width="0.8"/>
    <line data-bc-line="wf-kb" x1="222.7" y1="231.9" x2="260.3" y2="264.1" class="bc-inner-conn" stroke="var(--svg-accent-teal)" stroke-opacity="0.06" stroke-width="0.8"/>
    <line data-bc-line="doc-kb" x1="337.3" y1="231.9" x2="299.7" y2="264.1" class="bc-inner-conn" stroke="var(--svg-accent-purple)" stroke-opacity="0.06" stroke-width="0.8"/>
  </g>

  <!-- ═══ PARTICLES (flowing along bezier paths) ═══ -->
  <g class="svg-reveal svg-reveal-d8">
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-blue)" opacity="0.7">
      <animateMotion dur="4s" repeatCount="indefinite"><mpath href="#bc-p-ag-rev"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2" fill="var(--svg-accent-blue)" opacity="0.5">
      <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#bc-p-ag-cus"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-teal)" opacity="0.6">
      <animateMotion dur="4.5s" repeatCount="indefinite"><mpath href="#bc-p-wf-ops"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2" fill="var(--svg-accent-teal)" opacity="0.5">
      <animateMotion dur="5.5s" repeatCount="indefinite"><mpath href="#bc-p-wf-cost"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-purple)" opacity="0.6">
      <animateMotion dur="4.2s" repeatCount="indefinite"><mpath href="#bc-p-doc-bi"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2" fill="var(--svg-accent-orange)" opacity="0.6">
      <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#bc-p-kb-comp"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-orange)" opacity="0.5">
      <animateMotion dur="4.8s" repeatCount="indefinite"><mpath href="#bc-p-kb-cost"/></animateMotion>
    </circle>
  </g>

  <!-- ═══ INNER NODES: ainative Product Entities ═══ -->

  <!-- Agents (top center — hero node) -->
  <g class="svg-reveal svg-reveal-d1" data-bc-node="ag">
    <circle class="bc-halo" cx="280" cy="149" r="32" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.15" stroke-width="0.5">
      <animate attributeName="r" values="32;35;32" dur="4s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.15;0.06;0.15" dur="4s" repeatCount="indefinite"/>
    </circle>
    <circle cx="280" cy="149" r="32" fill="url(#bc-sphere-blue)" stroke="var(--svg-accent-blue)" stroke-opacity="0.4" stroke-width="1.2" filter="url(#bc-glow)"/>
    <!-- Bot icon -->
    <g transform="translate(280,149) scale(1.6)">
      <rect x="-10" y="-4" width="20" height="14" rx="3.5" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1.1" vector-effect="non-scaling-stroke"/>
      <circle cx="-4" cy="3" r="1.8" fill="var(--svg-accent-blue)"/>
      <circle cx="4" cy="3" r="1.8" fill="var(--svg-accent-blue)"/>
      <line x1="0" y1="-4" x2="0" y2="-9" stroke="var(--svg-accent-blue)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <circle cx="0" cy="-10.5" r="1.3" fill="var(--svg-accent-blue)"/>
    </g>
    <!-- Label below circle -->
    <text x="280" y="192" text-anchor="middle" fill="var(--svg-accent-blue)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Agents</text>
  </g>

  <!-- Workflows (center-left) -->
  <g class="svg-reveal svg-reveal-d2" data-bc-node="wf">
    <circle class="bc-halo" cx="203" cy="215" r="26" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="203" cy="215" r="26" fill="url(#bc-sphere-teal)" stroke="var(--svg-accent-teal)" stroke-opacity="0.4" stroke-width="1"/>
    <!-- Fork/branch icon -->
    <g transform="translate(203,215) scale(1.3)">
      <path d="M-8,0 L0,0 L8,-6" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.2" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <path d="M0,0 L8,6" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.2" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <circle cx="8" cy="-6" r="1.5" fill="var(--svg-accent-teal)"/>
      <circle cx="8" cy="6" r="1.5" fill="var(--svg-accent-teal)"/>
      <circle cx="-8" cy="0" r="1.5" fill="var(--svg-accent-teal)"/>
    </g>
    <!-- Label below circle -->
    <text x="203" y="252" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Workflows</text>
  </g>

  <!-- Documents (center-right) -->
  <g class="svg-reveal svg-reveal-d3" data-bc-node="doc">
    <circle class="bc-halo" cx="357" cy="215" r="26" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="4.5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="4.5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="357" cy="215" r="26" fill="url(#bc-sphere-purple)" stroke="var(--svg-accent-purple)" stroke-opacity="0.4" stroke-width="1"/>
    <!-- Document icon -->
    <g transform="translate(357,215) scale(1.3)">
      <rect x="-6" y="-9" width="12" height="18" rx="1.5" fill="none" stroke="var(--svg-accent-purple)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="-4" x2="3" y2="-4" stroke="var(--svg-accent-purple)" stroke-width="0.8" stroke-opacity="0.6" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="0" x2="2" y2="0" stroke="var(--svg-accent-purple)" stroke-width="0.8" stroke-opacity="0.6" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="4" x2="0" y2="4" stroke="var(--svg-accent-purple)" stroke-width="0.8" stroke-opacity="0.6" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Label below circle -->
    <text x="357" y="252" text-anchor="middle" fill="var(--svg-accent-purple)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Documents</text>
  </g>

  <!-- Knowledge (bottom center) -->
  <g class="svg-reveal svg-reveal-d4" data-bc-node="kb">
    <circle class="bc-halo" cx="280" cy="281" r="26" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="5.5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="5.5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="280" cy="281" r="26" fill="url(#bc-sphere-orange)" stroke="var(--svg-accent-orange)" stroke-opacity="0.4" stroke-width="1"/>
    <!-- Lightbulb icon -->
    <g transform="translate(280,281) scale(1.3)">
      <circle cx="0" cy="-2" r="6" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="6" x2="3" y2="6" stroke="var(--svg-accent-orange)" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <line x1="-2" y1="8.5" x2="2" y2="8.5" stroke="var(--svg-accent-orange)" stroke-width="0.8" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Label below circle -->
    <text x="280" y="318" text-anchor="middle" fill="var(--svg-accent-orange)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Knowledge</text>
  </g>

  <!-- ═══ OUTER NODES: Business Outcomes ═══ -->

  <!-- Revenue Growth (top-left, r=25) -->
  <g class="svg-reveal svg-reveal-d5" data-bc-node="rev">
    <circle class="bc-halo bc-outer-halo" cx="115" cy="65" r="25" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="25;28;25" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="115" cy="65" r="25" fill="url(#bc-sphere-blue)" stroke="var(--svg-accent-blue)" stroke-opacity="0.4" stroke-width="0.8" filter="url(#bc-glow-soft)"/>
    <!-- Trending up icon -->
    <g transform="translate(115,65) scale(1.25)">
      <path d="M-9,5 L-3,-3 L3,1 L9,-7" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
      <path d="M5,-7 L9,-7 L9,-3" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="115" y="101" text-anchor="middle" fill="var(--svg-accent-blue)" font-size="7.5" font-family="var(--font-body)">Revenue</text>
    <text x="115" y="110" text-anchor="middle" fill="var(--svg-accent-blue)" font-size="6" font-family="var(--font-body)">Growth</text>
  </g>

  <!-- Customer Success (top-right, r=21) -->
  <g class="svg-reveal svg-reveal-d5" data-bc-node="cus">
    <circle class="bc-halo bc-outer-halo" cx="445" cy="70" r="21" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="21;24;21" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="445" cy="70" r="21" fill="url(#bc-sphere-teal)" stroke="var(--svg-accent-teal)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Checkmark icon -->
    <g transform="translate(445,70) scale(1.05)">
      <path d="M-7,0 L-2,5 L8,-6" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="445" y="102" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="7.5" font-family="var(--font-body)">Customer</text>
    <text x="445" y="111" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="6" font-family="var(--font-body)">Success</text>
  </g>

  <!-- Operations Excellence (left, r=19) -->
  <g class="svg-reveal svg-reveal-d6" data-bc-node="ops">
    <circle class="bc-halo bc-outer-halo" cx="70" cy="190" r="19" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="19;22;19" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="70" cy="190" r="19" fill="url(#bc-sphere-teal)" stroke="var(--svg-accent-teal)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Gear icon -->
    <g transform="translate(70,190) scale(0.95)">
      <circle cx="0" cy="0" r="6.5" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <circle cx="0" cy="0" r="2.5" fill="var(--svg-accent-teal)" opacity="0.5"/>
    </g>
    <!-- Labels below circle -->
    <text x="70" y="220" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="7.5" font-family="var(--font-body)">Operations</text>
    <text x="70" y="229" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="6" font-family="var(--font-body)">Excellence</text>
  </g>

  <!-- Cost Efficiency (bottom-left, r=23) -->
  <g class="svg-reveal svg-reveal-d6" data-bc-node="cost">
    <circle class="bc-halo bc-outer-halo" cx="100" cy="320" r="23" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="23;26;23" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="100" cy="320" r="23" fill="url(#bc-sphere-orange)" stroke="var(--svg-accent-orange)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Down-trend icon -->
    <g transform="translate(100,320) scale(1.15)">
      <path d="M-9,-5 L-3,2 L3,-2 L9,7" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
      <path d="M5,7 L9,7 L9,3" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="100" y="354" text-anchor="middle" fill="var(--svg-accent-orange)" font-size="7.5" font-family="var(--font-body)">Cost</text>
    <text x="100" y="363" text-anchor="middle" fill="var(--svg-accent-orange)" font-size="6" font-family="var(--font-body)">Efficiency</text>
  </g>

  <!-- Business Intelligence (bottom-right, r=21) -->
  <g class="svg-reveal svg-reveal-d7" data-bc-node="bi">
    <circle class="bc-halo bc-outer-halo" cx="460" cy="325" r="21" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="21;24;21" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="460" cy="325" r="21" fill="url(#bc-sphere-purple)" stroke="var(--svg-accent-purple)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Bar chart icon -->
    <g transform="translate(460,325) scale(1.05)">
      <rect x="-8" y="0" width="4" height="8" rx="0.5" fill="var(--svg-accent-purple)" opacity="0.6"/>
      <rect x="-2" y="-4" width="4" height="12" rx="0.5" fill="var(--svg-accent-purple)" opacity="0.6"/>
      <rect x="4" y="-8" width="4" height="16" rx="0.5" fill="var(--svg-accent-purple)" opacity="0.6"/>
    </g>
    <!-- Labels below circle -->
    <text x="460" y="357" text-anchor="middle" fill="var(--svg-accent-purple)" font-size="7.5" font-family="var(--font-body)">Business</text>
    <text x="460" y="366" text-anchor="middle" fill="var(--svg-accent-purple)" font-size="6" font-family="var(--font-body)">Intelligence</text>
  </g>

  <!-- Compliance & Governance (right, r=25) -->
  <g class="svg-reveal svg-reveal-d7" data-bc-node="comp">
    <circle class="bc-halo bc-outer-halo" cx="490" cy="195" r="25" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="25;28;25" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="490" cy="195" r="25" fill="url(#bc-sphere-purple)" stroke="var(--svg-accent-purple)" stroke-opacity="0.4" stroke-width="0.8" filter="url(#bc-glow-soft)"/>
    <!-- Shield with check icon -->
    <g transform="translate(490,195) scale(1.25)">
      <path d="M0,-9 L7,-5.5 L7,1.5 C7,6.5 0,10 0,10 C0,10 -7,6.5 -7,1.5 L-7,-5.5 Z" fill="none" stroke="var(--svg-accent-purple)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <path d="M-3,1.5 L-0.5,4 L4.5,-2" fill="none" stroke="var(--svg-accent-purple)" stroke-width="0.9" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="490" y="231" text-anchor="middle" fill="var(--svg-accent-purple)" font-size="7.5" font-family="var(--font-body)">Compliance</text>
    <text x="490" y="240" text-anchor="middle" fill="var(--svg-accent-purple)" font-size="6" font-family="var(--font-body)">&amp; Governance</text>
  </g>

  <!-- ═══ CENTER WATERMARK ═══ -->
  <!-- ═══ CENTER LOGO ═══ -->
  <image class="bc-watermark svg-reveal svg-reveal-d4" href="/ainative-s-128.png" x="256" y="191" width="48" height="48" opacity="0.45"/>
</svg>

<script>
  function initConstellationDrift() {
    const svg = document.querySelector('.bc');
    if (!svg) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (prefersReduced.matches) return;

    // Spring physics: continuous rubber-band drift
    const SPRING = 0.4;
    const FRICTION = 0.9;
    const INNER_IMPULSE = [8, 20];
    const OUTER_IMPULSE = [16, 36];

    const NODES = {
      ag:   { impulse: INNER_IMPULSE },
      wf:   { impulse: INNER_IMPULSE },
      doc:  { impulse: INNER_IMPULSE },
      kb:   { impulse: INNER_IMPULSE },
      rev:  { impulse: OUTER_IMPULSE },
      cus:  { impulse: OUTER_IMPULSE },
      ops:  { impulse: OUTER_IMPULSE },
      cost: { impulse: OUTER_IMPULSE },
      bi:   { impulse: OUTER_IMPULSE },
      comp: { impulse: OUTER_IMPULSE },
    };

    function rand(min, max) {
      return min + Math.random() * (max - min);
    }

    // Build node states with initial velocity so motion starts immediately
    const nodeStates = new Map();
    const now = performance.now();
    svg.querySelectorAll('[data-bc-node]').forEach(el => {
      const id = el.dataset.bcNode;
      const cfg = NODES[id];
      if (!cfg) return;
      const angle = Math.random() * Math.PI * 2;
      const v0 = rand(cfg.impulse[0], cfg.impulse[1]) * 0.4;
      nodeStates.set(id, {
        el,
        dx: 0, dy: 0,
        vx: Math.cos(angle) * v0,
        vy: Math.sin(angle) * v0,
        impulse: cfg.impulse,
        nextImpulse: now + rand(2000, 5000),
      });
    });

    // Parse bezier connection originals
    const pathRe = /M([\d.-]+),([\d.-]+)\s*Q([\d.-]+),([\d.-]+)\s*([\d.-]+),([\d.-]+)/;
    const connPaths = [];
    svg.querySelectorAll('[data-bc-conn]').forEach(el => {
      const [src, tgt] = el.dataset.bcConn.split('-');
      const m = el.getAttribute('d').match(pathRe);
      if (!m) return;
      connPaths.push({
        el, src, tgt,
        sx: +m[1], sy: +m[2], cx: +m[3], cy: +m[4], ex: +m[5], ey: +m[6],
      });
    });

    // Parse line connection originals
    const connLines = [];
    svg.querySelectorAll('[data-bc-line]').forEach(el => {
      const [src, tgt] = el.dataset.bcLine.split('-');
      connLines.push({
        el, src, tgt,
        x1: +el.getAttribute('x1'), y1: +el.getAttribute('y1'),
        x2: +el.getAttribute('x2'), y2: +el.getAttribute('y2'),
      });
    });

    let prevTs = now;
    let rafId;

    function tick(ts) {
      const dt = Math.min(ts - prevTs, 32) / 1000;
      prevTs = ts;

      nodeStates.forEach(state => {
        // Spring: rubber-band pull toward origin
        state.vx -= state.dx * SPRING * dt;
        state.vy -= state.dy * SPRING * dt;

        // Damping: smooth continuous motion
        const damp = Math.exp(-FRICTION * dt);
        state.vx *= damp;
        state.vy *= damp;

        // Random impulse: gentle nudge in new direction
        if (ts >= state.nextImpulse) {
          const angle = Math.random() * Math.PI * 2;
          const mag = rand(state.impulse[0], state.impulse[1]);
          state.vx += Math.cos(angle) * mag;
          state.vy += Math.sin(angle) * mag;
          state.nextImpulse = ts + rand(3000, 7000);
        }

        // Integrate position
        state.dx += state.vx * dt;
        state.dy += state.vy * dt;

        state.el.style.transform = `translate(${state.dx}px,${state.dy}px)`;
      });

      // Update bezier connections
      for (const c of connPaths) {
        const s = nodeStates.get(c.src);
        const t = nodeStates.get(c.tgt);
        const sdx = s ? s.dx : 0, sdy = s ? s.dy : 0;
        const tdx = t ? t.dx : 0, tdy = t ? t.dy : 0;
        const adx = (sdx + tdx) / 2, ady = (sdy + tdy) / 2;
        c.el.setAttribute('d',
          `M${c.sx + sdx},${c.sy + sdy} Q${c.cx + adx},${c.cy + ady} ${c.ex + tdx},${c.ey + tdy}`
        );
      }

      // Update line connections
      for (const c of connLines) {
        const s = nodeStates.get(c.src);
        const t = nodeStates.get(c.tgt);
        const sdx = s ? s.dx : 0, sdy = s ? s.dy : 0;
        const tdx = t ? t.dx : 0, tdy = t ? t.dy : 0;
        c.el.setAttribute('x1', c.x1 + sdx);
        c.el.setAttribute('y1', c.y1 + sdy);
        c.el.setAttribute('x2', c.x2 + tdx);
        c.el.setAttribute('y2', c.y2 + tdy);
      }

      rafId = requestAnimationFrame(tick);
    }

    // Wait for reveal entrance animations to finish, then disable
    // transform transitions so JS can drive transforms directly
    setTimeout(() => {
      nodeStates.forEach(s => { s.el.style.transition = 'opacity 0.5s ease'; });
      prevTs = performance.now();
      rafId = requestAnimationFrame(tick);
    }, 1500);

    // Cleanup
    function stop() {
      cancelAnimationFrame(rafId);
      nodeStates.forEach(s => { s.el.style.transform = ''; });
    }

    document.addEventListener('astro:before-swap', stop, { once: true });

    prefersReduced.addEventListener('change', (e) => {
      if (e.matches) {
        stop();
      } else {
        prevTs = performance.now();
        nodeStates.forEach(s => {
          s.dx = 0; s.dy = 0; s.vx = 0; s.vy = 0;
          s.nextImpulse = prevTs + rand(500, 2000);
        });
        rafId = requestAnimationFrame(tick);
      }
    });
  }

  initConstellationDrift();
</script>
