---
import SectionLabel from '../ui/SectionLabel.astro';

const personas = [
  {
    title: 'Solo Founder',
    tagline: 'Run your business with AI agents',
    items: [
      'Marketing, sales, and support agents working proactively',
      'Chat with your business from Slack or Telegram',
      'See everything on one governed dashboard',
      'Heartbeat scheduling keeps agents running overnight',
    ],
    cta: {
      primary: { icon: 'compass', label: 'Read the case study', href: '/research/solo-builder-case-study/' },
      secondary: [
        { icon: 'book-open', label: 'Free book', href: '/book/' },
        { icon: 'github', label: 'Source', href: 'https://github.com/manavsehgal/ainative', external: true },
      ],
    },
  },
  {
    title: 'Agency Owner',
    tagline: 'Deploy AI operations for every client',
    items: [
      'Reusable profiles and workflow blueprints',
      'Multi-project portfolio management',
      'Cost tracking per client engagement',
      'Import and customize agent skills from repos',
    ],
    cta: {
      primary: { icon: 'book-open-text', label: 'Browse the docs', href: '/docs/' },
      secondary: [
        { icon: 'braces', label: 'API reference', href: '/docs/api/' },
        { icon: 'github', label: 'Source', href: 'https://github.com/manavsehgal/ainative', external: true },
      ],
    },
    highlight: true,
  },
  {
    title: 'PE Operating Partner',
    tagline: 'Transform portfolio companies at scale',
    items: [
      'Standardized AI playbooks across companies',
      'Governed execution with audit trails',
      'EBITDA-trackable agent ROI',
    ],
    roadmapItems: [
      'Portfolio-wide dashboards',
    ],
    cta: {
      primary: { icon: 'microscope', label: 'Read the research', href: '/research/ai-transformation/' },
      secondary: [
        { icon: 'book-open', label: 'Free book', href: '/book/' },
        { icon: 'book-open-text', label: 'How it works', href: '/docs/' },
      ],
    },
  },
];

const iconPaths: Record<string, string> = {
  compass: '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  'book-open': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  'book-open-text': '<path d="M12 7v14"/><path d="M16 12h2"/><path d="M16 8h2"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/><path d="M6 8h2"/><path d="M6 12h2"/>',
  braces: '<path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"/><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"/>',
  microscope: '<path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/>',
};

const platformFeatures = [
  '5 AI runtimes',
  '21+ agent profiles',
  '6 workflow patterns',
  'Human-in-the-loop',
  'Cost metering',
  '100% free',
];
---
<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <SectionLabel text="The Solution" />
      <h2 data-animate class="mt-4 mb-4"><code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">ainative-business</code> in practice.</h2>
      <p data-animate class="text-text-muted max-w-2xl mx-auto" style="transition-delay: 80ms">
        Whether you're building solo, running an agency, or transforming a portfolio — <code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">ainative-business</code> gives you the operating system to make AI agents work for your business.
      </p>
    </div>

    <!-- Persona lanes -->
    <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {personas.map(({ title, tagline, items, roadmapItems, cta, highlight }) => (
        <div
          data-animate
          class:list={[
            'rounded-xl border p-6 flex flex-col',
            highlight ? 'border-primary/40 bg-primary/[0.03]' : 'border-border bg-surface-raised',
          ]}
        >
          <div class="mb-4">
            <h3 class="text-lg font-semibold mb-1">{title}</h3>
            <p class="text-sm text-primary font-mono">{tagline}</p>
          </div>

          <ul class="space-y-3">
            {items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {item}
              </li>
            ))}
            {roadmapItems?.map((item) => (
              <li class="flex items-start gap-2 text-sm text-text-muted/60">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted/40 shrink-0 mt-0.5">
                  <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                </svg>
                <span>{item} <span class="text-xs font-mono text-text-muted/40">roadmap</span></span>
              </li>
            ))}
          </ul>

          <div class:list={['mt-auto pt-5 border-t', highlight ? 'border-primary/15' : 'border-border/60']}>
            <a
              href={cta.primary.href}
              class:list={[
                'inline-flex items-center justify-between gap-2 w-full font-mono text-xs uppercase tracking-[0.15em] transition-all',
                highlight
                  ? 'bg-primary text-surface px-4 py-2.5 rounded-md hover:bg-primary/90'
                  : 'text-primary hover:gap-3',
              ]}
            >
              <span class="inline-flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[cta.primary.icon] ?? ''} />
                {cta.primary.label}
              </span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>

            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4">
              {cta.secondary.map(({ icon, label, href, external }) => (
                <a
                  href={href}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                  class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.12em] text-text-muted hover:text-primary transition-colors"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[icon] ?? ''} />
                  {label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Shared platform layer -->
    <div data-animate class="flex items-center justify-center gap-3 flex-wrap">
      {platformFeatures.map((feature) => (
        <span class="font-mono text-[11px] tracking-wider text-text-muted border border-border rounded-full px-3 py-1">
          {feature}
        </span>
      ))}
    </div>
  </div>
</section>
