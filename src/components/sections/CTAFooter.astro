---
import AmberRule from '../ui/AmberRule.astro';
import WaitlistForm from '../ui/WaitlistForm.astro';
---
<section class="py-32 px-6">
  <div id="waitlist" class="scroll-mt-24">
    <AmberRule />
  </div>

  <div class="max-w-3xl mx-auto text-center">
    <p data-animate class="font-mono text-xs tracking-widest text-text-muted uppercase mb-6">
      AI Native Business
    </p>

    <h2 data-animate class="mb-6" style="transition-delay: 80ms">Curious about AI-native organizations?</h2>

    <p data-animate class="text-text-muted mb-10 max-w-lg mx-auto" style="transition-delay: 160ms">
      Read the book and follow the research.
    </p>

    <div data-animate class="max-w-md mx-auto mb-10" style="transition-delay: 200ms">
      <WaitlistForm
        variant="cta"
        id="cta-footer-waitlist"
        source="research-newsletter"
        buttonText="Subscribe"
      />
    </div>

    <div data-animate-stagger class="flex flex-col sm:flex-row items-center justify-center gap-4" style="transition-delay: 280ms">
      <a
        data-animate
        href="https://github.com/manavsehgal/ainative"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-8 py-3 hover:border-text-muted transition-colors rounded-md"
      >
        GitHub
      </a>
      <a
        data-animate
        href="/docs/"
        class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-8 py-3 hover:border-text-muted transition-colors rounded-md"
      >
        Documentation
      </a>
      <a
        data-animate
        href="/research/"
        class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-8 py-3 hover:border-text-muted transition-colors rounded-md"
      >
        Research
      </a>
    </div>

    <!-- Terminal CTA -->
    <p data-animate class="font-mono text-[10px] tracking-[0.2em] uppercase text-text-muted mt-10 mb-2">
      Try the companion software
    </p>
    <div data-animate class="max-w-sm mx-auto">
      <div class="relative border border-primary/30 rounded-lg primary-pulse overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2 border-b border-primary/10">
          <span class="font-mono text-[10px] uppercase tracking-widest text-text-muted">Terminal</span>
          <button
            id="footer-copy-btn"
            class="p-1 rounded text-text-muted/50 hover:text-text-muted transition-colors"
            aria-label="Copy to clipboard"
          >
            <svg id="footer-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <svg id="footer-check-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </button>
        </div>
        <div class="bg-surface-raised px-4 py-3">
          <pre class="font-mono text-lg sm:text-xl leading-relaxed text-text-muted"><span class="text-primary">$</span> <code id="footer-code">npx ainative</code><span class="hero-cursor">▌</span></pre>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initFooterCopy() {
    document.getElementById('footer-copy-btn')?.addEventListener('click', async () => {
      const code = document.getElementById('footer-code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      const copyIcon = document.getElementById('footer-copy-icon');
      const checkIcon = document.getElementById('footer-check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    });
  }

  initFooterCopy();
  document.addEventListener('astro:after-swap', initFooterCopy);
</script>
