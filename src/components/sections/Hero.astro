---
import TechTicker from './TechTicker.astro';

// Hero lands on the flagship product: Orionfold Arena. The primary CTA hands
// off to the parent storefront (orionfold.com/software/arena/) for the founding
// license; the secondary CTA keeps the free demo on this site. First convergence
// step toward orionfold.com after the shared design system. The Field Notes
// newsletter form moved out of the hero — re-place it in a dedicated section.
const ARENA_STORE = 'https://orionfold.com/software/arena/';
---
<section class="relative min-h-[calc(100dvh-80px)] flex items-start px-6 overflow-x-clip pt-[182px] pb-20">
  <!-- Dual atmospheric glow -->
  <div class="absolute inset-0 -z-10 flex items-center justify-center pointer-events-none">
    <div class="absolute w-[800px] h-[800px] rounded-full bg-primary/[0.10] blur-[180px]"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-primary/[0.15] blur-[100px]"></div>
    <div class="absolute right-[4%] top-[18%] w-[420px] h-[420px] rounded-full bg-[oklch(0.70_0.14_82/0.10)] blur-[120px]"></div>
  </div>

  <!-- Bottom gradient fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-40 pointer-events-none" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>

  <!-- Two-column grid — balanced text vs. product shot -->
  <div class="relative z-10 w-full max-w-7xl mx-auto grid lg:grid-cols-[1fr_1.05fr] gap-8 lg:gap-12 items-center py-16 lg:py-4">

    <!-- Left column: Content -->
    <div class="text-center lg:text-left" data-animate-stagger>

      <!-- Brand eyebrow -->
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-primary mb-3">
        AI Native Business · Companion cockpit
      </p>

      <h1
        class="hero-gradient-text font-display text-[clamp(1.9rem,3.6vw,2.9rem)] font-bold leading-[1.1] mb-4"
      >
        Run, compare, and score AI models locally.
      </h1>

      <p
        class="text-[clamp(0.9rem,1.8vw,1.1rem)] text-text-muted leading-relaxed mb-7 mx-auto lg:mx-0 max-w-md"
      >
        <strong class="text-text font-semibold">Orionfold Arena</strong> is the local-LLM cockpit: live readouts, a
        private leaderboard, side-by-side compare, and an overnight jobs loop.
      </p>

      <!-- Primary CTAs — storefront handoff + local demo -->
      <div data-animate class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center lg:justify-start gap-3 max-w-sm sm:max-w-none mx-auto lg:mx-0 mb-3">
        <a
          href={ARENA_STORE}
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 font-mono text-xs tracking-[0.12em] uppercase bg-primary text-surface px-6 py-3 rounded-md hover:shadow-[0_0_0_4px_var(--color-primary-glow)] transition-shadow"
        >
          Get Orionfold Arena
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M8 7h9v9"/></svg>
        </a>
        <a
          href="/arena/demo/"
          class="inline-flex items-center justify-center gap-2 font-mono text-xs tracking-[0.12em] uppercase text-primary border border-primary/30 px-6 py-3 rounded-md hover:bg-primary/10 transition-colors"
        >
          Try the live demo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Offer note — handoff to the parent storefront -->
      <p data-animate class="text-[11px] leading-relaxed text-text-muted mb-8 max-w-sm mx-auto lg:mx-0">
        <span class="text-primary">◆</span> Founding price <span class="text-text font-semibold">$349</span> for the first 25 licenses. Available on
        <a href={ARENA_STORE} rel="noopener" class="text-primary underline decoration-primary/40 underline-offset-2 hover:decoration-primary">Orionfold<span class="inline-block ml-0.5 align-text-top text-[9px]">↗</span></a>, our parent storefront.
      </p>

      <!-- Terminal — the free local path -->
      <p data-animate class="font-mono text-[10px] tracking-[0.2em] uppercase text-text-muted mb-2 max-w-sm mx-auto lg:mx-0">
        Or run it free, locally
      </p>
      <div data-animate class="max-w-sm mx-auto lg:mx-0">
        <div class="relative border border-primary/30 rounded-lg primary-pulse overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 border-b border-primary/10">
            <span class="font-mono text-[10px] uppercase tracking-widest text-text-muted">Terminal</span>
            <button
              id="hero-copy-btn"
              data-clipboard={`pip install fieldkit\nfieldkit arena up`}
              class="p-1 rounded text-text-muted/50 hover:text-text-muted transition-colors"
              aria-label="Copy to clipboard"
            >
              <svg id="hero-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg id="hero-check-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </button>
          </div>
          <div class="bg-surface-raised px-4 py-3">
            <pre class="font-mono text-sm sm:text-base leading-relaxed text-text-muted"><span class="text-primary">$</span> pip install fieldkit
<span class="text-primary">$</span> <code id="hero-code">fieldkit arena up</code><span class="hero-cursor">▌</span></pre>
          </div>
        </div>
      </div>

    </div>

    <!-- Right column: live Arena cockpit snapshot -->
    <a href="/arena/demo/" data-animate class="hero-shot block" style="transition-delay: 200ms" aria-label="Orionfold Arena: try the live cockpit demo">
      <div class="hero-shot__frame">
        <div class="hero-shot__bar">
          <span class="hero-shot__dot" style="background:#ff5f57"></span>
          <span class="hero-shot__dot" style="background:#febc2e"></span>
          <span class="hero-shot__dot" style="background:#28c840"></span>
          <span class="hero-shot__tab">orionfold arena · cockpit</span>
          <span class="hero-shot__live"><span class="hero-shot__livedot"></span>LIVE</span>
        </div>
        <div class="hero-shot__view">
          <img
            src="/products/orionfold-arena/screenshots/01-cockpit.png"
            alt="The Orionfold Arena cockpit: leaderboard, resident lane, and the live telemetry rail"
            width="2820" height="3072" loading="eager" decoding="async" fetchpriority="high"
          />
          <span class="hero-shot__sheen" aria-hidden="true"></span>
        </div>
      </div>
    </a>

  </div>

  <TechTicker />
</section>


<style>
  /* ── Gradient text ── */
  .hero-gradient-text {
    background: linear-gradient(135deg, oklch(0.78 0.12 230), var(--color-primary), oklch(0.58 0.18 280));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Blinking cursor ── */
  .hero-cursor {
    animation: hero-blink 1s step-end infinite;
    color: var(--color-primary);
  }
  @keyframes hero-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-cursor { animation: none; }
  }

  /* ── Arena cockpit snapshot ── */
  .hero-shot {
    position: relative;
    animation: hero-float 8s ease-in-out infinite;
  }
  .hero-shot::after {
    content: '';
    position: absolute;
    inset: -50px;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(ellipse at center, oklch(0.65 0.13 200 / 0.16) 0%, transparent 70%);
  }
  .hero-shot__frame {
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    overflow: hidden;
    background: var(--color-surface-raised);
    box-shadow: 0 30px 60px -24px rgb(0 0 0 / 0.55), 0 0 0 1px var(--color-primary-glow);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .hero-shot:hover .hero-shot__frame {
    transform: translateY(-4px);
    box-shadow: 0 42px 80px -24px rgb(0 0 0 / 0.65), 0 0 0 1px var(--color-primary);
  }
  .hero-shot__bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .hero-shot__dot { width: 0.6rem; height: 0.6rem; border-radius: 9999px; flex: none; }
  .hero-shot__tab {
    margin-left: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hero-shot__live {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    color: var(--color-primary);
    flex: none;
  }
  .hero-shot__livedot {
    width: 0.4rem; height: 0.4rem; border-radius: 9999px;
    background: var(--color-primary);
    animation: hero-live 2.2s ease-in-out infinite;
  }
  .hero-shot__view {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .hero-shot__view img { width: 100%; display: block; } /* taller than the view → reveals the cockpit top */
  .hero-shot__sheen {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg, transparent 38%, oklch(0.92 0.04 200 / 0.10) 50%, transparent 62%);
    transform: translateX(-130%);
    animation: hero-sheen 9s ease-in-out 2s infinite;
  }
  @keyframes hero-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  @keyframes hero-live { 0%, 100% { opacity: 1; box-shadow: 0 0 0 0 var(--color-primary-glow); } 50% { opacity: 0.45; box-shadow: 0 0 0 3px transparent; } }
  @keyframes hero-sheen { 0% { transform: translateX(-130%); } 30%, 100% { transform: translateX(130%); } }
  @media (prefers-reduced-motion: reduce) {
    .hero-shot { animation: none; }
    .hero-shot__livedot { animation: none; }
    .hero-shot__sheen { display: none; }
  }
</style>

<script>
  function initHeroCopy() {
    document.getElementById('hero-copy-btn')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const code = btn.dataset.clipboard ?? document.getElementById('hero-code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      const copyIcon = document.getElementById('hero-copy-icon');
      const checkIcon = document.getElementById('hero-check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    });
  }

  initHeroCopy();
  document.addEventListener('astro:after-swap', initHeroCopy);
</script>

