---
import SectionLabel from '../ui/SectionLabel.astro';
import { CHAPTERS, PARTS } from '../../lib/book/content';

const sharedOutcomes = [
  'Project-scoped execution',
  'Profiles + runtime overrides',
  'Workflow steps + schedules',
  'Inbox approvals + monitoring',
  'Budget guardrails + cost ledger',
  'Document context + outputs',
];

const featureRows = [
  {
    claude: 'Tools + permissions',
    openai: 'Approvals + dynamic tools',
    ainative: 'Unified inbox approvals',
    description:
      'Tool requests, user questions, and operator decisions land in one governed queue instead of splitting by provider.',
  },
  {
    claude: 'Sessions + project files',
    openai: 'Threads + conversation history',
    ainative: 'Resume with project context',
    description:
      'Tasks keep working directories, document context, and resumable runtime state so operators can restart work without losing the trail.',
  },
  {
    claude: 'MCP servers',
    openai: 'Auth + tool routing',
    ainative: 'Profile-backed runtime policy',
    description:
      'Reusable profiles carry instructions, allowed tools, MCP configuration, and runtime-specific overrides across both stacks.',
  },
  {
    claude: 'Streaming execution events',
    openai: 'Streamed agent events',
    ainative: 'One monitor surface',
    description:
      'Provider-labeled logs, task state, and approval history stay visible in a shared operational view.',
  },
  {
    claude: 'Usage snapshots',
    openai: 'Usage + approval events',
    ainative: 'Cross-runtime cost ledger',
    description:
      'Spend, token velocity, runtime share, and model concentration are tracked together so teams can compare real operator cost.',
  },
];

const launchedCapabilities = [
  { icon: 'M4 6h16M4 12h16M4 18h16', text: 'Shared provider runtime abstraction for tasks, schedules, workflows, task assist, and health checks.' },
  { icon: 'M5 12h14M12 5l7 7-7 7', text: 'OpenAI Codex App Server runtime with resumable threads, inbox approvals, monitoring, and provider-aware settings.' },
  { icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', text: 'Cross-provider profile compatibility with runtime declarations and provider-specific overrides.' },
  { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Usage metering ledger, spend guardrails, and a dedicated cross-runtime cost dashboard.' },
  { icon: 'M8 7v10M16 7v10M4 12h16', text: 'Fork/Join parallel workflows with 2–5 concurrent branches and a synthesis step.' },
  { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', text: 'Multi-agent swarm execution with Mayor→Workers→Refinery pattern and step-level retry.' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', text: 'Autonomous loop execution with four stop conditions: max iterations, time budget, human cancel, and agent-signaled completion.' },
  { icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', text: 'Agent self-improvement loops with explicit human approval.' },
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', text: 'Tool permission presets with layered risk tiers — read-only, git-safe, and full-auto.' },
  { icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10', text: 'Workflow context batching with batch approve/reject for learned context proposals.' },
  { icon: 'M10 21h7a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v11m0 5l4.879-4.879m0 0a3 3 0 104.243-4.242 3 3 0 00-4.243 4.242z', text: 'Unified detail view redesign across task, document, and workflow surfaces with bento grid layout.' },
  { icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', text: 'Built-in playbook with feature adoption tracking, guided journeys, and in-app documentation.' },
  { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', text: 'Conversational AI with tool catalog, @ mentions, multi-provider model selection, and bidirectional Slack/Telegram channels.' },
  { icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z', text: 'Environment scanner with health scoring, artifact discovery, and cross-project configuration comparison.' },
  { icon: 'M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z', text: `Interactive book reader with ${CHAPTERS.length} chapters across ${PARTS.length} parts, curated reading paths, customizable fonts and themes, and chapter regeneration pipeline.` },
  { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Heartbeat schedules with condition checklists, NLP intervals, active hours windowing, suppression logic, and per-firing cost controls.' },
  { icon: 'M13 10V3L4 14h7v7l9-11h-7z', text: 'Smart runtime router with content-based signals, profile affinity, and latency/cost/quality preference modes across 5 providers.' },
  { icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', text: 'Anthropic Direct API and OpenAI Direct API runtimes with streaming tool use, session resume, and budget enforcement.' },
  { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', text: 'Multi-channel delivery to Slack, Telegram, and webhooks with bidirectional chat and schedule integration.' },
  { icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', text: 'Ollama local runtime with model discovery, smart router integration, $0 cost tracking, and privacy-sensitive execution.' },
  { icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', text: 'Episodic agent memory with confidence decay, relevance-filtered retrieval, and operator review.' },
  { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', text: 'Browser automation with Chrome DevTools MCP (29 tools) and Playwright MCP (50+ tools) gated through the inbox approval flow.' },
  { icon: 'M3 10h18M3 14h18M3 18h18M3 6h18', text: 'Structured data tables with spreadsheet editing, computed columns, charts, workflow triggers, 12 agent tools, and CSV/XLSX/JSON export.' },
  { icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4', text: 'Database snapshots with atomic SQLite backup, configurable retention policies, and one-click restore with safety snapshots.' },
  { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Workflow step delays for drip sequences and cooldown windows — schedule-based resume that survives process restarts.' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', text: 'Bulk row enrichment — generate loop workflows that enrich every matching row in a table via agent execution, idempotent and resumable.' },
  { icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z', text: 'Skill composition — stack up to 3 skills per conversation with conflict detection, prompt-budget eviction, and runtime capability gating.' },
  { icon: 'M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2', text: 'Conversation templates — start chats from saved blueprints via hero button, /new-from-template, or the ⌘K Templates group.' },
  { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', text: 'Saved searches and filter namespace — #key:value grammar with pinned views surfaced in ⌘K palette and @ mention popover.' },
];

const roadmapNext = [
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', text: 'Instance upgrade session — guided in-app git merge with conflict resolution, AskUserQuestion prompts, and option cards for every clone-based user.' },
  { icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4', text: 'Direct runtime prompt caching and advanced capabilities — extended thinking, context compaction, and model selection.' },
  { icon: 'M10 21h7a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v11m0 5l4.879-4.879m0 0a3 3 0 104.243-4.242 3 3 0 00-4.243 4.242z', text: 'Workflow document pool — shared document context across workflow steps with automatic propagation and output collection.' },
  { icon: 'M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2', text: 'Chat conversation branches — fork conversations at any message to explore alternative paths without losing the original thread.' },
];
---
<section class="runtime-bridge relative overflow-hidden py-24 px-6 bg-surface-raised">
  <div class="runtime-bridge__glow runtime-bridge__glow--left" aria-hidden="true"></div>
  <div class="runtime-bridge__glow runtime-bridge__glow--right" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto">
    <div class="text-center max-w-4xl mx-auto mb-14">
      <SectionLabel text="Platforms" />
      <h2 data-animate class="mt-4 flex flex-col items-center gap-1">
        <span class="md:whitespace-nowrap">Already using Claude or Codex?</span>
        <span class="md:whitespace-nowrap">Keep the runtime. Add the ops layer.</span>
      </h2>
      <p data-animate class="text-text-muted mt-4 max-w-3xl mx-auto" style="transition-delay: 100ms">
        Claude Agent SDK and Codex App Server already provide state-of-the-art agent primitives. <code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">ainative-business</code> turns both into one governed execution surface for projects, profiles, workflows, schedules, approvals, monitoring, and cross-runtime spend visibility.
      </p>
      <p
        data-animate
        class="font-mono text-xs tracking-[0.16em] uppercase text-text-muted/90 mt-6"
        style="transition-delay: 180ms"
      >
        No migration tax. No single-provider bet. One operating model for both.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-[1fr_auto_1fr] items-center mb-10">
      <div data-animate class="runtime-brand runtime-brand--anthropic" style="transition-delay: 220ms">
        <div class="runtime-brand__logo runtime-brand__logo--anthropic" aria-hidden="true">
          <img
            src="/logos/anthropic-white.svg"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div>
          <p class="runtime-brand__title">Claude Agent SDK</p>
          <p class="runtime-brand__copy">Tools, permissions, MCP, sessions, and project-aware execution.</p>
        </div>
      </div>

      <div data-animate class="runtime-brand__bridge" style="transition-delay: 280ms" aria-hidden="true">
        <span></span>
        <div>Shared runtime layer</div>
        <span></span>
      </div>

      <div data-animate class="runtime-brand runtime-brand--openai" style="transition-delay: 340ms">
        <div class="runtime-brand__logo runtime-brand__logo--openai" aria-hidden="true">
          <img
            src="/logos/openai-white.svg"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div>
          <p class="runtime-brand__title">Codex App Server</p>
          <p class="runtime-brand__copy">Authentication, approvals, threads, event streams, and dynamic tool calls.</p>
        </div>
      </div>
    </div>

    <div data-animate-stagger class="flex flex-wrap justify-center gap-3 mb-12">
      {sharedOutcomes.map((outcome) => (
        <span
          data-animate
          class="shared-outcome font-mono text-[0.68rem] tracking-[0.16em] uppercase text-text-muted"
        >
          {outcome}
        </span>
      ))}
    </div>

    <figure data-animate class="runtime-shot img-reveal" style="transition-delay: 360ms">
      <div class="runtime-shot__frame">
        <img
          src="/screenshots/costs-list.png"
          alt="Cost and usage dashboard with budget pacing, spend metrics, runtime counts, and Anthropic/OpenAI pricing table"
          loading="lazy"
          decoding="async"
          class="w-full h-auto block"
        />
      </div>
    </figure>

    <div data-animate class="feature-map" style="transition-delay: 440ms">
        <div class="feature-map__header">
          <p class="feature-map__label">Feature map</p>
          <p class="feature-map__intro">
            <code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">ainative-business</code> does not replace either runtime. It standardizes how teams route, supervise, and measure work across both.
          </p>
        </div>

        <div class="feature-map__rows">
          {featureRows.map((row, index) => (
            <article class="feature-row" data-animate style={`transition-delay: ${420 + index * 90}ms`}>
              <div class="feature-row__platform feature-row__platform--anthropic">
                <p class="feature-row__vendor">Claude</p>
                <p class="feature-row__value">{row.claude}</p>
              </div>

              <div class="feature-row__center">
                <div class="feature-row__node" aria-hidden="true"></div>
                <div>
                  <h3 class="feature-row__title">{row.ainative}</h3>
                  <p class="feature-row__description">{row.description}</p>
                </div>
              </div>

              <div class="feature-row__platform feature-row__platform--openai">
                <p class="feature-row__vendor">Codex</p>
                <p class="feature-row__value">{row.openai}</p>
              </div>
            </article>
          ))}
        </div>
    </div>

    <div class="grid gap-4 mt-10">
      <article data-animate class="status-panel" style="transition-delay: 560ms">
        <p class="status-panel__label">Launched in <code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">ainative-business</code></p>
        <ul class="status-panel__list status-panel__list--2col">
          {launchedCapabilities.map(({ icon, text }) => (
            <li class="status-panel__item">
              <svg class="status-panel__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={icon} />
              </svg>
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </article>

      <article data-animate class="status-panel status-panel--roadmap" style="transition-delay: 620ms">
        <p class="status-panel__label">Roadmap next</p>
        <ul class="status-panel__list status-panel__list--2col">
          {roadmapNext.map(({ icon, text }) => (
            <li class="status-panel__item">
              <svg class="status-panel__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={icon} />
              </svg>
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .runtime-bridge__glow {
    position: absolute;
    width: 28rem;
    height: 28rem;
    border-radius: 999px;
    filter: blur(110px);
    opacity: 0.18;
    pointer-events: none;
  }

  .runtime-bridge__glow--left {
    top: -8rem;
    left: -8rem;
    background: color-mix(in oklab, var(--color-primary) 75%, transparent);
  }

  .runtime-bridge__glow--right {
    right: -10rem;
    bottom: -12rem;
    background: color-mix(in oklab, var(--color-success) 78%, transparent);
  }

  .runtime-brand {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1.1rem 1.15rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 85%, transparent);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--color-surface-overlay) 70%, transparent), color-mix(in oklab, var(--color-surface) 88%, transparent)),
      linear-gradient(135deg, color-mix(in oklab, var(--color-primary) 10%, transparent), transparent 58%);
    box-shadow: 0 24px 50px color-mix(in oklab, var(--color-surface) 84%, transparent);
  }

  .runtime-brand--openai {
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--color-surface-overlay) 70%, transparent), color-mix(in oklab, var(--color-surface) 88%, transparent)),
      linear-gradient(135deg, color-mix(in oklab, var(--color-success) 10%, transparent), transparent 58%);
  }

  .runtime-brand__logo {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    color: var(--color-text);
  }

  .runtime-brand__logo svg,
  .runtime-brand__logo img {
    display: block;
    width: auto;
    height: 1rem;
    max-width: 100%;
  }

  .runtime-brand__logo--anthropic img,
  .runtime-brand__logo--anthropic svg {
    height: 0.85rem;
  }

  .runtime-brand__logo--openai svg,
  .runtime-brand__logo--openai img {
    height: 1.65rem;
  }

  /* Invert white logos to black in light mode */
  :global(html[data-theme="light"]) .runtime-brand__logo img {
    filter: invert(1);
  }

  .runtime-brand__title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.45rem;
  }

  .runtime-brand__copy {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .runtime-brand__bridge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
    min-width: 8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .runtime-brand__bridge span {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .shared-outcome {
    padding: 0.8rem 0.95rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--color-border) 82%, transparent);
    background: color-mix(in oklab, var(--color-surface) 72%, transparent);
  }

  .feature-map {
    border: 1px solid color-mix(in oklab, var(--color-border) 82%, transparent);
    border-radius: 1.5rem;
    padding: 1.4rem;
    background:
      radial-gradient(circle at top left, color-mix(in oklab, var(--color-primary) 11%, transparent), transparent 35%),
      color-mix(in oklab, var(--color-surface) 86%, transparent);
    box-shadow: 0 28px 60px color-mix(in oklab, var(--color-surface) 86%, transparent);
  }

  .runtime-shot + .feature-map {
    margin-top: 2rem;
  }

  .feature-map__header {
    margin-bottom: 1.2rem;
  }

  .feature-map__label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .feature-map__intro {
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 42rem;
  }

  .feature-map__rows {
    display: grid;
    gap: 0.9rem;
  }

  .feature-row {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.24fr) minmax(0, 0.88fr);
    gap: 0.85rem;
    align-items: center;
  }

  .feature-row__platform,
  .feature-row__center {
    position: relative;
    border: 1px solid color-mix(in oklab, var(--color-border) 82%, transparent);
    border-radius: 1.15rem;
    min-height: 100%;
  }

  .feature-row__platform {
    padding: 0.85rem 0.9rem;
    background: color-mix(in oklab, var(--color-surface-raised) 70%, transparent);
  }

  .feature-row__center {
