---
import SectionLabel from '../ui/SectionLabel.astro';

const stats = [
  {
    value: '38',
    label: 'Product Surfaces',
    detail: 'Home, dashboard, projects, workflows, documents, tables, inbox, monitor, profiles, schedules, costs, chat, environment, playbook, book, settings, and command palette.',
  },
  {
    value: '31',
    label: 'Workflow Blueprints',
    detail: '6 orchestration patterns (sequence, planner-executor, checkpoint, parallel, loop, swarm) with 13 pre-built templates across technical and business-function domains.',
  },
  {
    value: '5',
    label: 'Provider Runtimes',
    detail: 'Claude Code, OpenAI Codex, Anthropic Direct API, OpenAI Direct API, and Ollama local models — all behind one governed layer with smart routing.',
  },
  {
    value: 'Local-first',
    label: 'Operating Model',
    detail: 'SQLite-backed control plane, local files, and approvals that stay close to the work.',
  },
];
---
<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <SectionLabel text="Progress" />
      <h2 data-animate class="mt-4">Shipped, not slideware</h2>
    </div>

    <div data-animate-stagger class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
      {stats.map(({ value, label, detail }) => (
        <div data-animate class="of-surface rounded-xl p-6 text-center">
          <div class="text-2xl md:text-3xl font-bold text-primary font-mono">
            {value}
          </div>
          <div class="text-text-muted text-sm mt-2 font-mono tracking-widest uppercase">{label}</div>
          <p class="text-xs text-text-muted leading-relaxed mt-4">{detail}</p>
        </div>
      ))}
    </div>
    <div data-animate class="max-w-3xl mx-auto text-center">
      <p class="text-text-muted leading-relaxed">
        163 shipped features across 38 surfaces — every one of them free and unlimited. The product operates as a full coordination workspace with 21 technical and business-function agent profiles, 6 orchestration patterns with 13 blueprint templates, heartbeat and clock-driven schedules with orchestration guardrails, governed permissions with ambient approvals, document-linked execution, structured data tables with charts and bulk row enrichment, 5-provider cost governance with smart routing, conversational AI with skill composition, conversation templates, saved searches, @ mentions, slash commands, and bidirectional Slack/Telegram channels, environment scanning with health scoring, episodic agent memory, database snapshots, and a self-updating book reader.
      </p>
    </div>
  </div>
</section>
