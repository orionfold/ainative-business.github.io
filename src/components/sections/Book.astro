---
import SectionLabel from '../ui/SectionLabel.astro';
import { PARTS, CHAPTERS } from '../../lib/book/content';

const totalReadingTime = CHAPTERS.reduce((sum, ch) => sum + ch.readingTime, 0);
const totalWords = CHAPTERS.reduce((sum, ch) => sum + ch.wordCount, 0);
const totalPages = Math.ceil(totalWords / 250);

const quotes = [
  {
    text: 'I am confident that we are going to see the one-person billion-dollar company, enabled by AI agents.',
    author: 'Sam Altman',
    role: 'CEO, OpenAI',
  },
  {
    text: 'I put 70–80% odds on one-person unicorns happening in 2026.',
    author: 'Dario Amodei',
    role: 'CEO, Anthropic',
  },
];
---
<section class="py-24 px-6 relative overflow-hidden">
  <!-- Ambient glow behind cover -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute top-1/2 left-[20%] -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full bg-primary/[0.08] blur-[140px]"></div>
  </div>

  <div class="max-w-7xl mx-auto grid lg:grid-cols-[auto_1fr] gap-12 lg:gap-16 items-center">

    <!-- Left: Large book cover -->
    <a
      href="/book/"
      data-animate
      class="block mx-auto lg:mx-0 relative group"
      aria-label="Read AI Native Business"
    >
      <img
        src="/book/images/ai-native-business-book.png"
        alt="AI Native Business book cover"
        width="340"
        height="510"
        class="w-[260px] sm:w-[300px] lg:w-[340px] h-auto transition-transform duration-500 group-hover:scale-[1.02]"
        style="transform: perspective(900px) rotateY(-6deg) rotateX(2deg); filter: drop-shadow(-10px 16px 36px oklch(0.2 0.04 250 / 0.4)) drop-shadow(0 0 64px oklch(0.55 0.18 250 / 0.18));"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Right: Text + quotes -->
    <div class="text-center lg:text-left">
      <SectionLabel text="The Book" />
      <h2 data-animate class="mt-4 mb-4">AI Native Business</h2>
      <p data-animate class="text-text-muted text-lg leading-relaxed mb-5 max-w-2xl mx-auto lg:mx-0" style="transition-delay: 80ms">
        Building Autonomous Business Systems with AI Agents. Generated by <code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">ainative-business</code>'s own document-writer agent — a book written by the software it describes.
      </p>

      <!-- Metadata pills -->
      <div data-animate class="flex items-center gap-1.5 flex-wrap justify-center lg:justify-start mb-6" style="transition-delay: 120ms">
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">{CHAPTERS.length} Chapters</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">{PARTS.length} Parts</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">~{totalReadingTime} Min Read</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">{totalWords.toLocaleString()} Words</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">~{totalPages} Pages</span>
      </div>

      <!-- CTA -->
      <a
        href="/book/"
        data-animate
        class="inline-flex items-center gap-1.5 text-primary font-mono text-sm tracking-wider hover:underline mb-10"
        style="transition-delay: 160ms"
      >
        Start Reading
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Validation quotes -->
      <div data-animate-stagger class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8">
        {quotes.map(({ text, author, role }) => (
          <figure data-animate class="relative rounded-xl border border-border bg-surface-raised p-5 border-l-[3px] border-l-primary text-left">
            <span aria-hidden="true" class="absolute top-2 right-3 text-3xl text-primary/20 font-serif leading-none select-none">"</span>
            <blockquote class="text-sm text-text-muted italic leading-relaxed mb-3">{text}</blockquote>
            <figcaption class="text-xs font-mono text-text-muted/60">
              <span class="font-semibold text-text-muted">{author}</span> — {role}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

  </div>
</section>
