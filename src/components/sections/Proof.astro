---
import SectionLabel from '../ui/SectionLabel.astro';
import ArchitectureGlance from '../svg/ArchitectureGlance.astro';

const metrics = [
  { value: '148', label: 'Features Shipped' },
  { value: '38', label: 'Operator Surfaces' },
  { value: '6', label: 'AI Runtimes' },
  { value: '56+', label: 'Agent Profiles' },
  { value: '37', label: 'Workflow Patterns' },
];

const quotes = [
  {
    text: 'I am confident that we are going to see the one-person billion-dollar company, enabled by AI agents.',
    author: 'Sam Altman',
    role: 'CEO, OpenAI',
  },
  {
    text: 'I put 70–80% odds on one-person unicorns happening in 2026.',
    author: 'Dario Amodei',
    role: 'CEO, Anthropic',
  },
];
---
<section class="py-24 px-6 bg-surface-raised/50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <SectionLabel text="Proof" />
      <h2 data-animate class="mt-4 mb-4">Not Slideware. Shipped Software.</h2>
      <p data-animate class="text-text-muted" style="transition-delay: 80ms">
        Every feature below is live in the community edition and inspectable on GitHub.
      </p>
    </div>

    <!-- Metric bar -->
    <div data-animate-stagger class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-14">
      {metrics.map(({ value, label }) => (
        <div data-animate class="rounded-xl border border-primary/15 bg-primary/[0.04] p-5 text-center">
          <div class="text-2xl md:text-3xl font-bold text-primary font-mono">{value}</div>
          <div class="text-xs text-text-muted mt-1 font-mono tracking-wider uppercase">{label}</div>
        </div>
      ))}
    </div>

    <!-- Architecture at a glance -->
    <div data-animate class="rounded-xl border border-border/60 bg-surface-raised/50 p-6 md:p-8 mb-14">
      <ArchitectureGlance />
      <div class="mt-4 text-center">
        <a href="/research/#architecture" class="inline-flex items-center gap-1.5 text-primary font-mono text-xs tracking-wider hover:underline">
          See full architecture
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Living Book -->
    <div data-animate class="relative rounded-xl border border-primary/20 bg-gradient-to-br from-primary/[0.06] to-primary/[0.02] p-6 md:p-8 md:pl-[280px] mb-14 overflow-visible">
      <!-- Book cover: absolutely positioned to bleed -->
      <a href="/book/" class="hidden md:block absolute -top-32 bottom-8 left-8 z-10 w-[220px] translate-y-[50px]">
        <img
          src="/book/images/ai-native-book-manav-sehgal.png"
          alt="AI Native Business book cover"
          width="220"
          height="330"
          class="w-full h-full object-contain"
          style="transform: perspective(800px) rotateY(-4deg) rotateX(1deg); filter: drop-shadow(-6px 10px 24px oklch(0.2 0.04 250 / 0.35)) drop-shadow(0 0 48px oklch(0.55 0.18 250 / 0.12));"
          loading="lazy"
          decoding="async"
        />
      </a>
      <!-- Mobile: inline cover -->
      <a href="/book/" class="md:hidden flex justify-center mb-6">
        <img
          src="/book/images/ai-native-book-manav-sehgal.png"
          alt="AI Native Business book cover"
          width="160"
          height="240"
          class="w-[160px] h-auto"
          style="filter: drop-shadow(-6px 10px 24px oklch(0.2 0.04 250 / 0.35));"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-success mb-2">Free Online Book</p>
      <h3 class="text-xl font-bold mb-1">AI Native Business</h3>
      <p class="text-text-muted leading-relaxed mb-3">
        Building Autonomous Business Systems with AI Agents.
        Generated by Stagent's own document-writer agent — a book written by the software it describes.
      </p>
      <div class="flex items-center gap-1.5 flex-wrap mb-4">
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">13 Chapters</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">4 Parts</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">~182 Min Read</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">~151 Pages</span>
      </div>
      <a href="/book/" class="inline-flex items-center gap-1.5 text-primary font-mono text-xs tracking-wider hover:underline">
        Start Reading
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Market validation quotes -->
    <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
      {quotes.map(({ text, author, role }) => (
        <div data-animate class="rounded-xl border border-border bg-surface-raised p-6 border-l-[3px] border-l-primary">
          <p class="text-sm text-text-muted italic leading-relaxed mb-3">"{text}"</p>
          <p class="text-xs font-mono text-text-muted/60">
            <span class="font-semibold text-text-muted">{author}</span> — {role}
          </p>
        </div>
      ))}
    </div>

    <!-- Community edition trust -->
    <p data-animate class="text-center text-xs text-text-muted/60 font-mono">
      Community edition under Apache 2.0 · Every line inspectable on GitHub · Local-first — your data never leaves your machine
    </p>
  </div>
</section>
