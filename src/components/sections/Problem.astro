---
import SectionLabel from '../ui/SectionLabel.astro';

const stats = [
  { value: '$52.6B', label: 'AI agent market by 2030', source: '46% CAGR' },
  { value: '36.3%', label: 'of new startups are solo-founded', source: 'Carta' },
  { value: '1,445%', label: 'surge in agentic AI inquiries', source: 'Gartner' },
];

const gaps = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 12H8M12 16V8"/></svg>`,
    title: 'Orchestration',
    description: 'Agents that work together, not in silos',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Visibility',
    description: 'See what\'s running, what it costs, what needs attention',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Governance',
    description: 'Human oversight without slowing agents down',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>`,
    title: 'Lifecycle',
    description: 'Plan, build, operate, and grow in one place',
  },
];
---
<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <SectionLabel text="The Problem" />
      <h2 data-animate class="mt-4 mb-4">The Missing Layer in Your AI Stack</h2>
      <p data-animate class="text-text-muted max-w-2xl mx-auto leading-relaxed" style="transition-delay: 80ms">
        AI models are powerful. Agent frameworks are maturing. But between "run this agent" and "run my business" — there's a gap no one has filled.
      </p>
    </div>

    <!-- Opportunity stats -->
    <div data-animate-stagger class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      {stats.map(({ value, label, source }) => (
        <div data-animate class="rounded-xl border border-primary/20 bg-primary/[0.04] p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-primary font-mono">{value}</div>
          <div class="text-sm text-text-muted mt-2">{label}</div>
          <div class="text-xs text-text-muted/60 mt-1 font-mono">{source}</div>
        </div>
      ))}
    </div>

    <!-- Bridge -->
    <p data-animate class="text-text-muted text-center max-w-2xl mx-auto mb-10 leading-relaxed">
      The demand is real. But most founders still stitch together 8–15 disconnected tools — one for chat, another for scheduling, another for cost tracking. No shared context. No unified governance. No single place to see what all your agents are doing.
    </p>

    <!-- Capability gaps -->
    <div data-animate-stagger class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      {gaps.map(({ icon, title, description }) => (
        <div data-animate class="rounded-xl border border-border bg-surface-raised p-5 text-center">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary mb-3" set:html={icon} />
          <div class="font-semibold text-sm mb-1">{title}</div>
          <p class="text-xs text-text-muted leading-relaxed">{description}</p>
        </div>
      ))}
    </div>

    <!-- Transition -->
    <p data-animate class="text-center text-primary font-semibold text-sm">
      That's what ainative builds.
    </p>
  </div>
</section>
