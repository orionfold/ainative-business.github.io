---

<div class="absolute bottom-8 left-0 right-0 z-10 overflow-hidden ticker-fade-mask pb-4">
  <div class="ticker-track" aria-label="The Orionfold Arena stack">
    {/* Two identical halves — each with pr-12 so the seam gap matches internal gap */}
    {[0, 1].map((i) => (
      <div class="ticker-half" aria-hidden={i === 1 ? 'true' : undefined}>
        {groups.map((group, gi) => (
          <>
            {gi > 0 && <div class="w-px h-6 bg-border shrink-0" />}
            <span class="font-mono text-[14px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-3 py-1 shrink-0 select-none">
              {group.label}
            </span>
            {group.items.map((item) => (
              <div class="flex items-center gap-2 shrink-0 select-none">
                {item.path && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-text-dim shrink-0" aria-hidden="true">
                    <path d={item.path} />
                  </svg>
                )}
                <span class="text-[16px] text-text-dim font-body whitespace-nowrap">{item.name}</span>
              </div>
            ))}
          </>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .ticker-fade-mask {
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll 40s linear infinite;
    will-change: transform;
  }

  /* Each half is identical: same content + same padding-right.
     Because both halves have equal pixel width, translateX(-50%)
     lands exactly at the start of the second half → seamless loop. */
  .ticker-half {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding-right: 3rem;
    flex-shrink: 0;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation-play-state: paused;
    }
  }
</style>
