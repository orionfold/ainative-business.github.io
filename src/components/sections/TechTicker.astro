  { label: 'HARDWARE',   items: [{ name: 'NVIDIA DGX Spark', path: ICON.nvidia }, { name: 'CUDA' }] },
  { label: 'SERVING',    items: [{ name: 'llama.cpp' }, { name: 'vLLM' }, { name: 'NVIDIA NIM' }, { name: 'Ollama', path: ICON.ollama }] },
  { label: 'MODELS',     items: [{ name: 'Hugging Face', path: ICON.huggingface }, { name: 'GGUF' }] },
  { label: 'CORE',       items: [{ name: 'Python', path: ICON.python }, { name: 'FastAPI', path: ICON.fastapi }, { name: 'Astro', path: ICON.astro }] },
