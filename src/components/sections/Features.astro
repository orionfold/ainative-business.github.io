---
import SectionLabel from '../ui/SectionLabel.astro';
import BrowserFrame from '../ui/BrowserFrame.astro';

const features = [
  {
    title: 'Workspace Overview',
    description: 'Open ainative-business to a concise operational brief: running tasks, pending approvals, active projects, and live agent activity in one place.',
    bullets: ['Needs-attention queue', 'Workspace-level metrics', 'Live agent activity panel'],
    screenshot: '/screenshots/home-list.png',
    alt: 'Home workspace showing summary metrics, tasks needing attention, and live activity',
  },
  {
    title: 'Execution Dashboard',
    description: 'Run the day-to-day queue from a status board that keeps planned, queued, running, completed, and failed work visible across projects.',
    bullets: ['Project and status filters', 'Column-based execution states', 'Inline task creation'],
    screenshot: '/screenshots/tasks-list.png',
    alt: 'Dashboard board showing tasks organized by status across multiple projects',
  },
  {
    title: 'AI-Assisted Creation',
    description: 'Describe what you need and let AI Assist generate sub-tasks, refine descriptions, or scaffold a full workflow — all inside the task creation form.',
    bullets: ['AI-generated sub-task suggestions', 'One-click apply to task description', 'Promote AI steps to reusable workflows'],
    screenshot: '/screenshots/tasks-create-form-ai-assist.png',
    alt: 'AI Assist panel with improved description, sub-task suggestions, and Create as Workflow option',
  },
  {
    title: 'Project Portfolio',
    description: 'Track parallel initiatives as projects with clean summaries, attached context, and a dedicated execution view for each body of work.',
    bullets: ['Portfolio card list', 'Status-aware progress', 'Scoped work context'],
    screenshot: '/screenshots/projects-list.png',
    alt: 'Projects portfolio with total projects, active count, linked tasks, and project cards',
  },
  {
    title: 'Project Detail',
    description: 'Drill into a project to see task distribution, recent completions, and the exact queue that is driving the initiative forward.',
    bullets: ['Status summary cards', 'Completion trend strip', 'Project-scoped task list'],
    screenshot: '/screenshots/projects-detail.png',
    alt: 'Project detail with status breakdown cards, progress strip, and scoped task list',
  },
  {
    title: 'Workflow Library',
    description: 'Manage multi-step workflows with clear lifecycle state, pattern labels, and reusable orchestration for repeated operational jobs.',
    bullets: ['Sequence, parallel, swarm, and checkpoint patterns', 'Project-aware workflow records', 'Pause, resume, and duplicate controls'],
    screenshot: '/screenshots/workflows-list.png',
    alt: 'Workflows library with pattern labels, status badges, and All/Templates/Runs tabs',
  },
  {
    title: 'Blueprint Catalog',
    description: 'Start from preconfigured blueprints for code review, research, planning, documentation, and personal workflows instead of creating flows from scratch.',
    bullets: ['Work and personal templates', 'Difficulty labels', 'Search and filter controls'],
    screenshot: '/screenshots/workflows-blueprints.png',
    alt: 'Blueprint gallery with 12 template cards, domain tabs, and Create Custom button',
  },
  {
    title: 'Document Operations',
    description: 'Store uploaded files in searchable table and grid views, then inspect extracted content and project/task links without leaving the workspace.',
    bullets: ['Table and grid browsing', 'Extraction status visibility', 'Linked task and project metadata'],
    screenshot: '/screenshots/documents-list.png',
    alt: 'Documents table view with files, sizes, directions, linked tasks, and status columns',
  },
  {
    title: 'Agent Profiles',
    description: 'Profiles make agent behavior explicit through instructions, tool policies, output formats, and tuning controls that operators can inspect and reuse.',
    bullets: ['Technical and business-function specialists', 'Auto-detect routing per task', 'Cross-provider support across 5 runtimes'],
    screenshot: '/screenshots/profiles-detail.png',
    alt: 'Code Reviewer profile detail with identity, configuration, runtime coverage, tools and policy',
  },
  {
    title: 'Scheduled Runs',
    description: 'Turn repeatable prompts into clock-driven or heartbeat schedules. Heartbeat mode evaluates conditions before acting, suppressing no-op runs when nothing needs attention.',
    bullets: ['Clock-driven and heartbeat modes', 'Natural language intervals', 'Delivery channel notifications'],
    screenshot: '/screenshots/schedules-detail.png',
    alt: 'Prospect Pipeline Pulse schedule detail with firings count, next fire time, and prompt',
  },
  {
    title: 'Human Oversight',
    description: 'The inbox surfaces agent messages, completions, failures, and permission requests with direct approval actions for governed execution.',
    bullets: ['Allow once / always allow / deny', 'Unread, permission, and message tabs', 'Decision history'],
    screenshot: '/screenshots/inbox-expanded.png',
    alt: 'Governance command center Permissions tab with responded Write and SendEmail tool requests',
  },
  {
    title: 'Live Monitoring',
    description: 'Follow live execution through log streaming, active-agent metrics, success-rate signals, and task/event filters built for debugging and oversight.',
    bullets: ['Auto-refreshing log stream', 'Workspace health cards', 'Task and event filtering'],
    screenshot: '/screenshots/monitor-list.png',
    alt: 'Monitor showing active agents, success rate, tasks today, and streaming log panel',
  },
  {
    title: 'Cost & Usage',
    description: 'Track spend, token velocity, runtime share, and model concentration across all six provider runtimes from one operational ledger — including Ollama at $0.',
    bullets: ['6-provider spend and token trends', 'Runtime and model breakdowns', 'Budget pacing with guardrails'],
    screenshot: '/screenshots/costs-list.png',
    alt: 'Cost and usage dashboard with budget pacing, spend metrics, provider counts, and Anthropic/OpenAI pricing table',
  },
  {
    title: 'Conversational AI',
    description: 'Ask questions, create tasks, and navigate your workspace through natural language. Chat from the app, Slack, or Telegram with the same engine and full tool access.',
    bullets: ['Tool catalog with @ mentions', 'Bidirectional Slack and Telegram channels', 'Multi-provider model selector with cost tiers'],
    screenshot: '/screenshots/chat-list.png',
    alt: 'Chat interface with suggested prompt categories, model selector, and conversation history sidebar',
  },
  {
    title: 'Structured Data Tables',
    description: 'Organize business data in Airtable-like tables with spreadsheet editing, computed columns, charts, workflow triggers, and full agent read-write access.',
    bullets: ['12 built-in templates across 5 categories', 'Charts, triggers, and cross-table relations', '12 agent tools for querying and updating data'],
    screenshot: '/screenshots/tables-list.png',
    alt: 'Tables list view with search, source and project filters, columns, rows, and updated timestamps',
  },
  {
    title: 'Environment Scanner',
    description: 'Scan and audit your Claude Code and Codex CLI setups with health scoring, artifact discovery, and cross-project comparison.',
    bullets: ['Composite health score across 4 dimensions', 'Artifact inventory with type filtering', 'Cross-project configuration comparison'],
    screenshot: '/screenshots/environment-list.png',
    alt: 'Environment dashboard showing 84 artifacts, health score of 88, MCP servers, skills, and safety ratings',
  },
];
---
<section id="features" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <SectionLabel text="Features" />
      <h2 data-animate class="mt-4">Built for real work</h2>
    </div>

    <div class="flex flex-col gap-24">
      {features.map(({ title, description, bullets, screenshot, alt }, i) => (
        <div
          data-animate
          class:list={[
            "grid md:grid-cols-2 gap-12 items-center",
            i % 2 === 1 && "md:[direction:rtl] md:[&>*]:![direction:ltr]"
          ]}
        >
          <div>
            <h3 class="text-xl font-semibold mb-4">{title}</h3>
            <p class="text-text-muted leading-relaxed mb-6">{description}</p>
            <ul class="space-y-2">
              {bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-sm text-text-muted">
                  <svg class="w-4 h-4 mt-0.5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
          <div class="img-reveal">
            <BrowserFrame src={screenshot} alt={alt} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
