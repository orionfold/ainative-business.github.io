---
import SectionLabel from '../../ui/SectionLabel.astro';

interface Props {
  articleCount: number;
}

const { articleCount } = Astro.props;

const stats = [
  { value: `${articleCount}`, label: 'articles already distill into fieldkit', source: '/field-notes/' },
  { value: '5', label: 'modules, one import each', source: 'fieldkit.{capabilities,nim,rag,eval,cli}' },
  { value: '8192', label: 'token preflight catches NIM 400s', source: 'before the network call' },
];

const gaps = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18"/><path d="M12 3v18"/><circle cx="12" cy="12" r="9"/></svg>`,
    title: 'Context overflow',
    description: 'NIM endpoints return 400 on quiet overflow — fieldkit catches it on the client',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.22-8.56"/><path d="M21 4v5h-5"/></svg>`,
    title: 'Retry gaps',
    description: 'Exponential backoff (0.5 s → 8 s) and cold-start polling are baked in, not bolted on',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/></svg>`,
    title: 'Schema drift',
    description: 'pgvector tables, indexes, and dimensions stay in sync — one ensure_schema() call',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 9h.01"/><path d="M15 9h.01"/><path d="M8 15s1.5 2 4 2 4-2 4-2"/></svg>`,
    title: 'Eval blindness',
    description: 'Bench, Judge, refusal detection, and trajectory analysis ship as one harness',
  },
];
---
<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <SectionLabel text="The Problem" />
      <h2 data-animate class="mt-4 mb-4">Stop copy-pasting glue between articles.</h2>
      <p data-animate class="text-text-muted max-w-2xl mx-auto leading-relaxed" style="transition-delay: 80ms">
        Building on Spark means lifting retry logic, context-window math, pgvector schemas, and eval rubrics from a half-dozen articles every project. The patterns are right; the copy-paste is fragile.
      </p>
    </div>

    <!-- Cost-of-copy-paste stats -->
    <div data-animate-stagger class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      {stats.map(({ value, label, source }) => (
        <div data-animate class="rounded-xl border border-primary/20 bg-primary/[0.04] p-6 text-center">
          <div class="text-3xl md:text-4xl font-bold text-primary font-mono">{value}</div>
          <div class="text-sm text-text-muted mt-2">{label}</div>
          <div class="text-xs text-text-muted/60 mt-1 font-mono">{source}</div>
        </div>
      ))}
    </div>

    <!-- Bridge -->
    <p data-animate class="text-text-muted text-center max-w-2xl mx-auto mb-10 leading-relaxed">
      Each pattern was first verified inside an article — KV-cache arithmetic, the OpenAI-compatible NIM client with its 8192-token preflight, the strict-context RAG pipeline from <em>naive-rag-on-spark</em>, the eval harness behind every evidence file. fieldkit is where those patterns live after they're tested.
    </p>

    <!-- Capability gaps -->
    <div data-animate-stagger class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      {gaps.map(({ icon, title, description }) => (
        <div data-animate class="rounded-xl border border-border bg-surface-raised p-5 text-center">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary mb-3" set:html={icon} />
          <div class="font-semibold text-sm mb-1">{title}</div>
          <p class="text-xs text-text-muted leading-relaxed">{description}</p>
        </div>
      ))}
    </div>

    <!-- Transition -->
    <p data-animate class="text-center text-primary font-semibold text-sm">
      <code class="font-mono text-[0.92em] text-primary bg-primary/10 px-1.5 py-0.5 rounded">fieldkit</code> is the tested distillate.
    </p>
  </div>
</section>
