        </div>
        <div class="flex flex-col gap-2">
          <span class="text-[0.65rem] uppercase tracking-[0.12em] text-text-dim">Reading</span>
          <a href="/book/" class="hover:text-primary transition-colors">Book</a>
          <a href="/field-notes/" class="hover:text-primary transition-colors">Field Notes</a>
