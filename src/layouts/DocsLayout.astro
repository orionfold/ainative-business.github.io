---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/prose.css';
import DocsSidebar from '../components/DocsSidebar.astro';
import { SITE, PUBLISHER } from '../data/seo';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
  };
}

// MDX pages pass frontmatter via Astro.props.frontmatter; .astro pages pass directly
const title = Astro.props.title || Astro.props.frontmatter?.title || 'Docs';
const description = Astro.props.description || Astro.props.frontmatter?.description || '';
const pageTitle = `${title} — ainative Docs`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: pageTitle,
    description,
    publisher: PUBLISHER,
    url: new URL(Astro.url.pathname, SITE.url).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Docs', item: `${SITE.url}/docs/` },
      { '@type': 'ListItem', position: 3, name: title, item: new URL(Astro.url.pathname, SITE.url).toString() },
    ],
  },
];
---
<Layout title={pageTitle} description={description} jsonLd={jsonLd}>
  <Nav />

  <div class="max-w-7xl mx-auto px-6 pt-28 pb-32 flex gap-8">
    <!-- Sidebar -->
    <DocsSidebar currentPath={Astro.url.pathname} />

    <!-- Main content -->
    <main class="flex-1 min-w-0 max-w-[72ch]">
      <article class="prose">
        <slot />
      </article>
    </main>
  </div>

  <Footer />
</Layout>
