---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import '../styles/book.css';
import { SITE, PUBLISHER } from '../data/seo';
import { CHAPTERS, PARTS } from '../lib/book/content';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'AI Native Business — The Book', description = '' } = Astro.props;
const pageTitle = `${title} — Stagent`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Book',
    name: 'AI Native Business: Building Autonomous Business Systems with AI Agents',
    author: {
      '@type': 'Person',
      name: 'Manav Sehgal',
    },
    description: `A practical guide to building AI-native applications — ${CHAPTERS.length} chapters across ${PARTS.length} parts, from organizational design to autonomous business systems built with AI agents.`,
    publisher: PUBLISHER,
    url: new URL(Astro.url.pathname, SITE.url).toString(),
    inLanguage: 'en',
    accessMode: 'textual',
    isAccessibleForFree: true,
    license: 'https://creativecommons.org/licenses/by-nc/4.0/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Book', item: `${SITE.url}/book/` },
      { '@type': 'ListItem', position: 3, name: title, item: new URL(Astro.url.pathname, SITE.url).toString() },
    ],
  },
];
---
<Layout title={pageTitle} description={description} jsonLd={jsonLd}>
  <main>
    <slot />
  </main>
</Layout>
