---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/prose.css';
import '../styles/api-prose.css';
import ApiDocsSidebar from '../components/ApiDocsSidebar.astro';
import { SITE, PUBLISHER } from '../data/seo';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
  };
}

const title = Astro.props.title || Astro.props.frontmatter?.title || 'API Reference';
const description = Astro.props.description || Astro.props.frontmatter?.description || '';
const pageTitle = `${title} — ainative API`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: pageTitle,
    description,
    proficiencyLevel: 'Beginner',
    publisher: PUBLISHER,
    url: new URL(Astro.url.pathname, SITE.url).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Docs', item: `${SITE.url}/docs/` },
      { '@type': 'ListItem', position: 3, name: 'API Reference', item: `${SITE.url}/docs/api/` },
      { '@type': 'ListItem', position: 4, name: title, item: new URL(Astro.url.pathname, SITE.url).toString() },
    ],
  },
];
---
<Layout title={pageTitle} description={description} jsonLd={jsonLd}>
  <Nav />

  <div class="max-w-[90rem] mx-auto px-6 pt-28 pb-32 flex gap-8">
    <!-- Sidebar -->
    <ApiDocsSidebar currentPath={Astro.url.pathname} />

    <!-- Main content -->
    <main class="flex-1 min-w-0 max-w-[90ch]">
      <article class="prose api-prose">
        <slot />
      </article>
    </main>
  </div>

  <Footer />
</Layout>
