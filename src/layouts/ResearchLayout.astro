---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/prose.css';
import { SITE, PUBLISHER } from '../data/seo';

interface Frontmatter {
  title?: string;
  description?: string;
  datePublished?: string;
  dateModified?: string;
  author?: string;
  readingTime?: string;
  canonical?: string;
  paperNumber?: string;
}

interface Props extends Frontmatter {
  frontmatter?: Frontmatter;
}

// Astro's MDX integration passes frontmatter via Astro.props.frontmatter,
// not as spread props. Support both patterns so this layout works for both
// .mdx pages (frontmatter object) and .astro callers (individual props).
const props = Astro.props;
const fm: Frontmatter = { ...(props.frontmatter ?? {}), ...props };

const {
  title = 'Research — ainative',
  description = 'AI transformation research: how solo founders, agencies, and PE firms build AI-native businesses with governed agent orchestration.',
  datePublished = '2026-03-01',
  dateModified = '2026-04-02',
  author = 'Manav Sehgal',
  readingTime,
  canonical = '/research/',
  paperNumber,
} = fm;

const canonicalUrl = `${SITE.url}${canonical}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: title,
    description,
    author: {
      '@type': 'Person',
      name: author,
    },
    publisher: PUBLISHER,
    datePublished,
    dateModified,
    wordCount: 5500,
    proficiencyLevel: 'Expert',
    url: canonicalUrl,
    image: `${SITE.url}/og-image.png`,
    about: [
      { '@type': 'Thing', name: 'AI agent orchestration' },
      { '@type': 'Thing', name: 'Human-in-the-loop AI' },
      { '@type': 'Thing', name: 'Claude Agent SDK' },
      { '@type': 'Thing', name: 'Codex App Server' },
      { '@type': 'Thing', name: 'AI cost governance' },
      { '@type': 'Thing', name: 'Agent governance' },
      { '@type': 'Thing', name: 'Multi-channel delivery' },
      { '@type': 'Thing', name: 'Chat system' },
      { '@type': 'Thing', name: 'Heartbeat scheduling' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Research',
        item: `${SITE.url}/research/`,
      },
      ...(canonical !== '/research/'
        ? [{
            '@type': 'ListItem',
            position: 3,
            name: title,
            item: canonicalUrl,
          }]
        : []),
    ],
  },
];
---
<Layout
  title={title}
  description={description}
  ogType="article"
  article={{ datePublished, dateModified, author }}
  jsonLd={jsonLd}
>
  <!-- Citation meta tags for Google Scholar / AI discovery -->
  <meta slot="head" name="citation_title" content={title} />
  <meta slot="head" name="citation_author" content={author} />
  <meta slot="head" name="citation_date" content={datePublished} />
  <meta slot="head" name="citation_public_url" content={canonicalUrl} />

  <!-- Reading progress bar -->
  <div
    id="reading-progress"
    class="fixed top-0 left-0 h-[2px] bg-primary z-50 transition-none"
    style="width: 0%"
  ></div>

  <Nav />

  <!-- Content -->
  <main class="max-w-[72ch] mx-auto px-6 pt-28 pb-32">
    {paperNumber && (
      <div class="mb-8 flex items-center gap-4">
        <a
          href="/research/"
          class="font-mono text-[10px] tracking-[0.22em] uppercase text-text-muted hover:text-primary transition-colors"
        >
          ← ainative Research
        </a>
        <span class="h-px flex-1 bg-border"></span>
        <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-amber">
          Paper №{paperNumber}
        </span>
      </div>
    )}
    <article class="prose">
      <slot />
    </article>
  </main>

  <Footer />

  <!-- Reading progress script -->
  <script>
    function initProgress() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = `${Math.min(progress, 100)}%`;
      }

      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    initProgress();
    document.addEventListener('astro:after-swap', initProgress);
  </script>
</Layout>
