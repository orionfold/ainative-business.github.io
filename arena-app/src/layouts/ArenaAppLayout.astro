        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.06em;
        color: var(--arena-text-dim); background: transparent; border: 1px solid var(--arena-border, #243044);
        border-radius: 0.35rem; padding: 0.32rem 0.7rem; cursor: pointer;
      }
      .arena-app .kp__scan:hover:not(:disabled) { color: var(--arena-accent); border-color: var(--arena-accent); }
      .arena-app .kp__scan:disabled { opacity: 0.4; cursor: default; }
      .arena-app .kp__note { font-size: 0.66rem; color: var(--arena-text-dim); }
      /* (c) trend */
      .arena-app .kp__trend {
        display: flex; flex-direction: column; gap: 0.55rem;
        padding: 0.7rem 0.85rem; border: 1px solid var(--arena-line); border-radius: 0.5rem;
        background: rgba(255,255,255,0.015);
      }
      .arena-app .kp__trend-head { display: flex; align-items: center; justify-content: space-between; }
      .arena-app .kp__trend-title { font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--arena-text-mute); }
      .arena-app .kp__cosine { font-family: var(--arena-mono); font-size: 0.54rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--arena-text-dim); border: 1px solid var(--arena-line); border-radius: 0.5rem; padding: 0.05rem 0.45rem; }
      .arena-app .kp__trend-body { display: flex; align-items: center; gap: 1rem; }
      .arena-app .kp__spark { color: var(--arena-ok); flex: none; }
      .arena-app .kp__trend-now { display: flex; flex-direction: column; }
      .arena-app .kp__trend-recall { font-family: var(--arena-mono); font-size: 0.85rem; color: var(--arena-ok); }
      .arena-app .kp__trend-sub { font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-dim); }
      /* (d) query console */
      .arena-app .kp__query {
        display: flex; flex-direction: column; gap: 0.6rem;
        padding: 0.7rem 0.85rem; border: 1px solid var(--arena-line); border-radius: 0.5rem;
        background: rgba(255,255,255,0.015);
      }
      .arena-app .kp__query-form { display: flex; gap: 0.5rem; }
      .arena-app .kp__input {
        flex: 1; font-family: var(--arena-mono); font-size: 0.74rem;
        background: var(--arena-bg, #0a0e14); color: var(--arena-text);
        border: 1px solid var(--arena-line); border-radius: 0.35rem; padding: 0.35rem 0.55rem;
      }
      .arena-app .kp__input:focus { outline: none; border-color: var(--arena-accent); }
      .arena-app .kp__prov { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
      .arena-app .kp__prov-label { font-family: var(--arena-mono); font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--arena-text-dim); }
      .arena-app .kp__prov-chip {
        font-family: var(--arena-mono); font-size: 0.58rem; color: var(--arena-text-dim);
        background: transparent; border: 1px solid var(--arena-line); border-radius: 0.5rem;
        padding: 0.1rem 0.5rem; cursor: pointer;
      }
      .arena-app .kp__prov-chip.is-on { color: var(--arena-bg, #0a0e14); background: var(--arena-accent); border-color: var(--arena-accent); }
      .arena-app .kp__qerr { margin: 0; font-size: 0.66rem; color: var(--arena-warn); font-family: var(--arena-mono); }
      .arena-app .kp__hits { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
      .arena-app .kp__hit { border: 1px solid var(--arena-line); border-radius: 0.4rem; padding: 0.5rem 0.55rem; background: var(--arena-bg, #0a0e14); }
      .arena-app .kp__hit-top { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }
      .arena-app .kp__hit-src { font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-accent); }
      .arena-app .kp__hit-prov { font-family: var(--arena-mono); font-size: 0.54rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--arena-text-dim); }
      .arena-app .kp__hit-prov[data-src="article"] { color: var(--arena-ok); }
      .arena-app .kp__hit-prov[data-src="scout"] { color: var(--arena-warn); }
      .arena-app .kp__hit-dist { margin-left: auto; font-family: var(--arena-mono); font-size: 0.58rem; color: var(--arena-text-dim); }
      .arena-app .kp__hit-text { margin: 0; font-size: 0.72rem; line-height: 1.45; color: var(--arena-text-mute); }
      .arena-app .kp__empty { margin: 0; color: var(--arena-text-dim); font-size: 0.74rem; }
      /* runs */
      .arena-app .kp__runs summary { font-size: 0.68rem; color: var(--arena-text-mute); cursor: pointer; }
      .arena-app .kp__runs-list { list-style: none; margin: 0.5rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
      .arena-app .kp__runs-list li { display: flex; align-items: center; gap: 0.7rem; font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim); }
      .arena-app .kp__runs-list code { color: var(--arena-text); }
      .arena-app .kp__runs-ver { color: var(--arena-text-dim); opacity: 0.7; }
      .arena-app .kp__runs-status[data-status="done"] { color: var(--arena-ok); }
      .arena-app .kp__runs-status[data-status="failed"] { color: var(--arena-warn); }

      /* ---------------------------------------------------------------
       *  Standup — autonomous harness (/arena/standup/) — M11
       * --------------------------------------------------------------- */
      .arena-app .standup { display: flex; flex-direction: column; gap: 1rem; }
      .arena-app .standup__offline {
        display: flex; align-items: flex-start; gap: 0.7rem; padding: 1rem 1.1rem;
        border: 1px dashed var(--arena-border); border-radius: 0.5rem;
        color: var(--arena-text-mute); font-size: 0.8rem; line-height: 1.5;
      }
      .arena-app .standup__offline code { font-family: var(--arena-mono); color: var(--arena-accent); font-size: 0.92em; }
      .arena-app .standup__offline strong { color: var(--arena-text); }
      .arena-app .standup__offline-dot {
        flex: 0 0 auto; width: 0.5rem; height: 0.5rem; margin-top: 0.35rem;
        border-radius: 50%; background: var(--arena-text-dim);
      }
      /* Spend rail — the M9 SpendDigest, "—" when the cost plane is absent */
      .arena-app .standup__spend {
        display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 1.1rem;
        padding: 0.8rem 1rem; border: 1px solid var(--arena-border);
        border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .standup__spend[data-over="true"] { border-color: var(--arena-warn); }
      .arena-app .standup__spend-total {
        font-family: var(--arena-mono); font-size: 1.05rem; font-weight: 700; color: var(--arena-text);
      }
      .arena-app .standup__spend[data-over="true"] .standup__spend-total { color: var(--arena-warn); }
      .arena-app .standup__spend-label {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.16em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .standup__spend-lanes { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-left: auto; }
      .arena-app .standup__spend-lane {
        font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text-mute);
        padding: 0.1rem 0.4rem; border: 1px solid var(--arena-border); border-radius: 0.3rem;
      }
      .arena-app .standup__spend-lane b { color: var(--arena-text); font-weight: 600; }
      /* Autonomy policy banner + RL memory digest (rl-lane-autonomy LA-5/11) */
      .arena-app .standup__autonomy {
        display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 0.8rem;
        padding: 0.55rem 0.9rem; border: 1px solid var(--arena-border);
        border-radius: 0.5rem; background: var(--arena-panel); margin-bottom: 0.7rem;
      }
      .arena-app .standup__autonomy[data-armed="true"] { border-color: var(--arena-ok); }
      .arena-app .standup__autonomy-dot {
        width: 0.5rem; height: 0.5rem; border-radius: 50%;
        background: var(--arena-text-dim); flex: none;
      }
      .arena-app .standup__autonomy[data-armed="true"] .standup__autonomy-dot {
        background: var(--arena-ok); box-shadow: 0 0 0 3px rgba(80,200,120,0.15);
      }
      .arena-app .standup__autonomy-label {
        font-family: var(--arena-mono); font-size: 0.7rem; font-weight: 600; color: var(--arena-text);
      }
      .arena-app .standup__autonomy-hint { font-size: 0.62rem; color: var(--arena-text-dim); }
      .arena-app .standup__autonomy-hint code { font-family: var(--arena-mono); color: var(--arena-text-mute); }
      .arena-app .standup__autonomy-rl {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.64rem;
        color: var(--arena-text-mute); padding: 0.1rem 0.45rem;
        border: 1px solid var(--arena-border); border-radius: 0.3rem;
      }
      .arena-app .standup__autonomy-rl[data-oom="true"] { color: var(--arena-warn); border-color: var(--arena-warn); }
      /* Four buckets */
      .arena-app .standup__cols {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.9rem;
      }
      .arena-app .standup__col {
        border: 1px solid var(--arena-border); border-radius: 0.5rem;
        background: var(--arena-panel); padding: 0.8rem 0.9rem; min-height: 6rem;
      }
      .arena-app .standup__col-head {
        display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.6rem;
      }
      .arena-app .standup__col-title {
        font-family: var(--arena-mono); font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase; color: var(--arena-text);
      }
      .arena-app .standup__col-count {
        font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text-dim);
      }
      .arena-app .standup__col[data-warn="true"] .standup__col-title { color: var(--arena-warn); }
      .arena-app .standup__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.35rem; }
      .arena-app .standup__row {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; color: var(--arena-text-mute);
      }
      .arena-app .standup__row code { font-family: var(--arena-mono); color: var(--arena-accent); font-size: 0.92em; }
      .arena-app .standup__row-status {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.08em;
        text-transform: uppercase; margin-left: auto;
      }
      .arena-app .standup__row-status[data-status="done"] { color: var(--arena-ok); }
      .arena-app .standup__row-status[data-status="failed"] { color: var(--arena-warn); }
      .arena-app .standup__row-status[data-status="queued"] { color: var(--arena-text-dim); }
      .arena-app .standup__row-reg code { color: var(--arena-warn); }
      .arena-app .standup__empty { font-size: 0.72rem; color: var(--arena-text-dim); font-style: italic; }
      .arena-app .standup__staged {
        font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim);
        letter-spacing: 0.04em;
      }
      .arena-app .standup__staged b { color: var(--arena-ok); }

      /* ---------------------------------------------------------------
       *  Reward signal — eval-is-reward gauge (/arena/reward/) — AF-3
       * --------------------------------------------------------------- */
      .arena-app .reward { display: flex; flex-direction: column; gap: 1rem; }
      .arena-app .reward__offline, .arena-app .reward__empty {
        display: flex; align-items: flex-start; gap: 0.7rem; padding: 1rem 1.1rem;
        border: 1px dashed var(--arena-border); border-radius: 0.5rem;
        color: var(--arena-text-mute); font-size: 0.8rem; line-height: 1.5;
      }
      .arena-app .reward__offline code, .arena-app .reward__empty code {
        font-family: var(--arena-mono); color: var(--arena-accent); font-size: 0.92em;
      }
      .arena-app .reward__offline strong, .arena-app .reward__empty strong { color: var(--arena-text); }
      .arena-app .reward__offline-dot {
        flex: 0 0 auto; width: 0.5rem; height: 0.5rem; margin-top: 0.35rem;
        border-radius: 50%; background: var(--arena-text-dim);
      }
      /* Three headline gauges */
      .arena-app .reward__gauges {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.9rem;
      }
      .arena-app .reward__gauge {
        display: flex; flex-direction: column; gap: 0.15rem; padding: 0.9rem 1rem;
        border: 1px solid var(--arena-border); border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .reward__gauge--reward { border-color: var(--arena-accent); }
      .arena-app .reward__gauge[data-alarm="true"] { border-color: var(--arena-warn); }
      .arena-app .reward__gauge-val {
        font-family: var(--arena-mono); font-size: 1.6rem; font-weight: 700; color: var(--arena-text); line-height: 1;
      }
      .arena-app .reward__gauge[data-alarm="true"] .reward__gauge-val { color: var(--arena-warn); }
      .arena-app .reward__gauge-label {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .reward__gauge-sub { font-size: 0.64rem; color: var(--arena-text-mute); }
      /* Gate verdict */
      .arena-app .reward__verdict {
        display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 0.9rem;
        padding: 0.6rem 0.9rem; border: 1px solid var(--arena-border);
        border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .reward__verdict[data-pass="true"] { border-color: var(--arena-ok); }
      .arena-app .reward__verdict[data-pass="false"] { border-color: var(--arena-warn); }
      .arena-app .reward__verdict-badge {
        font-family: var(--arena-mono); font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.1em; color: var(--arena-text-dim);
      }
      .arena-app .reward__verdict[data-pass="true"] .reward__verdict-badge { color: var(--arena-ok); }
      .arena-app .reward__verdict[data-pass="false"] .reward__verdict-badge { color: var(--arena-warn); }
      .arena-app .reward__verdict-rule { font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim); }
      .arena-app .reward__verdict-meta { margin-left: auto; font-size: 0.64rem; color: var(--arena-text-mute); }
      .arena-app .reward__verdict-meta code { font-family: var(--arena-mono); color: var(--arena-text); }
      .arena-app .reward__verdict[data-running="true"] { border-color: var(--arena-border); }
      .arena-app .reward__verdict[data-running="true"] .reward__verdict-badge { color: var(--arena-text-dim); }
      /* AF-9 run-history selector */
      .arena-app .reward__history { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 0.7rem; }
      .arena-app .reward__history-label {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .reward__history-select {
        font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text);
        background: var(--arena-panel); border: 1px solid var(--arena-border);
        border-radius: 0.4rem; padding: 0.3rem 0.5rem; cursor: pointer; max-width: 100%;
      }
      .arena-app .reward__history-select:hover { border-color: var(--arena-accent); }
      .arena-app .reward__history-now { font-size: 0.62rem; color: var(--arena-text-mute); }
      .arena-app .reward__history-now code { font-family: var(--arena-mono); color: var(--arena-text-dim); }
      /* AF-9 live run strip — eval/preflight streaming mid-flight */
      .arena-app .reward__live {
        display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 0.8rem;
        padding: 0.55rem 0.9rem; border: 1px solid var(--arena-accent);
        border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .reward__live-dot {
        width: 0.5rem; height: 0.5rem; border-radius: 50%; background: var(--arena-accent);
        animation: reward-live-pulse 1.4s ease-in-out infinite; flex: none;
      }
      @keyframes reward-live-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
      @media (prefers-reduced-motion: reduce) { .arena-app .reward__live-dot { animation: none; } }
      .arena-app .reward__live-label {
        font-family: var(--arena-mono); font-size: 0.66rem; font-weight: 700;
        letter-spacing: 0.14em; color: var(--arena-accent);
      }
      .arena-app .reward__live-count { font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text); }
      .arena-app .reward__live-bar {
        flex: 1; min-width: 120px; height: 0.4rem; border-radius: 0.3rem;
        background: var(--arena-line); overflow: hidden;
      }
      .arena-app .reward__live-fill {
        height: 100%; background: var(--arena-accent); border-radius: 0.3rem; transition: width 0.4s ease;
      }
      .arena-app .reward__live-eta { font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-mute); }
      /* Bucket breakdown */
      .arena-app .reward__buckets {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.7rem;
      }
      .arena-app .reward__bucket {
        display: flex; flex-direction: column; gap: 0.1rem; padding: 0.6rem 0.8rem;
        border: 1px solid var(--arena-border); border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .reward__bucket[data-warn="true"] { border-color: var(--arena-warn); }
      .arena-app .reward__bucket-n {
        font-family: var(--arena-mono); font-size: 1.1rem; font-weight: 700; color: var(--arena-text);
      }
      .arena-app .reward__bucket[data-warn="true"] .reward__bucket-n { color: var(--arena-warn); }
      .arena-app .reward__bucket-label {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.08em; color: var(--arena-text-dim);
      }
      .arena-app .reward__bucket-hint { font-size: 0.6rem; color: var(--arena-text-mute); }
      /* Per-row detail table */
      .arena-app .reward__rows { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
      .arena-app .reward__rows th {
        text-align: left; font-family: var(--arena-mono); font-size: 0.58rem;
        letter-spacing: 0.1em; text-transform: uppercase; color: var(--arena-text-dim);
        padding: 0.3rem 0.5rem; border-bottom: 1px solid var(--arena-border);
      }
      .arena-app .reward__rows td {
        padding: 0.3rem 0.5rem; border-bottom: 1px solid var(--arena-line); color: var(--arena-text-mute);
      }
      .arena-app .reward__rows td code { font-family: var(--arena-mono); color: var(--arena-accent); }
      .arena-app .reward__rows-boxed { font-family: var(--arena-mono); color: var(--arena-text); }
      .arena-app .reward__rows tr[data-bucket="truncated_think"] td { color: var(--arena-warn); }
      .arena-app .reward__rows-score { font-family: var(--arena-mono); text-align: right; color: var(--arena-text-dim); }
      .arena-app .reward__rows-score[data-hit="true"] { color: var(--arena-ok); font-weight: 700; }
      .arena-app .reward__foot {
        font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim); letter-spacing: 0.03em;
      }
      .arena-app .reward__foot b { color: var(--arena-accent); }
      .arena-app .reward__foot code { color: var(--arena-text-mute); }

      /* ---------------------------------------------------------------
       *  Build spine — vertical-build C1..C6 (/arena/build/) — AE-5/AF-1
       * --------------------------------------------------------------- */
      .arena-app .build { display: flex; flex-direction: column; gap: 1rem; }
      .arena-app .build__offline {
        display: flex; align-items: flex-start; gap: 0.7rem; padding: 1rem 1.1rem;
        border: 1px dashed var(--arena-border); border-radius: 0.5rem;
        color: var(--arena-text-mute); font-size: 0.8rem; line-height: 1.5;
      }
      .arena-app .build__offline code { font-family: var(--arena-mono); color: var(--arena-accent); font-size: 0.92em; }
      .arena-app .build__offline strong { color: var(--arena-text); }
      .arena-app .build__offline-dot {
        flex: 0 0 auto; width: 0.5rem; height: 0.5rem; margin-top: 0.35rem;
        border-radius: 50%; background: var(--arena-text-dim);
      }
      /* Head — vertical name + flow line + stages-complete progress */
      .arena-app .build__head {
        display: flex; align-items: flex-end; justify-content: space-between;
        flex-wrap: wrap; gap: 0.8rem 1.2rem;
        padding: 0.7rem 0.95rem; border: 1px solid var(--arena-border);
        border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .build__head-title { display: flex; flex-direction: column; gap: 0.25rem; }
      .arena-app .build__head-vertical {
        font-size: 1.05rem; font-weight: 650; color: var(--arena-text); letter-spacing: 0.01em;
      }
      .arena-app .build__head-sub {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.04em;
        color: var(--arena-text-dim);
      }
      .arena-app .build__head-progress { display: flex; align-items: center; gap: 0.55rem; }
      .arena-app .build__head-count { font-family: var(--arena-mono); font-size: 1.05rem; color: var(--arena-ok); font-weight: 600; }
      .arena-app .build__head-slash { color: var(--arena-text-dim); font-size: 0.8rem; }
      .arena-app .build__head-bar {
        width: 120px; height: 5px; border-radius: 3px; overflow: hidden;
        background: color-mix(in oklch, var(--arena-border) 60%, transparent);
      }
      .arena-app .build__head-fill { display: block; height: 100%; background: var(--arena-ok); transition: width 0.5s ease; }
      .arena-app .build__head-label {
        font-family: var(--arena-mono); font-size: 0.55rem; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .build__note {
        font-size: 0.72rem; line-height: 1.5; color: var(--arena-text-mute);
        padding: 0.5rem 0.7rem; border-left: 2px solid var(--arena-warn);
        background: color-mix(in oklch, var(--arena-warn) 6%, transparent); border-radius: 0 0.3rem 0.3rem 0;
      }
      .arena-app .build__note code { font-family: var(--arena-mono); color: var(--arena-accent); }
      .arena-app .build__note strong { color: var(--arena-warn); }
      /* Stage grid */
      .arena-app .build__grid {
        display: grid; gap: 0.7rem;
        grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      }
      .arena-app .build__card {
        display: flex; flex-direction: column; gap: 0.32rem;
        padding: 0.7rem 0.8rem; border: 1px solid var(--arena-border);
        border-left: 3px solid var(--arena-text-dim); border-radius: 0.5rem;
        background: var(--arena-panel); text-decoration: none; color: inherit;
        position: relative; transition: border-color 0.18s ease, transform 0.18s ease;
      }
      .arena-app .build__card[data-state="done"]   { border-left-color: var(--arena-ok); }
      .arena-app .build__card[data-state="active"]  { border-left-color: var(--arena-accent); }
      .arena-app .build__card[data-state="idle"]    { border-left-color: var(--arena-text-dim); }
      .arena-app .build__card[data-state="hold"]    { border-left-color: var(--arena-warn); }
      .arena-app .build__card--link { cursor: pointer; }
      .arena-app .build__card--link:hover { border-color: var(--arena-accent); transform: translateY(-1px); }
      .arena-app .build__card-top { display: flex; align-items: center; justify-content: space-between; }
      .arena-app .build__card-code {
        font-family: var(--arena-mono); font-size: 0.55rem; letter-spacing: 0.1em;
        color: var(--arena-text-dim); border: 1px solid var(--arena-border);
        border-radius: 0.25rem; padding: 0.05rem 0.3rem;
      }
      .arena-app .build__card-state {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-family: var(--arena-mono); font-size: 0.55rem; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .build__card-state[data-tone="done"]   { color: var(--arena-ok); }
      .arena-app .build__card-state[data-tone="active"] { color: var(--arena-accent); }
      .arena-app .build__card-state[data-tone="hold"]   { color: var(--arena-warn); }
      .arena-app .build__card-dot {
        width: 0.42rem; height: 0.42rem; border-radius: 50%; background: var(--arena-text-dim);
      }
      .arena-app .build__card-dot[data-tone="done"]   { background: var(--arena-ok); box-shadow: 0 0 5px var(--arena-ok-dim); }
      .arena-app .build__card-dot[data-tone="active"] { background: var(--arena-accent); animation: build-pulse 1.8s ease-in-out infinite; }
      .arena-app .build__card-dot[data-tone="hold"]   { background: var(--arena-warn); }
      @keyframes build-pulse {
        0%, 100% { box-shadow: 0 0 0 2px color-mix(in oklch, var(--arena-accent) 28%, transparent); }
        50%      { box-shadow: 0 0 0 5px color-mix(in oklch, var(--arena-accent) 10%, transparent); }
      }
      .arena-app .build__card-label { font-size: 0.92rem; font-weight: 620; color: var(--arena-text); }
      .arena-app .build__card-headline { font-size: 0.74rem; color: var(--arena-text); line-height: 1.35; }
      .arena-app .build__card-headline[data-empty="true"] { color: var(--arena-text-dim); font-style: italic; }
      .arena-app .build__card-detail { font-size: 0.63rem; color: var(--arena-text-dim); line-height: 1.4; }
      .arena-app .build__card-gate {
        display: flex; align-items: center; gap: 0.4rem; margin-top: 0.15rem;
        padding-top: 0.4rem; border-top: 1px solid color-mix(in oklch, var(--arena-border) 60%, transparent);
      }
      .arena-app .build__card-gate-chip {
        font-family: var(--arena-mono); font-size: 0.5rem; letter-spacing: 0.08em;
        padding: 0.05rem 0.32rem; border-radius: 0.25rem;
        border: 1px solid var(--arena-text-dim); color: var(--arena-text-dim);
      }
      .arena-app .build__card-gate-chip[data-tone="pass"] {
        color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 45%, var(--arena-border));
        background: color-mix(in oklch, var(--arena-ok) 10%, transparent);
      }
      .arena-app .build__card-gate-chip[data-tone="hold"] {
        color: var(--arena-warn); border-color: color-mix(in oklch, var(--arena-warn) 45%, var(--arena-border));
        background: color-mix(in oklch, var(--arena-warn) 10%, transparent);
      }
      .arena-app .build__card-gate-text { font-size: 0.6rem; color: var(--arena-text-mute); }
      .arena-app .build__card-link {
        position: absolute; top: 0.6rem; right: 0.7rem;
        font-family: var(--arena-mono); font-size: 0.52rem; color: var(--arena-text-dim); opacity: 0;
        transition: opacity 0.18s ease;
      }
      .arena-app .build__card--link:hover .build__card-link { opacity: 1; }
      .arena-app .build__foot {
        font-size: 0.7rem; line-height: 1.55; color: var(--arena-text-mute);
        padding-top: 0.6rem; border-top: 1px solid var(--arena-border);
      }
      .arena-app .build__foot b { color: var(--arena-accent); }
      .arena-app .build__foot strong { color: var(--arena-text); }
      .arena-app .build__foot a { color: var(--arena-text-dim); }
      .arena-app .build__foot a:hover { color: var(--arena-accent); }
      .arena-app .build__foot b { color: var(--arena-accent); }

      /* AE-26 — inventory-truth chips (disk-verified artifact facts per stage) */
      .arena-app .build__inv {
        display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.15rem;
        padding-top: 0.4rem; border-top: 1px dashed color-mix(in oklch, var(--arena-border) 60%, transparent);
      }
      .arena-app .build__inv-chip {
        display: inline-flex; align-items: center; gap: 0.25rem;
        font-family: var(--arena-mono); font-size: 0.55rem;
        padding: 0.08rem 0.36rem; border-radius: 0.28rem;
        border: 1px solid color-mix(in oklch, var(--arena-ok) 35%, var(--arena-border));
        color: var(--arena-ok);
        background: color-mix(in oklch, var(--arena-ok) 7%, transparent);
      }
      .arena-app .build__inv-chip[data-tone="hold"] {
        border-color: color-mix(in oklch, var(--arena-warn) 50%, var(--arena-border));
        color: var(--arena-warn);
        background: color-mix(in oklch, var(--arena-warn) 10%, transparent);
      }
      .arena-app .build__inv-chip code { font-size: 0.55rem; color: var(--arena-text-dim); }
      .arena-app .build__inv-chip i { font-style: normal; color: var(--arena-text-dim); }

      /* AE-30 — runtime-readiness roster (observed; read-only half of AF-20) */
      .arena-app .build__rt {
        display: flex; flex-direction: column; gap: 0.45rem;
        padding: 0.6rem 0.85rem; border-radius: 0.5rem;
        border: 1px solid var(--arena-border);
        background: color-mix(in oklch, var(--arena-bg) 85%, transparent);
      }
      .arena-app .build__rt-head { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
      .arena-app .build__rt-title {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .build__rt-count { font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text); }
      .arena-app .build__rt-sub { font-size: 0.58rem; color: var(--arena-text-mute); }
      .arena-app .build__rt-list { display: flex; flex-wrap: wrap; gap: 0.35rem; }
      .arena-app .build__rt-chip {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-family: var(--arena-mono); font-size: 0.58rem;
        padding: 0.14rem 0.45rem; border-radius: 0.3rem;
        border: 1px solid var(--arena-border); color: var(--arena-text-dim);
      }
      .arena-app .build__rt-chip b { color: var(--arena-text); font-weight: 600; }
      .arena-app .build__rt-chip i { font-style: normal; color: var(--arena-text-mute); }
      .arena-app .build__rt-chip[data-tone="pass"] { border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-border)); }
      .arena-app .build__rt-chip[data-tone="hold"] { border-color: color-mix(in oklch, var(--arena-warn) 45%, var(--arena-border)); }
      .arena-app .build__rt-dot { width: 0.4rem; height: 0.4rem; border-radius: 50%; background: var(--arena-text-dim); }
      .arena-app .build__rt-dot[data-tone="pass"] { background: var(--arena-ok); box-shadow: 0 0 4px var(--arena-ok-dim); }
      .arena-app .build__rt-dot[data-tone="hold"] { background: var(--arena-warn); }

      /* AE-27 — corpus handshake (intent control + producer liveness) */
      .arena-app .build__shake {
        display: flex; flex-direction: column; gap: 0.45rem;
        padding: 0.6rem 0.85rem; border-radius: 0.5rem;
        border: 1px dashed var(--arena-border);
        background: color-mix(in oklch, var(--arena-bg) 85%, transparent);
      }
      .arena-app .build__shake-head { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
      .arena-app .build__shake-title {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .build__shake-live {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-dim);
      }
      .arena-app .build__shake-live[data-tone="pass"] { color: var(--arena-ok); }
      .arena-app .build__shake-live[data-tone="hold"] { color: var(--arena-warn); }
      .arena-app .build__shake-dot { width: 0.42rem; height: 0.42rem; border-radius: 50%; background: var(--arena-text-dim); }
      .arena-app .build__shake-dot[data-tone="pass"] { background: var(--arena-ok); animation: build-pulse 1.8s ease-in-out infinite; }
      .arena-app .build__shake-dot[data-tone="hold"] { background: var(--arena-warn); }
      .arena-app .build__shake-src { font-size: 0.55rem; color: var(--arena-text-mute); }
      .arena-app .build__shake-req {
        display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
        font-size: 0.66rem; color: var(--arena-text);
      }
      .arena-app .build__shake-req[data-fulfilled="true"] .build__shake-req-state { color: var(--arena-ok); }
      .arena-app .build__shake-req-meta { font-size: 0.6rem; color: var(--arena-text-dim); }
      .arena-app .build__shake-form { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; }
      .arena-app .build__shake-input {
        font-family: var(--arena-mono); font-size: 0.62rem;
        padding: 0.28rem 0.5rem; border-radius: 0.3rem; width: 7.5rem;
        border: 1px solid var(--arena-border); background: var(--arena-bg);
        color: var(--arena-text);
      }
      .arena-app .build__shake-input--note { width: 18rem; max-width: 100%; }
      .arena-app .build__shake-btn {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.06em;
        padding: 0.3rem 0.7rem; border-radius: 0.3rem; cursor: pointer;
        border: 1px solid color-mix(in oklch, var(--arena-accent) 50%, var(--arena-border));
        color: var(--arena-accent); background: color-mix(in oklch, var(--arena-accent) 8%, transparent);
      }
      .arena-app .build__shake-btn:disabled { opacity: 0.5; cursor: default; }
      .arena-app .build__shake-msg { font-size: 0.6rem; color: var(--arena-warn); }
      .arena-app .build__shake-foot { font-size: 0.56rem; color: var(--arena-text-mute); line-height: 1.45; }

      /* AE-6 — corpus-synth live strip (the in-CC-session synth heartbeat) */
      .arena-app .build__corpus {
        display: flex; flex-direction: column; gap: 0.5rem;
        padding: 0.7rem 0.85rem; border-radius: 0.5rem;
        border: 1px solid var(--arena-border);
        background: color-mix(in oklch, var(--arena-bg) 85%, transparent);
      }
      .arena-app .build__corpus[data-running="true"] {
        border-left: 2px solid var(--arena-accent);
        background: color-mix(in oklch, var(--arena-accent) 5%, transparent);
      }
      .arena-app .build__corpus-head { display: flex; align-items: center; gap: 0.5rem; }
      .arena-app .build__corpus-dot {
        width: 0.5rem; height: 0.5rem; border-radius: 50%;
        background: var(--arena-text-dim);
      }
      .arena-app .build__corpus-dot[data-running="true"] {
        background: var(--arena-accent); box-shadow: 0 0 5px var(--arena-accent);
        animation: build-pulse 1.8s ease-in-out infinite;
      }
      .arena-app .build__corpus-label {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.14em;
        color: var(--arena-accent); font-weight: 600;
      }
      .arena-app .build__corpus-run { font-size: 0.62rem; color: var(--arena-text-mute); }
      .arena-app .build__corpus-run code { font-family: var(--arena-mono); color: var(--arena-text-dim); }
      .arena-app .build__corpus-verify {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.55rem;
        padding: 0.05rem 0.36rem; border-radius: 0.25rem;
      }
      .arena-app .build__corpus-verify[data-tone="pass"] {
        color: var(--arena-ok); background: color-mix(in oklch, var(--arena-ok) 12%, transparent);
      }
      .arena-app .build__corpus-verify[data-tone="hold"] {
        color: var(--arena-warn); background: color-mix(in oklch, var(--arena-warn) 12%, transparent);
      }
      .arena-app .build__corpus-bar-row { display: flex; align-items: center; gap: 0.6rem; }
      .arena-app .build__corpus-count {
        font-family: var(--arena-mono); font-size: 0.85rem; color: var(--arena-text);
        font-weight: 600; white-space: nowrap;
      }
      .arena-app .build__corpus-slash { color: var(--arena-text-dim); font-size: 0.7rem; }
      .arena-app .build__corpus-rows { font-size: 0.6rem; color: var(--arena-text-dim); font-weight: 400; }
      .arena-app .build__corpus-bar {
        flex: 1; height: 0.4rem; border-radius: 0.4rem; overflow: hidden;
        background: color-mix(in oklch, var(--arena-border) 70%, transparent);
      }
      .arena-app .build__corpus-fill {
        display: block; height: 100%; background: var(--arena-accent);
        transition: width 0.5s ease;
      }
      .arena-app .build__corpus-fill[data-done="true"] { background: var(--arena-ok); }
      .arena-app .build__corpus-eta {
        font-family: var(--arena-mono); font-size: 0.56rem; color: var(--arena-text-dim);
        white-space: nowrap;
      }
      .arena-app .build__corpus-mix {
        display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap;
      }
      .arena-app .build__corpus-mix-label {
        font-size: 0.55rem; letter-spacing: 0.08em; color: var(--arena-text-dim);
        text-transform: uppercase; margin-right: 0.15rem;
      }
      .arena-app .build__corpus-chip {
        font-family: var(--arena-mono); font-size: 0.56rem; color: var(--arena-text-mute);
        padding: 0.04rem 0.34rem; border-radius: 0.25rem;
        border: 1px solid var(--arena-border);
      }
      .arena-app .build__corpus-chip b { color: var(--arena-text); margin-left: 0.22rem; }

      /* AE-8 — bench provenance card (version · disjointness · self-verify · mix) */
      .arena-app .build__bench {
        display: flex; flex-direction: column; gap: 0.5rem;
        padding: 0.7rem 0.85rem; border-radius: 0.5rem;
        border: 1px solid var(--arena-border);
        border-left: 2px solid var(--arena-ok);
        background: color-mix(in oklch, var(--arena-ok) 4%, transparent);
      }
      .arena-app .build__bench-head { display: flex; align-items: baseline; gap: 0.55rem; }
      .arena-app .build__bench-label {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.14em;
        color: var(--arena-ok); font-weight: 600;
      }
      .arena-app .build__bench-id { font-size: 0.62rem; color: var(--arena-text-mute); }
      .arena-app .build__bench-id code { font-family: var(--arena-mono); color: var(--arena-text-dim); }
      .arena-app .build__bench-id b { color: var(--arena-text); }
      .arena-app .build__bench-tol {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.55rem;
        color: var(--arena-text-dim);
      }
      .arena-app .build__bench-counts {
        display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
      }
      .arena-app .build__bench-count {
        font-family: var(--arena-mono); font-size: 0.85rem; color: var(--arena-text);
        font-weight: 600; white-space: nowrap;
      }
      .arena-app .build__bench-cap { font-size: 0.6rem; color: var(--arena-text-dim); font-weight: 400; }
      .arena-app .build__bench-plus { color: var(--arena-text-dim); font-size: 0.7rem; }
      .arena-app .build__bench-fact {
        font-family: var(--arena-mono); font-size: 0.55rem;
        padding: 0.05rem 0.36rem; border-radius: 0.25rem;
      }
      .arena-app .build__bench-fact[data-tone="pass"] {
        color: var(--arena-ok); background: color-mix(in oklch, var(--arena-ok) 12%, transparent);
      }
      .arena-app .build__bench-fact[data-tone="hold"] {
        color: var(--arena-warn); background: color-mix(in oklch, var(--arena-warn) 12%, transparent);
      }
      .arena-app .build__bench-mix {
        display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap;
      }
      .arena-app .build__bench-mix-label {
        font-size: 0.55rem; letter-spacing: 0.08em; color: var(--arena-text-dim);
        text-transform: uppercase; margin: 0 0.05rem 0 0.2rem;
      }
      .arena-app .build__bench-chip {
        font-family: var(--arena-mono); font-size: 0.56rem; color: var(--arena-text-mute);
        padding: 0.04rem 0.34rem; border-radius: 0.25rem;
        border: 1px solid var(--arena-border);
      }
      .arena-app .build__bench-chip b { color: var(--arena-text); margin-left: 0.22rem; }
      .arena-app .build__bench-corpus {
        display: flex; align-items: center; gap: 0.4rem;
        font-family: var(--arena-mono); font-size: 0.58rem; color: var(--arena-text-mute);
      }
      .arena-app .build__bench-corpus[data-tone="pass"] { color: var(--arena-ok); }
      .arena-app .build__bench-corpus[data-tone="hold"] { color: var(--arena-warn); }
      .arena-app .build__bench-corpus-dot {
        width: 0.45rem; height: 0.45rem; border-radius: 50%; background: var(--arena-ok);
      }
      .arena-app .build__bench-corpus-dot[data-tone="hold"] { background: var(--arena-warn); }
      .arena-app .build__bench-corpus-meta { color: var(--arena-text-dim); }

      /* AE-7 — build-gate ledger (allow/hold + consequence per human gate) */
      .arena-app .build__gates {
        display: flex; flex-direction: column; gap: 0.55rem;
        padding-top: 0.7rem; border-top: 1px solid var(--arena-border);
      }
      .arena-app .build__gates-head { display: flex; align-items: baseline; gap: 0.6rem; }
      .arena-app .build__gates-title {
        font-size: 0.78rem; font-weight: 620; color: var(--arena-text);
      }
      .arena-app .build__gates-sub {
        font-family: var(--arena-mono); font-size: 0.56rem; letter-spacing: 0.06em;
        color: var(--arena-text-dim);
      }
      .arena-app .build__gates-list { display: flex; flex-direction: column; gap: 0.3rem; }
      .arena-app .build__gate {
        display: grid;
        grid-template-columns: minmax(7rem, 0.9fr) minmax(7rem, 1fr) auto;
        grid-template-areas: "stage name ctrl" "conseq conseq conseq";
        align-items: center; gap: 0.3rem 0.6rem;
        padding: 0.4rem 0.6rem; border-radius: 0.4rem;
        border: 1px solid var(--arena-border); border-left: 2px solid var(--arena-text-dim);
        background: color-mix(in oklch, var(--arena-bg) 85%, transparent);
      }
      .arena-app .build__gate[data-tone="pass"] { border-left-color: var(--arena-ok); }
      .arena-app .build__gate[data-tone="hold"] { border-left-color: var(--arena-warn); }
      .arena-app .build__gate[data-tone="pending"] { border-left-color: var(--arena-text-dim); }
      .arena-app .build__gate-stage {
        grid-area: stage; display: flex; align-items: center; gap: 0.4rem;
        font-size: 0.72rem; font-weight: 600; color: var(--arena-text);
      }
      .arena-app .build__gate-code {
        font-family: var(--arena-mono); font-size: 0.5rem; color: var(--arena-text-dim);
        padding: 0.02rem 0.28rem; border-radius: 0.2rem; border: 1px solid var(--arena-border);
      }
      .arena-app .build__gate-name {
        grid-area: name; font-family: var(--arena-mono); font-size: 0.6rem;
        color: var(--arena-text-mute);
      }
      .arena-app .build__gate-ctrl {
        grid-area: ctrl; display: inline-flex; align-items: center; gap: 0.3rem;
        font-family: var(--arena-mono); font-size: 0.56rem; letter-spacing: 0.05em;
        padding: 0.1rem 0.42rem; border-radius: 0.3rem; border: 1px solid var(--arena-text-dim);
        color: var(--arena-text-dim);
      }
      .arena-app .build__gate-ctrl[data-tone="pass"] {
        color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 45%, var(--arena-border));
        background: color-mix(in oklch, var(--arena-ok) 8%, transparent);
      }
      .arena-app .build__gate-ctrl[data-tone="hold"] {
        color: var(--arena-warn); border-color: color-mix(in oklch, var(--arena-warn) 45%, var(--arena-border));
        background: color-mix(in oklch, var(--arena-warn) 8%, transparent);
      }
      .arena-app .build__gate-ctrl-dot {
        width: 0.4rem; height: 0.4rem; border-radius: 50%; background: currentColor;
      }
      .arena-app .build__gate-conseq {
        grid-area: conseq; font-size: 0.6rem; line-height: 1.4; color: var(--arena-text-dim);
      }

      /* ---------------------------------------------------------------
       *  SFT training feed — live NeMo p65 LoRA SFT (/arena/sft/) — AF
       * --------------------------------------------------------------- */
      .arena-app .sft { display: flex; flex-direction: column; gap: 1rem; }
      .arena-app .sft__offline, .arena-app .sft__empty {
        display: flex; align-items: flex-start; gap: 0.7rem; padding: 1rem 1.1rem;
        border: 1px dashed var(--arena-border); border-radius: 0.5rem;
        color: var(--arena-text-mute); font-size: 0.8rem; line-height: 1.5;
      }
      .arena-app .sft__offline code, .arena-app .sft__empty code {
        font-family: var(--arena-mono); color: var(--arena-accent); font-size: 0.92em;
      }
      .arena-app .sft__offline strong, .arena-app .sft__empty strong { color: var(--arena-text); }
      .arena-app .sft__offline-dot {
        flex: 0 0 auto; width: 0.5rem; height: 0.5rem; margin-top: 0.35rem;
        border-radius: 50%; background: var(--arena-text-dim);
      }
      /* Run-history selector */
      .arena-app .sft__history { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 0.7rem; }
      .arena-app .sft__history-label {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .sft__history-select {
        font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text);
        background: var(--arena-panel); border: 1px solid var(--arena-border);
        border-radius: 0.4rem; padding: 0.3rem 0.5rem; cursor: pointer; max-width: 100%;
      }
      .arena-app .sft__history-select:hover { border-color: var(--arena-accent); }
      .arena-app .sft__history-now { font-size: 0.62rem; color: var(--arena-text-mute); }
      .arena-app .sft__history-now code { font-family: var(--arena-mono); color: var(--arena-text-dim); }
      /* Live strip — phase + iter progress bar + ETA */
      .arena-app .sft__live {
        display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 0.8rem;
        padding: 0.55rem 0.9rem; border: 1px solid var(--arena-border);
        border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .sft__live[data-running="true"] { border-color: var(--arena-accent); }
      .arena-app .sft__live-dot {
        width: 0.5rem; height: 0.5rem; border-radius: 50%; background: var(--arena-text-dim); flex: none;
      }
      .arena-app .sft__live-dot[data-running="true"] {
        background: var(--arena-accent); animation: sft-live-pulse 1.4s ease-in-out infinite;
      }
      @keyframes sft-live-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
      @media (prefers-reduced-motion: reduce) { .arena-app .sft__live-dot[data-running="true"] { animation: none; } }
      .arena-app .sft__live-label {
        font-family: var(--arena-mono); font-size: 0.66rem; font-weight: 700;
        letter-spacing: 0.14em; color: var(--arena-text-dim);
      }
      .arena-app .sft__live[data-running="true"] .sft__live-label { color: var(--arena-accent); }
      .arena-app .sft__live-count { font-family: var(--arena-mono); font-size: 0.66rem; color: var(--arena-text); }
      .arena-app .sft__live-bar {
        flex: 1; min-width: 120px; height: 0.4rem; border-radius: 0.3rem;
        background: var(--arena-line); overflow: hidden;
      }
      .arena-app .sft__live-fill {
        height: 100%; background: var(--arena-accent); border-radius: 0.3rem; transition: width 0.4s ease;
      }
      .arena-app .sft__live-fill[data-done="true"] { background: var(--arena-ok); }
      .arena-app .sft__live-eta { font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-mute); }
      /* Headline gauges */
      .arena-app .sft__gauges {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.9rem;
      }
      .arena-app .sft__gauge {
        display: flex; flex-direction: column; gap: 0.15rem; padding: 0.9rem 1rem;
        border: 1px solid var(--arena-border); border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .sft__gauge--accent { border-color: var(--arena-accent); }
      .arena-app .sft__gauge[data-alarm="true"] { border-color: var(--arena-warn); }
      .arena-app .sft__gauge-val {
        font-family: var(--arena-mono); font-size: 1.6rem; font-weight: 700; color: var(--arena-text); line-height: 1;
      }
      .arena-app .sft__gauge[data-alarm="true"] .sft__gauge-val { color: var(--arena-warn); }
      .arena-app .sft__gauge-unit { font-size: 0.8rem; font-weight: 400; color: var(--arena-text-dim); margin-left: 0.15rem; }
      .arena-app .sft__gauge-label {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .sft__gauge-sub { font-size: 0.64rem; color: var(--arena-text-mute); }
      /* Loss curve */
      .arena-app .sft__curve {
        display: flex; flex-direction: column; gap: 0.5rem; padding: 0.9rem 1rem;
        border: 1px solid var(--arena-border); border-radius: 0.5rem; background: var(--arena-panel);
      }
      .arena-app .sft__curve-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap; }
      .arena-app .sft__curve-title {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .sft__curve-meta { font-size: 0.62rem; color: var(--arena-text-mute); }
      .arena-app .sft__curve-meta code { font-family: var(--arena-mono); color: var(--arena-text-dim); }
      /* AE-25 / BUG-1 — canonical-heartbeat provenance + failed-run error line */
      .arena-app .sft__feed-chip {
        font-family: var(--arena-mono); font-size: 0.5rem; letter-spacing: 0.06em;
        text-transform: uppercase; padding: 0.04rem 0.34rem; margin-right: 0.45rem;
        border-radius: 0.6rem; border: 1px solid var(--arena-accent); color: var(--arena-accent);
      }
      .arena-app .sft__error {
        font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-warn);
        border: 1px dashed var(--arena-warn); border-radius: 0.4rem;
        background: rgba(255,180,80,0.07); padding: 0.45rem 0.7rem; line-height: 1.45;
        overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
        -webkit-line-clamp: 3; -webkit-box-orient: vertical;
      }
      .arena-app .sft__spark { width: 100%; height: 96px; display: block; }
      .arena-app .sft__spark-area { fill: var(--arena-accent); opacity: 0.10; }
      .arena-app .sft__spark-line { fill: none; stroke: var(--arena-accent); stroke-width: 1.6; vector-effect: non-scaling-stroke; }
      .arena-app .sft__spark-dot { fill: var(--arena-accent); }
      /* Checkpoints */
      .arena-app .sft__ckpts { display: flex; align-items: center; flex-wrap: wrap; gap: 0.4rem 0.6rem; }
      .arena-app .sft__ckpts-label {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .sft__ckpt {
        font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text);
        background: var(--arena-panel); border: 1px solid var(--arena-border);
        border-radius: 0.3rem; padding: 0.15rem 0.45rem;
      }
      .arena-app .sft__ckpts-none { font-size: 0.62rem; color: var(--arena-text-mute); }
      .arena-app .sft__foot {
        font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim); letter-spacing: 0.03em; line-height: 1.6;
      }
      .arena-app .sft__foot b { color: var(--arena-accent); }
      .arena-app .sft__foot code { color: var(--arena-text-mute); }
      .arena-app .sft__foot a { color: var(--arena-accent); text-decoration: none; }
      .arena-app .sft__foot a:hover { text-decoration: underline; }

      /* Built-together timeline */
      .arena-app .lab-timeline { margin: 1.75rem 0 1rem; }
      .arena-app .lab-timeline__head {
        display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 0.8rem;
      }
      .arena-app .lab-timeline__title {
        font-family: var(--arena-mono); font-size: 0.74rem; font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase; color: var(--arena-text);
      }
      .arena-app .lab-timeline__sub { font-size: 0.68rem; color: var(--arena-text-dim); }
      .arena-app .lab-timeline__list { list-style: none; margin: 0; padding: 0; }
      .arena-app .lab-timeline__item {
        display: grid; grid-template-columns: 6rem 14px 1fr auto; align-items: center; gap: 0.6rem;
        padding: 0.4rem 0; border-bottom: 1px solid var(--arena-line);
      }
      .arena-app .lab-timeline__date {
        font-family: var(--arena-mono); font-size: 0.64rem; color: var(--arena-text-dim);
      }
      .arena-app .lab-timeline__dot {
        width: 7px; height: 7px; border-radius: 50%; background: var(--arena-accent);
        box-shadow: 0 0 6px var(--arena-accent-glow); justify-self: center;
      }
      .arena-app .lab-timeline__title-text { font-size: 0.76rem; color: var(--arena-text-mute); }
      .arena-app .lab-timeline__hash {
        font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-dim);
      }

      /* =====================================================================
       *  Models / Capabilities browser (/arena/models/)
       * =================================================================== */
      .model-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      .model-card {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        padding: 1rem 1.1rem 0.9rem;
        color: var(--arena-text);
        transition: border-color 130ms ease, transform 130ms ease, box-shadow 130ms ease;
      }
      .model-card:hover {
        border-color: color-mix(in oklch, var(--arena-accent) 35%, var(--arena-line));
        transform: translateY(-2px);
        box-shadow:
          inset 0 1px 0 oklch(1 0 0 / 0.05),
          0 14px 40px -22px color-mix(in oklch, var(--arena-accent-glow) 60%, transparent);
      }
      .model-card__top {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        font-family: var(--arena-mono);
        font-size: 0.56rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .model-card__kind {
        padding: 0.12rem 0.45rem;
        border-radius: 3px;
        border: 1px solid var(--arena-line);
        color: var(--arena-text-mute);
      }
      .model-card__kind--models { color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line)); }
      .model-card__kind--benches { color: var(--arena-accent-glow); border-color: color-mix(in oklch, var(--arena-accent) 40%, var(--arena-line)); }
      .model-card__vertical { color: var(--arena-text-dim); }
      .model-card__tier { margin-left: auto; color: var(--arena-text-dim); }
      .model-card__headline {
        font-family: var(--arena-font);
        font-size: 1.02rem;
        line-height: 1.25;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 0;
        color: var(--arena-text);
      }
      .model-card__base {
        font-family: var(--arena-mono);
        font-size: 0.68rem;
        color: var(--arena-text-mute);
        margin: 0;
        word-break: break-all;
      }
      .model-card__stack {
        align-self: flex-start;
        font-family: var(--arena-mono);
        font-size: 0.55rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        padding: 0.1rem 0.4rem;
        border: 1px solid var(--arena-line);
        border-radius: 3px;
      }
      .model-card__foot {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.6rem;
        margin-top: auto;
        padding-top: 0.6rem;
        border-top: 1px solid var(--arena-line-soft);
        font-family: var(--arena-mono);
        font-size: 0.68rem;
      }
      .model-card__rec { color: var(--arena-text-mute); }
      .model-card__rec b { color: var(--arena-text); }
      .model-card__rec-tok { color: var(--arena-accent-glow); }
      .model-card__go { color: var(--arena-accent); letter-spacing: 0.04em; }

      /* ---- detail page ---- */
      .model-detail__crumb {
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        letter-spacing: 0.1em;
        margin: 0 0 0.6rem;
      }
      .model-detail__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: baseline;
        margin: 0.7rem 0 0;
        font-size: 0.78rem;
        color: var(--arena-text-mute);
      }
      .model-detail__meta b { color: var(--arena-text); }
      .model-detail__meta-sep { color: var(--arena-line); }
      .model-detail__grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 19rem);
        gap: 1.25rem;
        align-items: start;
      }
      @media (max-width: 1000px) { .model-detail__grid { grid-template-columns: 1fr; } }
      .model-detail__main { display: flex; flex-direction: column; gap: 1.1rem; }
      .model-detail__side { display: flex; flex-direction: column; gap: 1.1rem; position: sticky; top: 200px; }
      @media (max-width: 1000px) { .model-detail__side { position: static; } }
      .model-detail__panel { overflow: hidden; }
      .model-detail__uses { margin: 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; line-height: 1.5; color: var(--arena-text-mute); }
      .model-detail__uses li { color: var(--arena-text); }
      .model-detail__audience { margin: 0.85rem 0 0; font-size: 0.85rem; color: var(--arena-text-mute); line-height: 1.5; }
      .model-detail__table th, .model-detail__table td { font-family: var(--arena-mono); }
      .model-detail__row--rec { background: color-mix(in oklch, var(--arena-gold) 9%, transparent); }
      .model-detail__row--rec td { color: var(--arena-text); }
      .model-detail__rec-badge {
        margin-left: 0.5rem;
        font-size: 0.55rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: oklch(0.18 0.04 80);
        background: var(--arena-gold);
        padding: 0.08rem 0.4rem;
        border-radius: 3px;
      }
      .model-detail__note { margin: 0.6rem 1.1rem 0.9rem; font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim); }
      .model-detail__drift { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
      .model-detail__drift li { display: flex; flex-direction: column; gap: 0.2rem; padding-left: 0.85rem; border-left: 2px solid color-mix(in oklch, var(--arena-warn) 50%, var(--arena-line)); }
      .model-detail__drift-item { color: var(--arena-text); font-size: 0.88rem; }
      .model-detail__drift-bound { color: var(--arena-text-mute); font-size: 0.78rem; line-height: 1.45; }
      .model-detail__links { display: flex; flex-direction: column; gap: 0.5rem; }
      .model-detail__links .arena-btn { justify-content: center; }
      .model-detail__local { margin: 0 0 0.5rem; font-size: 0.8rem; color: var(--arena-text-mute); }
      .model-detail__cmd { margin: 0 0 0.5rem; padding: 0.7rem 0.85rem; background: var(--arena-bg-deep); border: 1px solid var(--arena-line); border-radius: 6px; font-family: var(--arena-mono); font-size: 0.74rem; color: var(--arena-accent-glow); overflow-x: auto; }

      /* =====================================================================
       *  FrontierScatter — efficiency frontier chart (leaderboard + model curve)
       * =================================================================== */
      .frontier-scatter { position: relative; width: 100%; }
      .frontier-scatter--empty { padding: 2rem 1rem; text-align: center; }
      .frontier-plot { width: 100%; color: var(--arena-text-dim); }
      .frontier-plot .u-axis { color: var(--arena-text-dim); }
      .frontier-tip {
        position: absolute;
        z-index: 5;
        transform: translate(-50%, calc(-100% - 12px));
        pointer-events: none;
        background: var(--arena-panel);
        border: 1px solid color-mix(in oklch, var(--arena-accent) 30%, var(--arena-line));
        border-radius: 6px;
        padding: 0.45rem 0.6rem;
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        color: var(--arena-text-mute);
        white-space: nowrap;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        box-shadow: 0 10px 28px -10px rgba(0,0,0,0.6);
      }
      .frontier-tip b { color: var(--arena-text); font-size: 0.74rem; }
      .frontier-tip__grp { color: var(--arena-text-dim); }
      .frontier-tip__row { color: var(--arena-accent-glow); }
      .frontier-tip__pareto { color: var(--arena-gold); }
      .frontier-tip__rec { color: var(--arena-gold); }
      .frontier-legend {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.6rem;
        padding-top: 0.6rem;
        border-top: 1px solid var(--arena-line-soft);
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        color: var(--arena-text-mute);
      }
      .frontier-legend__item { display: inline-flex; align-items: center; gap: 0.4rem; }
      .frontier-legend__swatch { width: 10px; height: 10px; border-radius: 50%; }
      .frontier-legend__swatch--line { width: 14px; height: 3px; border-radius: 2px; }
      .frontier-legend__note { color: var(--arena-text-dim); margin-left: auto; }

      .lb-frontier { margin-bottom: 1.5rem; }
      .lb-frontier__lede {
        margin: 0 0 1rem;
        max-width: 70ch;
        font-size: 0.92rem;
        line-height: 1.6;
        color: var(--arena-text-mute);
      }
      .lb-frontier__lede b { color: var(--arena-text); }
      .lb-frontier__lede em { color: var(--arena-accent-glow); font-style: normal; }
      .lb-frontier__foot {
        margin: 0.8rem 0 0;
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        line-height: 1.5;
        color: var(--arena-text-dim);
      }

      /* =====================================================================
       *  Compare — winner banner + head-to-head delta strip (v0.2)
       * =================================================================== */
      .arena-app .compare-winner {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        margin: 1rem 0 0.4rem;
        padding: 0.7rem 1rem;
        border: 1px solid color-mix(in oklch, var(--win-accent) 45%, var(--arena-line));
        border-radius: 8px;
        background: color-mix(in oklch, var(--win-accent) 9%, var(--arena-panel));
        box-shadow: 0 0 0 1px color-mix(in oklch, var(--win-accent) 12%, transparent),
                    0 8px 30px -16px var(--win-accent);
        animation: arena-rise-in 280ms ease-out both;
      }
      .arena-app .compare-winner__tag {
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app .compare-winner__text { font-size: 0.95rem; color: var(--arena-text-mute); }
      .arena-app .compare-winner__text b { color: var(--win-accent); }

      /* Head-to-head metric cards — telemetry-rail vocabulary (label · value ·
         peak-bar sparkline of the session's runs). Replaces the old DeltaStrip. */
      .arena-app .compare-metrics {
        margin: 0.6rem 0 0.7rem;
        border: 1px solid var(--arena-line);
        border-radius: 10px;
        background: color-mix(in oklch, var(--arena-bg-deep) 55%, transparent);
        overflow: hidden;
      }
      .arena-app .compare-metrics__legend {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.6rem;
        padding: 0.5rem 0.85rem;
        border-bottom: 1px solid var(--arena-line);
      }
      .arena-app .compare-metrics__head {
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app .compare-metrics__key {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--arena-mono);
        font-size: 0.6rem;
      }
      .arena-app .compare-metrics__keytext { color: var(--arena-text-dim); letter-spacing: 0.03em; }
      .arena-app .compare-metrics__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
        gap: 1px;
        background: var(--arena-line);
      }
      .arena-app .compare-metric {
        display: flex;
        flex-direction: column;
        gap: 0.32rem;
        padding: 0.6rem 0.8rem 0.65rem;
        background: var(--arena-bg-deep);
        min-width: 0;
      }
      .arena-app .compare-metric__label {
        font-family: var(--arena-mono);
        font-size: 0.57rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app .compare-metric__vals {
        display: flex;
        align-items: baseline;
        gap: 0.38rem;
        font-family: var(--arena-mono);
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .arena-app .compare-metric__vs {
        font-size: 0.56rem;
        color: var(--arena-text-dim);
        letter-spacing: 0.04em;
      }
      .arena-app .compare-metric__spark {
        display: flex;
        flex-direction: column;
        gap: 1px;
        margin-top: 0.12rem;
      }
      .arena-app .compare-metric__canvas {
        width: 100%;
        height: 9px;
        display: block;
        opacity: 0.92;
      }

      /* =====================================================================
       *  ⌘K command palette
       * =================================================================== */
      .arena-app .cmdk {
        position: fixed;
        inset: 0;
        z-index: 80;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 12vh;
        background: oklch(0.06 0.01 250 / 0.62);
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
        animation: arena-rise-in 120ms ease-out both;
      }
      .arena-app .cmdk__panel {
        width: min(40rem, 92vw);
        max-height: 70vh;
        display: flex;
        flex-direction: column;
        background: var(--arena-panel);
        border: 1px solid color-mix(in oklch, var(--arena-accent) 28%, var(--arena-line));
        border-radius: 12px;
        overflow: hidden;
        box-shadow:
          0 0 0 1px oklch(0 0 0 / 0.4),
          0 30px 80px -24px oklch(0 0 0 / 0.7),
          0 0 60px -30px var(--arena-accent-glow);
      }
      .arena-app .cmdk__inputrow {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 0.9rem;
        border-bottom: 1px solid var(--arena-line);
        background: var(--arena-panel-2);
      }
      .arena-app .cmdk__prompt {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.16em;
        color: var(--arena-accent-glow);
        border: 1px solid var(--arena-line);
        border-radius: 4px;
        padding: 0.18rem 0.4rem;
      }
      .arena-app .cmdk__input {
        flex: 1;
        background: transparent;
        border: 0;
        outline: none;
        color: var(--arena-text);
        font-family: var(--arena-font);
        font-size: 1rem;
      }
      .arena-app .cmdk__input::placeholder { color: var(--arena-text-dim); }
      .arena-app .cmdk__esc {
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        color: var(--arena-text-dim);
        border: 1px solid var(--arena-line);
        border-radius: 3px;
        padding: 0.1rem 0.4rem;
      }
      .arena-app .cmdk__results { overflow-y: auto; padding: 0.35rem; }
      .arena-app .cmdk__empty { padding: 1.4rem 1rem; text-align: center; color: var(--arena-text-mute); font-size: 0.85rem; }
      .arena-app .cmdk__row {
        display: grid;
        grid-template-columns: 1.4rem 1fr auto auto;
        align-items: baseline;
        gap: 0.6rem;
        width: 100%;
        text-align: left;
        background: transparent;
        border: 0;
        border-radius: 6px;
        padding: 0.5rem 0.65rem;
        cursor: pointer;
        color: var(--arena-text);
        font-family: var(--arena-font);
      }
      .arena-app .cmdk__row--active { background: color-mix(in oklch, var(--arena-accent) 16%, transparent); }
      .arena-app .cmdk__glyph { font-size: 0.8rem; color: var(--arena-text-dim); }
      .arena-app .cmdk__glyph--model { color: var(--arena-ok); }
      .arena-app .cmdk__glyph--action { color: var(--arena-accent-glow); }
      .arena-app .cmdk__glyph--lane { color: var(--arena-warn); }
      .arena-app .cmdk__label { font-size: 0.88rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .arena-app .cmdk__sub { font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-dim); white-space: nowrap; }
      .arena-app .cmdk__type {
        font-family: var(--arena-mono);
        font-size: 0.54rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app .cmdk__foot {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0.5rem 0.9rem;
        border-top: 1px solid var(--arena-line);
        background: var(--arena-bg-deep);
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.08em;
        color: var(--arena-text-dim);
      }
      .arena-app .cmdk__foot kbd {
        font-family: var(--arena-mono);
        font-size: 0.55rem;
        padding: 0.06rem 0.32rem;
        border: 1px solid var(--arena-line);
        border-radius: 3px;
        color: var(--arena-text-mute);
        margin-right: 0.15rem;
      }
      .arena-app .cmdk__foot-spacer { flex: 1; }

      /* ================= v0.3 — eval prompts ================= */

      .arena-app .eval-trigger { white-space: nowrap; }

      /* Slide-over drawer */
      .arena-app .eval-drawer__scrim {
        position: fixed; inset: 0; z-index: 60;
        background: color-mix(in oklch, var(--arena-bg-deep) 60%, transparent);
        backdrop-filter: blur(1px);
      }
      .arena-app .eval-drawer {
        position: fixed; top: 0; right: 0; bottom: 0; z-index: 61;
        width: min(34rem, 92vw);
        display: flex; flex-direction: column;
        border-radius: 0;
        border-left: 1px solid var(--arena-line);
        background: var(--arena-panel);
        animation: eval-drawer-in 0.16s ease-out;
      }
      @keyframes eval-drawer-in { from { transform: translateX(1.5rem); opacity: 0.4; } to { transform: none; opacity: 1; } }
      .arena-app .eval-drawer__head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--arena-line);
      }
      .arena-app .eval-drawer__title { font-family: var(--arena-mono); font-size: 0.8rem; letter-spacing: 0.04em; }
      .arena-app .eval-drawer__close {
        background: none; border: none; color: var(--arena-text-mute);
        cursor: pointer; font-size: 0.9rem; padding: 0.2rem 0.4rem;
      }
      .arena-app .eval-drawer__close:hover { color: var(--arena-text); }
      .arena-app .eval-drawer__benchbar {
        display: flex; flex-wrap: wrap; gap: 0.3rem;
        padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--arena-line-soft);
      }
      .arena-app .eval-drawer__benchpill {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.22rem 0.5rem; border-radius: 5px;
        border: 1px solid var(--arena-line);
        background: var(--arena-panel-2); color: var(--arena-text-mute);
        font-size: 0.66rem; font-family: var(--arena-mono); cursor: pointer;
      }
      .arena-app .eval-drawer__benchpill:hover { color: var(--arena-text); border-color: var(--arena-accent-dim); }
      .arena-app .eval-drawer__benchpill.is-active {
        color: var(--arena-bg); background: var(--arena-accent);
        border-color: var(--arena-accent);
      }
      .arena-app .eval-drawer__benchpill-tag {
        font-size: 0.5rem; letter-spacing: 0.06em; text-transform: uppercase;
        padding: 0.05rem 0.25rem; border-radius: 3px;
        background: color-mix(in oklch, var(--arena-ok) 22%, transparent);
        color: var(--arena-ok);
      }
      .arena-app .eval-drawer__benchpill-tag--x {
        background: color-mix(in oklch, var(--arena-warn) 20%, transparent);
        color: var(--arena-warn);
      }
      .arena-app .eval-drawer__benchpill.is-active .eval-drawer__benchpill-tag { background: color-mix(in oklch, var(--arena-bg) 30%, transparent); color: var(--arena-bg); }
      .arena-app .eval-drawer__filterbar {
        display: flex; gap: 0.4rem; padding: 0.5rem 0.9rem;
        border-bottom: 1px solid var(--arena-line-soft);
      }
      .arena-app .eval-drawer__search {
        flex: 1; padding: 0.35rem 0.5rem; border-radius: 5px;
        border: 1px solid var(--arena-line); background: var(--arena-bg);
        color: var(--arena-text); font-size: 0.72rem; font-family: var(--arena-mono);
      }
      .arena-app .eval-drawer__familysel { max-width: 9rem; }
      .arena-app .eval-drawer__list { flex: 1; overflow-y: auto; padding: 0.5rem; display: flex; flex-direction: column; gap: 0.35rem; }
      .arena-app .eval-drawer__loading,
      .arena-app .eval-drawer__empty { color: var(--arena-text-dim); font-size: 0.72rem; padding: 1rem; text-align: center; }
      .arena-app .eval-drawer__more {
        margin: 0.3rem auto; padding: 0.35rem 0.8rem; cursor: pointer;
        background: var(--arena-panel-2); border: 1px solid var(--arena-line);
        border-radius: 5px; color: var(--arena-text-mute); font-size: 0.66rem;
      }
      .arena-app .eval-drawer__more:hover { color: var(--arena-text); }

      .arena-app .eval-row {
        display: flex; flex-direction: column; gap: 0.35rem; text-align: left;
        padding: 0.55rem 0.6rem; border-radius: 6px;
        border: 1px solid var(--arena-line-soft); background: var(--arena-panel-2);
        cursor: pointer; width: 100%;
      }
      .arena-app .eval-row:hover { border-color: var(--arena-accent-dim); background: var(--arena-panel-3); }
      .arena-app .eval-row__q {
        font-size: 0.74rem; line-height: 1.35; color: var(--arena-text);
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      }
      .arena-app .eval-row__meta { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }

      /* Badges (shared by drawer rows + the eval chip) */
      .arena-app .eval-badge {
        font-family: var(--arena-mono); font-size: 0.55rem; letter-spacing: 0.04em;
        padding: 0.08rem 0.34rem; border-radius: 3px; white-space: nowrap;
        border: 1px solid var(--arena-line);
        color: var(--arena-text-mute); background: var(--arena-panel);
      }
      .arena-app .eval-badge--fam { color: var(--arena-text); border-color: var(--arena-accent-dim); }
      .arena-app .eval-badge--det { color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line)); }
      .arena-app .eval-badge--judge { color: var(--arena-accent-glow); border-color: var(--arena-accent-dim); }
      .arena-app .eval-badge--ref { color: var(--arena-warn); border-color: color-mix(in oklch, var(--arena-warn) 40%, var(--arena-line)); }
      .arena-app .eval-badge--ctx { color: var(--arena-text-dim); }
      /* AE-11 — astro preview facets (tier / subtopic / inline gold). */
      .arena-app .eval-badge--tier { color: var(--arena-accent-glow); border-color: var(--arena-accent-dim); }
      .arena-app .eval-badge--sub { color: var(--arena-text-dim); border-color: var(--arena-line); }
      .arena-app .eval-badge--gold { color: var(--arena-warn); border-color: color-mix(in oklch, var(--arena-warn) 40%, var(--arena-line)); font-weight: 600; }

      /* AE-10 — scout candidates panel on the Compare pane. */
      .arena-app .scout-panel { margin: 0 0 0.85rem; padding: 0; overflow: hidden; }
      .arena-app .scout-panel__summary {
        display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
        padding: 0.5rem 0.75rem; list-style: none; user-select: none;
        font-family: var(--arena-mono); font-size: 0.66rem;
      }
      .arena-app .scout-panel__summary::-webkit-details-marker { display: none; }
      .arena-app .scout-panel__icon { font-size: 0.8rem; }
      .arena-app .scout-panel__title { color: var(--arena-text); font-weight: 700; letter-spacing: 0.04em; }
      .arena-app .scout-panel__run { color: var(--arena-text-dim); }
      .arena-app .scout-panel__count {
        margin-left: auto; color: var(--arena-text-mute); font-size: 0.6rem;
        padding: 0.08rem 0.4rem; border: 1px solid var(--arena-line); border-radius: 999px;
      }
      .arena-app .scout-panel__body { padding: 0.25rem 0.75rem 0.8rem; border-top: 1px solid var(--arena-line); }
      .arena-app .scout-panel__gate {
        margin: 0.6rem 0 0.7rem; font-size: 0.7rem; line-height: 1.5;
        color: var(--arena-text-dim);
      }
      .arena-app .scout-panel__gate b { color: var(--arena-accent-glow); }
      .arena-app .scout-panel__picks {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
        gap: 0.5rem;
      }
      .arena-app .scout-pick {
        border: 1px solid var(--arena-line); border-radius: 5px;
        padding: 0.5rem 0.6rem; background: var(--arena-panel);
      }
      .arena-app .scout-pick__head { display: flex; align-items: center; gap: 0.4rem; }
      .arena-app .scout-pick__rank {
        font-family: var(--arena-mono); font-size: 0.62rem; font-weight: 700;
        color: var(--arena-accent-glow);
      }
      .arena-app .scout-pick__repo { font-size: 0.66rem; color: var(--arena-text); overflow-wrap: anywhere; }
      .arena-app .scout-pick__score {
        margin-left: auto; flex: none; font-family: var(--arena-mono); font-size: 0.6rem;
        font-weight: 700; color: var(--arena-ok);
      }
      .arena-app .scout-pick__tag { margin: 0.35rem 0; font-size: 0.66rem; color: var(--arena-text-dim); }
      .arena-app .scout-pick__axes { display: flex; flex-wrap: wrap; gap: 0.25rem; }
      .arena-app .scout-axis {
        display: inline-flex; align-items: baseline; gap: 0.2rem;
        font-family: var(--arena-mono); font-size: 0.54rem;
        padding: 0.06rem 0.3rem; border: 1px solid var(--arena-line); border-radius: 3px;
      }
      .arena-app .scout-axis__k { color: var(--arena-text-mute); text-transform: uppercase; letter-spacing: 0.04em; }
      .arena-app .scout-axis__v { color: var(--arena-text); }
      .arena-app .scout-axis--ok { border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line)); }
      .arena-app .scout-axis--ok .scout-axis__v { color: var(--arena-ok); }
      .arena-app .scout-axis--warn { border-color: color-mix(in oklch, var(--arena-warn) 40%, var(--arena-line)); }
      .arena-app .scout-axis--warn .scout-axis__v { color: var(--arena-warn); }
      .arena-app .scout-pick__warn { margin: 0.4rem 0 0; font-size: 0.6rem; color: var(--arena-warn); }
      .arena-app .scout-panel__ruled { margin-top: 0.7rem; font-size: 0.64rem; color: var(--arena-text-dim); }
      .arena-app .scout-panel__ruled summary { cursor: pointer; color: var(--arena-text-mute); }
      .arena-app .scout-panel__ruled-list { margin: 0.4rem 0 0; padding-left: 1rem; display: grid; gap: 0.25rem; }
      .arena-app .scout-panel__ruled-list code { color: var(--arena-text); }
      .arena-app .scout-panel__note { margin: 0.75rem 0 0; font-size: 0.64rem; color: var(--arena-text-mute); }
      .arena-app .scout-panel__gatebtn {
        font-family: var(--arena-mono); font-size: 0.62rem; cursor: pointer;
        color: var(--arena-accent-glow); background: transparent;
        border: 1px solid var(--arena-accent-dim); border-radius: 4px;
        padding: 0.12rem 0.45rem;
      }
      .arena-app .scout-panel__gatebtn:hover { background: color-mix(in oklch, var(--arena-accent-glow) 12%, transparent); }

      /* Eval chip (above the composer) */
      .arena-app .eval-chip {
        display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
        gap: 0.5rem; margin-bottom: 0.4rem; padding: 0.4rem 0.55rem;
        border-radius: 6px; border: 1px solid var(--arena-accent-dim);
        background: color-mix(in oklch, var(--arena-accent) 8%, var(--arena-panel));
      }
      .arena-app .eval-chip__main { display: flex; flex-wrap: wrap; align-items: center; gap: 0.35rem; }
      .arena-app .eval-chip__bench { font-family: var(--arena-mono); font-size: 0.7rem; color: var(--arena-text); }
      .arena-app .eval-chip__edited { font-size: 0.6rem; color: var(--arena-warn); }
      .arena-app .eval-chip__right { display: flex; align-items: center; gap: 0.5rem; }
      .arena-app .eval-chip__clear {
        background: none; border: 1px solid var(--arena-line); border-radius: 4px;
        color: var(--arena-text-mute); cursor: pointer; font-size: 0.62rem; padding: 0.15rem 0.4rem;
      }
      .arena-app .eval-chip__clear:hover { color: var(--arena-text); border-color: var(--arena-text-mute); }

      /* Judge segmented control */
      .arena-app .judge-select { display: inline-flex; align-items: center; gap: 0.25rem; }
      .arena-app .judge-select--muted { font-size: 0.6rem; color: var(--arena-ok); font-family: var(--arena-mono); }
      .arena-app .judge-select__label { font-size: 0.58rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--arena-text-dim); }
      .arena-app .judge-select__seg {
        padding: 0.14rem 0.45rem; font-size: 0.62rem; cursor: pointer;
        border: 1px solid var(--arena-line); border-radius: 4px;
        background: var(--arena-panel-2); color: var(--arena-text-mute);
        font-family: var(--arena-mono);
      }
      .arena-app .judge-select__seg.is-active { background: var(--arena-accent); color: var(--arena-bg); border-color: var(--arena-accent); }
      .arena-app .judge-select__seg.is-disabled,
      .arena-app .judge-select__seg:disabled { opacity: 0.4; cursor: not-allowed; }

      /* Score block (chat turn + compare side/verdict) */
      .arena-app .chat-turn__eval,
      .arena-app .compare-side__eval { margin-top: 0.5rem; }
      .arena-app .eval-score { display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.72rem; }
      .arena-app .eval-score--pending { flex-direction: row; align-items: center; gap: 0.4rem; color: var(--arena-text-dim); }
      .arena-app .eval-score__row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
      .arena-app .eval-score__badge {
        font-family: var(--arena-mono); font-size: 0.58rem; padding: 0.1rem 0.4rem;
        border-radius: 4px; border: 1px solid var(--arena-line);
      }
      .arena-app .eval-score__badge--det { color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line)); }
      .arena-app .eval-score__badge--judge { color: var(--arena-accent-glow); border-color: var(--arena-accent-dim); }
      .arena-app .eval-score__badge--skip { color: var(--arena-warn); border-color: color-mix(in oklch, var(--arena-warn) 35%, var(--arena-line)); }
      .arena-app .eval-score__value { font-family: var(--arena-mono); font-weight: 600; color: var(--arena-text); }
      .arena-app .eval-score__meter { flex: 1; min-width: 4rem; height: 5px; border-radius: 3px; background: var(--arena-panel-3); overflow: hidden; }
      .arena-app .eval-score__meter-fill { display: block; height: 100%; }
      .arena-app .eval-score__meter-fill--ok { background: var(--arena-ok); }
      .arena-app .eval-score__meter-fill--mid { background: var(--arena-warn); }
      .arena-app .eval-score__meter-fill--low { background: oklch(0.62 0.2 25); }
      .arena-app .eval-score__why { font-size: 0.65rem; color: var(--arena-text-mute); }
      .arena-app .eval-score__rationale summary { font-size: 0.62rem; color: var(--arena-text-dim); cursor: pointer; }
      .arena-app .eval-score__rationale p { margin: 0.3rem 0 0; font-size: 0.66rem; color: var(--arena-text-mute); }
      .arena-app .eval-score__spinner {
        width: 0.7rem; height: 0.7rem; border-radius: 50%;
        border: 2px solid var(--arena-line); border-top-color: var(--arena-accent);
        animation: eval-spin 0.7s linear infinite;
      }
      @keyframes eval-spin { to { transform: rotate(360deg); } }

      /* Reference panels */
      .arena-app .eval-reference summary,
      .arena-app .compare-reference summary {
        cursor: pointer; font-size: 0.66rem; color: var(--arena-warn); font-family: var(--arena-mono);
      }
      .arena-app .eval-reference__body,
      .arena-app .compare-reference__body {
        margin: 0.4rem 0 0; padding: 0.5rem 0.6rem; border-radius: 5px;
        background: var(--arena-bg); border: 1px solid var(--arena-line-soft);
        font-size: 0.7rem; white-space: pre-wrap; color: var(--arena-text);
        max-height: 14rem; overflow-y: auto;
      }
      .arena-app .compare-reference { margin: 0.6rem 0; padding: 0.6rem 0.8rem; }
      .arena-app .eval-score-col {
        display: flex; flex-direction: column; gap: 0.4rem; padding: 0.6rem;
        border-radius: 6px; border: 1px solid var(--arena-line-soft);
        border-top: 2px solid var(--side-accent); background: var(--arena-panel-2);
      }
      .arena-app .eval-score-col .compare-score-col__tag { color: var(--side-accent); }
      .arena-app .compare-duel__evalnote { font-size: 0.66rem; color: var(--arena-text-mute); }

      /* ------------------------------------------------------------------ *
       * arena-enhancements v2 cut 2 — lane truth + run-context (AE-21..24)
       * ------------------------------------------------------------------ */
      /* AE-24 — the per-pane provenance chip: run-id · age · live ◉ / prior ○ */
      .arena-app .prov-chip {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-family: var(--arena-mono); font-size: 0.56rem; line-height: 1.4;
        padding: 0.04rem 0.4rem; border-radius: 0.35rem;
        border: 1px solid var(--arena-line); color: var(--arena-text-dim);
        white-space: nowrap;
      }
      .arena-app .prov-chip__run { color: var(--arena-text-mute); }
      .arena-app .prov-chip--live { color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line)); }
      .arena-app .prov-chip--live .prov-chip__mark { animation: arena-pulse 1.4s infinite; }
      .arena-app .prov-chip--current { color: var(--arena-ok); }
      .arena-app .prov-chip--prior { border-style: dashed; opacity: 0.8; }
      .arena-app .prov-chip--unanchored { opacity: 0.75; }
      /* AE-24 — prior-run rows on the live eval leaderboard group */
      .arena-app .evalbench tr[data-prior="true"] { opacity: 0.55; }
      .arena-app .evalbench tr[data-prior="true"]:hover { opacity: 1; }
      .arena-app .lane-cell__prior {
        font-family: var(--arena-mono); font-size: 0.54rem; color: var(--arena-text-dim);
        border: 1px dashed var(--arena-line); border-radius: 0.3rem; padding: 0.02rem 0.3rem;
        margin-left: 0.4rem;
      }
      /* AE-21 — rail lane-truth badge (drift / multi-lane) + the AE-23 run cell */
      .telemetry-rail__badge {
        font-family: var(--arena-mono); font-size: 0.5rem; line-height: 1.3;
        padding: 0.02rem 0.3rem; border-radius: 0.3rem; margin-left: 0.35rem;
        border: 1px solid var(--arena-line); color: var(--arena-text-dim);
      }
      .telemetry-rail__badge[data-state="warn"] {
        color: var(--arena-warn);
        border-color: color-mix(in oklch, var(--arena-warn) 45%, var(--arena-line));
        background: rgba(255,180,80,0.10);
      }
      .telemetry-rail__badge[data-state="ok"] {
        color: var(--arena-ok);
        border-color: color-mix(in oklch, var(--arena-ok) 35%, var(--arena-line));
      }
      .telemetry-rail__cell--run .telemetry-rail__value[data-state="ok"] { color: var(--arena-ok); }
      /* AE-21 — CurrentLane source/drift chips (cockpit card) */
      .arena-app .current-lane__chip--source { opacity: 0.8; }
      .arena-app .current-lane__chip--drift {
        color: var(--arena-warn);
        border-color: color-mix(in oklch, var(--arena-warn) 45%, var(--arena-line));
      }
      /* AE-21/22 — LaneTruth: the serving-lane system-of-record section (Models) */
      .arena-app .lanetruth { margin: 0 0 1rem; padding: 0.8rem 1rem; }
      .arena-app .lanetruth__probing { margin: 0; font-size: 0.72rem; color: var(--arena-text-dim); }
      .arena-app .lanetruth__head { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
      .arena-app .lanetruth__title {
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--arena-text);
      }
      .arena-app .lanetruth__sub { font-size: 0.62rem; color: var(--arena-text-dim); }
      .arena-app .lanetruth__clear {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.58rem;
        padding: 0.1rem 0.5rem; border-radius: 0.35rem; cursor: pointer;
        border: 1px solid var(--arena-line); background: transparent; color: var(--arena-text-dim);
      }
      .arena-app .lanetruth__clear:hover:not(:disabled) { color: var(--arena-text); border-color: var(--arena-text-dim); }
      .arena-app .lanetruth__drift {
        display: flex; align-items: center; gap: 0.5rem; margin: 0.55rem 0 0;
        padding: 0.4rem 0.6rem; border-radius: 0.4rem; font-size: 0.66rem;
        color: var(--arena-warn); background: rgba(255,180,80,0.10);
        border: 1px solid color-mix(in oklch, var(--arena-warn) 45%, var(--arena-line));
      }
      .arena-app .lanetruth__drift-mark { font-family: var(--arena-mono); font-weight: 700; white-space: nowrap; }
      .arena-app .lanetruth__err { margin: 0.45rem 0 0; font-size: 0.64rem; color: var(--arena-warn); }
      .arena-app .lanetruth__empty {
        margin: 0.55rem 0 0; font-size: 0.68rem; color: var(--arena-text-dim); line-height: 1.5;
      }
      .arena-app .lanetruth__list { list-style: none; margin: 0.55rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
      .arena-app .lanetruth__lane {
        display: flex; align-items: center; gap: 0.55rem;
        padding: 0.35rem 0.55rem; border-radius: 0.4rem;
        border: 1px solid var(--arena-line-soft); background: var(--arena-panel-2);
        font-size: 0.68rem;
      }
      .arena-app .lanetruth__lane[data-active="true"] {
        border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line));
      }
      .arena-app .lanetruth__dot {
        width: 7px; height: 7px; border-radius: 50%; flex: none;
        background: var(--arena-ok); box-shadow: 0 0 6px color-mix(in oklch, var(--arena-ok) 50%, transparent);
      }
      .arena-app .lanetruth__model { color: var(--arena-text); }
      .arena-app .lanetruth__meta { font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-dim); }
      .arena-app .lanetruth__active-tag {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.56rem;
        color: var(--arena-ok); border: 1px solid color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line));
        border-radius: 0.35rem; padding: 0.06rem 0.4rem; white-space: nowrap;
      }
      .arena-app .lanetruth__select {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.58rem;
        padding: 0.1rem 0.55rem; border-radius: 0.35rem; cursor: pointer;
        border: 1px solid var(--arena-line); background: transparent; color: var(--arena-text);
      }
      .arena-app .lanetruth__select:hover:not(:disabled) { border-color: var(--arena-ok); color: var(--arena-ok); }
      .arena-app .lanetruth__select:disabled, .arena-app .lanetruth__clear:disabled { opacity: 0.5; cursor: default; }
      .arena-app .lanetruth__note { margin: 0.5rem 0 0; font-size: 0.64rem; color: var(--arena-warn); }
      .arena-app .lanetruth__hint {
        margin: 0.5rem 0 0; font-size: 0.62rem; color: var(--arena-text-dim); opacity: 0.85;
      }
      .arena-app .lanetruth__hint-tag {
        font-family: var(--arena-mono); font-size: 0.54rem; text-transform: uppercase;
        border: 1px dashed var(--arena-line); border-radius: 0.3rem; padding: 0.02rem 0.3rem;
        margin-right: 0.35rem;
      }

      @media (prefers-reduced-motion: reduce) {
        .arena-app *,
        .arena-app *::before,
        .arena-app *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
        }
        .arena-app .cockpit-hero__head::after { display: none; }
      }
    </style>
  </body>
</html>
