---
/**
 * ArenaAppLayout — the standalone Spark Arena web app shell.
 *
 * Spec §1 / Desirability D1: "one-process cockpit, real-time, beautiful."
 * §1.3 frames Arena as a local-first take on the familiar model-arena surface
 * — same battle/leaderboard shape, but operator-driven, hardware-real. So the chrome IS
 * an app shell (top bar · persistent telemetry rail · main canvas) — NOT a
 * page-in-a-site. This layout deliberately bypasses BaseLayout: no editorial
 * Nav, no editorial Footer, no prose column, no light theme. The cockpit owns
 * its own viewport.
 *
 * The editorial site's design tokens (Geist Sans / Mono · OKLCH hue 250) are
 * reused as the substrate so the app feels of-the-house — but the app shell,
 * layout, and component vocabulary are bespoke. The bezel chrome, instrument
 * gauges, rank badges, and score bars below are the differentiated cockpit
 * surface — not generic dashboard parts.
 *
 * Pages mount inside <main class="arena-app__canvas"><slot /></main>. The
 * persistent telemetry rail above the canvas is a single <TelemetryGauge>
 * island reused across every Arena page; its sidecar-offline contract is
 * the same one M3 shipped.
 */
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource-variable/geist-mono';

import TelemetryRail from '../components/arena/TelemetryRail.astro';
import CommandPalette from '../components/arena/CommandPalette.jsx';
import { getCollection } from 'astro:content';
import leaderboardMirror from '../data/arena-mirror/leaderboard.json';
import { buildCommandIndex } from '../lib/arena/command-index.mjs';

interface Props {
  title: string;
  description?: string;
  /** Which top-nav tab is active. */
  active?: 'cockpit' | 'leaderboard' | 'chat' | 'compare' | 'models' | 'jobs' | 'standup' | 'sft' | 'reward' | 'build' | 'cortex' | 'lab';
  /** Hide the persistent telemetry rail on this page (e.g., a fullscreen compare). */
  hideRail?: boolean;
}

const { title, description, active = 'cockpit', hideRail = false } = Astro.props;

// Breadcrumb echo of the active tab, shown next to the wordmark so each page
// can drop its own oversized <h1> title block (the tab + this crumb already say
// "you are here"). Keep in sync with the tab list below.
const ACTIVE_LABELS: Record<string, string> = {
  cockpit: 'Cockpit',
  models: 'Models',
  leaderboard: 'Leaderboard',
  chat: 'Chat',
  compare: 'Compare',
  jobs: 'Jobs',
  standup: 'Standup',
  sft: 'SFT',
  reward: 'Reward',
  build: 'Build',
  cortex: 'Cortex',
  lab: 'Lab',
};
const activeLabel = ACTIVE_LABELS[active] ?? '';

// Chat + Compare are working panes — let them fill the viewport (full-bleed)
// rather than the 96rem reading cap that suits the leaderboard tables / model grid.
const wideCanvas = active === 'chat' || active === 'compare';

const desc = description ??
  'Orionfold Arena — the operator cockpit for the DGX Spark. Local-first chat, side-by-side rubric-scored compare, and a private leaderboard for every artifact your Spark has produced.';

// Demo bundle (`ARENA_DEMO=1`): boot the sidecar-less replay shim. Read at
// build time so the boot <script> is only emitted into the demo bundle.
const isDemo = process.env.ARENA_DEMO === '1';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '/') || '/';
// In the baked Arena bundle (`ARENA_BUILD=1`) `base` is already `/arena/` AND
// the `arena/**` routes are pruned to the bundle root, so `href('arena/chat/')`
// would double to `/arena/arena/chat/` (404). Strip the redundant leading
// segment in that mode only. Dev (`/`) and the public mirror (`/field-notes/`)
// keep it because their Arena pages live under `…/arena/`.
const bakedArena = base.replace(/\/$/, '').endsWith('/arena');
const href = (path: string) => {
  const rel = bakedArena && path.startsWith('arena/') ? path.slice('arena/'.length) : path;
  return `${base}${rel}`.replace(/\/+/g, '/');
};

// Build the ⌘K command index once per page (build-time; serialized into the
// island so search works offline on the public mirror).
let cmdIndex: any[] = [];
try {
  const [arts, articles] = await Promise.all([
    getCollection('artifacts'),
    getCollection('articles'),
  ]);
  cmdIndex = buildCommandIndex({ artifacts: arts, articles, leaderboard: leaderboardMirror, href });
} catch (_e) {
  cmdIndex = [];
}
---
<!doctype html>
<html lang="en" class="arena-app" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#0a0e14" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href={href('favicon.svg')} />
    <title>{title}</title>
    {isDemo && <script is:inline src={href('arena-demo/boot.js')}></script>}
  </head>
  <body class="arena-app__body">
    <!--
      Shared telemetry bus — ONE EventSource to /api/telemetry/stream for the
      whole page, fanned out to every consumer (the rail + the LiveLeaderboard /
      LiveVsBaseline / hero islands). Before this existed each consumer opened
      its OWN stream: the homepage held 3 and the leaderboard 2. With the
      browser's ~6-connection-per-origin HTTP/1.1 cap and the server's ~1-2 s
      lag to reap a navigated-away stream, rapid tab switching piled lingering
      streams past the cap, stalling the next page's stream/fetches and flashing
      a false "Sidecar offline". A single ref-counted, after-load connection
      keeps every page at one telemetry socket and kills that contention.

      Classic inline script (runs during parse, before any deferred island
      module), installed UNCONDITIONALLY (islands need it even when the rail is
      hidden). Consumers call window.__arenaTelemetry.subscribe({onTelemetry,
      onError, onHeartbeat, onUnreachable}) → returns an unsubscribe fn.
    -->
    <script is:inline>
      window.__arenaTelemetry = (function () {
        var subs = new Set();
        var es = null, arming = false, lastData = null;
        var host = window.location.hostname || '';
        var isDemo = !!window.__ARENA_DEMO__;
        var isLoopback = host === '127.0.0.1' || host === 'localhost';
        var isLan = /^10\.0\.0\.\d+$/.test(host);
        var reachable = isDemo || isLoopback || isLan;
        var base = isDemo ? window.location.origin
                          : window.location.protocol + '//' + host + ':7866';

        function fan(method, arg) {
          subs.forEach(function (s) { try { if (s[method]) s[method](arg); } catch (e) {} });
        }
        function open() {
          if (es || !reachable) return;
          try { es = new EventSource(base + '/api/telemetry/stream'); }
          catch (e) { fan('onError', 2); return; }
          es.addEventListener('telemetry', function (ev) {
            var d; try { d = JSON.parse(ev.data); } catch (e) { return; }
            lastData = d; fan('onTelemetry', d);
          });
          es.addEventListener('heartbeat', function () { fan('onHeartbeat'); });
          es.onerror = function () { fan('onError', es ? es.readyState : 2); };
        }
        function armOpen() {
          // Defer past the load event: a stream opened mid-parse keeps the tab's
          // loading spinner spinning and holds a connection during the critical
          // asset-load window.
          if (es || arming || !reachable) return;
          arming = true;
          if (document.readyState === 'complete') setTimeout(open, 0);
          else window.addEventListener('load', function () { setTimeout(open, 0); }, { once: true });
        }
        // Force the socket closed when the page is navigated away (incl. into
        // the back/forward cache). Chromium does NOT reliably drop a
        // mid-response SSE connection on its own when the document is replaced,
        // so the server kept holding the old subscriber — every tab switch
        // leaked one connection until the ~6-per-origin cap stalled the next
        // page's stream/fetches and flashed a false "Sidecar offline". pagehide
        // guarantees a FIN so the server reaps the subscriber within ~1 s.
        window.addEventListener('pagehide', function () {
          if (es) { try { es.close(); } catch (e) {} es = null; arming = false; }
        });
        return {
          reachable: reachable,
          base: base,
          subscribe: function (handler) {
            subs.add(handler);
            if (!reachable) {
              try { (handler.onUnreachable || handler.onError || function () {})(2); } catch (e) {}
              return function () { subs.delete(handler); };
            }
            // Replay the last payload so a late subscriber paints immediately.
            if (lastData && handler.onTelemetry) { try { handler.onTelemetry(lastData); } catch (e) {} }
            armOpen();
            return function () {
              subs.delete(handler);
              if (subs.size === 0 && es) { try { es.close(); } catch (e) {} es = null; arming = false; }
            };
          }
        };
      })();
    </script>
    <!--
      Top app bar — brand · tabs · sidecar status pill.
      Sticky across scroll; backdrop-blurred when the canvas scrolls under.
    -->
    <header class="arena-app__bar" role="banner">
      <div class="arena-app__lead">
      <a class="arena-app__brand" href={href('arena/')} aria-label="Spark Arena home">
        <svg class="arena-app__mark" width="22" height="22" viewBox="0 0 22 22" aria-hidden="true">
          <!-- Three lit-up cells of a 4×4 instrument grid — the cockpit monogram. -->
          <rect x="0.5"  y="0.5"  width="4" height="4" rx="0.5" class="arena-app__mark-cell" />
          <rect x="6.5"  y="0.5"  width="4" height="4" rx="0.5" class="arena-app__mark-cell" />
          <rect x="12.5" y="0.5"  width="4" height="4" rx="0.5" class="arena-app__mark-cell arena-app__mark-cell--lit" />
          <rect x="0.5"  y="6.5"  width="4" height="4" rx="0.5" class="arena-app__mark-cell arena-app__mark-cell--lit" />
          <rect x="6.5"  y="6.5"  width="4" height="4" rx="0.5" class="arena-app__mark-cell arena-app__mark-cell--accent" />
          <rect x="12.5" y="6.5"  width="4" height="4" rx="0.5" class="arena-app__mark-cell" />
          <rect x="0.5"  y="12.5" width="4" height="4" rx="0.5" class="arena-app__mark-cell" />
          <rect x="6.5"  y="12.5" width="4" height="4" rx="0.5" class="arena-app__mark-cell arena-app__mark-cell--lit" />
          <rect x="12.5" y="12.5" width="4" height="4" rx="0.5" class="arena-app__mark-cell" />
        </svg>
        <span class="arena-app__wordmark">
          <span class="arena-app__wordmark-1">ORIONFOLD</span>
          <span class="arena-app__wordmark-2">ARENA</span>
        </span>
        <span class="arena-app__version" aria-label="version">v0.2</span>
      </a>
        {activeLabel && (
          <span class="arena-app__crumb" aria-hidden="true">
            <span class="arena-app__crumb-sep">›</span>{activeLabel}
          </span>
        )}
      </div>

      {/*
        AE-12 — flow-based nav IA. The flat 11-tab row read as a list, not a
        lifecycle, and overflowed. Regrouped into the three stages of the model
        lifecycle (BUILD/TRAIN → SERVE/INFER → REVIEW/META) with hairline-
        divided clusters + section labels. Route hrefs are UNCHANGED (AE-R5):
        this is grouping + ordering + labels only, trivially reversible. The
        Build/Train group hosts the S3 `/arena/build/` spine pane (AE-5).
      */}
      <nav class="arena-app__tabs" aria-label="Arena sections">
        <div class="arena-app__navgroup" data-flow="build">
          <span class="arena-app__navgroup-label" title="Build / Train">Build</span>
          <a href={href('arena/models/')}      class:list={["arena-app__tab", active === 'models'      && 'is-active']}>Models</a>
          <a href={href('arena/build/')}       class:list={["arena-app__tab", active === 'build'       && 'is-active']}>Build</a>
          <a href={href('arena/sft/')}         class:list={["arena-app__tab", active === 'sft'         && 'is-active']}>SFT</a>
          <a href={href('arena/reward/')}      class:list={["arena-app__tab", active === 'reward'      && 'is-active']}>Reward</a>
          <a href={href('arena/jobs/')}        class:list={["arena-app__tab", active === 'jobs'        && 'is-active']}>Jobs</a>
          <a href={href('arena/standup/')}     class:list={["arena-app__tab", active === 'standup'     && 'is-active']}>Standup</a>
        </div>
        <div class="arena-app__navgroup" data-flow="serve">
          <span class="arena-app__navgroup-label" title="Serve / Infer">Serve</span>
          <a href={href('arena/chat/')}        class:list={["arena-app__tab", active === 'chat'        && 'is-active']}>Chat</a>
          <a href={href('arena/compare/')}     class:list={["arena-app__tab", active === 'compare'     && 'is-active']}>Compare</a>
          <a href={href('arena/leaderboard/')} class:list={["arena-app__tab", active === 'leaderboard' && 'is-active']}>Leaderboard</a>
        </div>
        <div class="arena-app__navgroup" data-flow="review">
          <span class="arena-app__navgroup-label" title="Review / Meta">Review</span>
          <a href={href('arena/')}            class:list={["arena-app__tab", active === 'cockpit'     && 'is-active']}>Cockpit</a>
          <a href={href('arena/lab/')}         class:list={["arena-app__tab", active === 'lab'         && 'is-active']}>Lab</a>
          <a href={href('arena/cortex/')}      class:list={["arena-app__tab", active === 'cortex'      && 'is-active']}>Cortex</a>
          <a href={href('arena/settings/')}    class:list={["arena-app__tab", active === 'settings'    && 'is-active']}>Settings</a>
        </div>
      </nav>

      <div class="arena-app__status" role="status" aria-live="polite">
        <span class="arena-app__status-dot" id="arena-sidecar-dot" data-state="probing" aria-hidden="true"></span>
        <span class="arena-app__status-label" id="arena-sidecar-label">probing</span>
        <span class="arena-app__status-host" id="arena-sidecar-host">127.0.0.1:7866</span>
      </div>
    </header>

    {!hideRail && (
      <div class="arena-app__rail">
        <TelemetryRail />
      </div>
    )}

    <main class:list={["arena-app__canvas", wideCanvas && "arena-app__canvas--wide"]}>
      <slot />
    </main>

    <footer class="arena-app__chrome-footer">
      <span class="arena-app__chrome-mono">ORIONFOLD&nbsp;ARENA</span>
      <span class="arena-app__chrome-sep">·</span>
      <span>operator cockpit for the DGX Spark</span>
      <span class="arena-app__chrome-spacer"></span>
      <span class="arena-app__chrome-copy">© 2026 Orionfold LLC</span>
      <span class="arena-app__chrome-spacer"></span>
      <a class="arena-app__chrome-link" href="https://orionfold.com" rel="noopener">Made by Orionfold ↗</a>
    </footer>

    <!-- Global ⌘K command palette — one island for the whole app. -->
    <CommandPalette client:only="preact" index={cmdIndex} />

    <script type="module" is:inline>
      // Sidecar status pill — probes /healthz on the FastAPI sidecar at
      // 127.0.0.1:7866 every 4s. On error, flips the pill to "offline" with
      // a yellow dot; on success, "live" with a green pulsing dot.
      // (Pre-v0.1.1 used /api/health, which the sidecar never registered.)
      const dot = document.getElementById('arena-sidecar-dot');
      const lbl = document.getElementById('arena-sidecar-label');
      const host = window.location.hostname;
      const isLoopback = ['127.0.0.1', 'localhost'].includes(host);
      const isLan = /^10\.0\.0\.\d+$/.test(host);
      const isDemo = !!window.__ARENA_DEMO__;
      if (isDemo) {
        // Demo bundle — surfaces replay real captured runs; label honestly.
        if (dot) dot.dataset.state = 'live';
        if (lbl) lbl.textContent = 'demo session';
      } else if (!isLoopback && !isLan) {
        // Public mirror — short-circuit to "mirror" state. No probing.
        if (dot) dot.dataset.state = 'mirror';
        if (lbl) lbl.textContent = 'public mirror';
      } else {
        const sidecarBase = `${window.location.protocol}//${host}:7866`;
        const probe = async () => {
          try {
            const r = await fetch(`${sidecarBase}/healthz`, { cache: 'no-store' });
            if (r.ok) {
              if (dot) dot.dataset.state = 'live';
              if (lbl) lbl.textContent = 'sidecar live';
            } else {
              if (dot) dot.dataset.state = 'offline';
              if (lbl) lbl.textContent = 'sidecar offline';
            }
          } catch {
            if (dot) dot.dataset.state = 'offline';
            if (lbl) lbl.textContent = 'sidecar offline';
          }
        };
        probe();
        setInterval(probe, 4000);
      }
    </script>

    <style is:global>
      /*
       * =====================================================================
       *  SPARK ARENA — standalone web app stylesheet
       * =====================================================================
       *  Scoped under `html.arena-app` so we never collide with the editorial
       *  site's global.css. Imports the Geist faces from BaseLayout's same
       *  @fontsource sources at the top of this layout.
       *
       *  Design language:
       *    - dark-only cockpit; deep slate background, hairline rules
       *    - bezel chrome: every panel has an inner stroke + outer stroke
       *    - instrument typography: mono labels, mono numerics, tabular-nums
       *    - traffic-light accents (green=OK · amber=warn · red=alarm)
       *    - blue is reserved for primary actions and links
       *    - no card shadows — flat, technical
       */

      html.arena-app {
        --arena-bg:        oklch(0.10 0.012 250);
        --arena-bg-deep:   oklch(0.075 0.012 250);
        --arena-panel:     oklch(0.14 0.012 250);
        --arena-panel-2:   oklch(0.17 0.012 250);
        --arena-panel-3:   oklch(0.20 0.012 250);
        --arena-line:      oklch(0.27 0.012 250);
        --arena-line-soft: oklch(0.22 0.012 250);
        --arena-text:      oklch(0.94 0.012 250);
        --arena-text-mute: oklch(0.72 0.012 250);
        --arena-text-dim:  oklch(0.58 0.012 250);

        /* Two-tier top-bar height (AE-12) — drives the sticky telemetry-rail offset. */
        --arena-bar-h: 92px;

        /* Primary action / link / highlight — same hue 250 as the rest of the brand. */
        --arena-accent:    oklch(0.72 0.18 250);
        --arena-accent-dim: oklch(0.55 0.14 250);
        --arena-accent-glow: oklch(0.78 0.22 250);

        /* Traffic-light state colours — explicit OKLCH for predictable rendering. */
        --arena-ok:        oklch(0.78 0.18 155);
        --arena-ok-dim:    oklch(0.50 0.14 155);
        --arena-warn:      oklch(0.83 0.16 78);
        --arena-warn-dim:  oklch(0.58 0.14 78);
        --arena-alarm:     oklch(0.68 0.22 25);
        --arena-alarm-dim: oklch(0.48 0.18 25);

        /* Medal accents — used by the leaderboard top-3 badges. */
        --arena-gold:      oklch(0.84 0.16 92);
        --arena-silver:    oklch(0.82 0.025 250);
        --arena-bronze:    oklch(0.72 0.13 50);

        --arena-font:      "Geist Sans", system-ui, -apple-system, "Segoe UI", sans-serif;
        --arena-mono:      "Geist Mono Variable", "Geist Mono", ui-monospace, SFMono-Regular, Menlo, monospace;

        background: var(--arena-bg);
        color: var(--arena-text);
        color-scheme: dark;
        font-family: var(--arena-font);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      html.arena-app body {
        margin: 0;
        background:
          /* Faint instrument-grid backdrop — barely there until you look. */
          linear-gradient(var(--arena-line-soft) 1px, transparent 1px) 0 0 / 48px 48px,
          linear-gradient(90deg, var(--arena-line-soft) 1px, transparent 1px) 0 0 / 48px 48px,
          radial-gradient(ellipse 80% 60% at 50% 0%, oklch(0.18 0.04 250 / 0.55), transparent 70%),
          var(--arena-bg);
        background-attachment: fixed;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      html.arena-app *,
      html.arena-app *::before,
      html.arena-app *::after { box-sizing: border-box; }
      /* Exclude chrome anchors that own their color (buttons, nav tabs) in every
       * state. Without :not(), this generic rule out-specifies their single-class
       * color rules (0,1,2 > 0,2,0 once the not() raises it — but the bare rule beat
       * 0,1,0/0,2,0 alike) and paints the label accent-blue on an accent-blue fill →
       * invisible "Try in chat" button + invisible active-tab label. */
      html.arena-app a:not(.arena-btn):not(.arena-app__tab) { color: var(--arena-accent); text-decoration: none; }
      html.arena-app a:not(.arena-btn):not(.arena-app__tab):hover { color: var(--arena-accent-glow); }
      html.arena-app code, html.arena-app kbd, html.arena-app pre {
        font-family: var(--arena-mono);
        font-variant-numeric: tabular-nums;
      }
      html.arena-app code { font-size: 0.92em; color: var(--arena-text); }
      html.arena-app ::selection { background: var(--arena-accent); color: var(--arena-bg); }
      html.arena-app :focus-visible {
        outline: 2px solid var(--arena-accent);
        outline-offset: 2px;
        border-radius: 2px;
      }

      /* --------------- Top app bar -------------------------------------- */
      /*
       * AE-12 — two-tier bar. With the nav regrouped into three lifecycle
       * clusters (each with a section label + hairline divider), the 11 tabs no
       * longer fit beside the brand + status on one 60px row (LAB/CORTEX were
       * clipped). The bar is now a 2-row grid: brand + status share the top
       * tier; the nav owns a full-width second tier, so every tab is reachable
       * and the lifecycle reads left→right. Bar height is a var so the sticky
       * telemetry rail offset stays in sync.
       */
      .arena-app__bar {
        position: sticky;
        top: 0;
        z-index: 30;
        display: grid;
        grid-template-columns: 1fr auto;
        grid-template-areas:
          "lead status"
          "nav  nav";
        row-gap: 0.4rem;
        column-gap: clamp(1rem, 3vw, 2.5rem);
        align-items: center;
        padding: 0.5rem clamp(1rem, 2vw, 1.75rem) 0.55rem;
        min-height: var(--arena-bar-h);
        background: color-mix(in oklch, var(--arena-bg-deep) 88%, transparent);
        backdrop-filter: blur(14px) saturate(1.4);
        -webkit-backdrop-filter: blur(14px) saturate(1.4);
        border-bottom: 1px solid var(--arena-line);
        box-shadow: 0 1px 0 0 oklch(0.32 0.02 250 / 0.18) inset;
      }
      .arena-app__brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--arena-text);
      }
      .arena-app__brand:hover { color: var(--arena-text); }
      .arena-app__mark {
        flex: 0 0 auto;
        filter: drop-shadow(0 0 6px oklch(0.72 0.18 250 / 0.4));
      }
      .arena-app__mark-cell { fill: oklch(0.30 0.02 250); }
      .arena-app__mark-cell--lit { fill: oklch(0.55 0.05 250); }
      .arena-app__mark-cell--accent { fill: var(--arena-accent); }
      .arena-app__wordmark {
        display: inline-flex;
        flex-direction: column;
        line-height: 0.95;
        letter-spacing: 0.18em;
        font-family: var(--arena-mono);
        font-weight: 600;
        font-size: 0.72rem;
        text-transform: uppercase;
      }
      .arena-app__wordmark-1 { color: var(--arena-text-mute); }
      .arena-app__wordmark-2 { color: var(--arena-text); }
      .arena-app__version {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        margin-left: 0.5rem;
        padding-left: 0.7rem;
        border-left: 1px solid var(--arena-line);
      }
      .arena-app__lead {
        grid-area: lead;
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        min-width: 0;
      }
      .arena-app__crumb {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--arena-text);
        white-space: nowrap;
      }
      .arena-app__crumb-sep {
        color: var(--arena-text-dim);
        font-weight: 400;
      }
      @media (max-width: 780px) {
        .arena-app__crumb { display: none; }
      }

      .arena-app__tabs {
        grid-area: nav;
        display: inline-flex;
        align-items: stretch;
        gap: 0.4rem;
        justify-self: center;
        max-width: 100%;
        padding: 4px;
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        background: color-mix(in oklch, var(--arena-bg-deep) 70%, transparent);
        /* AE-12: the nav owns a full-width second tier, so the three lifecycle
           groups fit at operator widths; on a narrow viewport scroll within the
           pill rather than break the grid. */
        overflow-x: auto;
        scrollbar-width: none;
      }
      .arena-app__tabs::-webkit-scrollbar { display: none; }
      /* AE-12: lifecycle cluster — a tiny section label + its tabs, divided
         from the next cluster by a hairline. */
      .arena-app__navgroup {
        display: inline-flex;
        align-items: center;
        gap: 0.18rem;
        padding-right: 0.45rem;
        border-right: 1px solid var(--arena-line-soft);
      }
      .arena-app__navgroup:last-child { border-right: 0; padding-right: 0; }
      .arena-app__navgroup-label {
        font-family: var(--arena-mono);
        font-size: 0.52rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        padding: 0 0.4rem 0 0.3rem;
        white-space: nowrap;
        user-select: none;
      }
      .arena-app__tab {
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        text-decoration: none;
        color: var(--arena-text-mute);
        padding: 0.42rem 0.95rem;
        border-radius: 5px;
        transition: color 120ms ease, background 120ms ease;
      }
      .arena-app__tab:hover { color: var(--arena-text); background: var(--arena-panel); }
      .arena-app__tab.is-active {
        color: var(--arena-bg);
        background: var(--arena-accent);
        box-shadow:
          inset 0 1px 0 oklch(1 0 0 / 0.25),
          0 0 0 1px var(--arena-accent-dim),
          0 0 12px oklch(0.72 0.18 250 / 0.35);
      }
      .arena-app__tab.is-stub {
        color: var(--arena-text-dim);
        opacity: 0.55;
        cursor: not-allowed;
      }
      @media (max-width: 820px) {
        /* AE-12: reclaim width on small viewports — drop the section labels
           (the hairline dividers still read the grouping) and tighten tabs;
           the full-width nav tier scrolls horizontally past this. */
        .arena-app__navgroup-label { display: none; }
        .arena-app__navgroup { padding-right: 0.35rem; }
        .arena-app__tab { padding: 0.4rem 0.65rem; letter-spacing: 0.1em; }
      }

      .arena-app__status {
        grid-area: status;
        justify-self: end;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--arena-text-mute);
        padding: 0.3rem 0.65rem 0.3rem 0.55rem;
        border: 1px solid var(--arena-line);
        border-radius: 999px;
        background: color-mix(in oklch, var(--arena-bg-deep) 80%, transparent);
      }
      .arena-app__status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--arena-text-dim);
        box-shadow: 0 0 0 2px color-mix(in oklch, var(--arena-text-dim) 25%, transparent);
      }
      .arena-app__status-dot[data-state="live"] {
        background: var(--arena-ok);
        box-shadow: 0 0 0 2px color-mix(in oklch, var(--arena-ok) 30%, transparent);
        animation: arena-pulse 1.6s ease-in-out infinite;
      }
      .arena-app__status-dot[data-state="offline"] {
        background: var(--arena-warn);
        box-shadow: 0 0 0 2px color-mix(in oklch, var(--arena-warn) 30%, transparent);
      }
      .arena-app__status-dot[data-state="mirror"] {
        background: var(--arena-text-dim);
      }
      @keyframes arena-pulse {
        0%, 100% { box-shadow: 0 0 0 2px color-mix(in oklch, var(--arena-ok) 30%, transparent); }
        50%      { box-shadow: 0 0 0 5px color-mix(in oklch, var(--arena-ok) 12%, transparent); }
      }
      .arena-app__status-host {
        font-size: 0.62rem;
        color: var(--arena-text-dim);
        padding-left: 0.5rem;
        border-left: 1px solid var(--arena-line);
        letter-spacing: 0.1em;
      }
      @media (max-width: 700px) {
        .arena-app__status-label, .arena-app__status-host { display: none; }
      }

      /* --------------- Telemetry rail ----------------------------------- */
      .arena-app__rail {
        position: sticky;
        top: var(--arena-bar-h); /* AE-12: follows the two-tier bar height */
        z-index: 20;
        background: color-mix(in oklch, var(--arena-bg-deep) 70%, transparent);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--arena-line);
      }

      /* --------------- Canvas ------------------------------------------- */
      .arena-app__canvas {
        flex: 1;
        width: 100%;
        max-width: 96rem;
        margin: 0 auto;
        padding: 1.25rem clamp(1rem, 2vw, 2rem) 4rem;
      }
      /* Working panes (chat / compare) fill the viewport — the side-by-side
         duel and the chat stream want the width; reading-heavy pages keep the cap. */
      .arena-app__canvas--wide {
        max-width: none;
      }

      /* --------------- Chrome footer ------------------------------------ */
      .arena-app__chrome-footer {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.6rem;
        padding: 1.25rem clamp(1rem, 2vw, 2rem);
        border-top: 1px solid var(--arena-line);
        background: var(--arena-bg-deep);
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app__chrome-mono { color: var(--arena-text-mute); }
      .arena-app__chrome-sep { color: var(--arena-line); }
      .arena-app__chrome-copy { color: var(--arena-text-mute); }
      .arena-app__chrome-spacer { flex: 1; }
      .arena-app__chrome-link {
        color: var(--arena-text-mute);
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }
      .arena-app__chrome-link:hover { color: var(--arena-accent); }
      .arena-app__chrome-footer code {
        font-size: 0.85em;
        color: var(--arena-text-mute);
      }

      /* =====================================================================
       *  Bezel — the cockpit's universal panel chrome.
       *  Inner stroke + outer stroke = faux-recessed instrument feel.
       * =================================================================== */
      .bezel {
        position: relative;
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        box-shadow:
          inset 0 1px 0 oklch(1 0 0 / 0.04),
          inset 0 0 0 1px oklch(0 0 0 / 0.4);
      }
      .bezel--quiet {
        background: color-mix(in oklch, var(--arena-panel) 60%, transparent);
      }
      .bezel--lit {
        background: var(--arena-panel);
        border-color: color-mix(in oklch, var(--arena-accent) 30%, var(--arena-line));
        box-shadow:
          inset 0 1px 0 oklch(1 0 0 / 0.05),
          inset 0 0 0 1px oklch(0 0 0 / 0.4),
          0 0 0 1px color-mix(in oklch, var(--arena-accent) 8%, transparent),
          0 8px 32px -16px color-mix(in oklch, var(--arena-accent) 30%, transparent);
      }
      .bezel__head {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 1rem;
        border-bottom: 1px solid var(--arena-line);
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--arena-text-mute);
      }
      .bezel__head-title { color: var(--arena-text); font-weight: 500; }
      .bezel__head-tag {
        margin-left: auto;
        padding: 0.18rem 0.5rem;
        border: 1px solid var(--arena-line);
        border-radius: 3px;
        font-size: 0.6rem;
        letter-spacing: 0.16em;
        color: var(--arena-text-dim);
      }
      .bezel__head-tag--live { color: var(--arena-ok); border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line)); }
      .bezel__head-tag--warn { color: var(--arena-warn); border-color: color-mix(in oklch, var(--arena-warn) 40%, var(--arena-line)); }
      .bezel__head-tag--cold { color: var(--arena-text-dim); }
      .bezel__body { padding: 1rem 1.1rem; }
      .bezel__body--flush { padding: 0; }

      /* =====================================================================
       *  Pageheader — used on each cockpit page.
       * =================================================================== */
      .pageheader {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-bottom: 1.25rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--arena-line);
      }
      .pageheader__title {
        font-family: var(--arena-font);
        font-weight: 700;
        font-size: clamp(1.6rem, 2.2vw, 2.1rem);
        line-height: 1.05;
        letter-spacing: -0.022em;
        margin: 0;
        color: var(--arena-text);
      }
      .pageheader__eyebrow {
        font-family: var(--arena-mono);
        font-size: 0.65rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--arena-accent);
        margin: 0 0 0.55rem;
      }
      .pageheader__blurb {
        color: var(--arena-text-mute);
        max-width: 58ch;
        font-size: 0.95rem;
        margin: 0.55rem 0 0;
        line-height: 1.55;
      }
      .pageheader__actions {
        display: inline-flex;
        gap: 0.6rem;
        flex-wrap: wrap;
      }

      /* =====================================================================
       *  Buttons + filter chips.
       * =================================================================== */
      .arena-btn {
        appearance: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--arena-text);
        padding: 0.55rem 1rem;
        border: 1px solid var(--arena-line);
        border-radius: 6px;
        background: var(--arena-panel);
        transition: border-color 120ms ease, background 120ms ease, color 120ms ease;
      }
      .arena-btn:hover {
        border-color: var(--arena-accent-dim);
        background: var(--arena-panel-2);
        color: var(--arena-accent-glow);
      }
      .arena-btn--primary {
        color: var(--arena-bg);
        background: var(--arena-accent);
        border-color: var(--arena-accent-dim);
      }
      .arena-btn--primary:hover {
        background: var(--arena-accent-glow);
        color: var(--arena-bg);
      }

      .filterbar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding: 0.6rem 0.85rem;
        margin-bottom: 1.25rem;
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        background: color-mix(in oklch, var(--arena-bg-deep) 60%, transparent);
      }
      .filterbar__label {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        margin-right: 0.4rem;
      }
      .filterbar__chip {
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
        padding: 0.32rem 0.7rem;
        border: 1px solid var(--arena-line);
        border-radius: 999px;
        background: transparent;
        cursor: pointer;
      }
      .filterbar__chip[aria-pressed="true"],
      .filterbar__chip.is-active {
        color: var(--arena-bg);
        background: var(--arena-accent);
        border-color: var(--arena-accent-dim);
      }
      .filterbar__chip:hover:not([aria-pressed="true"]):not(.is-active) {
        color: var(--arena-text);
        border-color: var(--arena-text-dim);
      }

      /* =====================================================================
       *  KPI strip — used on the cockpit landing.
       * =================================================================== */
      .kpi-strip {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
        gap: 1px;
        background: var(--arena-line);
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1.5rem;
      }
      .kpi-strip__cell {
        background: var(--arena-panel);
        padding: 1rem 1.1rem 0.95rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .kpi-strip__label {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .kpi-strip__value {
        font-family: var(--arena-font);
        font-size: 1.55rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--arena-text);
        font-variant-numeric: tabular-nums;
      }
      .kpi-strip__hint {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        color: var(--arena-text-dim);
        letter-spacing: 0.04em;
      }
      .kpi-strip__hint--ok { color: var(--arena-ok); }
      .kpi-strip__hint--accent { color: var(--arena-accent); }

      /* =====================================================================
       *  Big-grid cockpit layout — two-column under wide; collapses cleanly.
       * =================================================================== */
      .cockpit-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
        gap: 1.25rem;
        margin-bottom: 1.5rem;
      }
      @media (max-width: 1100px) {
        .cockpit-grid { grid-template-columns: 1fr; }
      }

      /* =====================================================================
       *  Training flow (AE-13) — SFT → Reward → RL as one left→right chain.
       * =================================================================== */
      .trainflow { margin-bottom: 1.5rem; }
      .trainflow__chain {
        display: flex;
        align-items: stretch;
        gap: 0.5rem;
      }
      .trainflow__arrow {
        display: flex;
        align-items: center;
        color: var(--arena-text-dim);
        font-size: 1.1rem;
        flex: 0 0 auto;
      }
      .trainflow__node {
        flex: 1 1 0;
        min-width: 0;
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-areas:
          "dot   label"
          "value value"
          "hint  hint";
        gap: 0.15rem 0.5rem;
        padding: 0.75rem 0.9rem;
        border: 1px solid var(--arena-line);
        border-radius: 6px;
        background: color-mix(in oklch, var(--arena-bg-deep) 45%, transparent);
        text-decoration: none;
        transition: border-color 120ms ease, background 120ms ease;
      }
      .trainflow__node:hover {
        border-color: var(--arena-accent-dim);
        background: color-mix(in oklch, var(--arena-accent) 6%, var(--arena-panel));
      }
      .trainflow__node-dot {
        grid-area: dot;
        align-self: center;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--arena-text-dim);
      }
      .trainflow__node-dot[data-state="running"] { background: var(--arena-warn); box-shadow: 0 0 6px var(--arena-warn-dim); animation: arena-pulse 1.4s infinite; }
      .trainflow__node-dot[data-state="done"]    { background: var(--arena-ok);   box-shadow: 0 0 6px var(--arena-ok-dim); }
      .trainflow__node-dot[data-state="warn"]    { background: var(--arena-warn); box-shadow: 0 0 6px var(--arena-warn-dim); }
      .trainflow__node-label {
        grid-area: label;
        align-self: center;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
      }
      .trainflow__node-value {
        grid-area: value;
        font-family: var(--arena-font);
        font-size: 1.05rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        color: var(--arena-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .trainflow__node[data-state="idle"] .trainflow__node-value { color: var(--arena-text-dim); font-weight: 500; }
      .trainflow__node-hint {
        grid-area: hint;
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.06em;
        color: var(--arena-text-dim);
      }
      @media (max-width: 720px) {
        .trainflow__chain { flex-direction: column; }
        .trainflow__arrow { transform: rotate(90deg); align-self: center; }
      }

      /* =====================================================================
       *  Leaderboard — the marquee surface.
       *  Bench-anchored rows + rank badges (#1 #2 #3) + score bars.
       * =================================================================== */
      .bench-group { margin-bottom: 1.5rem; }
      .bench-group__head {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        flex-wrap: wrap;
        padding: 0.85rem 1rem;
        border: 1px solid var(--arena-line);
        border-bottom: 0;
        border-radius: 8px 8px 0 0;
        background: var(--arena-panel-2);
      }
      .bench-group__id {
        font-family: var(--arena-mono);
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--arena-text);
        letter-spacing: 0.04em;
      }
      .bench-group__metric {
        font-family: var(--arena-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--arena-text-dim);
        margin-left: auto;
      }
      /* AF-28 — the live eval-run projection + the cached-tier staleness stamp */
      .evalbench__live-tag {
        font-family: var(--arena-mono); font-size: 0.55rem; font-weight: 700;
        letter-spacing: 0.06em; text-transform: uppercase;
        padding: 1px 7px; border-radius: 999px;
        color: #76b900; background: rgba(118,185,0,0.12); border: 1px solid rgba(118,185,0,0.4);
      }
      .lb-cached-stamp {
        font-size: 0.58rem; letter-spacing: 0.08em; text-transform: none;
        padding: 0.06rem 0.45rem; border-radius: 0.6rem;
        border: 1px dashed var(--arena-line); color: var(--arena-text-dim);
        margin-left: 0.6rem;
      }
      .bench-group__count {
        font-family: var(--arena-mono);
        font-size: 0.65rem;
        color: var(--arena-text-mute);
      }

      .ranktable {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border: 1px solid var(--arena-line);
        border-radius: 0 0 8px 8px;
        background: var(--arena-panel);
        overflow: hidden;
      }
      .ranktable th, .ranktable td {
        padding: 0.7rem 0.95rem;
        text-align: left;
        font-size: 0.88rem;
        vertical-align: middle;
        border-bottom: 1px solid var(--arena-line-soft);
      }
      .ranktable tr:last-child td { border-bottom: 0; }
      .ranktable th {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        font-weight: 500;
        background: var(--arena-panel-2);
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--arena-line);
      }
      .ranktable td {
        color: var(--arena-text);
        font-variant-numeric: tabular-nums;
      }
      .ranktable tbody tr {
        transition: background 100ms ease;
      }
      .ranktable tbody tr:hover {
        background: color-mix(in oklch, var(--arena-accent) 5%, var(--arena-panel));
      }

      .rankcol-rank { width: 4.5rem; }
      .rankcol-lane { width: auto; }
      .rankcol-score { width: 22%; min-width: 12rem; }
      .rankcol-tok { width: 8rem; }
      .rankcol-num { width: 5rem; text-align: right; }
      .rankcol-pct { width: 7rem; text-align: right; }

      .rank-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.3rem;
        height: 1.7rem;
        padding: 0 0.55rem;
        border-radius: 4px;
        font-family: var(--arena-mono);
        font-size: 0.78rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.04em;
        color: var(--arena-bg);
        background: var(--arena-panel-3);
        border: 1px solid var(--arena-line);
        color: var(--arena-text-dim);
      }
      .rank-badge--1 {
        background: var(--arena-gold);
        color: oklch(0.18 0.04 80);
        border-color: oklch(0.55 0.16 80);
        box-shadow: 0 0 0 1px oklch(1 0 0 / 0.12) inset, 0 0 12px -4px var(--arena-gold);
      }
      .rank-badge--2 {
        background: var(--arena-silver);
        color: oklch(0.18 0.02 250);
        border-color: oklch(0.55 0.025 250);
        box-shadow: 0 0 0 1px oklch(1 0 0 / 0.12) inset;
      }
      .rank-badge--3 {
        background: var(--arena-bronze);
        color: oklch(0.18 0.03 40);
        border-color: oklch(0.50 0.13 40);
        box-shadow: 0 0 0 1px oklch(1 0 0 / 0.10) inset;
      }

      .lane-cell {
        display: inline-flex;
        flex-direction: column;
        gap: 0.15rem;
        min-width: 0;
      }
      .lane-cell__id {
        font-family: var(--arena-mono);
        font-size: 0.88rem;
        color: var(--arena-text);
        letter-spacing: 0.02em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .lane-cell__slug {
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        color: var(--arena-text-dim);
        letter-spacing: 0.05em;
      }

      .scorebar {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.7rem;
        min-width: 11rem;
      }
      .scorebar__track {
        position: relative;
        flex: 1;
        height: 8px;
        border-radius: 4px;
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        overflow: hidden;
      }
      .scorebar__fill {
        position: absolute;
        inset: 0 auto 0 0;
        background: linear-gradient(
          90deg,
          color-mix(in oklch, var(--scorebar-color, var(--arena-accent)) 60%, transparent),
          var(--scorebar-color, var(--arena-accent))
        );
        box-shadow: 0 0 10px -2px var(--scorebar-color, var(--arena-accent));
      }
      .scorebar__value {
        font-family: var(--arena-mono);
        font-size: 0.85rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        color: var(--scorebar-color, var(--arena-text));
        min-width: 4.5rem;
        text-align: right;
      }

      /* Recent runs ticker — used on the cockpit landing. */
      .ticker {
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .ticker__row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 0.85rem;
        padding: 0.7rem 1rem;
        border-bottom: 1px solid var(--arena-line-soft);
      }
      .ticker__row:last-child { border-bottom: 0; }
      .ticker__row:hover { background: color-mix(in oklch, var(--arena-accent) 4%, var(--arena-panel)); }
      .ticker__rank {
        font-family: var(--arena-mono);
        font-size: 0.75rem;
        color: var(--arena-text-dim);
        min-width: 1.5rem;
      }
      .ticker__lane {
        font-family: var(--arena-mono);
        font-size: 0.82rem;
        color: var(--arena-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .ticker__lane-hint {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        color: var(--arena-text-dim);
        letter-spacing: 0.06em;
      }
      .ticker__score {
        font-family: var(--arena-mono);
        font-size: 0.95rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        color: var(--arena-ok);
        min-width: 4rem;
        text-align: right;
      }
      .ticker__score--mid { color: var(--arena-accent-glow); }
      .ticker__score--low { color: var(--arena-warn); }

      /* Empty-state placeholder. */
      .empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        text-align: center;
        gap: 0.6rem;
        color: var(--arena-text-mute);
        border: 1px dashed var(--arena-line);
        border-radius: 8px;
        background: color-mix(in oklch, var(--arena-bg-deep) 50%, transparent);
        font-size: 0.9rem;
      }
      .empty code { font-size: 0.85em; color: var(--arena-accent); }

      /* =====================================================================
       *  Telemetry rail — instrument panel above the canvas.
       *  Six bezel cells, each with label · big readout · unit · status dot.
       * =================================================================== */
      .telemetry-rail {
        display: grid;
        /* 5 single metric cells + the Throughput/TTFT dual cell (spans 2) = 7 tracks. */
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 0;
        align-items: stretch;
      }
      @media (max-width: 1100px) {
        .telemetry-rail { grid-template-columns: repeat(4, minmax(0, 1fr)); }
        .telemetry-rail__cell--dual { grid-column: span 2; }
      }
      .telemetry-rail__cell--dual { grid-column: span 2; }
      .telemetry-rail__dualtop {
        display: flex;
        gap: 0.9rem;
      }
      .telemetry-rail__sub {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        flex: 1 1 0;
        min-width: 0;
      }
      .telemetry-rail__mini {
        width: 100%;
        height: 22px;
        display: block;
        margin-top: 0.15rem;
        opacity: 0.92;
      }
      .telemetry-rail__source {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.04em;
        color: var(--arena-text-dim);
        margin-top: 0.35rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .telemetry-rail__source[data-where="spark"]      { color: var(--arena-ok); }
      .telemetry-rail__source[data-where="openrouter"] { color: var(--arena-accent, #5b9cff); }
      .telemetry-rail__cell {
        position: relative;
        padding: 0.65rem 0.9rem 0.7rem;
        border-right: 1px solid var(--arena-line);
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        min-width: 0;
      }
      .telemetry-rail__label {
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .telemetry-rail__dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--arena-text-dim);
      }
      .telemetry-rail__dot[data-state="ok"]    { background: var(--arena-ok);    box-shadow: 0 0 6px var(--arena-ok-dim); }
      .telemetry-rail__dot[data-state="warn"]  { background: var(--arena-warn);  box-shadow: 0 0 6px var(--arena-warn-dim); }
      .telemetry-rail__dot[data-state="alarm"] { background: var(--arena-alarm); box-shadow: 0 0 6px var(--arena-alarm-dim); animation: arena-pulse 1.4s infinite; }
      .telemetry-rail__value {
        font-family: var(--arena-mono);
        font-size: 1.25rem;
        font-weight: 600;
        line-height: 1.1;
        color: var(--arena-text);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .telemetry-rail__value[data-state="ok"]    { color: var(--arena-ok); }
      .telemetry-rail__value[data-state="warn"]  { color: var(--arena-warn); }
      .telemetry-rail__value[data-state="alarm"] { color: var(--arena-alarm); }
      .telemetry-rail__hint {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.08em;
        color: var(--arena-text-dim);
      }
      .telemetry-rail__chart {
        padding: 0.45rem 0.9rem 0.5rem;
        border-left: 1px solid var(--arena-line);
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        min-width: 18rem;
      }
      .telemetry-rail__chart-plot {
        width: 100%;
        min-height: 56px;
      }
      .telemetry-rail__offline {
        grid-column: 1 / -1;
        padding: 0.55rem 0.9rem;
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        color: var(--arena-warn);
        background: color-mix(in oklch, var(--arena-warn) 8%, transparent);
        border-top: 1px solid color-mix(in oklch, var(--arena-warn) 25%, var(--arena-line));
      }
      .telemetry-rail__offline code { color: var(--arena-warn); }

      /* =====================================================================
       *  Current-lane chip — one big card on the cockpit landing.
       * =================================================================== */
      .lane-card {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }
      .lane-card__row {
        display: grid;
        grid-template-columns: 7rem 1fr;
        align-items: baseline;
        gap: 0.75rem;
      }
      .lane-card__label {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .lane-card__value {
        font-family: var(--arena-mono);
        font-size: 0.92rem;
        color: var(--arena-text);
        letter-spacing: 0.02em;
        word-break: break-all;
      }
      .lane-card__value--big {
        font-family: var(--arena-font);
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--arena-text);
        letter-spacing: -0.005em;
      }
      .lane-card__chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.18rem 0.55rem;
        border: 1px solid var(--arena-line);
        border-radius: 999px;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
      }
      .lane-card__chip--warm {
        color: var(--arena-ok);
        border-color: color-mix(in oklch, var(--arena-ok) 40%, var(--arena-line));
        background: color-mix(in oklch, var(--arena-ok) 10%, transparent);
      }
      .lane-card__chip-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        box-shadow: 0 0 6px currentColor;
      }

      /* =====================================================================
       *  Chat / Compare panes — the islands carry the bulk of the UX; this
       *  ensures their wrapper feels like a cockpit instrument, not a card
       *  in a docs page.
       * =================================================================== */
      .arena-pane {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 10px;
        overflow: hidden;
        min-height: 65vh;
      }
      .arena-pane__head {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.85rem 1.1rem;
        border-bottom: 1px solid var(--arena-line);
        background: var(--arena-panel-2);
        font-family: var(--arena-mono);
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-pane__head-title { color: var(--arena-text); font-weight: 500; }
      .arena-pane__head-meta {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .arena-pane__body { padding: 1rem 1.1rem; }

      /* AE-13: data-flow boundary note — a one-line crosslink that makes the
       * Jobs (operator dispatch) ↔ Standup (overnight-cron review) split
       * explicit + navigable, so it reads as one flow not two disconnected tabs. */
      .arena-pane__boundary {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0 0 1rem;
        padding: 0.55rem 0.85rem;
        border: 1px solid var(--arena-line);
        border-left: 2px solid var(--arena-accent-dim);
        border-radius: 6px;
        background: color-mix(in oklch, var(--arena-bg-deep) 55%, transparent);
        font-size: 0.78rem;
        color: var(--arena-text-mute);
        line-height: 1.4;
      }
      .arena-pane__boundary strong { color: var(--arena-text); font-weight: 600; }
      .arena-pane__boundary a { white-space: nowrap; }

      /* Restyle the existing TelemetryGauge island when it lands inside the
       * arena-app shell — original was tailored to BaseLayout.
       * The rail version (TelemetryRail.astro) is separate. */
      .arena-app .telemetry-gauge { gap: 1rem; }
      .arena-app .gauge-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
        gap: 0;
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        overflow: hidden;
        background: var(--arena-panel);
      }
      .arena-app .gauge-chip {
        border: 0;
        border-right: 1px solid var(--arena-line);
        border-radius: 0;
        padding: 0.7rem 0.9rem 0.75rem;
        background: var(--arena-panel);
      }
      .arena-app .gauge-chip:last-child { border-right: 0; }
      .arena-app .gauge-chip__label {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.18em;
        color: var(--arena-text-dim);
      }
      .arena-app .gauge-chip__value {
        font-family: var(--arena-mono);
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--arena-text);
        margin-top: 0.25rem;
      }
      .arena-app .gauge-chip--green { border-bottom: 2px solid var(--arena-ok); }
      .arena-app .gauge-chip--yellow { border-bottom: 2px solid var(--arena-warn); }
      .arena-app .gauge-chip--red   { border-bottom: 2px solid var(--arena-alarm); }
      .arena-app .gauge-sparkline {
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        padding: 0.65rem 0.85rem 0.55rem;
        background: var(--arena-panel);
      }
      .arena-app .gauge-sparkline__caption {
        font-family: var(--arena-mono);
        color: var(--arena-text-dim);
        font-size: 0.65rem;
        letter-spacing: 0.08em;
      }
      .arena-app .gauge-status {
        color: var(--arena-text-mute);
        font-family: var(--arena-mono);
        font-size: 0.78rem;
      }
      .arena-app .gauge-status--offline {
        color: var(--arena-warn);
      }

      /* The CurrentLane island styling (M3 shipped these classes). */
      .arena-app .current-lane { display: flex; flex-direction: column; gap: 0.5rem; }
      .arena-app .current-lane__row {
        display: grid;
        grid-template-columns: 7rem 1fr;
        gap: 0.7rem;
        align-items: baseline;
      }
      .arena-app .current-lane__label {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app .current-lane__value {
        font-family: var(--arena-mono);
        font-size: 0.92rem;
        color: var(--arena-text);
      }
      .arena-app .current-lane__chip {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
      }
      .arena-app .current-lane__status {
        font-family: var(--arena-mono);
        font-size: 0.85rem;
        color: var(--arena-text-mute);
      }
      .arena-app .current-lane--offline .current-lane__status { color: var(--arena-warn); }
      .arena-app .current-lane__roster {
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        color: var(--arena-text-dim);
      }

      /* ChatLane island restyle to fit the cockpit pane. */
      .arena-app .chat-lane { gap: 0.85rem; }
      .arena-app .chat-lane__meta {
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        color: var(--arena-text-mute);
        border-bottom-color: var(--arena-line);
      }
      .arena-app .chat-turn {
        background: var(--arena-bg-deep);
        border-color: var(--arena-line);
        border-radius: 6px;
      }
      .arena-app .chat-turn--user { border-left-color: var(--arena-accent); }
      .arena-app .chat-turn--assistant { border-left-color: var(--arena-ok); }
      .arena-app .chat-turn__role {
        font-family: var(--arena-mono);
        letter-spacing: 0.18em;
        color: var(--arena-text-dim);
      }
      .arena-app .chat-turn__body { color: var(--arena-text); }
      .arena-app .chat-turn__think { background: var(--arena-bg); border-color: var(--arena-line); }
      .arena-app .chat-turn__chip {
        font-family: var(--arena-mono);
        background: var(--arena-bg-deep);
        border-color: var(--arena-line);
        color: var(--arena-text-mute);
      }
      /* Composer — wide, centered, rounded (model-arena style). The wrapper is the
       * rounded card; the textarea sits flush inside it (transparent, borderless)
       * and the kbd-row + Send share a divider footer. Mirrors .compare-duel__composer. */
      .arena-app .chat-lane__composer {
        position: relative;
        width: 100%;
        max-width: 56rem;
        margin: 0.6rem auto 0;
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 18px;
        padding: 0.9rem 1rem 0.7rem;
        box-shadow: 0 6px 24px oklch(0 0 0 / 0.28);
        transition: border-color 140ms ease, box-shadow 140ms ease;
      }
      .arena-app .chat-lane__composer:focus-within {
        border-color: var(--arena-accent-dim);
        box-shadow: 0 6px 28px oklch(0 0 0 / 0.34),
          0 0 0 1px color-mix(in oklch, var(--arena-accent) 30%, transparent);
      }
      .arena-app .chat-lane__textarea {
        width: 100%;
        box-sizing: border-box;
        resize: vertical;
        min-height: 3.25rem;
        background: transparent;
        border: 0;
        color: var(--arena-text);
        font-family: var(--arena-font);
        font-size: 0.95rem;
        line-height: 1.55;
        padding: 0.15rem 0.25rem;
      }
      .arena-app .chat-lane__textarea:focus { outline: none; }
      .arena-app .chat-lane__textarea::placeholder { color: var(--arena-text-dim); }
      .arena-app .chat-lane__composer-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 0.55rem;
        padding-top: 0.55rem;
        border-top: 1px solid var(--arena-line-soft);
      }
      .arena-app .chat-lane__send {
        flex: none;
        cursor: pointer;
        background: var(--arena-accent);
        border: 1px solid var(--arena-accent-dim);
        color: var(--arena-bg);
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 0.5rem 1.3rem;
        border-radius: 10px;
      }
      .arena-app .chat-lane__send:not([disabled]):hover {
        background: var(--arena-accent-glow);
      }
      .arena-app .chat-lane__send[disabled] { opacity: 0.45; cursor: default; }

      /* Model-selection bar (chat tab) — pick any lane to chat with. */
      .arena-app .chat-modelbar {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        flex-wrap: wrap;
        padding: 0.5rem 0.1rem 0.7rem;
        border-bottom: 1px solid var(--arena-line-soft);
        margin-bottom: 0.6rem;
      }
      .arena-app .chat-modelbar__label {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
      }
      .arena-app .chat-modelbar__select {
        max-width: 22rem;
      }
      .arena-app .chat-modelbar__needsload {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
      }
      .arena-app .chat-modelbar__warn {
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        color: var(--arena-warn);
      }
      .arena-app .chat-modelbar__loadbtn {
        cursor: pointer;
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--arena-bg);
        background: var(--arena-accent);
        border: 1px solid var(--arena-accent-dim);
        border-radius: 7px;
        padding: 0.35rem 0.8rem;
      }
      .arena-app .chat-modelbar__loadbtn:hover:not([disabled]) { background: var(--arena-accent-glow); }
      .arena-app .chat-modelbar__loadbtn[disabled] { opacity: 0.5; cursor: default; }
      .arena-app .chat-modelbar__warm {
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        color: var(--arena-ok);
      }
      .arena-app .chat-modelbar__status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        color: var(--arena-text-mute);
      }
      .arena-app .chat-modelbar__spinner {
        width: 0.78rem;
        height: 0.78rem;
        border: 2px solid var(--arena-line);
        border-top-color: var(--arena-accent);
        border-radius: 50%;
        animation: arena-spin 0.8s linear infinite;
        flex: none;
      }
      @media (prefers-reduced-motion: reduce) {
        .arena-app .chat-modelbar__spinner { animation: none; }
      }
      .arena-app .chat-modelbar__allmodels {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        color: var(--arena-text-mute);
        cursor: pointer;
      }
      .arena-app .chat-modelbar__allmodels input { accent-color: var(--arena-accent); }

      /* Cockpit hero CTA (replaced the removed prompt box). */
      .arena-app .cockpit-hero__cta {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        justify-content: center;
        align-items: flex-start;
      }
      .arena-app .cockpit-hero__chatbtn { font-size: 0.8rem; padding: 0.6rem 1.4rem; }

      /* CompareDuel island restyle. Full layout — the P3-era island shipped with
       * most of these classes unstyled (only the side shell + head landed in the
       * polish migration), so the columns grid / tag / composer / verdict were
       * collapsing to stacked full-width bars. */
      .arena-app .compare-duel {
        background: transparent;
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
      }
      .arena-app .compare-duel__controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .arena-app .compare-duel__field { display: flex; align-items: center; gap: 0.5rem; }
      .arena-app .compare-duel__field-label {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-duel__select {
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        color: var(--arena-text);
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        border-radius: 6px;
        padding: 0.4rem 0.6rem;
      }
      .arena-app .compare-duel__field-spacer { flex: 1 1 auto; }
      .arena-app .compare-duel__lane-b {
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-duel__lane-b code { color: #5b9cff; }
      .arena-app .compare-duel__allmodels {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.06em;
        color: var(--arena-text-mute);
        cursor: pointer;
      }
      .arena-app .compare-duel__allmodels input { accent-color: var(--arena-accent); }

      /* On-demand local load progress in the side body. */
      .arena-app .compare-side__loading {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--arena-mono);
        font-size: 0.78rem;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-side__spinner {
        width: 0.8rem;
        height: 0.8rem;
        border: 2px solid var(--arena-line);
        border-top-color: var(--side-accent);
        border-radius: 50%;
        animation: arena-spin 0.8s linear infinite;
        flex: none;
      }
      @keyframes arena-spin { to { transform: rotate(360deg); } }
      @media (prefers-reduced-motion: reduce) {
        .arena-app .compare-side__spinner { animation: none; }
      }

      /* "Model not loaded" notice + confirm button in the side body. */
      .arena-app .compare-side__needsload {
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        align-items: flex-start;
        padding: 0.4rem 0;
      }
      .arena-app .compare-side__needsload-msg {
        font-size: 0.82rem;
        line-height: 1.5;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-side__needsload-msg strong { color: var(--side-accent); }
      .arena-app .compare-side__loadbtn {
        cursor: pointer;
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--arena-bg);
        background: var(--side-accent);
        border: 1px solid var(--side-accent);
        border-radius: 8px;
        padding: 0.45rem 1rem;
        transition: filter 120ms ease;
      }
      .arena-app .compare-side__loadbtn:hover { filter: brightness(1.12); }

      /* The duel — two equal columns, stacking under 860px. */
      .arena-app .compare-duel__columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        align-items: start;
      }
      .arena-app .compare-side {
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        border-top: 2px solid var(--side-accent);
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
      }
      .arena-app .compare-side--streaming {
        box-shadow: 0 0 0 1px var(--side-accent),
          0 0 18px color-mix(in oklch, var(--side-accent) 28%, transparent);
      }
      .arena-app .compare-side--error { border-color: var(--arena-alarm); }
      .arena-app .compare-side__head {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0.8rem;
        background: var(--arena-panel-2);
        border-bottom: 1px solid var(--arena-line);
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-side__tag {
        flex: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 5px;
        background: var(--side-accent);
        color: var(--arena-bg);
        font-weight: 700;
        font-size: 0.72rem;
        letter-spacing: 0;
      }
      .arena-app .compare-side__title { color: var(--arena-text); }
      .arena-app .compare-side__meta {
        padding: 0.55rem 0.8rem 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .arena-app .compare-side__meta code {
        font-family: var(--arena-mono);
        font-size: 0.68rem;
        color: var(--arena-accent-glow);
      }
      .arena-app .compare-side__warn {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        color: var(--arena-warn);
      }
      .arena-app .compare-side__think { margin: 0.55rem 0.8rem 0; }
      .arena-app .compare-side__think summary {
        cursor: pointer;
        font-family: var(--arena-mono);
        font-size: 0.66rem;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-side__think-body {
        white-space: pre-wrap;
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        line-height: 1.5;
        color: var(--arena-text-mute);
        margin: 0.4rem 0 0;
        max-height: 16rem;
        overflow-y: auto;
      }
      .arena-app .compare-side__body {
        padding: 0.85rem;
        color: var(--arena-text);
        font-size: 0.9rem;
        line-height: 1.6;
        min-height: 4.5rem;
        word-break: break-word;
      }
      .arena-app .compare-side__body em { color: var(--arena-text-dim); }
      .arena-app .compare-side__cursor { color: var(--side-accent); }
      .arena-app .compare-side__perf {
        margin-top: auto;
        padding: 0.6rem 0.8rem;
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        border-top: 1px solid var(--arena-line);
      }
      .arena-app .compare-side__chip,
      .arena-app .compare-side__score {
        font-family: var(--arena-mono);
        font-variant-numeric: tabular-nums;
      }
      .arena-app .compare-side__chip {
        font-size: 0.62rem;
        color: var(--arena-text-mute);
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 4px;
        padding: 0.15rem 0.45rem;
      }
      .arena-app .compare-side__chip--muted { color: var(--arena-text-dim); }
      .arena-app .compare-side__chip--cost {
        color: var(--arena-warn);
        border-color: color-mix(in oklch, var(--arena-warn) 35%, var(--arena-line));
      }

      /* Verdict — per-side score columns. */
      .arena-app .compare-duel__verdict {
        border: 1px solid var(--arena-line);
        border-radius: 10px;
        background: var(--arena-bg-deep);
        padding: 0.9rem 1rem;
      }
      .arena-app .compare-duel__verdict-title {
        margin: 0 0 0.7rem;
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-duel__verdict-rubric { color: var(--arena-accent-glow); }
      /* AF-27 — format-scope disclosure + bench auto-match note */
      .arena-app .compare-duel__scope-chip {
        font-family: var(--arena-mono); font-size: 0.52rem; font-weight: 600;
        letter-spacing: 0.06em; text-transform: uppercase;
        padding: 0.08rem 0.4rem; margin-left: 0.5rem; border-radius: 0.6rem;
        border: 1px dashed var(--arena-warn); color: var(--arena-warn);
        vertical-align: middle;
      }
      .arena-app .compare-duel__automatch {
        font-size: 0.7rem; color: var(--arena-text-mute); line-height: 1.5;
        border-left: 2px solid var(--arena-accent); padding: 0.2rem 0 0.2rem 0.7rem;
        margin: 0;
      }
      .arena-app .compare-duel__automatch code {
        font-family: var(--arena-mono); font-size: 0.64rem; color: var(--arena-accent);
      }
      .arena-app .compare-duel__verdict-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .arena-app .compare-score-col {
        border: 1px solid var(--arena-line);
        border-top: 2px solid var(--side-accent);
        border-radius: 8px;
        padding: 0.7rem 0.8rem;
      }
      .arena-app .compare-score-col__head {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: space-between;
      }
      .arena-app .compare-score-col__tag {
        flex: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.4rem;
        height: 1.4rem;
        border-radius: 5px;
        background: var(--side-accent);
        color: var(--arena-bg);
        font-family: var(--arena-mono);
        font-weight: 700;
        font-size: 0.7rem;
      }
      .arena-app .compare-score-col__total {
        font-family: var(--arena-mono);
        font-size: 1.1rem;
        font-variant-numeric: tabular-nums;
        color: var(--arena-text);
      }
      .arena-app .compare-score-col__count { font-size: 0.72rem; color: var(--arena-text-mute); }
      .arena-app .compare-score-col__checks {
        list-style: none;
        margin: 0.7rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .arena-app .compare-score-col__check {
        display: grid;
        grid-template-columns: auto 1fr;
        column-gap: 0.5rem;
        row-gap: 0.15rem;
        align-items: start;
        font-size: 0.74rem;
      }
      .arena-app .compare-score-col__check-icon { font-weight: 700; }
      .arena-app .compare-score-col__check--pass .compare-score-col__check-icon { color: var(--arena-ok); }
      .arena-app .compare-score-col__check--fail .compare-score-col__check-icon { color: var(--arena-alarm); }
      .arena-app .compare-score-col__check-name {
        font-family: var(--arena-mono);
        font-size: 0.68rem;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-score-col__check-why {
        grid-column: 2;
        color: var(--arena-text-dim);
      }

      /* Operator prefs (separate signal). */
      .arena-app .compare-duel__prefs {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex-wrap: wrap;
      }
      .arena-app .compare-duel__prefs-label {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
      }
      .arena-app .compare-duel__prefs-buttons { display: flex; gap: 0.5rem; }
      .arena-app .compare-duel__pref {
        cursor: pointer;
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        color: var(--arena-text);
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 6px;
        padding: 0.35rem 0.7rem;
        transition: border-color 120ms ease, background 120ms ease;
      }
      .arena-app .compare-duel__pref:hover:not(:disabled) { border-color: var(--arena-accent-dim); }
      .arena-app .compare-duel__pref--active {
        border-color: var(--arena-accent);
        background: color-mix(in oklch, var(--arena-accent) 14%, transparent);
        color: var(--arena-accent-glow);
      }
      .arena-app .compare-duel__pref:disabled { cursor: default; opacity: 0.7; }
      .arena-app .compare-duel__prefs-thanks {
        margin: 0;
        font-size: 0.74rem;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-duel__error {
        margin: 0;
        padding: 0.6rem 0.8rem;
        border: 1px solid var(--arena-alarm);
        border-radius: 8px;
        background: color-mix(in oklch, var(--arena-alarm) 10%, transparent);
        color: var(--arena-text);
        font-size: 0.82rem;
      }

      /* Composer — wide, centered, rounded (model-arena style). Shared shape with
       * the chat composer; see .chat-composer below. */
      .arena-app .compare-duel__composer {
        width: 100%;
        max-width: 56rem;
        margin: 0 auto;
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 18px;
        padding: 0.9rem 1rem 0.7rem;
        box-shadow: 0 6px 24px oklch(0 0 0 / 0.28);
        transition: border-color 140ms ease, box-shadow 140ms ease;
      }
      .arena-app .compare-duel__composer:focus-within {
        border-color: var(--arena-accent-dim);
        box-shadow: 0 6px 28px oklch(0 0 0 / 0.34),
          0 0 0 1px color-mix(in oklch, var(--arena-accent) 30%, transparent);
      }
      .arena-app .compare-duel__textarea {
        width: 100%;
        box-sizing: border-box;
        resize: vertical;
        min-height: 3.5rem;
        background: transparent;
        border: 0;
        color: var(--arena-text);
        font-family: var(--arena-sans);
        font-size: 0.95rem;
        line-height: 1.55;
        padding: 0.15rem 0.25rem;
      }
      .arena-app .compare-duel__textarea:focus { outline: none; }
      .arena-app .compare-duel__textarea::placeholder { color: var(--arena-text-dim); }
      .arena-app .compare-duel__composer-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 0.5rem;
      }
      .arena-app .compare-duel__hint {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.04em;
        color: var(--arena-text-dim);
      }
      .arena-app .compare-duel__hint kbd {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        border-radius: 4px;
        padding: 0.05rem 0.3rem;
        color: var(--arena-text-mute);
      }
      .arena-app .compare-duel__send {
        flex: none;
        cursor: pointer;
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--arena-bg);
        background: var(--arena-accent);
        border: 1px solid var(--arena-accent-dim);
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        transition: background 120ms ease;
      }
      .arena-app .compare-duel__send:hover:not(:disabled) { background: var(--arena-accent-glow); }
      .arena-app .compare-duel__send:disabled { opacity: 0.45; cursor: default; }
      .arena-app .compare-duel--offline { padding: 1.5rem; }
      .arena-app .compare-duel__status { color: var(--arena-text-mute); }
      @media (max-width: 860px) {
        .arena-app .compare-duel__columns,
        .arena-app .compare-duel__verdict-grid { grid-template-columns: 1fr; }
      }

      /* =====================================================================
       *  Misc helpers.
       * =================================================================== */
      .arena-app .muted { color: var(--arena-text-mute); }
      .arena-app .dim   { color: var(--arena-text-dim); }
      .arena-app .ok    { color: var(--arena-ok); }
      .arena-app .warn  { color: var(--arena-warn); }
      .arena-app .alarm { color: var(--arena-alarm); }
      .arena-app .mono  { font-family: var(--arena-mono); }

      /* =====================================================================
       *  v0.1.1 — cockpit density (prompt hero + 3-col grid + activity feed)
       *  Per /home/nvidia/.claude/plans/review-and-improve-the-harmonic-ladybug.md
       *  goal: ALL three of [hero, KPI strip, 3-col grid] fit above the fold
       *  at 1440×900 (~700px canvas budget under the 60+120 sticky chrome).
       * =================================================================== */

      /* Cockpit hero — prompt input takes the hero slot, mini header on the
         left, secondary actions stacked on the right. Submits to
         /arena/chat/?prompt=... which ChatLane auto-fires on mount. */
      .cockpit-hero {
        display: grid;
        grid-template-columns: minmax(14rem, 18rem) 1fr auto;
        gap: 1.1rem;
        align-items: end;
        padding-bottom: 1rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--arena-line);
      }
      .cockpit-hero__head { min-width: 0; }
      .cockpit-hero__eyebrow {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        margin: 0 0 0.35rem;
      }
      .cockpit-hero__title {
        font-family: var(--arena-font);
        font-size: 1.7rem;
        line-height: 1;
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--arena-text);
        margin: 0;
      }
      .cockpit-hero__form {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        min-width: 0;
      }
      .cockpit-hero__inputrow {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.55rem;
        align-items: stretch;
      }
      .cockpit-hero__prompt {
        font-family: var(--arena-font);
        font-size: 0.95rem;
        line-height: 1.4;
        padding: 0.6rem 0.8rem;
        min-height: 3.2rem;
        max-height: 8rem;
        background: var(--arena-bg-deep);
        color: var(--arena-text);
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        resize: vertical;
        transition: border-color 120ms ease, box-shadow 120ms ease;
      }
      .cockpit-hero__prompt:focus {
        outline: none;
        border-color: var(--arena-accent-dim);
        box-shadow: 0 0 0 2px color-mix(in oklch, var(--arena-accent) 18%, transparent);
      }
      .cockpit-hero__prompt::placeholder {
        color: var(--arena-text-dim);
        font-style: italic;
      }
      .cockpit-hero__send {
        background: var(--arena-accent);
        border: 1px solid var(--arena-accent-dim);
        color: var(--arena-bg);
        font-family: var(--arena-mono);
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 0 1rem;
        cursor: pointer;
        border-radius: 6px;
        white-space: nowrap;
        transition: background 120ms ease;
      }
      .cockpit-hero__send:hover { background: var(--arena-accent-glow); }
      .cockpit-hero__hint {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        color: var(--arena-text-dim);
      }
      .cockpit-hero__hint kbd {
        font-family: var(--arena-mono);
        font-size: 0.55rem;
        padding: 0.06rem 0.32rem;
        border: 1px solid var(--arena-line);
        border-radius: 3px;
        color: var(--arena-text-mute);
        background: var(--arena-bg-deep);
      }
      .cockpit-hero__actions {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        align-self: stretch;
        justify-content: flex-end;
      }
      .cockpit-hero__actions .arena-btn {
        font-size: 0.62rem;
        padding: 0.4rem 0.8rem;
      }
      @media (max-width: 1100px) {
        .cockpit-hero { grid-template-columns: 1fr; gap: 0.7rem; }
        .cockpit-hero__actions { flex-direction: row; }
      }

      /* Compact KPI strip — same 5 cells, ~40% shorter. Hints hide < 1280px. */
      .kpi-strip--compact { margin-bottom: 1rem; }
      .kpi-strip--compact .kpi-strip__cell {
        padding: 0.55rem 0.8rem 0.5rem;
        gap: 0.18rem;
      }
      .kpi-strip--compact .kpi-strip__value {
        font-size: 1.18rem;
      }
      @media (max-width: 1280px) {
        .kpi-strip--compact .kpi-strip__hint { display: none; }
      }

      /* Dense 3-col cockpit grid: top-runs ticker / active lane / activity feed.
         Wraps to 2-col with lane card spanning below at 1380px; falls to 1-col
         at 1100px. */
      .cockpit-grid--dense {
        grid-template-columns: minmax(0, 1.55fr) minmax(0, 0.85fr) minmax(0, 1fr);
        gap: 1rem;
        margin-bottom: 1.25rem;
      }
      @media (max-width: 1380px) {
        .cockpit-grid--dense {
          grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
        }
        .cockpit-grid--dense > .cockpit-grid__lane {
          grid-column: 1 / -1;
        }
      }
      @media (max-width: 1100px) {
        .cockpit-grid--dense { grid-template-columns: 1fr; }
        .cockpit-grid--dense > .cockpit-grid__lane { grid-column: auto; }
      }

      /* Dense ticker — 5-col grid (rank · lane · scorebar · pct · tok/s).
         Inline bench-id hint replaces the second row so we get 8 lanes in
         the same vertical slot as the old 6. */
      .ticker--dense .ticker__row {
        grid-template-columns: 2rem minmax(0, 1fr) 7rem 4.2rem 4rem;
        gap: 0.7rem;
        padding: 0.42rem 0.85rem;
        align-items: center;
      }
      .ticker--dense .ticker__lane {
        font-size: 0.78rem;
      }
      .ticker--dense .ticker__lane-suffix {
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        color: var(--arena-text-dim);
        letter-spacing: 0.04em;
        margin-left: 0.45rem;
      }
      .ticker--dense .ticker__bar {
        display: flex;
        align-items: center;
        min-width: 6rem;
      }
      .ticker--dense .ticker__bar-track {
        position: relative;
        flex: 1;
        height: 6px;
        border-radius: 3px;
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        overflow: hidden;
      }
      .ticker--dense .ticker__bar-fill {
        position: absolute;
        inset: 0 auto 0 0;
        background: linear-gradient(
          90deg,
          color-mix(in oklch, var(--ticker-color, var(--arena-ok)) 50%, transparent),
          var(--ticker-color, var(--arena-ok))
        );
        box-shadow: 0 0 8px -2px var(--ticker-color, var(--arena-ok));
      }
      .ticker--dense .ticker__score { font-size: 0.82rem; min-width: 3.5rem; }
      .ticker__tok {
        font-family: var(--arena-mono);
        font-size: 0.72rem;
        font-variant-numeric: tabular-nums;
        color: var(--arena-accent-glow);
        text-align: right;
        min-width: 3.5rem;
      }

      /* Activity feed — third column of the dense grid. Operator-private. */
      .activity-feed {
        display: flex;
        flex-direction: column;
        min-height: 0;
      }
      .activity-feed .bezel__body--flush {
        display: flex;
        flex-direction: column;
        min-height: 0;
      }
      .activity-feed__status {
        padding: 1rem 1rem;
        margin: 0;
        color: var(--arena-text-mute);
        font-size: 0.82rem;
        line-height: 1.5;
      }
      .activity-feed__status code {
        color: var(--arena-accent);
        font-size: 0.85em;
      }
      .activity-feed__row {
        display: grid;
        grid-template-columns: 2.4rem 1ch minmax(0, 1fr);
        gap: 0.5rem;
        align-items: baseline;
        padding: 0.42rem 0.85rem;
        border-bottom: 1px solid var(--arena-line-soft);
        font-family: var(--arena-mono);
        font-size: 0.7rem;
      }
      .activity-feed__row:last-child { border-bottom: 0; }
      .activity-feed__row:hover {
        background: color-mix(in oklch, var(--arena-accent) 4%, var(--arena-panel));
      }
      .activity-feed__ts {
        color: var(--arena-text-dim);
        font-size: 0.65rem;
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .activity-feed__glyph { color: var(--arena-text-dim); }
      .activity-feed__glyph--chat    { color: var(--arena-accent-glow); }
      .activity-feed__glyph--compare { color: var(--arena-ok); }
      .activity-feed__glyph--pref    { color: var(--arena-warn); }
      .activity-feed__body {
        color: var(--arena-text-mute);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .activity-feed__verb {
        color: var(--arena-text);
        text-transform: uppercase;
        font-size: 0.58rem;
        letter-spacing: 0.14em;
      }
      .activity-feed__metric {
        color: var(--arena-text);
        font-variant-numeric: tabular-nums;
      }
      .activity-feed__id {
        color: var(--arena-text-dim);
        font-size: 0.65rem;
      }
      .activity-feed__chip {
        display: inline-block;
        margin-left: 0.45rem;
        padding: 0.05rem 0.4rem;
        font-size: 0.55rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: 1px solid var(--arena-line);
        border-radius: 3px;
        color: var(--arena-text-dim);
      }

      /* CurrentLane compact — two-row dense layout for the cockpit grid. */
      .arena-app .current-lane--compact {
        gap: 0.32rem;
      }
      .arena-app .current-lane--compact .current-lane__row {
        gap: 0.5rem;
        font-size: 0.78rem;
      }
      .arena-app .current-lane--compact .current-lane__label {
        font-size: 0.55rem;
        letter-spacing: 0.18em;
      }
      .arena-app .current-lane--compact .current-lane__value {
        font-size: 0.78rem;
      }
      .arena-app .current-lane--compact .current-lane__sep {
        color: var(--arena-text-dim);
        opacity: 0.6;
      }

      /* §1.3 essay → <details> at bottom of cockpit (was inline section). */
      .cockpit-about {
        margin-top: 1rem;
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        background: var(--arena-panel);
      }
      .cockpit-about > summary {
        list-style: none;
        cursor: pointer;
        padding: 0.7rem 1rem;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .cockpit-about > summary::-webkit-details-marker { display: none; }
      .cockpit-about > summary::before {
        content: "▸";
        color: var(--arena-accent);
        transition: transform 120ms ease;
        display: inline-block;
      }
      .cockpit-about[open] > summary::before { transform: rotate(90deg); }
      .cockpit-about > summary:hover { color: var(--arena-text); }
      .cockpit-about__body {
        padding: 0 1.2rem 1.2rem;
        color: var(--arena-text-mute);
        font-size: 0.92rem;
        line-height: 1.65;
        max-width: 60ch;
      }

      /* =====================================================================
       *  v0.1.1 — chat overhaul (markdown + abort + copy/regenerate +
       *  slash menu + session switcher + prompt chips + kbd row)
       * =================================================================== */

      /* Top bar: lane pill + session switcher + new-chat button. */
      .arena-app .chat-lane__topbar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding-bottom: 0.65rem;
        margin-bottom: 0.8rem;
        border-bottom: 1px solid var(--arena-line-soft);
      }
      .arena-app .chat-lane__topbar-spacer { flex: 1; }

      .arena-app .chat-lane-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.28rem 0.7rem;
        border: 1px solid var(--arena-line);
        background: var(--arena-panel);
        border-radius: 999px;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.1em;
        color: var(--arena-text-mute);
        cursor: default;
        max-width: 36rem;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .arena-app .chat-lane-pill__model {
        color: var(--arena-text);
        font-weight: 500;
      }
      .arena-app .chat-lane-pill__sep { opacity: 0.5; }
      .arena-app .chat-lane-pill__endpoint { color: var(--arena-text-dim); }
      .arena-app .chat-lane-pill__ctx {
        color: var(--arena-accent-glow);
        font-weight: 600;
      }

      .arena-app .chat-session-switcher {
        position: relative;
      }
      .arena-app .chat-session-switcher__pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.26rem 0.7rem;
        border: 1px solid var(--arena-line);
        background: var(--arena-bg-deep);
        border-radius: 999px;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        color: var(--arena-text-mute);
        cursor: pointer;
        transition: border-color 120ms ease, color 120ms ease;
      }
      .arena-app .chat-session-switcher__pill:hover {
        border-color: var(--arena-accent-dim);
        color: var(--arena-text);
      }
      .arena-app .chat-session-switcher__chevron {
        font-size: 0.55rem;
        color: var(--arena-text-dim);
      }
      .arena-app .chat-session-switcher__popover {
        position: absolute;
        top: calc(100% + 0.35rem);
        left: 0;
        z-index: 12;
        width: min(22rem, 90vw);
        max-height: 22rem;
        overflow-y: auto;
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        box-shadow:
          0 0 0 1px color-mix(in oklch, var(--arena-bg-deep) 50%, transparent),
          0 12px 28px -6px rgba(0, 0, 0, 0.45);
      }
      .arena-app .chat-session-switcher__row {
        display: grid;
        grid-template-columns: 5.5rem 1fr auto;
        gap: 0.6rem;
        align-items: baseline;
        padding: 0.5rem 0.8rem;
        cursor: pointer;
        border-bottom: 1px solid var(--arena-line-soft);
        font-family: var(--arena-mono);
        font-size: 0.68rem;
        color: var(--arena-text-mute);
      }
      .arena-app .chat-session-switcher__row:last-child { border-bottom: 0; }
      .arena-app .chat-session-switcher__row:hover {
        background: color-mix(in oklch, var(--arena-accent) 8%, var(--arena-panel));
        color: var(--arena-text);
      }
      .arena-app .chat-session-switcher__row--current {
        background: color-mix(in oklch, var(--arena-accent) 12%, var(--arena-panel));
        color: var(--arena-text);
      }
      .arena-app .chat-session-switcher__row-id {
        color: var(--arena-accent-glow);
      }
      .arena-app .chat-session-switcher__row-meta {
        color: var(--arena-text-dim);
        font-size: 0.6rem;
        text-align: right;
      }
      .arena-app .chat-session-switcher__empty {
        padding: 1rem;
        color: var(--arena-text-mute);
        font-size: 0.78rem;
        text-align: center;
      }

      .arena-btn--ghost {
        background: transparent;
        border: 1px solid var(--arena-line);
        color: var(--arena-text-mute);
        font-family: var(--arena-mono);
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 0.3rem 0.65rem;
        border-radius: 4px;
        cursor: pointer;
        transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
      }
      .arena-btn--ghost:hover {
        border-color: var(--arena-accent-dim);
        color: var(--arena-text);
        background: color-mix(in oklch, var(--arena-accent) 5%, transparent);
      }

      /* Empty state replaces the old .chat-lane__empty: title + sub + 4 chips. */
      .arena-app .chat-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        padding: 1rem 1rem 0.75rem;
        text-align: center;
      }
      .arena-app .chat-empty__title {
        font-family: var(--arena-font);
        font-size: 0.98rem;
        font-weight: 500;
        color: var(--arena-text);
        margin: 0;
      }
      .arena-app .chat-empty__sub {
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        margin: 0;
      }

      .arena-app .chat-prompt-chips {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 0.5rem;
        margin: 0.85rem 0 0.3rem;
        width: 100%;
      }
      @media (max-width: 1100px) {
        .arena-app .chat-prompt-chips { grid-template-columns: repeat(3, 1fr); }
      }
      @media (max-width: 760px) {
        .arena-app .chat-prompt-chips { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 520px) {
        .arena-app .chat-prompt-chips { grid-template-columns: 1fr; }
      }
      .arena-app .chat-prompt-chip {
        text-align: left;
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        padding: 0.55rem 0.7rem;
        min-height: 52px;
        cursor: pointer;
        transition: border-color 120ms ease, transform 120ms ease, background 120ms ease;
        display: flex;
        flex-direction: column;
        gap: 0.28rem;
      }
      .arena-app .chat-prompt-chip:hover {
        border-color: var(--arena-accent-dim);
        background: var(--arena-panel);
        transform: translateY(-1px);
      }
      .arena-app .chat-prompt-chip__kind {
        font-family: var(--arena-mono);
        font-size: 0.56rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--arena-accent);
      }
      .arena-app .chat-prompt-chip__body {
        font-family: var(--arena-font);
        font-size: 0.74rem;
        line-height: 1.35;
        color: var(--arena-text-mute);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* Per-turn action row (Copy / Regenerate) — hover-revealed. */
      .arena-app .chat-turn { position: relative; }
      .arena-app .chat-turn__actions {
        position: absolute;
        top: 0.5rem;
        right: 0.6rem;
        display: flex;
        gap: 0.4rem;
        opacity: 0;
        transition: opacity 120ms ease;
      }
      .arena-app .chat-turn:hover .chat-turn__actions,
      .arena-app .chat-turn:focus-within .chat-turn__actions {
        opacity: 1;
      }
      .arena-app .chat-turn__action {
        background: transparent;
        border: 1px solid var(--arena-line);
        color: var(--arena-text-mute);
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.2rem 0.5rem;
        border-radius: 3px;
        cursor: pointer;
      }
      .arena-app .chat-turn__action:hover {
        border-color: var(--arena-accent-dim);
        color: var(--arena-text);
      }
      .arena-app .chat-turn__action--ok {
        border-color: color-mix(in oklch, var(--arena-ok) 50%, var(--arena-line));
        color: var(--arena-ok);
      }

      /* Composer wrapper: relative so token-count + slash menu can anchor. */
      .arena-app .chat-tokencount {
        position: absolute;
        top: 0.55rem;
        right: 0.75rem;
        pointer-events: none;
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.1em;
        color: var(--arena-text-dim);
        background: color-mix(in oklch, var(--arena-bg-deep) 75%, transparent);
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
      }
      .arena-app .chat-tokencount--warn { color: var(--arena-warn); }

      /* Slash menu — floating panel above the textarea. */
      .arena-app .chat-slashmenu {
        position: absolute;
        bottom: calc(100% + 0.35rem);
        left: 0;
        z-index: 10;
        width: min(26rem, 100%);
        background: var(--arena-panel);
        border: 1px solid var(--arena-line);
        border-radius: 8px;
        box-shadow:
          0 0 0 1px color-mix(in oklch, var(--arena-bg-deep) 50%, transparent),
          0 12px 28px -6px rgba(0, 0, 0, 0.45);
        overflow: hidden;
      }
      .arena-app .chat-slashmenu__head {
        padding: 0.42rem 0.8rem;
        background: var(--arena-bg-deep);
        font-family: var(--arena-mono);
        font-size: 0.55rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--arena-text-dim);
        border-bottom: 1px solid var(--arena-line-soft);
      }
      .arena-app .chat-slashmenu__row {
        display: grid;
        grid-template-columns: 6rem 1fr;
        gap: 0.6rem;
        align-items: baseline;
        padding: 0.5rem 0.8rem;
        cursor: pointer;
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        color: var(--arena-text-mute);
        border-bottom: 1px solid var(--arena-line-soft);
      }
      .arena-app .chat-slashmenu__row:last-child { border-bottom: 0; }
      .arena-app .chat-slashmenu__row--active {
        background: color-mix(in oklch, var(--arena-accent) 12%, transparent);
        color: var(--arena-text);
      }
      .arena-app .chat-slashmenu__name {
        color: var(--arena-accent-glow);
        font-weight: 500;
      }
      .arena-app .chat-slashmenu__desc {
        color: var(--arena-text-dim);
        font-size: 0.62rem;
      }

      /* Keyboard hints row under the composer. */
      .arena-app .chat-kbd-row {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-wrap: wrap;
        flex: 1 1 auto;
      }
      .arena-app .chat-kbd-row kbd {
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.06em;
        padding: 0.14rem 0.42rem;
        border: 1px solid var(--arena-line);
        background: var(--arena-bg-deep);
        border-radius: 3px;
        color: var(--arena-text-mute);
      }
      .arena-app .chat-kbd-hint {
        font-family: var(--arena-mono);
        font-size: 0.58rem;
        letter-spacing: 0.06em;
        color: var(--arena-text-dim);
      }

      /* Stop button — variant of .chat-lane__send. Same shape, alarm color. */
      .arena-app .chat-lane__send--stop {
        background: var(--arena-alarm-dim);
        border-color: var(--arena-alarm);
      }
      .arena-app .chat-lane__send--stop:hover {
        background: var(--arena-alarm);
      }

      /* Toast confirmation (used by /copy + Copy button). */
      .arena-app .chat-toast {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 50;
        background: var(--arena-panel);
        border: 1px solid var(--arena-accent-dim);
        color: var(--arena-text);
        font-family: var(--arena-mono);
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        padding: 0.55rem 1rem;
        border-radius: 6px;
        box-shadow: 0 0 0 1px color-mix(in oklch, var(--arena-accent) 18%, transparent),
                    0 10px 24px -6px rgba(0, 0, 0, 0.5);
        animation: arena-toast-in 150ms ease;
      }
      @keyframes arena-toast-in {
        from { opacity: 0; transform: translate(-50%, 6px); }
        to   { opacity: 1; transform: translate(-50%, 0); }
      }

      /* Markdown prose on assistant turns. Scoped to .chat-markdown so user
         turns + reasoning <pre> stay raw. Code blocks use our OKLCH palette
         instead of highlight.js's default themes. */
      .arena-app .chat-markdown { color: var(--arena-text); }
      .arena-app .chat-markdown p {
        margin: 0.45rem 0;
        line-height: 1.55;
      }
      .arena-app .chat-markdown p:first-child { margin-top: 0; }
      .arena-app .chat-markdown p:last-child { margin-bottom: 0; }
      .arena-app .chat-markdown ul,
      .arena-app .chat-markdown ol {
        padding-left: 1.4rem;
        margin: 0.5rem 0;
        line-height: 1.55;
      }
      .arena-app .chat-markdown li { margin: 0.18rem 0; }
      .arena-app .chat-markdown strong { color: var(--arena-text); font-weight: 600; }
      .arena-app .chat-markdown em { color: var(--arena-text-mute); }
      .arena-app .chat-markdown code {
        font-family: var(--arena-mono);
        font-size: 0.88em;
        padding: 0.05rem 0.35rem;
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line-soft);
        border-radius: 3px;
        color: var(--arena-accent-glow);
      }
      .arena-app .chat-markdown pre {
        margin: 0.7rem 0;
        padding: 0.85rem 1rem;
        background: var(--arena-bg-deep);
        border: 1px solid var(--arena-line);
        border-radius: 6px;
        overflow-x: auto;
        font-family: var(--arena-mono);
        font-size: 0.78rem;
        line-height: 1.5;
      }
      .arena-app .chat-markdown pre code {
        padding: 0;
        background: transparent;
        border: 0;
        color: var(--arena-text);
        font-size: inherit;
      }
      .arena-app .chat-markdown blockquote {
        margin: 0.7rem 0;
        padding: 0.2rem 0 0.2rem 0.85rem;
        border-left: 3px solid var(--arena-accent-dim);
        color: var(--arena-text-mute);
        font-style: italic;
      }
      .arena-app .chat-markdown h1,
      .arena-app .chat-markdown h2,
      .arena-app .chat-markdown h3 {
        margin: 1rem 0 0.4rem;
        line-height: 1.25;
        letter-spacing: -0.01em;
        color: var(--arena-text);
      }
      .arena-app .chat-markdown h1 { font-size: 1.15rem; }
      .arena-app .chat-markdown h2 { font-size: 1.05rem; }
      .arena-app .chat-markdown h3 { font-size: 0.95rem; }
      .arena-app .chat-markdown a {
        color: var(--arena-accent);
        text-decoration: underline;
        text-decoration-color: var(--arena-accent-dim);
      }
      .arena-app .chat-markdown a:hover { color: var(--arena-accent-glow); }
      .arena-app .chat-markdown table {
        border-collapse: collapse;
        margin: 0.7rem 0;
        font-family: var(--arena-mono);
        font-size: 0.78rem;
      }
      .arena-app .chat-markdown th,
      .arena-app .chat-markdown td {
        padding: 0.35rem 0.7rem;
        border: 1px solid var(--arena-line);
        text-align: left;
      }
      .arena-app .chat-markdown th {
        background: var(--arena-bg-deep);
        color: var(--arena-text);
        font-weight: 500;
      }

      /* highlight.js token colors — OKLCH palette mapped to .hljs-*. We ship
         our own theme instead of importing one of hljs's because every
         shipped theme uses hex/rgb that clashes with our oklch backdrop. */
      .arena-app .chat-markdown .hljs            { color: var(--arena-text); }
      .arena-app .chat-markdown .hljs-keyword,
      .arena-app .chat-markdown .hljs-built_in,
      .arena-app .chat-markdown .hljs-type       { color: var(--arena-accent-glow); }
      .arena-app .chat-markdown .hljs-string,
      .arena-app .chat-markdown .hljs-attr       { color: var(--arena-ok); }
      .arena-app .chat-markdown .hljs-number,
      .arena-app .chat-markdown .hljs-literal    { color: var(--arena-warn); }
      .arena-app .chat-markdown .hljs-comment,
      .arena-app .chat-markdown .hljs-quote      { color: var(--arena-text-dim); font-style: italic; }
      .arena-app .chat-markdown .hljs-title,
      .arena-app .chat-markdown .hljs-function,
      .arena-app .chat-markdown .hljs-class      { color: var(--arena-text); font-weight: 500; }
      .arena-app .chat-markdown .hljs-variable,
      .arena-app .chat-markdown .hljs-params     { color: var(--arena-text-mute); }
      .arena-app .chat-markdown .hljs-meta,
      .arena-app .chat-markdown .hljs-tag        { color: var(--arena-accent); }
      .arena-app .chat-markdown .hljs-section,
      .arena-app .chat-markdown .hljs-symbol     { color: var(--arena-accent-glow); }
      .arena-app .chat-markdown .hljs-deletion   { color: var(--arena-alarm); }
      .arena-app .chat-markdown .hljs-addition   { color: var(--arena-ok); }

      /* =====================================================================
       *  v0.2 — signature visual identity. A bolder, more expressive cockpit
       *  within the same OKLCH system: purposeful motion, instrument glow,
       *  and a tightened "flight deck" band. All motion is opt-out via
       *  prefers-reduced-motion (the guard block at the very bottom).
       * =================================================================== */

      /* Reusable: a lit instrument edge — for "active"/"resident"/"live"
         surfaces that should read as powered-on, not just bordered. */
      .arena-app .instrument-glow {
        box-shadow:
          inset 0 1px 0 oklch(1 0 0 / 0.05),
          inset 0 0 0 1px oklch(0 0 0 / 0.4),
          0 0 0 1px color-mix(in oklch, var(--arena-accent) 14%, transparent),
          0 10px 40px -18px color-mix(in oklch, var(--arena-accent-glow) 55%, transparent);
      }

      /* A slow telemetry-style heartbeat — used by the brand mark's accent
         cell and any "the box is alive" affordance. */
      @keyframes arena-signal-pulse {
        0%, 100% { opacity: 1; filter: drop-shadow(0 0 3px var(--arena-accent-glow)); }
        50%      { opacity: 0.62; filter: drop-shadow(0 0 7px var(--arena-accent-glow)); }
      }
      .arena-app .signal-pulse { animation: arena-signal-pulse 2.4s ease-in-out infinite; }

      /* Brand mark: the accent cell now breathes in time with the live dot,
         so the chrome reads as a running instrument the moment you land. */
      .arena-app__mark-cell--accent { animation: arena-signal-pulse 2.4s ease-in-out infinite; transform-box: fill-box; }

      /* Flight-deck band: deepen the top bar so bar+rail read as one cockpit
         header rather than two stacked strips. */
      .arena-app__bar {
        background: linear-gradient(
          180deg,
          color-mix(in oklch, var(--arena-bg-deep) 94%, transparent),
          color-mix(in oklch, var(--arena-bg-deep) 82%, transparent));
      }

      /* Count-up / draw-in entrance for numeric + bar elements. Opt-in via
         the class so we never animate static prose. */
      @keyframes arena-rise-in {
        from { opacity: 0; transform: translateY(4px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .arena-app .rise-in { animation: arena-rise-in 260ms ease-out both; }

      /* Frontier polyline + scorebar fills "draw in" from zero width. */
      @keyframes arena-draw-in {
        from { transform: scaleX(0); }
        to   { transform: scaleX(1); }
      }

      /* Hero sheen — a faint moving scanline behind the cockpit title so the
         landing reads as a live screen, not a flat header. Pseudo-element on
         the hero head; pointer-events none, sits under the text. */
      .arena-app .cockpit-hero__head { position: relative; }
      .arena-app .cockpit-hero__head::after {
        content: "";
        position: absolute;
        inset: -0.4rem -0.6rem;
        pointer-events: none;
        z-index: -1;
        background:
          repeating-linear-gradient(
            0deg,
            color-mix(in oklch, var(--arena-accent) 5%, transparent) 0px,
            color-mix(in oklch, var(--arena-accent) 5%, transparent) 1px,
            transparent 1px,
            transparent 4px);
        mask-image: radial-gradient(120% 100% at 0% 50%, #000 30%, transparent 75%);
        -webkit-mask-image: radial-gradient(120% 100% at 0% 50%, #000 30%, transparent 75%);
        opacity: 0.5;
        animation: arena-sheen 6s linear infinite;
      }
      @keyframes arena-sheen {
        0%   { background-position-y: 0; }
        100% { background-position-y: -16px; }
      }

      /* Live "what the Spark is doing now" status line under the hero title. */
      .arena-app .cockpit-hero__now {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0.5rem 0 0;
        font-family: var(--arena-mono);
        font-size: 0.62rem;
        letter-spacing: 0.1em;
        color: var(--arena-text-mute);
      }
      .arena-app .cockpit-hero__now-dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: var(--arena-ok);
        box-shadow: 0 0 6px var(--arena-ok);
      }
      .arena-app .cockpit-hero__now--offline .cockpit-hero__now-dot {
        background: var(--arena-text-dim); box-shadow: none;
      }
      .arena-app .cockpit-hero__now b { color: var(--arena-text); font-weight: 600; }

      /* Thin live-now strip that replaced the cockpit hero title block. */
      .arena-app .cockpit-now {
        display: flex;
        align-items: center;
        padding-bottom: 0.65rem;
        margin-bottom: 0.9rem;
        border-bottom: 1px solid var(--arena-line);
      }
      .arena-app .cockpit-now .cockpit-hero__now { margin-top: 0; font-size: 0.66rem; }

      /* =====================================================================
       *  P5 — Telemetry ↔ article-evidence bridge (cockpit)
       * =================================================================== */
      .arena-app .cockpit-bridge {
        display: grid;
        grid-template-columns: minmax(16rem, 1fr) 2.4fr;
        gap: 1rem;
        margin: 1.25rem 0;
      }
      @media (max-width: 1100px) {
        .arena-app .cockpit-bridge { grid-template-columns: 1fr; }
      }

      /* Live vs baseline island */
      .arena-app .lvb { display: flex; flex-direction: column; gap: 0.7rem; }
      .arena-app .lvb__head {
        display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem;
      }
      .arena-app .lvb__title {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-mute);
      }
      .arena-app .lvb__src {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.06em;
        color: var(--arena-accent); text-decoration: none;
      }
      .arena-app .lvb__src:hover { text-decoration: underline; }
      .arena-app .lvb__src--plain { color: var(--arena-text-dim); }
      .arena-app .lvb__bars { display: flex; flex-direction: column; gap: 0.45rem; }
      .arena-app .lvb__row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.4rem 0.55rem; border: 1px solid var(--arena-line);
        border-radius: 0.4rem; background: var(--arena-surface-2, rgba(255,255,255,0.02));
      }
      .arena-app .lvb__row--live { border-color: color-mix(in oklch, var(--arena-accent) 40%, var(--arena-line)); }
      .arena-app .lvb__row-label {
        display: inline-flex; align-items: center; gap: 0.4rem;
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .lvb__row-val {
        font-family: var(--arena-mono); font-size: 0.9rem; font-weight: 600; color: var(--arena-text);
      }
      .arena-app .lvb__dot {
        width: 6px; height: 6px; border-radius: 50%; background: var(--arena-text-dim);
      }
      .arena-app .lvb__dot--on {
        background: var(--arena-ok); box-shadow: 0 0 6px var(--arena-ok);
        animation: arena-signal-pulse 2.4s ease-in-out infinite;
      }
      .arena-app .lvb__verdict { margin: 0; font-size: 0.72rem; line-height: 1.4; }
      .arena-app .lvb__muted { color: var(--arena-text-dim); }
      .arena-app .lvb__muted code {
        font-family: var(--arena-mono); font-size: 0.92em;
        color: var(--arena-text-mute); background: rgba(255,255,255,0.05);
        padding: 0.05em 0.35em; border-radius: 0.25rem;
      }
      .arena-app .lvb__delta { font-family: var(--arena-mono); font-weight: 600; }
      .arena-app .lvb__delta--up { color: var(--arena-ok); }
      .arena-app .lvb__delta--mid { color: var(--arena-accent-glow); }
      .arena-app .lvb__delta--down { color: var(--arena-warn); }

      /* Evidence band */
      .arena-app .evidence-band { display: flex; flex-direction: column; gap: 0.7rem; }
      .arena-app .evidence-band__head { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
      .arena-app .evidence-band__title {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-mute);
      }
      .arena-app .evidence-band__sub { font-size: 0.68rem; color: var(--arena-text-dim); }
      .arena-app .evidence-band__grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr)); gap: 0.7rem;
      }
      .arena-app .evidence-card {
        display: flex; flex-direction: column; gap: 0.3rem;
        padding: 0.7rem 0.8rem; text-decoration: none; color: inherit;
        border-left: 2px solid var(--evidence-color, var(--arena-accent));
        transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;
      }
      .arena-app .evidence-card:hover {
        transform: translateY(-2px);
        background: rgba(255,255,255,0.025);
      }
      .arena-app .evidence-card__kind {
        display: inline-flex; align-items: center; gap: 0.35rem;
        font-family: var(--arena-mono); font-size: 0.56rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .evidence-card__glyph { color: var(--evidence-color, var(--arena-accent)); }
      .arena-app .evidence-card__value {
        font-family: var(--arena-mono); font-size: 1.3rem; font-weight: 700; color: var(--arena-text);
        line-height: 1.1;
      }
      .arena-app .evidence-card__label { font-size: 0.68rem; color: var(--arena-text-mute); line-height: 1.35; }
      .arena-app .evidence-card__src {
        margin-top: auto; font-family: var(--arena-mono); font-size: 0.58rem;
        letter-spacing: 0.04em; color: var(--arena-accent); text-transform: capitalize;
      }

      /* =====================================================================
       *  P6 — Lab (co-iteration board + timeline + operator notes)
       * =================================================================== */
      .arena-app .lab-board {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1.25rem 0;
      }
      @media (max-width: 1100px) { .arena-app .lab-board { grid-template-columns: 1fr; } }

      .arena-app .lab-lane__head {
        display: flex; align-items: baseline; gap: 0.5rem; padding: 0 0.2rem 0.6rem;
        border-bottom: 1px solid var(--arena-line); margin-bottom: 0.8rem;
      }
      .arena-app .lab-lane__label {
        font-family: var(--arena-mono); font-size: 0.74rem; font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase; color: var(--arena-text);
      }
      .arena-app .lab-lane--now    .lab-lane__label { color: var(--arena-ok); }
      .arena-app .lab-lane--next   .lab-lane__label { color: var(--arena-accent-glow); }
      .arena-app .lab-lane__tag {
        font-family: var(--arena-mono); font-size: 0.56rem; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .lab-lane__count {
        margin-left: auto; font-family: var(--arena-mono); font-size: 0.7rem;
        color: var(--arena-text-mute); background: rgba(255,255,255,0.05);
        padding: 0.05rem 0.45rem; border-radius: 0.6rem;
      }
      .arena-app .lab-lane__cards { display: flex; flex-direction: column; gap: 0.7rem; }
      .arena-app .lab-card { padding: 0.85rem 0.95rem; display: flex; flex-direction: column; gap: 0.45rem; }
      .arena-app .lab-card__title { margin: 0; font-size: 0.92rem; font-weight: 600; color: var(--arena-text); }
      .arena-app .lab-card__detail { margin: 0; font-size: 0.74rem; line-height: 1.45; color: var(--arena-text-mute); }
      .arena-app .lab-card__foot {
        display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
        margin-top: 0.2rem; flex-wrap: wrap;
      }
      .arena-app .lab-card__link {
        font-family: var(--arena-mono); font-size: 0.62rem; letter-spacing: 0.04em;
        color: var(--arena-accent); text-decoration: none;
      }
      .arena-app .lab-card__link:hover { text-decoration: underline; }
      .arena-app .lab-card__link--none { color: var(--arena-text-dim); }

      /* Operator-private notes (loopback-only island) */
      .arena-app .labnotes { position: relative; }
      .arena-app .labnotes__toggle {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.04em;
        color: var(--arena-text-dim); background: transparent;
        border: 1px solid var(--arena-line); border-radius: 0.4rem;
        padding: 0.15rem 0.45rem; cursor: pointer;
      }
      .arena-app .labnotes__toggle:hover { color: var(--arena-text); border-color: var(--arena-accent); }
      .arena-app .labnotes__pin { color: var(--arena-accent); }
      .arena-app .labnotes__panel {
        margin-top: 0.5rem; width: 100%; display: flex; flex-direction: column; gap: 0.4rem;
      }
      .arena-app .labnotes__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
      .arena-app .labnotes__item {
        display: flex; align-items: flex-start; gap: 0.4rem; font-size: 0.7rem;
        color: var(--arena-text-mute); background: rgba(255,255,255,0.03);
        border-left: 2px solid var(--arena-accent); padding: 0.3rem 0.45rem; border-radius: 0.25rem;
      }
      .arena-app .labnotes__body { flex: 1; line-height: 1.4; }
      .arena-app .labnotes__del {
        background: transparent; border: 0; color: var(--arena-text-dim); cursor: pointer;
        font-size: 0.9rem; line-height: 1; padding: 0;
      }
      .arena-app .labnotes__del:hover { color: var(--arena-warn); }
      .arena-app .labnotes__form { display: flex; gap: 0.35rem; }
      .arena-app .labnotes__input {
        flex: 1; font-family: var(--arena-sans, inherit); font-size: 0.7rem;
        background: var(--arena-bg, #0a0e14); color: var(--arena-text);
        border: 1px solid var(--arena-line); border-radius: 0.35rem; padding: 0.3rem 0.45rem;
      }
      .arena-app .labnotes__input:focus { outline: none; border-color: var(--arena-accent); }
      .arena-app .labnotes__add {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.06em;
        color: var(--arena-bg, #0a0e14); background: var(--arena-accent); border: 0;
        border-radius: 0.35rem; padding: 0.3rem 0.6rem; cursor: pointer;
      }
      .arena-app .labnotes__add:disabled { opacity: 0.4; cursor: default; }

      /* =====================================================================
       *  Jobs — control plane (/arena/jobs/) — M8
       * =================================================================== */
      .arena-app .jobs { display: flex; flex-direction: column; gap: 1rem; }
      .arena-app .jobs__offline {
        display: flex; align-items: flex-start; gap: 0.7rem;
        padding: 1rem 1.1rem; font-size: 0.78rem; line-height: 1.5;
        color: var(--arena-text-mute); border: 1px dashed var(--arena-line);
        border-radius: 0.5rem; background: rgba(255,255,255,0.02);
      }
      .arena-app .jobs__offline code { font-family: var(--arena-mono); color: var(--arena-accent); font-size: 0.92em; }
      .arena-app .jobs__offline strong { color: var(--arena-text); }
      .arena-app .jobs__offline-dot {
        width: 8px; height: 8px; border-radius: 50%; margin-top: 0.35rem; flex: none;
        background: var(--arena-text-dim);
      }
      .arena-app .jobs__regression {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.55rem 0.85rem; font-size: 0.74rem; line-height: 1.4;
        color: var(--arena-text); border-radius: 0.45rem;
        border: 1px solid color-mix(in oklch, var(--arena-warn) 45%, var(--arena-line));
        background: color-mix(in oklch, var(--arena-warn) 9%, transparent);
      }
      .arena-app .jobs__regression code { font-family: var(--arena-mono); color: var(--arena-warn); }
      .arena-app .jobs__regression-tag {
        font-family: var(--arena-mono); font-size: 0.55rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--arena-bg, #0a0e14);
        background: var(--arena-warn); border-radius: 3px; padding: 0.12rem 0.4rem; flex: none;
      }
      .arena-app .jobs__dispatch {
        display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
        padding: 0.7rem 0.85rem; border: 1px solid var(--arena-line); border-radius: 0.5rem;
        background: rgba(255,255,255,0.02);
      }
      .arena-app .jobs__dispatch-label {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--arena-text-dim);
      }
      .arena-app .jobs__input {
        flex: 1; min-width: 9rem; font-family: var(--arena-mono); font-size: 0.72rem;
        background: var(--arena-bg, #0a0e14); color: var(--arena-text);
        border: 1px solid var(--arena-line); border-radius: 0.35rem; padding: 0.3rem 0.5rem;
      }
      .arena-app .jobs__input:focus { outline: none; border-color: var(--arena-accent); }
      .arena-app .jobs__input:disabled { opacity: 0.45; }
      .arena-app .jobs__go {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.06em;
        color: var(--arena-bg, #0a0e14); background: var(--arena-accent); border: 0;
        border-radius: 0.35rem; padding: 0.32rem 0.7rem; cursor: pointer;
      }
      .arena-app .jobs__go:disabled { opacity: 0.4; cursor: default; }
      .arena-app .jobs__scan {
        font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.06em;
        color: var(--arena-text-dim); background: transparent;
        border: 1px solid var(--arena-border, #243044);
        border-radius: 0.35rem; padding: 0.32rem 0.7rem; cursor: pointer;
      }
      .arena-app .jobs__scan:hover:not(:disabled) { color: var(--arena-accent); border-color: var(--arena-accent); }
      .arena-app .jobs__scan:disabled { opacity: 0.4; cursor: default; }
      /* RLVR async-enqueue affordance (rl-lane-autonomy LA-4) */
      .arena-app .jobs__dispatch--rl { border-style: dashed; }
      /* AE-29 — the operator-armed SFT dispatch form + the held-queued cue */
      .arena-app .jobs__dispatch--sft { border-style: dashed; }
      .arena-app .jobs__input--mode { width: auto; }
      .arena-app .jobs__card-armed {
        font-family: var(--arena-mono); font-size: 0.58rem; color: var(--arena-warn);
        padding-top: 0.3rem;
      }
      .arena-app .jobs__card-armed code { font-size: 0.55rem; color: var(--arena-text-dim); }
      .arena-app .jobs__dispatch--rl .jobs__go {
        color: var(--arena-text); background: transparent;
        border: 1px solid var(--arena-accent);
      }
      /* Live rl_run progress (rl-lane-autonomy LA-9) */
      .arena-app .jobs__rl {
        margin-top: 0.4rem; padding: 0.4rem 0.5rem; border-radius: 0.35rem;
        background: rgba(255,255,255,0.025); border: 1px solid var(--arena-line);
      }
      .arena-app .jobs__rl-head {
        display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem;
      }
      .arena-app .jobs__rl-phase {
        font-family: var(--arena-mono); font-size: 0.58rem; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--arena-accent);
      }
      .arena-app .jobs__rl-step { font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-dim); }
      .arena-app .jobs__rl-bar {
        height: 4px; margin: 0.35rem 0; border-radius: 2px;
        background: var(--arena-line); overflow: hidden;
      }
      .arena-app .jobs__rl-fill { display: block; height: 100%; background: var(--arena-accent); transition: width 0.4s ease; }
      .arena-app .jobs__rl-metrics {
        display: flex; gap: 0.6rem; flex-wrap: wrap;
        font-family: var(--arena-mono); font-size: 0.6rem; color: var(--arena-text-mute);
      }
      .arena-app .jobs__rl-metrics[data-inversion="true"] .jobs__rl-held { color: var(--arena-warn); font-weight: 600; }
      .arena-app .jobs__rl-mem { margin-left: auto; }
      /* AE-2 — GRPO step internals (keep-rate / n_used / advantage-spread) + the
         no-op badge: a zero-advantage step must read distinct from a stall. */
      .arena-app .jobs__rl-grpo {
        margin-top: 0.2rem; display: flex; gap: 0.6rem; flex-wrap: wrap;
        font-family: var(--arena-mono); font-size: 0.58rem; color: var(--arena-text-dim);
      }
      .arena-app .jobs__rl-grpo[data-degenerate="true"] { color: var(--arena-warn); }
      .arena-app .jobs__rl-noop {
        margin-left: auto; padding: 0.02rem 0.32rem; border-radius: 0.3rem;
        background: rgba(255, 196, 0, 0.14); color: var(--arena-warn); font-weight: 600;
      }
      .arena-app .jobs__rl-warn {
        margin-top: 0.3rem; font-size: 0.58rem; line-height: 1.3; color: var(--arena-warn);
      }
      /* rl-lane-autonomy education layer (LA-13/14/16) — the live interpreter,
         the per-phase guide cards, and the post-run debrief. */
      .arena-app .jobs__rl-interp {
        margin-top: 0.35rem; padding: 0.3rem 0.4rem; border-radius: 0.3rem;
        border-left: 2px solid var(--arena-text-dim); background: rgba(255,255,255,0.02);
        display: flex; flex-direction: column; gap: 0.1rem;
      }
      .arena-app .jobs__rl-interp[data-kind="pitfall"] { border-left-color: var(--arena-warn); }
      .arena-app .jobs__rl-interp[data-kind="define"] { border-left-color: var(--arena-ok); }
