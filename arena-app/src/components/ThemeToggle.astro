---
/**
 * 3-state theme toggle: Light | System | Dark.
 * Persists to localStorage; in System mode, follows prefers-color-scheme.
 * Tailwind chrome to match the cloned ainative.business nav.
 */
---
<div
  class="theme-toggle inline-flex items-center rounded-full border border-border bg-surface-raised/50 p-0.5"
  role="radiogroup"
  aria-label="Theme"
>
  <!-- Light -->
  <button
    type="button"
    role="radio"
    aria-checked="false"
    aria-label="Light theme"
    data-theme-value="light"
    class="theme-toggle-btn rounded-full p-1.5 text-text-muted transition-colors"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>

  <!-- System -->
  <button
    type="button"
    role="radio"
    aria-checked="true"
    aria-label="System theme"
    data-theme-value="system"
    class="theme-toggle-btn rounded-full p-1.5 text-text-muted transition-colors"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
    </svg>
  </button>

  <!-- Dark -->
  <button
    type="button"
    role="radio"
    aria-checked="false"
    aria-label="Dark theme"
    data-theme-value="dark"
    class="theme-toggle-btn rounded-full p-1.5 text-text-muted transition-colors"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</div>

<style>
  .theme-toggle-btn[aria-checked="true"] {
    background: var(--color-surface-overlay);
    color: var(--color-primary);
  }
</style>

<script>
  function initThemeToggle() {
    const toggles = document.querySelectorAll('.theme-toggle');

    function getSystemTheme(): string {
      return matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }

    function applyTheme(resolved: string) {
      document.documentElement.setAttribute('data-theme', resolved);
    }

    function updateButtons(preference: string) {
      toggles.forEach((toggle) => {
        toggle.querySelectorAll<HTMLButtonElement>('.theme-toggle-btn').forEach((btn) => {
          const isActive = btn.dataset.themeValue === preference;
          btn.setAttribute('aria-checked', String(isActive));
        });
      });
    }

    function setTheme(preference: string) {
      if (preference === 'system') {
        localStorage.removeItem('theme');
        applyTheme(getSystemTheme());
      } else {
        localStorage.setItem('theme', preference);
        applyTheme(preference);
      }
      updateButtons(preference);
    }

    const stored = localStorage.getItem('theme');
    const preference = (stored === 'light' || stored === 'dark') ? stored : 'system';
    updateButtons(preference);

    toggles.forEach((toggle) => {
      toggle.querySelectorAll<HTMLButtonElement>('.theme-toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const value = btn.dataset.themeValue;
          if (value) setTheme(value);
        });
      });
    });

    const mq = matchMedia('(prefers-color-scheme: light)');
    mq.addEventListener('change', () => {
      if (!localStorage.getItem('theme')) {
        applyTheme(getSystemTheme());
      }
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
