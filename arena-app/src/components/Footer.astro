---
const base = import.meta.env.BASE_URL.replace(/\/+$/, '/') || '/';
const fieldkitHref = `${base}fieldkit/`.replace(/\/+/g, '/');
const fieldnotesHref = base;
const year = new Date().getFullYear();
---
<footer class="border-t border-border py-6 px-6">
  <div class="max-w-6xl mx-auto">
    <p class="max-w-2xl mx-auto mb-6 pb-6 border-b border-border text-xs italic text-text-dim text-balance text-center">
      A personal research project by Manav Sehgal. Built on personal time and personal resources.
      Articles publish at ainative.business/field-notes/. Opinions expressed are the author's own,
      not those of any employer.
    </p>
    <div class="flex flex-col items-center gap-4 text-text-muted text-xs font-mono sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
      <div class="flex flex-wrap items-center justify-center gap-6 sm:justify-start">
        <a href={fieldnotesHref} class="hover:text-primary transition-colors">Field Notes</a>
        <a href={fieldkitHref} class="hover:text-primary transition-colors">Fieldkit</a>
        <a
          href="https://github.com/manavsehgal/ai-field-notes"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-primary transition-colors"
        >
          GitHub
        </a>
      </div>
      <div class="flex flex-col items-center gap-1 sm:items-end">
        <span>© {year} Manav Sehgal. Apache 2.0.</span>
      </div>
    </div>
  </div>
</footer>
