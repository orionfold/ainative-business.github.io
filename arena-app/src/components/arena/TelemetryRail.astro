---
/**
 * TelemetryRail — the persistent instrument rail under the app bar.
 *
 * Renders bezel cells (GPU% / TEMP / UNIFIED MEM / THROUGHPUT+TTFT / LANE /
 * OPENROUTER). Each continuously-sampled metric (GPU%, temp, unified-mem,
 * throughput) carries its own fixed-window peak bar chart directly under the
 * readout: each bar is the PEAK value over one bucket window (not an
 * instantaneous sample), the chart fills left→right and only once full does
 * the oldest bar FIFO off the left edge. The unified-mem chart sits under the
 * UNIFIED cell (with the 8 GB guard band) rather than as a separate wide
 * chart. Subscribes to the same
 * SSE source as the M3 <TelemetryGauge> island (GET /api/telemetry/stream on
 * the FastAPI sidecar at 127.0.0.1:7866).
 *
 * Throughput + TTFT share one dual cell (they come from the same generation):
 * a merged source line spanning both names the model + where it ran
 * (Spark GPU / OpenRouter) so the figures are never ambiguous about origin.
 *
 * The rail is a static Astro shell + an inline preact-free script driving
 * EventSource directly (time-to-first-tick under 100ms; no framework).
 *
 * Cell colour-thresholds per spec §4.6:
 *   GPU%   green ≤80  · yellow 80–95 · red ≥95
 *   GPU°C  green <80  · yellow ≥80   · red ≥90
 *   Unified used > total-8 → yellow (envelope guard headroom)
 */
---
<div class="telemetry-rail" id="telemetry-rail" aria-label="Spark telemetry instrument rail">
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="gpu" data-state="idle"></span>
      GPU&nbsp;Util
    </span>
    <span class="telemetry-rail__value" data-metric="gpu_util">—</span>
    <span class="telemetry-rail__hint">% utilisation</span>
    <canvas class="telemetry-rail__mini" data-spark="gpu" width="160" height="22"></canvas>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="temp" data-state="idle"></span>
      GPU&nbsp;Temp
    </span>
    <span class="telemetry-rail__value" data-metric="gpu_temp_c">—</span>
    <span class="telemetry-rail__hint">°C die</span>
    <canvas class="telemetry-rail__mini" data-spark="temp" width="160" height="22"></canvas>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="unified" data-state="idle"></span>
      Unified
    </span>
    <span class="telemetry-rail__value" data-metric="unified">—</span>
    <span class="telemetry-rail__hint" data-metric="unified-hint">GB of 128 · 8 GB guard</span>
    <canvas class="telemetry-rail__mini" data-spark="unified" width="160" height="22"></canvas>
  </div>
  <div class="telemetry-rail__cell telemetry-rail__cell--dual">
    <div class="telemetry-rail__dualtop">
      <div class="telemetry-rail__sub">
        <span class="telemetry-rail__label">
          <span class="telemetry-rail__dot" data-cell="tok" data-state="idle"></span>
          Throughput
        </span>
        <span class="telemetry-rail__value" data-metric="tok_per_s">—</span>
        <span class="telemetry-rail__hint">tok / second</span>
        <canvas class="telemetry-rail__mini" data-spark="tok" width="160" height="22"></canvas>
      </div>
      <div class="telemetry-rail__sub">
        <span class="telemetry-rail__label">
          <span class="telemetry-rail__dot" data-cell="ttft" data-state="idle"></span>
          TTFT
        </span>
        <span class="telemetry-rail__value" data-metric="ttft_ms">—</span>
        <span class="telemetry-rail__hint">ms · first token</span>
      </div>
    </div>
    <span class="telemetry-rail__source" data-metric="speed-source">throughput &amp; first-token from the active lane</span>
  </div>
  <div class="telemetry-rail__cell telemetry-rail__cell--run" id="rail-run-cell" hidden
       title="Run-context (AE-23) — the vertical this cockpit is oriented to + whether a lane is armed. Select/clear the active lane on the Models pane.">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="run" data-state="idle"></span>
      Run
    </span>
    <span class="telemetry-rail__value" data-metric="run_label" style="font-size: 0.92rem;">—</span>
    <span class="telemetry-rail__hint" data-metric="run-hint">run-context</span>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="lane" data-state="idle"></span>
      {/* AE-15: label flips to "Configured Lane" when nothing live is serving. */}
      <span data-metric="lane-label">Active&nbsp;Lane</span>
      {/* AE-21: drift / multi-lane truth from discovery (poll, not SSE). */}
      <span class="telemetry-rail__badge" data-metric="lane-extra" hidden></span>
    </span>
    <span class="telemetry-rail__value" data-metric="lane_id" style="font-size: 0.92rem;">idle</span>
    <span class="telemetry-rail__hint" data-metric="lane-hint">no warm brain</span>
  </div>
  {/* Cloud-lane hide rule (Field Edition Decision 8): this OpenRouter spend
      cell stays hidden until a key is wired. It starts hidden and the
      telemetry stream's ``openrouter_enabled`` flag reveals it on a keyed box
      (the dev cockpit). A keyless founding-25 customer never sees it. */}
  <div class="telemetry-rail__cell" id="telemetry-rail-cost" hidden>
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="cost" data-state="idle"></span>
      OpenRouter
    </span>
    <span class="telemetry-rail__value" data-metric="openrouter_cost_usd">$0.00</span>
    <span class="telemetry-rail__hint" data-metric="cost-hint">spend · session</span>
  </div>
  <div class="telemetry-rail__offline" id="telemetry-rail-offline" hidden>
    <strong>Sidecar offline</strong> — start with <code>fieldkit arena serve</code> on the Spark to feed this rail.
  </div>
</div>

<script is:inline>
  // Direct EventSource subscription — no framework. Same shape the M3
  // <TelemetryGauge> uses, but driven into raw DOM cells + per-cell sparklines.
  //
  // Classic IIFE, NOT type="module": the EventSource-ctor catch below does a
  // bare `return`, which at a module's top level is an "Illegal return
  // statement" SyntaxError. No imports are used, so a classic script loses
  // nothing. See HANDOFF gotcha on inline module scripts.
  (function () {
  const host = window.location.hostname;
  const isLoopback = ['127.0.0.1', 'localhost'].includes(host);
  const isLan = /^10\.0\.0\.\d+$/.test(host);
  const isDemo = !!window.__ARENA_DEMO__;
  const railEl = document.getElementById('telemetry-rail');
  const offlineEl = document.getElementById('telemetry-rail-offline');
  if (!railEl) {} // noop guard
  else if (!isDemo && !isLoopback && !isLan) {
    offlineEl.hidden = false;
  } else {
    const base = isDemo ? window.location.origin : `${window.location.protocol}//${host}:7866`;
    const cells = {
      gpu_util:    railEl.querySelector('[data-metric="gpu_util"]'),
      gpu_temp_c:  railEl.querySelector('[data-metric="gpu_temp_c"]'),
      unified:     railEl.querySelector('[data-metric="unified"]'),
      unifiedHint: railEl.querySelector('[data-metric="unified-hint"]'),
      tok_per_s:   railEl.querySelector('[data-metric="tok_per_s"]'),
      ttft_ms:     railEl.querySelector('[data-metric="ttft_ms"]'),
      speedSource: railEl.querySelector('[data-metric="speed-source"]'),
      lane_id:     railEl.querySelector('[data-metric="lane_id"]'),
      laneHint:    railEl.querySelector('[data-metric="lane-hint"]'),
      laneLabel:   railEl.querySelector('[data-metric="lane-label"]'),
      cost:        railEl.querySelector('[data-metric="openrouter_cost_usd"]'),
      costHint:    railEl.querySelector('[data-metric="cost-hint"]'),
      costCell:    railEl.querySelector('#telemetry-rail-cost'),
    };
    const dots = {
      gpu:     railEl.querySelector('[data-cell="gpu"]'),
      temp:    railEl.querySelector('[data-cell="temp"]'),
      unified: railEl.querySelector('[data-cell="unified"]'),
      tok:     railEl.querySelector('[data-cell="tok"]'),
      ttft:    railEl.querySelector('[data-cell="ttft"]'),
      lane:    railEl.querySelector('[data-cell="lane"]'),
      cost:    railEl.querySelector('[data-cell="cost"]'),
    };
    const sparks = {
      gpu:     railEl.querySelector('[data-spark="gpu"]'),
      temp:    railEl.querySelector('[data-spark="temp"]'),
      unified: railEl.querySelector('[data-spark="unified"]'),
      tok:     railEl.querySelector('[data-spark="tok"]'),
    };

    // Fixed-window PEAK bar charts. Each metric keeps a FIFO ring of finalized
    // bars; every bar is the PEAK value seen over one BUCKET_S window (not an
    // instantaneous sample). The chart fills left→right; only once SLOTS bars
    // exist does each new bar displace the oldest off the left edge (FIFO).
    // At 0.5 s telemetry ticks, BUCKET_S=2 folds 4 ticks/bar → SLOTS×2 = 60 s
    // of history across a full chart (matches the old sliding-window span).
    const SLOTS = 30;     // bars across the chart when full
    const BUCKET_S = 2;   // seconds of telemetry folded into each bar
    const METRICS = ['gpu', 'temp', 'used', 'tok'];
    const bars = { gpu: [], temp: [], used: [], tok: [] }; // finalized peaks, ≤ SLOTS, oldest first
    const cur = { gpu: null, temp: null, used: null, tok: null }; // running peak, current bucket
    let bucketStart = null;

    // Fold one tick's value into the current bucket's running peak (null = gap).
    function foldPeak(metric, v) {
      if (v == null) return;
      cur[metric] = cur[metric] == null ? v : Math.max(cur[metric], v);
    }
    // Seal the current bucket into a bar on every series + advance the FIFO ring.
    function sealBucket() {
      for (const m of METRICS) {
        bars[m].push(cur[m]);
        if (bars[m].length > SLOTS) bars[m].shift();
        cur[m] = null;
      }
    }

    // Render a metric as fixed-width peak bars, left-aligned so the chart fills
    // L→R. The in-progress bucket is drawn (dimmed) as the rightmost forming
    // bar so the chart stays live between seals. opts: {color, max, band} —
    // band draws a guard ribbon at the top (unified-mem); null bars are gaps.
    function drawBars(canvas, finalized, current, opts) {
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      const W = canvas.width, H = canvas.height;
      ctx.clearRect(0, 0, W, H);
      let max = opts.max;
      if (max != null && opts.band != null) {
        const gy = (opts.band / max) * H;
        ctx.fillStyle = 'oklch(0.83 0.16 78 / 0.10)';
        ctx.fillRect(0, 0, W, gy);
      }
      let vals = finalized.slice();
      if (current != null) vals.push(current);
      if (vals.length > SLOTS) vals = vals.slice(vals.length - SLOTS);
      if (!vals.length) return;
      if (max == null) { max = 1e-9; for (const v of vals) if (v != null) max = Math.max(max, v); }
      const slotW = W / SLOTS;
      const gap = slotW > 3 ? 1 : 0;
      const barW = Math.max(slotW - gap, 1);
      ctx.fillStyle = opts.color;
      for (let i = 0; i < vals.length; i++) {
        const v = vals[i];
        if (v == null) continue;
        const h = Math.max((Math.min(v, max) / max) * (H - 1.5), 1);
        const isForming = current != null && i === vals.length - 1;
        ctx.globalAlpha = isForming ? 0.5 : 1;
        ctx.fillRect(i * slotW, H - h, barW, h);
      }
      ctx.globalAlpha = 1;
    }

    function classForGpu(v) {
      if (v == null) return 'idle';
      if (v >= 95) return 'alarm';
      if (v >= 80) return 'warn';
      return 'ok';
    }
    function classForTemp(v) {
      if (v == null) return 'idle';
      if (v >= 90) return 'alarm';
      if (v >= 80) return 'warn';
      return 'ok';
    }
    function setCell(el, value, state) {
      if (!el) return;
      el.textContent = value;
      if (state) el.dataset.state = state;
    }
    function setDot(el, state) {
      if (!el) return;
      el.dataset.state = state || 'idle';
    }

    let lastTick = Date.now();
    setInterval(() => {
      if (Date.now() - lastTick > 6000) offlineEl.hidden = false;
    }, 2000);

    // Paint from the shared telemetry bus (window.__arenaTelemetry) — ONE
    // EventSource for the whole page, opened after the load event. The bus
    // owns the socket + after-load deferral; this just renders each payload.
    function applyTelemetry(t) {
      offlineEl.hidden = true;
      lastTick = Date.now();
      try {
        const now = Date.now() / 1000;
        const inflight = t.inflight;

        // GPU util
        const gpuState = classForGpu(t.gpu_util);
        setCell(cells.gpu_util, t.gpu_util != null ? `${t.gpu_util.toFixed(0)}%` : '—', gpuState);
        setDot(dots.gpu, gpuState);
        // Temp
        const tempState = classForTemp(t.gpu_temp_c);
        setCell(cells.gpu_temp_c, t.gpu_temp_c != null ? `${t.gpu_temp_c.toFixed(0)}°` : '—', tempState);
        setDot(dots.temp, tempState);
        // Unified
        const used = t.unified_used_gb, total = t.unified_total_gb;
        if (used != null && total != null) {
          const guardWarn = used > total - 8;
          setCell(cells.unified, `${used.toFixed(1)} / ${total.toFixed(0)}`, guardWarn ? 'warn' : 'ok');
          setDot(dots.unified, guardWarn ? 'warn' : 'ok');
          if (cells.unifiedHint) cells.unifiedHint.textContent = `GB · ${(total - used).toFixed(1)} headroom`;
        }
        // Throughput — bright while live, dimmed (still shown) as the last
        // generation's rate at idle, dash only before the first run. Carries
        // its unit (tok/s) like the TTFT cell.
        if (t.tok_per_s != null) {
          const state = inflight ? 'ok' : 'idle';
          setCell(cells.tok_per_s, `${t.tok_per_s.toFixed(1)} tok/s`, state);
          setDot(dots.tok, state);
        } else {
          setCell(cells.tok_per_s, '—', 'idle');
          setDot(dots.tok, 'idle');
        }
        // TTFT
        if (t.ttft_ms != null) {
          setCell(cells.ttft_ms, `${t.ttft_ms.toFixed(0)} ms`, 'ok');
          setDot(dots.ttft, 'ok');
        } else {
          setCell(cells.ttft_ms, '—', 'idle');
          setDot(dots.ttft, 'idle');
        }
        // Merged source under Throughput+TTFT: <full model> on <where>.
        const whereLabel = t.speed_where === 'spark' ? 'Spark GPU'
          : t.speed_where === 'openrouter' ? 'OpenRouter' : '';
        if (cells.speedSource) {
          if (t.speed_model && whereLabel) {
            cells.speedSource.textContent = `${t.speed_model} on ${whereLabel}`;
            cells.speedSource.dataset.where = t.speed_where;
          } else {
            cells.speedSource.textContent = 'throughput & first-token from the active lane';
            cells.speedSource.removeAttribute('data-where');
          }
        }
        // OpenRouter spend — cloud-lane hide rule (Field Edition Decision 8):
        // reveal the cell only on a keyed box. ``openrouter_enabled === false``
        // (a keyless customer) keeps it hidden; absent (demo replay / legacy
        // payloads) leaves it shown so the marketing demo is unaffected.
        if (cells.costCell) cells.costCell.hidden = (t.openrouter_enabled === false);
        const cost = t.openrouter_cost_usd;
        if (cost != null && !Number.isNaN(cost)) {
          const dollars = cost >= 1 ? `$${cost.toFixed(2)}` : `$${cost.toFixed(4)}`;
          setCell(cells.cost, dollars, cost > 0 ? 'ok' : 'idle');
          setDot(dots.cost, cost > 0 ? 'ok' : 'idle');
          if (cells.costHint) {
            const n = t.openrouter_calls || 0;
            cells.costHint.textContent = n > 0 ? `${n} call${n === 1 ? '' : 's'} · session` : 'spend · session';
          }
        }
        // Lane — AE-15 telemetry lane-truth. Reconcile what's CONFIGURED (the
        // static Hermes resident, ``resident_lane``) against what's actually
        // SERVING. Priority: a live in-flight stream → a running rl_run/external
        // GPU lane (``active_lane_*`` — the arbiter tore the resident down) → a
        // liveness-probed resident (``resident_live``) → the last warm
        // generation → and, last, the configured-but-idle lane labelled HONESTLY
        // ("Configured Lane", dimmed) instead of falsely claiming it's active.
        let laneName = null, laneHint = '', laneState = 'idle', laneLabel = 'Active Lane';
        if (t.speed_model && inflight) {
          laneName = t.speed_model; laneState = 'ok';
          laneHint = `streaming · ${whereLabel || 'Spark GPU'}`;
        } else if (t.active_lane_model) {
          laneName = t.active_lane_model; laneState = 'ok';
          laneHint = t.active_lane_where === 'rl' ? 'RL lane · live' : 'active · live';
        } else if (t.resident_lane && t.resident_live) {
          laneName = t.resident_lane; laneState = 'ok';
          laneHint = 'resident · live';
        } else if (t.speed_model) {
          laneName = t.speed_model; laneState = 'ok';
          laneHint = `${whereLabel || 'last run'} · warm`;
        } else if (t.resident_lane) {
          // Configured but nothing is answering — don't claim it's active.
          laneName = t.resident_lane; laneState = 'warn'; laneLabel = 'Configured Lane';
          laneHint = 'configured · idle';
        }
        if (cells.laneLabel) cells.laneLabel.textContent = laneLabel;
        if (laneName) {
          setCell(cells.lane_id, laneName, laneState);
          setDot(dots.lane, laneState);
          if (cells.laneHint) cells.laneHint.textContent = laneHint;
        } else {
          setCell(cells.lane_id, 'idle', 'idle');
          setDot(dots.lane, 'idle');
          if (cells.laneHint) cells.laneHint.textContent = 'no warm brain';
        }

        // Fold this tick into the running peak; seal + advance the FIFO ring on
        // the bucket boundary, then redraw all four fixed-window bar charts.
        if (bucketStart == null) bucketStart = now;
        foldPeak('gpu', t.gpu_util);
        foldPeak('temp', t.gpu_temp_c);
        foldPeak('used', used);
        foldPeak('tok', t.tok_per_s);
        if (now - bucketStart >= BUCKET_S) { sealBucket(); bucketStart = now; }
        drawBars(sparks.gpu, bars.gpu, cur.gpu, { color: 'oklch(0.74 0.16 165)', max: 100 });
        drawBars(sparks.temp, bars.temp, cur.temp, { color: 'oklch(0.83 0.16 78)', max: 100 });
        drawBars(sparks.unified, bars.used, cur.used, { color: 'oklch(0.72 0.18 250)', max: Math.max(total || 128, 64), band: 8 });
        drawBars(sparks.tok, bars.tok, cur.tok, { color: 'oklch(0.74 0.16 165)' });
      } catch {}
    }
    window.__arenaTelemetry.subscribe({
      onTelemetry: applyTelemetry,
      onError: (rs) => { if (rs === 2) offlineEl.hidden = false; },
      onUnreachable: () => { offlineEl.hidden = false; },
    });

    // AE-21/23 — run-context banner cell + lane-truth extras (drift badge,
    // multi-lane count). A light 12 s poll of GET /api/run-context; the SSE
    // above keeps owning the 0.5 s lane label, this only writes its own
    // elements (run cell + the lane-extra badge) so there are never two
    // writers on one node.
    const runCell = document.getElementById('rail-run-cell');
    const runVal = railEl.querySelector('[data-metric="run_label"]');
    const runHint = railEl.querySelector('[data-metric="run-hint"]');
    const runDot = railEl.querySelector('[data-cell="run"]');
    const laneExtra = railEl.querySelector('[data-metric="lane-extra"]');
    function fmtAgoIso(iso) {
      if (!iso) return '';
      const t = Date.parse(iso);
      if (Number.isNaN(t)) return '';
      const s = Math.max(0, (Date.now() - t) / 1000);
      if (s < 90) return 'just now';
      if (s < 5400) return Math.round(s / 60) + 'm ago';
      if (s < 172800) return (s / 3600).toFixed(1) + 'h ago';
      return Math.round(s / 86400) + 'd ago';
    }
    async function pollRunContext() {
      try {
        const r = await fetch(base + '/api/run-context', { headers: { Accept: 'application/json' } });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const c = await r.json();
        if (runCell) runCell.hidden = false;
        const label = c.label || c.vertical || '—';
        if (runVal) { runVal.textContent = label; runVal.dataset.state = c.lane_live ? 'ok' : 'idle'; }
        if (runDot) runDot.dataset.state = c.drift ? 'warn' : (c.lane_live ? 'ok' : 'idle');
        if (runHint) {
          runHint.textContent = c.anchored
            ? ('armed ' + (fmtAgoIso(c.run_started) || '—') + (c.lane && c.lane.model ? ' · ' + c.lane.model : ''))
            : (c.lane_live ? 'lane live · select to anchor' : 'unanchored · no lane armed');
        }
        if (laneExtra) {
          if (c.drift) {
            laneExtra.hidden = false;
            laneExtra.textContent = '⚠ drift';
            laneExtra.title = c.drift;
            laneExtra.dataset.state = 'warn';
          } else if ((c.discovered_n || 0) > 1) {
            laneExtra.hidden = false;
            laneExtra.textContent = c.discovered_n + ' lanes';
            laneExtra.title = c.discovered_n + ' resident lanes discovered — pick the active one on the Models pane';
            laneExtra.dataset.state = 'ok';
          } else {
            laneExtra.hidden = true;
          }
        }
      } catch (e) { /* sidecar-down is the SSE banner's story; leave the cells */ }
    }
    pollRunContext();
    setInterval(function () {
      if (document.visibilityState === 'visible') pollRunContext();
    }, 12000);
  }
  })();
</script>
