---
/**
 * TelemetryRail — the persistent instrument rail under the app bar.
 *
 * Renders bezel cells (GPU% / TEMP / UNIFIED MEM / THROUGHPUT+TTFT / LANE /
 * OPENROUTER). Each continuously-sampled metric (GPU%, temp, unified-mem,
 * throughput) carries its own rolling 60s mini-sparkline directly under the
 * readout; the unified-mem spark sits under the UNIFIED cell (with the 8 GB
 * guard band) rather than as a separate wide chart. Subscribes to the same
 * SSE source as the M3 <TelemetryGauge> island (GET /api/telemetry/stream on
 * the FastAPI sidecar at 127.0.0.1:7866).
 *
 * Throughput + TTFT share one dual cell (they come from the same generation):
 * a merged source line spanning both names the model + where it ran
 * (Spark GPU / OpenRouter) so the figures are never ambiguous about origin.
 *
 * The rail is a static Astro shell + an inline preact-free script driving
 * EventSource directly (time-to-first-tick under 100ms; no framework).
 *
 * Cell colour-thresholds per spec §4.6:
 *   GPU%   green ≤80  · yellow 80–95 · red ≥95
 *   GPU°C  green <80  · yellow ≥80   · red ≥90
 *   Unified used > total-8 → yellow (envelope guard headroom)
 */
---
<div class="telemetry-rail" id="telemetry-rail" aria-label="Spark telemetry instrument rail">
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="gpu" data-state="idle"></span>
      GPU&nbsp;Util
    </span>
    <span class="telemetry-rail__value" data-metric="gpu_util">—</span>
    <span class="telemetry-rail__hint">% utilisation</span>
    <canvas class="telemetry-rail__mini" data-spark="gpu" width="160" height="22"></canvas>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="temp" data-state="idle"></span>
      GPU&nbsp;Temp
    </span>
    <span class="telemetry-rail__value" data-metric="gpu_temp_c">—</span>
    <span class="telemetry-rail__hint">°C die</span>
    <canvas class="telemetry-rail__mini" data-spark="temp" width="160" height="22"></canvas>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="unified" data-state="idle"></span>
      Unified
    </span>
    <span class="telemetry-rail__value" data-metric="unified">—</span>
    <span class="telemetry-rail__hint" data-metric="unified-hint">GB of 128 · 8 GB guard</span>
    <canvas class="telemetry-rail__mini" data-spark="unified" width="160" height="22"></canvas>
  </div>
  <div class="telemetry-rail__cell telemetry-rail__cell--dual">
    <div class="telemetry-rail__dualtop">
      <div class="telemetry-rail__sub">
        <span class="telemetry-rail__label">
          <span class="telemetry-rail__dot" data-cell="tok" data-state="idle"></span>
          Throughput
        </span>
        <span class="telemetry-rail__value" data-metric="tok_per_s">—</span>
        <span class="telemetry-rail__hint">tok / second</span>
        <canvas class="telemetry-rail__mini" data-spark="tok" width="160" height="22"></canvas>
      </div>
      <div class="telemetry-rail__sub">
        <span class="telemetry-rail__label">
          <span class="telemetry-rail__dot" data-cell="ttft" data-state="idle"></span>
          TTFT
        </span>
        <span class="telemetry-rail__value" data-metric="ttft_ms">—</span>
        <span class="telemetry-rail__hint">ms · first token</span>
      </div>
    </div>
    <span class="telemetry-rail__source" data-metric="speed-source">throughput &amp; first-token from the active lane</span>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="lane" data-state="idle"></span>
      Active&nbsp;Lane
    </span>
    <span class="telemetry-rail__value" data-metric="lane_id" style="font-size: 0.92rem;">idle</span>
    <span class="telemetry-rail__hint" data-metric="lane-hint">no warm brain</span>
  </div>
  <div class="telemetry-rail__cell">
    <span class="telemetry-rail__label">
      <span class="telemetry-rail__dot" data-cell="cost" data-state="idle"></span>
      OpenRouter
    </span>
    <span class="telemetry-rail__value" data-metric="openrouter_cost_usd">$0.00</span>
    <span class="telemetry-rail__hint" data-metric="cost-hint">spend · since start</span>
  </div>
  <div class="telemetry-rail__offline" id="telemetry-rail-offline" hidden>
    <strong>Sidecar offline</strong> — start with <code>fieldkit arena serve</code> on the Spark to feed this rail.
  </div>
</div>

<script is:inline>
  // Direct EventSource subscription — no framework. Same shape the M3
  // <TelemetryGauge> uses, but driven into raw DOM cells + per-cell sparklines.
  //
  // Classic IIFE, NOT type="module": the EventSource-ctor catch below does a
  // bare `return`, which at a module's top level is an "Illegal return
  // statement" SyntaxError. No imports are used, so a classic script loses
  // nothing. See HANDOFF gotcha on inline module scripts.
  (function () {
  const host = window.location.hostname;
  const isLoopback = ['127.0.0.1', 'localhost'].includes(host);
  const isLan = /^10\.0\.0\.\d+$/.test(host);
  const isDemo = !!window.__ARENA_DEMO__;
  const railEl = document.getElementById('telemetry-rail');
  const offlineEl = document.getElementById('telemetry-rail-offline');
  if (!railEl) {} // noop guard
  else if (!isDemo && !isLoopback && !isLan) {
    offlineEl.hidden = false;
  } else {
    const base = isDemo ? window.location.origin : `${window.location.protocol}//${host}:7866`;
    const cells = {
      gpu_util:    railEl.querySelector('[data-metric="gpu_util"]'),
      gpu_temp_c:  railEl.querySelector('[data-metric="gpu_temp_c"]'),
      unified:     railEl.querySelector('[data-metric="unified"]'),
      unifiedHint: railEl.querySelector('[data-metric="unified-hint"]'),
      tok_per_s:   railEl.querySelector('[data-metric="tok_per_s"]'),
      ttft_ms:     railEl.querySelector('[data-metric="ttft_ms"]'),
      speedSource: railEl.querySelector('[data-metric="speed-source"]'),
      lane_id:     railEl.querySelector('[data-metric="lane_id"]'),
      laneHint:    railEl.querySelector('[data-metric="lane-hint"]'),
      cost:        railEl.querySelector('[data-metric="openrouter_cost_usd"]'),
      costHint:    railEl.querySelector('[data-metric="cost-hint"]'),
    };
    const dots = {
      gpu:     railEl.querySelector('[data-cell="gpu"]'),
      temp:    railEl.querySelector('[data-cell="temp"]'),
      unified: railEl.querySelector('[data-cell="unified"]'),
      tok:     railEl.querySelector('[data-cell="tok"]'),
      ttft:    railEl.querySelector('[data-cell="ttft"]'),
      lane:    railEl.querySelector('[data-cell="lane"]'),
      cost:    railEl.querySelector('[data-cell="cost"]'),
    };
    const sparks = {
      gpu:     railEl.querySelector('[data-spark="gpu"]'),
      temp:    railEl.querySelector('[data-spark="temp"]'),
      unified: railEl.querySelector('[data-spark="unified"]'),
      tok:     railEl.querySelector('[data-spark="tok"]'),
    };

    // Rolling 60s of every continuously-sampled signal, on a shared time axis.
    const WINDOW_S = 60;
    const series = { t: [], gpu: [], temp: [], used: [], tok: [] };

    // Generic mini-sparkline. opts: {color, fill, max, band} — band draws a
    // guard ribbon at the top (unified-mem). null values are gaps (tok/s idle).
    function drawMini(canvas, vals, opts) {
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      const W = canvas.width, H = canvas.height;
      ctx.clearRect(0, 0, W, H);
      const ts = series.t;
      if (opts.band != null && opts.max) {
        const gy = (opts.band / opts.max) * H;
        ctx.fillStyle = 'oklch(0.83 0.16 78 / 0.10)';
        ctx.fillRect(0, 0, W, gy);
      }
      const pts = [];
      for (let i = 0; i < ts.length; i++) if (vals[i] != null) pts.push([ts[i], vals[i]]);
      if (pts.length < 2) return;
      const t0 = pts[0][0], tN = pts[pts.length - 1][0], dt = Math.max(tN - t0, 1);
      let max = opts.max;
      if (max == null) { max = 1e-9; for (const p of pts) max = Math.max(max, p[1]); }
      const x = (t) => ((t - t0) / dt) * W;
      const y = (v) => H - (Math.min(v, max) / max) * (H - 3) - 1.5;
      ctx.beginPath();
      pts.forEach((p, i) => (i ? ctx.lineTo(x(p[0]), y(p[1])) : ctx.moveTo(x(p[0]), y(p[1]))));
      ctx.strokeStyle = opts.color;
      ctx.lineWidth = 1.4;
      ctx.stroke();
      ctx.lineTo(x(pts[pts.length - 1][0]), H);
      ctx.lineTo(x(pts[0][0]), H);
      ctx.closePath();
      ctx.fillStyle = opts.fill || 'rgba(127,127,127,0.10)';
      ctx.fill();
    }

    function classForGpu(v) {
      if (v == null) return 'idle';
      if (v >= 95) return 'alarm';
      if (v >= 80) return 'warn';
      return 'ok';
    }
    function classForTemp(v) {
      if (v == null) return 'idle';
      if (v >= 90) return 'alarm';
      if (v >= 80) return 'warn';
      return 'ok';
    }
    function setCell(el, value, state) {
      if (!el) return;
      el.textContent = value;
      if (state) el.dataset.state = state;
    }
    function setDot(el, state) {
      if (!el) return;
      el.dataset.state = state || 'idle';
    }

    let lastTick = Date.now();
    setInterval(() => {
      if (Date.now() - lastTick > 6000) offlineEl.hidden = false;
    }, 2000);

    // Paint from the shared telemetry bus (window.__arenaTelemetry) — ONE
    // EventSource for the whole page, opened after the load event. The bus
    // owns the socket + after-load deferral; this just renders each payload.
    function applyTelemetry(t) {
      offlineEl.hidden = true;
      lastTick = Date.now();
      try {
        const now = Date.now() / 1000;
        const inflight = t.inflight;

        // GPU util
        const gpuState = classForGpu(t.gpu_util);
        setCell(cells.gpu_util, t.gpu_util != null ? `${t.gpu_util.toFixed(0)}%` : '—', gpuState);
        setDot(dots.gpu, gpuState);
        // Temp
        const tempState = classForTemp(t.gpu_temp_c);
        setCell(cells.gpu_temp_c, t.gpu_temp_c != null ? `${t.gpu_temp_c.toFixed(0)}°` : '—', tempState);
        setDot(dots.temp, tempState);
        // Unified
        const used = t.unified_used_gb, total = t.unified_total_gb;
        if (used != null && total != null) {
          const guardWarn = used > total - 8;
          setCell(cells.unified, `${used.toFixed(1)} / ${total.toFixed(0)}`, guardWarn ? 'warn' : 'ok');
          setDot(dots.unified, guardWarn ? 'warn' : 'ok');
          if (cells.unifiedHint) cells.unifiedHint.textContent = `GB · ${(total - used).toFixed(1)} headroom`;
        }
        // Throughput — bright while live, dimmed (still shown) as the last
        // generation's rate at idle, dash only before the first run. Carries
        // its unit (tok/s) like the TTFT cell.
        if (t.tok_per_s != null) {
          const state = inflight ? 'ok' : 'idle';
          setCell(cells.tok_per_s, `${t.tok_per_s.toFixed(1)} tok/s`, state);
          setDot(dots.tok, state);
        } else {
          setCell(cells.tok_per_s, '—', 'idle');
          setDot(dots.tok, 'idle');
        }
        // TTFT
        if (t.ttft_ms != null) {
          setCell(cells.ttft_ms, `${t.ttft_ms.toFixed(0)} ms`, 'ok');
          setDot(dots.ttft, 'ok');
        } else {
          setCell(cells.ttft_ms, '—', 'idle');
          setDot(dots.ttft, 'idle');
        }
        // Merged source under Throughput+TTFT: <full model> on <where>.
        const whereLabel = t.speed_where === 'spark' ? 'Spark GPU'
          : t.speed_where === 'openrouter' ? 'OpenRouter' : '';
        if (cells.speedSource) {
          if (t.speed_model && whereLabel) {
            cells.speedSource.textContent = `${t.speed_model} on ${whereLabel}`;
            cells.speedSource.dataset.where = t.speed_where;
          } else {
            cells.speedSource.textContent = 'throughput & first-token from the active lane';
            cells.speedSource.removeAttribute('data-where');
          }
        }
        // OpenRouter spend
        const cost = t.openrouter_cost_usd;
        if (cost != null && !Number.isNaN(cost)) {
          const dollars = cost >= 1 ? `$${cost.toFixed(2)}` : `$${cost.toFixed(4)}`;
          setCell(cells.cost, dollars, cost > 0 ? 'ok' : 'idle');
          setDot(dots.cost, cost > 0 ? 'ok' : 'idle');
          if (cells.costHint) {
            const n = t.openrouter_calls || 0;
            cells.costHint.textContent = n > 0 ? `${n} call${n === 1 ? '' : 's'} · since start` : 'spend · since start';
          }
        }
        // Lane — friendly model name (active lane while streaming, else the
        // last/warm model) + where.
        const lane = t.speed_model || t.lane_id || t.resident_lane;
        if (lane) {
          setCell(cells.lane_id, lane, 'ok');
          setDot(dots.lane, 'ok');
          if (cells.laneHint) {
            const where = whereLabel || 'resident';
            cells.laneHint.textContent = inflight ? `streaming · ${where}` : `${where} · warm`;
          }
        } else {
          setCell(cells.lane_id, 'idle', 'idle');
          setDot(dots.lane, 'idle');
          if (cells.laneHint) cells.laneHint.textContent = 'no warm brain';
        }

        // Append to the shared rolling series + redraw every mini-spark.
        series.t.push(now);
        series.gpu.push(t.gpu_util != null ? t.gpu_util : null);
        series.temp.push(t.gpu_temp_c != null ? t.gpu_temp_c : null);
        series.used.push(used != null ? used : null);
        series.tok.push(t.tok_per_s != null ? t.tok_per_s : null);
        while (series.t.length && series.t[0] < now - WINDOW_S) {
          for (const k of ['t', 'gpu', 'temp', 'used', 'tok']) series[k].shift();
        }
        drawMini(sparks.gpu, series.gpu, { color: 'oklch(0.74 0.16 165)', fill: 'oklch(0.74 0.16 165 / 0.14)', max: 100 });
        drawMini(sparks.temp, series.temp, { color: 'oklch(0.83 0.16 78)', fill: 'oklch(0.83 0.16 78 / 0.14)', max: 100 });
        drawMini(sparks.unified, series.used, { color: 'oklch(0.72 0.18 250)', fill: 'oklch(0.72 0.18 250 / 0.18)', max: Math.max(total || 128, 64), band: 8 });
        drawMini(sparks.tok, series.tok, { color: 'oklch(0.74 0.16 165)', fill: 'oklch(0.74 0.16 165 / 0.14)' });
      } catch {}
    }
    window.__arenaTelemetry.subscribe({
      onTelemetry: applyTelemetry,
      onError: (rs) => { if (rs === 2) offlineEl.hidden = false; },
      onUnreachable: () => { offlineEl.hidden = false; },
    });
  }
  })();
</script>
