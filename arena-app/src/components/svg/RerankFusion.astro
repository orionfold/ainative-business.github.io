---
// Signature figure for "rerank-fusion-retrieval-on-spark".
// Two retrieval paths (dense cosine via Nemotron + pgvector on the top;
// lexical BM25 via Postgres ts_rank_cd on the bottom) converge at a fusion
// node (RRF, teal accent), then pass through a reranker head (amber
// accent — the cross-encoder scorer) before the top-K chunks feed the
// generator. Topology: dual-path → fuse → rerank → generate.
const cy = 100;
---
<svg viewBox="0 0 300 200" role="img" aria-label="Hybrid retrieval chain — dense cosine and lexical BM25 run in parallel, fuse via Reciprocal Rank Fusion, pass through a reranker, and feed the generator" data-svg-animate xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="rf-band-teal" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-teal)" stop-opacity="0.02"/>
      <stop offset="50%"  stop-color="var(--svg-accent-teal)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--svg-accent-teal)" stop-opacity="0.02"/>
    </linearGradient>
    <linearGradient id="rf-band-amber" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-orange)" stop-opacity="0.02"/>
      <stop offset="50%"  stop-color="var(--svg-accent-orange)" stop-opacity="0.14"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.02"/>
    </linearGradient>
    <linearGradient id="rf-band-blue" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-blue)" stop-opacity="0.02"/>
      <stop offset="50%"  stop-color="var(--svg-accent-blue)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.02"/>
    </linearGradient>
    <linearGradient id="rf-rerank-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="var(--svg-accent-orange)" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.15"/>
    </linearGradient>
    <radialGradient id="rf-rerank-halo" cx="0.5" cy="0.5" r="0.6">
      <stop offset="0%"   stop-color="var(--svg-accent-orange)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Atmospheric bands: teal dual-path retrieval, amber rerank, blue generate -->
  <rect x="10"  y="54"  width="140" height="92" rx="3" fill="url(#rf-band-teal)" stroke="none"/>
  <rect x="168" y={cy - 20} width="52"  height="40" rx="3" fill="url(#rf-band-amber)" stroke="none"/>
  <rect x="180" y={cy - 34} width="56"  height="68"       fill="url(#rf-rerank-halo)" stroke="none"/>
  <rect x="234" y={cy - 20} width="56"  height="40" rx="3" fill="url(#rf-band-blue)"  stroke="none"/>

  <!-- Top path: Q → embed → pgvector (dense) -->
  <g class="svg-reveal svg-reveal-d1">
    <path class="line-draw svg-reveal-d2"
          d={`M 46 ${cy} L 58 70`}
          fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.5"/>
    <path class="line-draw svg-reveal-d3"
          d={`M 82 70 L 120 70 L 165 ${cy - 6}`}
          fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.5"/>
  </g>
  <!-- Bottom path: Q → BM25 (lexical) -->
  <g class="svg-reveal svg-reveal-d1">
    <path class="line-draw svg-reveal-d2"
          d={`M 46 ${cy} L 58 130`}
          fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.5" stroke-dasharray="3 2"/>
    <path class="line-draw svg-reveal-d3"
          d={`M 82 130 L 120 130 L 165 ${cy + 6}`}
          fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.5" stroke-dasharray="3 2"/>
  </g>
  <!-- Fusion → rerank → generate spine -->
  <g class="svg-reveal svg-reveal-d4">
    <path class="line-draw svg-reveal-d5"
          d={`M 176 ${cy} L 210 ${cy} L 246 ${cy}`}
          fill="none" stroke="var(--svg-accent-orange)" stroke-width="1.5"/>
  </g>

  <!-- Stage 0: Q -->
  <g class="svg-reveal svg-reveal-d2">
    <rect x="14" y={cy - 12} width="32" height="24" rx="4"
          fill="var(--svg-bg-inner)" stroke="var(--svg-bg-inner-stroke)"/>
    <line x1="20" y1={cy - 4} x2="40" y2={cy - 4}
          stroke="var(--svg-text-faint)" stroke-width="1"/>
    <line x1="20" y1={cy + 2} x2="36" y2={cy + 2}
          stroke="var(--svg-text-faint)" stroke-width="1"/>
    <text x="30" y={cy - 22} text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="8">question</text>
  </g>

  <!-- Top node: pgvector dense (teal) -->
  <g class="svg-reveal svg-reveal-d3">
    <rect x="58" y="54" width="54" height="32" rx="5"
          fill="var(--svg-bg-inner)" stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <text x="85" y="70" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">dense</text>
    <text x="85" y="80" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="7">embed + pgvector</text>
  </g>

  <!-- Bottom node: BM25 lexical (teal dashed) -->
  <g class="svg-reveal svg-reveal-d3">
    <rect x="58" y="114" width="54" height="32" rx="5"
          fill="var(--svg-bg-inner)" stroke="var(--svg-accent-teal)" stroke-width="1"
          stroke-dasharray="3 2"/>
    <text x="85" y="130" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">bm25</text>
    <text x="85" y="140" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="7">ts_rank_cd</text>
  </g>

  <!-- Fusion node (teal chip) -->
  <g class="svg-reveal svg-reveal-d4">
    <circle cx="160" cy={cy} r="10"
            fill="var(--svg-bg-inner)" stroke="var(--svg-accent-teal)" stroke-width="1"/>
    <text x="160" y={cy + 3} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="8" font-weight="600">RRF</text>
    <text x="160" y={cy + 24} text-anchor="middle"
          fill="var(--svg-text-muted)" font-family="var(--font-mono)"
          font-size="7">k = 60</text>
  </g>

  <!-- Rerank head (amber accent, halo'd — the star) -->
  <g class="svg-reveal svg-reveal-d5">
    <rect x="184" y={cy - 16} width="42" height="32" rx="6"
          fill="url(#rf-rerank-grad)"
          stroke="var(--svg-accent-orange)" stroke-width="1.5"/>
    <text x="205" y={cy - 1} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">rerank</text>
    <text x="205" y="114" text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="7">nemotron 1b</text>
  </g>

  <!-- Rerank callout -->
  <g class="svg-reveal svg-reveal-d6">
    <text x="205" y={cy - 28} text-anchor="middle"
          fill="var(--svg-accent-orange)" font-family="var(--font-mono)"
          font-size="7" letter-spacing="0.2em" font-weight="600">CROSS-ENC</text>
  </g>

  <!-- Stage 5: generator + stream -->
  <g class="svg-reveal svg-reveal-d6">
    <rect x="244" y={cy - 14} width="40" height="28" rx="5"
          fill="var(--svg-bg-inner)" stroke="var(--svg-accent-blue)" stroke-width="1"/>
    <text x="264" y={cy - 1} text-anchor="middle"
          fill="var(--svg-text-bright)" font-family="var(--font-mono)"
          font-size="9" font-weight="600">llama</text>
    <text x="264" y="114" text-anchor="middle"
          fill="var(--svg-text-faint)" font-family="var(--font-mono)"
          font-size="7">:8000</text>
  </g>

  <!-- Labels under the two retrieval lanes -->
  <g class="svg-reveal svg-reveal-d7">
    <text x="12" y="48" text-anchor="start"
          fill="var(--svg-accent-teal)" font-family="var(--font-mono)"
          font-size="7" letter-spacing="0.2em" font-weight="600">SEMANTIC</text>
    <text x="12" y="162" text-anchor="start"
          fill="var(--svg-accent-teal)" font-family="var(--font-mono)"
          font-size="7" letter-spacing="0.2em" font-weight="600">LEXICAL</text>
  </g>
</svg>
