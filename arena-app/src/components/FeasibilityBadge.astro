---
interface Props {
  verdict?: string | null;
  evaluated?: boolean;
}
const { verdict, evaluated = false } = Astro.props;
const value = verdict || (evaluated ? 'unevaluated' : 'unevaluated');
const labels: Record<string, string> = {
  'spark-feasible': 'Spark-feasible',
  'borderline': 'Borderline',
  'out-of-envelope': 'Out of envelope',
  'unevaluated': 'Unevaluated',
};
---
<span class={`feasibility-badge feasibility-badge--${value}`} title={value}>
  {labels[value] || value}
</span>

<style>
.feasibility-badge {
  display: inline-block;
  padding: 0.15rem 0.6rem;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border: 1px solid var(--rule);
  color: var(--ink);
}
.feasibility-badge--spark-feasible {
  background: color-mix(in oklch, var(--ink) 8%, transparent);
  border-color: color-mix(in oklch, var(--ink) 30%, transparent);
}
.feasibility-badge--borderline {
  background: transparent;
  border-color: color-mix(in oklch, var(--ink) 25%, transparent);
  color: color-mix(in oklch, var(--ink) 70%, var(--paper));
}
.feasibility-badge--out-of-envelope {
  background: transparent;
  border-color: color-mix(in oklch, var(--ink) 18%, transparent);
  color: color-mix(in oklch, var(--ink) 50%, var(--paper));
  text-decoration: line-through;
  text-decoration-color: color-mix(in oklch, var(--ink) 30%, transparent);
}
.feasibility-badge--unevaluated {
  background: transparent;
  border-color: color-mix(in oklch, var(--ink) 15%, transparent);
  color: color-mix(in oklch, var(--ink) 60%, var(--paper));
}
</style>
