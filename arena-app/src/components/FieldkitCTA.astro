---
import { FIELDKIT_CTAS } from '../data/fieldkit-ctas.ts';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = FIELDKIT_CTAS[slug];

const base = import.meta.env.BASE_URL.replace(/\/+$/, '/') || '/';
const moduleHref = (m: string) => `${base}fieldkit/api/${m}/`.replace(/\/+/g, '/');
const homeHref = `${base}fieldkit/`.replace(/\/+/g, '/');
---
{entry && (
  <aside class="fk-cta" aria-labelledby={`fk-cta-${slug}-title`}>
    <div class="fk-cta__rule" aria-hidden="true"></div>
    <header class="fk-cta__header">
      <span class="fk-cta__eyebrow">Build this faster with fieldkit</span>
      <h2 id={`fk-cta-${slug}-title`} class="fk-cta__title">{entry.headline}</h2>
      <p class="fk-cta__pitch">{entry.pitch}</p>
    </header>

    <ul class="fk-cta__components">
      {entry.components.map((c) => (
        <li>
          <a class="fk-cta__component" href={moduleHref(c.module)}>
            <code class="fk-cta__api">{c.name}</code>
            <span class="fk-cta__why">{c.why}</span>
          </a>
        </li>
      ))}
    </ul>

    <a class="fk-cta__home" href={homeHref}>
      <span>Browse all of fieldkit</span>
      <span class="fk-cta__arrow" aria-hidden="true">→</span>
    </a>
  </aside>
)}

<style>
  .fk-cta {
    max-width: 64rem;
    margin: 5rem auto 0;
    padding: 2rem 1.5rem 2.25rem;
    background: var(--color-surface-overlay);
    border: 1px solid color-mix(in oklch, var(--color-primary-dim) 35%, var(--color-border));
    border-radius: 0.75rem;
    position: relative;
  }
  .fk-cta__rule {
    position: absolute;
    top: -1px;
    left: 1.5rem;
    right: 1.5rem;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-primary) 25%,
      var(--color-primary-glow) 50%,
      var(--color-primary) 75%,
      transparent 100%
    );
    opacity: 0.85;
    border-radius: 2px;
  }
  .fk-cta__header {
    margin: 0 0 1.25rem;
  }
  .fk-cta__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    background: color-mix(in oklch, var(--color-primary-dim) 18%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-primary-dim) 40%, transparent);
    padding: 0.25em 0.7em;
    border-radius: 999px;
    margin-bottom: 0.85rem;
  }
  .fk-cta__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 0.55rem;
  }
  .fk-cta__pitch {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.55;
  }

  .fk-cta__components {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 0.6rem;
  }
  .fk-cta__component {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.85rem 1rem;
    background: color-mix(in oklch, var(--color-primary-dim) 6%, var(--color-surface));
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, transform 120ms ease, background 120ms ease;
  }
  .fk-cta__component:hover {
    border-color: var(--color-primary);
    background: color-mix(in oklch, var(--color-primary-dim) 12%, var(--color-surface));
    transform: translateY(-1px);
  }
  .fk-cta__api {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-primary);
    background: none;
    border: none;
    padding: 0;
    letter-spacing: -0.01em;
    word-break: break-word;
  }
  .fk-cta__why {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .fk-cta__home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-primary);
    text-decoration: none;
    padding: 0.5rem 0.85rem;
    border: 1px solid color-mix(in oklch, var(--color-primary-dim) 40%, transparent);
    border-radius: 0.5rem;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .fk-cta__home:hover {
    background: color-mix(in oklch, var(--color-primary-dim) 15%, transparent);
    border-color: var(--color-primary);
  }
  .fk-cta__arrow {
    transition: transform 120ms ease;
  }
  .fk-cta__home:hover .fk-cta__arrow {
    transform: translateX(2px);
  }

  @media (max-width: 48rem) {
    .fk-cta {
      margin-top: 3.5rem;
      padding: 1.5rem 1.1rem 1.75rem;
    }
    .fk-cta__title {
      font-size: 1.3rem;
    }
    .fk-cta__components {
      grid-template-columns: 1fr;
    }
  }
</style>
