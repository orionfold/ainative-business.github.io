---
// Chat — /arena/chat/
//
// Standalone app shell — uses ArenaAppLayout (no editorial chrome). The
// <ChatLane> island carries the actual chat UX; this page restyles its
// container as a cockpit pane.
import ArenaAppLayout from '../../layouts/ArenaAppLayout.astro';
import ChatLane from '../../components/arena/ChatLane.jsx';

const title = 'Spark Arena — Chat';
const description =
  'Single-lane chat against the resident Spark brain — streams via SSE, persists locally, never mirrored.';
---
<ArenaAppLayout title={title} description={description} active="chat">

  <header class="pageheader">
    <div>
      <p class="pageheader__eyebrow">M4 · operator-private</p>
      <h1 class="pageheader__title">Chat</h1>
      <p class="pageheader__blurb">
        Streams <code>POST /api/chat/stream</code> on the FastAPI sidecar at
        <code>127.0.0.1:7866</code>. History persists to
        <code>~/.fieldkit/arena.db</code> — operator-private; the M6 mirror
        exporter hardcodes <code>chat_*</code> tables out of its allowlist.
      </p>
    </div>
  </header>

  <div class="arena-pane">
    <header class="arena-pane__head">
      <span class="arena-pane__head-title">Resident&nbsp;brain</span>
      <span class="arena-pane__head-meta">
        <span style="font-family: var(--arena-mono); font-size: 0.6rem; letter-spacing: 0.18em; color: var(--arena-text-dim);">SSE stream</span>
        <span style="opacity: 0.4;">·</span>
        <span style="font-family: var(--arena-mono); font-size: 0.62rem; color: var(--arena-text-mute);">
          chat_sessions.publishable = 0
        </span>
      </span>
    </header>
    <div class="arena-pane__body">
      {/* v0.1.1 — ChatLane reads ?prompt=<encoded> on mount, fills the
          textarea, and auto-sends once. The cockpit hero form submits
          here. The URL is scrubbed after dispatch so refresh doesn't
          re-send. */}
      <ChatLane client:only="preact" />
    </div>
  </div>

</ArenaAppLayout>
