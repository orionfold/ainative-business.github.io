---
/**
 * /bookmarks/ — client-hydrated list of articles the reader has bookmarked
 * via BookmarkStar. Reads localStorage `afn:bookmarks` and renders one
 * card per saved slug, with the last-known reading position indicator if
 * available (`afn:position:<slug>`).
 *
 * Static at build time (empty placeholder); JS hydrates the actual list on
 * the client. Survives the static export to /field-notes/bookmarks/.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import AmberRule from '../components/ui/AmberRule.astro';

const pageTitle = 'Bookmarks — ainative';
const pageDescription = 'Articles you bookmarked, with last reading position. Stored locally in this browser only.';
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="bookmarks">
    <header class="bookmarks__masthead">
      <p class="bookmarks__eyebrow">Saved for later</p>
      <h1 class="bookmarks__title">Bookmarks</h1>
      <p class="bookmarks__intro">
        Articles you starred via the bookmark button. Stored in this browser only — clearing site data clears your list. Each card shows where you left off.
      </p>
    </header>

    <AmberRule />

    <div class="bookmarks__list" data-bookmarks-list>
      <p class="bookmarks__empty" data-bookmarks-empty>
        No bookmarks yet. Open any article and click the <strong>Bookmark</strong> pill in the header to save it here.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .bookmarks {
    max-width: 56rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 6rem;
  }
  .bookmarks__masthead { max-width: 48rem; margin: 0 0 2rem; }
  .bookmarks__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .bookmarks__title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .bookmarks__intro {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  .bookmarks__list { display: grid; gap: 0.85rem; margin-top: 2.5rem; }
  .bookmarks__empty {
    padding: 2rem 1.5rem;
    border: 1px dashed var(--color-border);
    border-radius: 10px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  /* Cards are JS-injected so the rules below need to bypass Astro's
     component scoping. Bare classnames are unique enough across the site. */
  /* Cards are JS-injected so the rules below need to bypass Astro's
     component scoping. Bare classnames are unique enough across the site. */
  :global(.bookmark-card) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in oklch, var(--color-surface-raised) 60%, transparent);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, background 0.15s;
  }
  :global(.bookmark-card:hover) {
    border-color: color-mix(in oklch, var(--color-primary) 40%, var(--color-border));
    background: color-mix(in oklch, var(--color-primary) 5%, var(--color-surface-raised));
  }
  :global(.bookmark-card__main) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  :global(.bookmark-card__title) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.3;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.bookmark-card__meta) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
  }
  :global(.bookmark-card__progress) {
    flex-shrink: 0;
    width: 4.5rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-surface-overlay);
    overflow: hidden;
  }
  :global(.bookmark-card__progress-bar) {
    height: 100%;
    background: var(--color-primary);
    transition: width 0.2s;
  }
  :global(.bookmark-card__remove) {
    flex-shrink: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  :global(.bookmark-card__remove:hover) {
    color: oklch(0.68 0.15 20);
    border-color: oklch(0.68 0.15 20 / 0.5);
  }

  @media (max-width: 640px) {
    :global(.bookmark-card) { flex-wrap: wrap; }
    :global(.bookmark-card__main) { flex: 1 1 100%; }
  }
</style>

<script>
  function initBookmarksPage() {
    const list = document.querySelector<HTMLElement>('[data-bookmarks-list]');
    const empty = document.querySelector<HTMLElement>('[data-bookmarks-empty]');
    if (!list || !empty) return;

    type Bookmark = { addedAt: number; title?: string };

    function readBookmarks(): Record<string, Bookmark> {
      try {
        const raw = localStorage.getItem('afn:bookmarks');
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch { return {}; }
    }
    function writeBookmarks(next: Record<string, Bookmark>) {
      try { localStorage.setItem('afn:bookmarks', JSON.stringify(next)); } catch {}
    }
    function readPosition(slug: string): number | null {
      try {
        const raw = localStorage.getItem(`afn:position:${slug}`);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        if (parsed && typeof parsed.pct === 'number') return parsed.pct;
      } catch {}
      return null;
    }

    const base = (document.querySelector('base')?.href ?? location.origin) + (
      // honour Astro's base path — read from <link rel="canonical"> if exposed,
      // otherwise infer from current path. The simplest reliable thing: use
      // location.pathname's prefix up to and including /bookmarks.
      ''
    );
    function articleHref(slug: string): string {
      // /bookmarks/ → /articles/<slug>/   ; /field-notes/bookmarks/ → /field-notes/articles/<slug>/
      const path = location.pathname;
      const idx = path.lastIndexOf('/bookmarks');
      const prefix = idx >= 0 ? path.slice(0, idx) : '';
      return `${prefix || ''}/articles/${slug}/`.replace(/\/+/g, '/');
    }

    function render() {
      const bookmarks = readBookmarks();
      const slugs = Object.keys(bookmarks).sort((a, b) => bookmarks[b].addedAt - bookmarks[a].addedAt);
      list!.querySelectorAll<HTMLElement>('.bookmark-card').forEach((el) => el.remove());

      if (slugs.length === 0) {
        empty!.style.display = '';
        return;
      }
      empty!.style.display = 'none';

      for (const slug of slugs) {
        const b = bookmarks[slug];
        const pct = readPosition(slug);
        const card = document.createElement('a');
        card.className = 'bookmark-card';
        card.href = articleHref(slug);

        const main = document.createElement('div');
        main.className = 'bookmark-card__main';
        const title = document.createElement('span');
        title.className = 'bookmark-card__title';
        title.textContent = b.title ?? slug;
        const meta = document.createElement('span');
        meta.className = 'bookmark-card__meta';
        const dateStr = b.addedAt ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(b.addedAt)) : '';
        meta.textContent = pct != null
          ? `Saved ${dateStr} · ${Math.round(pct * 100)}% read`
          : `Saved ${dateStr}`;
        main.appendChild(title);
        main.appendChild(meta);

        const progressOuter = document.createElement('span');
        progressOuter.className = 'bookmark-card__progress';
        const progressBar = document.createElement('span');
        progressBar.className = 'bookmark-card__progress-bar';
        progressBar.style.width = `${Math.round((pct ?? 0) * 100)}%`;
        progressOuter.appendChild(progressBar);

        const remove = document.createElement('button');
        remove.type = 'button';
        remove.className = 'bookmark-card__remove';
        remove.textContent = 'Remove';
        remove.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const next = readBookmarks();
          delete next[slug];
          writeBookmarks(next);
          render();
        });

        card.appendChild(main);
        card.appendChild(progressOuter);
        card.appendChild(remove);
        list!.appendChild(card);
      }
    }
    render();
  }

  initBookmarksPage();
  document.addEventListener('astro:after-swap', initBookmarksPage);
</script>
